#!/usr/bin/env bash
# mcp-host-bash — host-side launcher for a generic "run a bash command on
# the host" MCP server, fronted by mcp-proxy so the in-container claude
# can reach it via CLAUDE_MCP_HTTP_BRIDGE.
#
# What this gives you
#
# A second MCP server visible inside the containerised claude (alongside
# any other bridged servers such as the Salesforce mcp-adaptor) that
# exposes a single `run_command` tool. The tool executes argv against
# whitelisted binaries on the **host**, so the container can drive
# host-only operations (corp git, host-only CLIs, scripts under the
# operator's home dir) without needing the binaries themselves installed
# inside the Linux container.
#
# How it's wired
#
#   container claude                       host
#   ───────────────                       ────
#   .mcp.json: host-bash, type=http
#       │
#       ▼                       (HTTP, streamable)
#   http://host.docker.internal:8766/mcp ───────► mcp-proxy --port 8766
#                                                    │
#                                                    ▼  (stdio)
#                                                 cli-mcp-server
#                                                    │
#                                                    ▼  (subprocess)
#                                                 the actual command
#
# The container side is the existing CLAUDE_MCP_HTTP_BRIDGE plumbing
# (claude-watch PR #148). The HOST side is what this script stands up.
#
# Off-the-shelf pieces (no hand-rolled MCP server needed):
#
#   - mcp-proxy:     PyPI 'mcp-proxy'. Hosts a stdio MCP server over
#                    HTTP. Same component validated in v24 workbot for
#                    the mcp-adaptor bridge.
#   - cli-mcp-server: PyPI 'cli-mcp-server'. Generic stdio MCP server
#                    with an `run_command` tool and an env-var-driven
#                    allow-list (ALLOWED_COMMANDS / ALLOWED_FLAGS /
#                    ALLOWED_DIR / COMMAND_TIMEOUT /
#                    ALLOW_SHELL_OPERATORS). MIT, last release 2025-07.
#
# Both packages are statically installed once via `uv tool install`
# (see `examples/compose/bin/install-host-deps`); the launcher exec's
# the installed binaries directly with NO per-launch network fetch.
# Earlier versions called `uvx mcp-proxy` / `uvx cli-mcp-server` which
# re-resolved + re-fetched from PyPI on every start — slow, fragile
# (TLS / network blips fail the launcher), and broken under corp-CA
# environments. Static install is operator-run once; subsequent
# launches are offline.
#
# Security model
#
# `run_command` is a substantial privilege escalation: anything that has
# API access to the in-container claude can run code on the host. The
# allow-list is your safety floor.
#
#   ALLOWED_COMMANDS — comma-separated list of binary names the server
#                      will exec. NEVER set this to "all" in production.
#                      Default: a read-y / observation / standard-dev-tool
#                      floor (file inspection, text munging, VCS, language
#                      toolchains, common corp-dev binaries, read-only
#                      network probes). See DEFAULT_ALLOWED_COMMANDS in
#                      this script for the exact list. Destructive,
#                      privileged, scheduling, and outbound-bytes binaries
#                      are gated behind CW_PROFILE=corp-dev-trusted.
#   ALLOWED_FLAGS    — comma-separated flag whitelist, OR "all" to skip
#                      flag filtering (still bounded by ALLOWED_COMMANDS).
#   ALLOWED_DIR      — absolute path. The server refuses commands that
#                      would resolve outside this tree. Default: $HOME.
#   COMMAND_TIMEOUT  — per-command wall-clock cap, seconds. Default: 30.
#   ALLOW_SHELL_OPERATORS — "true"/"false". When false (default), the
#                      server rejects pipes/redirects/&&/||, so the
#                      container can't string commands together.
#
# Bearer-token authentication
#
#   `mcp-proxy` upstream has NO inbound-auth feature (verified via
#   README + source read 2026-05-14). To gate access without depending
#   on the network layer alone, the launcher can front mcp-proxy with
#   `mcp-proxy-auth-shim` (a tiny stdlib-only reverse proxy that
#   validates `Authorization: Bearer <secret>` on every request).
#
#   Set `MCP_HOST_BASH_BEARER` to a random secret to enable the shim.
#   Generate one once and keep it OUT of version control:
#
#       head -c 32 /dev/urandom | base64
#
#   When the bearer is set, the launcher binds mcp-proxy to
#   127.0.0.1 on an internal port (default: $PORT + 1; override with
#   `MCP_HOST_BASH_UPSTREAM_PORT`) and binds the shim on the
#   operator-facing `$MCP_HOST_BASH_BIND:$PORT`. Callers MUST send
#   `Authorization: Bearer $MCP_HOST_BASH_BEARER` on every POST or
#   the shim 401's them without forwarding.
#
#   Container callers (exec-hook-bridge) read the SAME secret from
#   `CLAUDE_HOST_HOOK_BRIDGE_BEARER` — wire both vars in your `.env`
#   to the same generated value.
#
#   When `MCP_HOST_BASH_BEARER` is UNSET/empty:
#     - The launcher logs a startup warning (especially loud when the
#       bind is non-loopback — that combination is the worst-case
#       LAN-exposed-no-auth profile).
#     - mcp-proxy binds directly at `$MCP_HOST_BASH_BIND:$PORT`, no
#       shim in front. Behavior matches the pre-bearer-auth launcher.
#
# Override via a config file at $MCP_HOST_BASH_CONFIG (default:
# $HOME/.config/claude-container/mcp-host-bash.env). The file is
# sourced before launch — standard KEY=VALUE lines, comments with #.
# Operator-supplied values override the defaults below.
#
# Bind address
#
#   MCP_HOST_BASH_BIND — host address mcp-proxy listens on. Default:
#       127.0.0.1 (loopback only). Defense-in-depth floor — any caller
#       reachable on the port can issue `run_command` against the host
#       shell, so the safe default is "no LAN exposure, no
#       sibling-uid exposure" unless the operator explicitly opts in.
#       Set MCP_HOST_BASH_BIND=0.0.0.0 (or a specific interface IP) to
#       expose beyond loopback — typical case is an in-container claude
#       on a Linux Docker bridge network reaching the host via
#       `host.docker.internal`. The value is passed verbatim to
#       `mcp-proxy --host`. PAIR THIS WITH BEARER-TOKEN AUTH (see the
#       host-bash block in examples/compose/.env.example) when opening
#       beyond loopback — anything reachable on the port can exec
#       binaries on the host as the operator user.
#
#       Linux Docker bridge net specifics: the in-container claude
#       reaches the host's docker0 gateway (172.17.0.1 by default),
#       which CANNOT route to host loopback. Those operators have two
#       options: (a) set MCP_HOST_BASH_BIND=0.0.0.0 and gate access with
#       the bearer token; (b) run the container with `--network host`
#       so it shares the host netns and can dial 127.0.0.1:8766
#       directly. macOS Docker Desktop's host.docker.internal NAT
#       routes loopback by default so the safe default Just Works for
#       the typical Mac compose stack.
#
# CW_PROFILE — opt-in trust profile that widens the default allow-list
# for specific operator workflows:
#
#   CW_PROFILE=corp-dev (default): the read-y dev-tooling floor — file
#       inspection, text munging, VCS, language toolchains (node / npm /
#       python / make / etc.), common corp-dev binaries (envchain / sfdx
#       / jenkins-builds), and read-only network probes (ping / dig /
#       host / nslookup). Excludes anything that writes off-host or
#       mutates system state.
#   CW_PROFILE=corp-dev-trusted: adds host-scheduling tooling (cron /
#       launchd / systemd timers / Task Scheduler), file mutation
#       (rm / chmod / mkdir / tee / cp / mv), key/cert tooling
#       (openssl / ssh-keygen), outbound bytes (curl / wget /
#       scp), and container management (docker / docker-compose) so
#       the container can wire periodic claude-event jobs, push
#       artifacts, and recreate its own stack from inside its session.
#       Host-OS agnostic — the relevant subset depends on the
#       operator's host.
#
# Explicit ALLOWED_COMMANDS in $MCP_HOST_BASH_CONFIG always wins over
# the profile default; the profile is a convenience baseline, not a
# ceiling.
#
# Logging
#
# mcp-proxy logs JSON-RPC traffic to stderr. cli-mcp-server logs each
# `run_command` invocation to stderr including the resolved argv. We
# tee both into $MCP_HOST_BASH_LOG (default:
# $HOME/.local/state/claude-container/mcp-host-bash.log) AND to stdout/
# stderr so the operator can either follow live (foreground) or audit
# later (when running under launchd / a tmux pane).
#
# Off switch
#
# Two ways to stop the server:
#   1. Ctrl-C in the foreground (this script traps SIGTERM/SIGINT and
#      tears mcp-proxy down cleanly).
#   2. Set MCP_HOST_BASH_DISABLED=1 in your shell env before launch;
#      the script refuses to start, exit 0. Use this as a "soft kill
#      switch" when the launcher is wired into launchd / login startup.
#
# Usage
#
#   mcp-host-bash                  # start in foreground (Ctrl-C to stop)
#   mcp-host-bash --port 9000      # custom port (default: 8766)
#   mcp-host-bash --print-cmd      # print the planned exec argv + exit 0
#   mcp-host-bash --help           # this help
#
# Container .env wiring
#
#   CLAUDE_MCP_HTTP_BRIDGE=host-bash=http://host.docker.internal:8766/mcp
#
# (Combine with the existing mcp-adaptor entry via `:` if you have both:
#   CLAUDE_MCP_HTTP_BRIDGE=mcp-adaptor=...8765/mcp:host-bash=...8766/mcp )
#
# Inside the container, after `docker compose up -d`:
#   claude mcp list                # should show host-bash, Connected
#   /mcp                           # in the claude REPL — same surface
#
# Exit codes
#   0   normal shutdown (or --help / --print-cmd / MCP_HOST_BASH_DISABLED)
#   1   missing mcp-proxy / cli-mcp-server on PATH (run install-host-deps)
#       or port already bound
#   2   bad flag / argv parse error

set -euo pipefail

# -----------------------------------------------------------------------------
# Defaults
# -----------------------------------------------------------------------------

DEFAULT_PORT=8766
# The default allow-list is the read-y / observation / standard-dev-tool
# floor most operators want without having to opt in. It covers:
#   - file inspection: ls, cat, head, tail, grep, find, file, stat, diff,
#     sort, uniq, wc
#   - text munging: awk, sed, cut, tr, xargs, base64, jq, yq
#     (sed/awk -i flags can write, but allow-list filters by command name
#     not args; the ALLOWED_DIR fence still bounds writes to $HOME.)
#   - VCS / forge: git, gh
#   - shell discovery: pwd, echo, which, env, printenv, hostname, uname,
#     date, basename, dirname
#   - language toolchains: node, npm, yarn, python, python3, pip, make
#   - corp-dev toolset (Andrew/Regrello surface): envchain, jenkins-builds,
#     sfdx, force, sf, sfdc
#   - read-y network probes: ping, host, dig, nslookup
#
# Deliberately NOT in the default (escalation requires CW_PROFILE=corp-dev-trusted):
#   - curl, wget, scp — write files / push bytes off-host
#   - openssl, ssh-keygen — generate / write keys
#   - bash, sh, zsh, fish — arbitrary script exec
#   - rm, chmod, mv, cp — destructive / privilege-changing
#   - crontab, launchctl, systemctl, schtasks — host scheduling
DEFAULT_ALLOWED_COMMANDS="ls,cat,pwd,git,gh,head,tail,grep,find,echo,jq,yq,make,awk,sed,cut,tr,wc,xargs,which,printenv,env,sort,uniq,diff,file,stat,base64,uname,hostname,date,basename,dirname,node,npm,yarn,python,python3,pip,ping,host,dig,nslookup,envchain,jenkins-builds,sfdx,force,sf,sfdc"
DEFAULT_ALLOWED_FLAGS="all"
DEFAULT_COMMAND_TIMEOUT=30
DEFAULT_ALLOW_SHELL_OPERATORS="false"

# Trust profiles — opt-in widened allow-lists for specific operator
# workflows. CW_PROFILE selects one of the named profiles below. The
# default (unset / empty) keeps the conservative read-only list above.
#
# Each profile ADDS to (not replaces) the read-only default — the goal
# is "let the container do its job without losing the safety floor".
#
# Operator sets CW_PROFILE=corp-dev-trusted in their .env when they
# want the container to manage host-side scheduled jobs (cron /
# launchd / systemd timers / Task Scheduler) for periodic
# claude-event emission. The widened list is host-OS-agnostic: the
# operator's actual OS determines which subset is meaningful (cron on
# Linux, launchctl on macOS, schtasks on Windows), but the allow-list
# carries enough binaries to cover all three.
#
# - `corp-dev` (default): the read-y dev-tooling floor (see
#   DEFAULT_ALLOWED_COMMANDS above).
# - `corp-dev-trusted`: adds host scheduling, file mutation, key/cert
#   tooling, outbound bytes, and container management so the container
#   can wire periodic events, push artifacts, and recreate its own
#   stack from inside its session:
#     * `sw_vers` / `lsb_release` — extra OS detection (uname is in default).
#     * `crontab` — Linux + macOS cron entry mgmt.
#     * `launchctl` — macOS launchd load/unload.
#     * `systemctl` — Linux systemd unit mgmt (user units; no sudo).
#     * `schtasks` / `powershell` / `pwsh` — Windows Task Scheduler.
#     * `mkdir` / `tee` / `chmod` — drop scheduled-task definition files.
#     * `cp` / `mv` / `rm` — rotate / dismantle scheduled-task files.
#     * `curl` / `wget` — claude-event POST, webhook firing, file fetch.
#     * `scp` — push artifacts to remote hosts.
#     * `openssl` / `ssh-keygen` — generate / inspect keys + certs.
#     * `docker` / `docker-compose` — recreate the compose stack from
#       inside the container session (`docker compose up -d
#       --force-recreate <svc>`, `docker compose exec <svc> ...`).
#       Trusted-only because the binary covers destructive subcommands
#       (`docker rm`, `docker stop`, `docker kill`) alongside read-y
#       ones (`docker ps`, `docker logs`); cli-mcp-server's allow-list
#       is per-binary, not per-subcommand.
#   ALLOWED_DIR stays the operator's $HOME by default (no /etc, no /usr,
#   no /System) so the widening doesn't escape the home tree.
#
# Operators can override either profile's expanded list by setting
# ALLOWED_COMMANDS explicitly in $MCP_HOST_BASH_CONFIG; that file is
# sourced AFTER the profile defaults are applied, so the operator's
# value wins. Setting CW_PROFILE to an unknown name logs a warning
# and falls back to the conservative default.
TRUSTED_EXTRAS="sw_vers,lsb_release,crontab,launchctl,systemctl,schtasks,powershell,pwsh,mkdir,tee,chmod,cp,mv,rm,curl,wget,scp,openssl,ssh-keygen,docker,docker-compose"

# Honor XDG-ish locations on macOS too (just paths, not the spec itself).
MCP_HOST_BASH_CONFIG="${MCP_HOST_BASH_CONFIG:-${HOME}/.config/claude-container/mcp-host-bash.env}"
MCP_HOST_BASH_LOG="${MCP_HOST_BASH_LOG:-${HOME}/.local/state/claude-container/mcp-host-bash.log}"

# -----------------------------------------------------------------------------
# Argv parsing
# -----------------------------------------------------------------------------

usage() {
    sed -n '2,/^set -euo/p' "$0" | sed -e 's/^# \{0,1\}//' -e '/^set -euo/d'
}

PORT=""
PRINT_CMD=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --port)
            shift
            if [ "$#" -eq 0 ]; then
                echo "mcp-host-bash: --port requires a value" >&2
                exit 2
            fi
            PORT="$1"
            shift
            ;;
        --port=*)
            PORT="${1#--port=}"
            shift
            ;;
        --print-cmd)
            # Test-only hook: build the planned exec argv but print it
            # (one-per-line) instead of executing. No uvx / network /
            # port-bind probe runs in this mode — used by the test
            # suite to verify argv construction without external deps.
            PRINT_CMD=1
            shift
            ;;
        *)
            printf 'mcp-host-bash: unknown argument %q\n' "$1" >&2
            echo 'See --help for usage.' >&2
            exit 2
            ;;
    esac
done

PORT="${PORT:-$DEFAULT_PORT}"

# -----------------------------------------------------------------------------
# Soft kill switch
# -----------------------------------------------------------------------------

if [ "${MCP_HOST_BASH_DISABLED:-0}" = "1" ] && [ "$PRINT_CMD" = "0" ]; then
    echo "mcp-host-bash: MCP_HOST_BASH_DISABLED=1 — refusing to start. Unset to enable." >&2
    exit 0
fi

# -----------------------------------------------------------------------------
# Load operator overrides
#
# The config file is plain KEY=VALUE lines (bash-source compatible). We
# only honor the env-var keys cli-mcp-server / this script consume —
# stray keys are harmless because we explicitly export the curated set
# below.
# -----------------------------------------------------------------------------

if [ -f "$MCP_HOST_BASH_CONFIG" ] && [ "$PRINT_CMD" = "0" ]; then
    # shellcheck disable=SC1090
    . "$MCP_HOST_BASH_CONFIG"
elif [ -f "$MCP_HOST_BASH_CONFIG" ] && [ "$PRINT_CMD" = "1" ]; then
    # In test mode, still source so --print-cmd reflects operator overrides.
    # shellcheck disable=SC1090
    . "$MCP_HOST_BASH_CONFIG"
fi

# Compose the profile-derived default allow-list. CW_PROFILE selects.
# Unknown profile names fall back to the conservative default with a
# stderr warning so the operator notices (rather than silently dropping
# their requested expansion). PROFILE_WARN is captured for the banner
# below.
PROFILE_WARN=""
case "${CW_PROFILE:-}" in
    ""|corp-dev)
        PROFILE_ALLOWED_COMMANDS="$DEFAULT_ALLOWED_COMMANDS"
        ;;
    corp-dev-trusted)
        PROFILE_ALLOWED_COMMANDS="${DEFAULT_ALLOWED_COMMANDS},${TRUSTED_EXTRAS}"
        ;;
    *)
        PROFILE_WARN="mcp-host-bash: unknown CW_PROFILE='${CW_PROFILE}', falling back to default."
        PROFILE_ALLOWED_COMMANDS="$DEFAULT_ALLOWED_COMMANDS"
        ;;
esac

# CLAUDE_HOOK_BRIDGE_BINS — operator-declared comma-separated list of
# host hook binary BASENAMES the in-container exec-hook bridge is
# allowed to invoke via `run_command`. Merged into the effective
# ALLOWED_COMMANDS list below.
#
# Why a separate knob (vs. just adding telemetry-hook etc. to
# TRUSTED_EXTRAS): hook binary basenames are operator-specific. Andrew's
# corp telemetry hook is `telemetry-hook`; another operator's corp
# environment may have `corp-trace-hook`, `audit-fire`, etc. Forcing
# every operator to fork mcp-host-bash to add their hook binary is
# friction we don't need; a single env var covers the bridge use case
# without expanding the trust profile floor.
#
# The merged result is the union of (profile default ∪ hook bridge
# bins). Operator-supplied ALLOWED_COMMANDS in $MCP_HOST_BASH_CONFIG
# still wins absolute when set (matches the existing behaviour).
HOOK_BRIDGE_BINS="${CLAUDE_HOOK_BRIDGE_BINS:-}"
if [ -n "$HOOK_BRIDGE_BINS" ]; then
    PROFILE_ALLOWED_COMMANDS="${PROFILE_ALLOWED_COMMANDS},${HOOK_BRIDGE_BINS}"
fi

# Apply defaults for any keys the config file didn't set. Done AFTER
# sourcing so operator overrides win. Operator's explicit
# ALLOWED_COMMANDS (from $MCP_HOST_BASH_CONFIG) wins over the
# profile-derived default; that lets the operator narrow or expand
# beyond the profile without editing this script.
ALLOWED_COMMANDS="${ALLOWED_COMMANDS:-$PROFILE_ALLOWED_COMMANDS}"
ALLOWED_FLAGS="${ALLOWED_FLAGS:-$DEFAULT_ALLOWED_FLAGS}"
ALLOWED_DIR="${ALLOWED_DIR:-${HOME}}"
COMMAND_TIMEOUT="${COMMAND_TIMEOUT:-$DEFAULT_COMMAND_TIMEOUT}"
ALLOW_SHELL_OPERATORS="${ALLOW_SHELL_OPERATORS:-$DEFAULT_ALLOW_SHELL_OPERATORS}"

# -----------------------------------------------------------------------------
# Build the exec argv
#
# We launch mcp-proxy as the foreground process; it spawns cli-mcp-server
# as a subprocess and forwards stdio<->HTTP. mcp-proxy's `--port N` /
# `--host` flags are stable; the trailing `--` + stdio-server argv tells
# it which binary to spawn.
#
# `--host` defaults to 127.0.0.1 (loopback only) — that is the safe
# floor. `run_command` is a privilege escalation: anything reachable on
# the port can exec binaries on the host as the operator user, so the
# default must NOT expose the port to the LAN / sibling Docker
# containers / other local UIDs without explicit operator opt-in.
#
# To allow non-loopback callers (typical case: an in-container claude
# on a Linux Docker bridge network reaching the host via
# host.docker.internal), set MCP_HOST_BASH_BIND=0.0.0.0 (or any
# interface IP) in the launcher's env. The value is passed verbatim to
# mcp-proxy --host. PAIR WITH BEARER-TOKEN AUTH (see .env.example
# host-bash block) when opening beyond loopback.
# -----------------------------------------------------------------------------

# Resolve the bind address. Default 127.0.0.1 (loopback) — operator must
# explicitly set MCP_HOST_BASH_BIND to widen the listener.
BIND_HOST="${MCP_HOST_BASH_BIND:-127.0.0.1}"

# Resolve bearer-auth mode. When MCP_HOST_BASH_BEARER is set, we
# launch mcp-proxy on an internal loopback port and front it with
# mcp-proxy-auth-shim on the public-facing port. When unset, mcp-proxy
# binds the public-facing port directly (no shim, no auth — matches
# pre-bearer-auth behavior; the startup banner warns loudly in this
# mode, especially when the bind is non-loopback).
BEARER="${MCP_HOST_BASH_BEARER:-}"
if [ -n "$BEARER" ]; then
    UPSTREAM_PORT="${MCP_HOST_BASH_UPSTREAM_PORT:-$((PORT + 1))}"
    MCP_PROXY_PORT="$UPSTREAM_PORT"
    MCP_PROXY_HOST="127.0.0.1"
else
    UPSTREAM_PORT=""
    MCP_PROXY_PORT="$PORT"
    MCP_PROXY_HOST="$BIND_HOST"
fi

argv=(
    mcp-proxy
    --port "$MCP_PROXY_PORT"
    --host "$MCP_PROXY_HOST"
    # mcp-proxy --env NAME VALUE pairs forward env into the stdio
    # subprocess. cli-mcp-server reads its allow-list from env, so
    # this is how we apply the policy.
    #
    # NB: mcp-proxy 0.11.0 changed `--env` from a single `KEY=VALUE`
    # arg to two separate args (`KEY` and `VALUE`). Earlier
    # versions of this script used the old single-arg form and
    # mcp-proxy 0.11.0 errors with "argument -e/--env: expected 2
    # arguments". The two-arg form is what 0.11.0+ accepts.
    --env ALLOWED_COMMANDS "$ALLOWED_COMMANDS"
    --env ALLOWED_FLAGS "$ALLOWED_FLAGS"
    --env ALLOWED_DIR "$ALLOWED_DIR"
    --env COMMAND_TIMEOUT "$COMMAND_TIMEOUT"
    --env ALLOW_SHELL_OPERATORS "$ALLOW_SHELL_OPERATORS"
    --
    cli-mcp-server
)

# When the bearer is set, build the shim argv too. The shim binds the
# operator-facing port, validates the bearer header on every request,
# and forwards authenticated requests to mcp-proxy's internal port.
shim_argv=()
if [ -n "$BEARER" ]; then
    shim_argv=(
        mcp-proxy-auth-shim
        --listen-host "$BIND_HOST"
        --listen-port "$PORT"
        --upstream-host 127.0.0.1
        --upstream-port "$UPSTREAM_PORT"
    )
fi

if [ "$PRINT_CMD" = "1" ]; then
    # Print mode: one argv per line for the test suite. When the shim
    # is in play, print the shim argv first (separator-less header
    # `SHIM:`), then a blank line, then the mcp-proxy argv. Tests can
    # parse either both blocks or just the mcp-proxy block depending
    # on what they assert.
    if [ "${#shim_argv[@]}" -gt 0 ]; then
        echo "SHIM:"
        printf '%s\n' "${shim_argv[@]}"
        echo
        echo "MCP_PROXY:"
    fi
    printf '%s\n' "${argv[@]}"
    exit 0
fi

# -----------------------------------------------------------------------------
# Pre-flight: the static binaries must be installed.
#
# We deliberately do NOT call `uvx mcp-proxy` here — that would
# re-fetch the package from PyPI on every launch, slow + fragile +
# corp-CA-hostile (TLS errors at launch even with UV_NATIVE_TLS=1).
# Run `examples/compose/bin/install-host-deps` ONCE to populate
# ~/.local/bin/{mcp-proxy,cli-mcp-server} statically; subsequent
# launches are entirely offline.
# -----------------------------------------------------------------------------

missing_bins=()
for bin in mcp-proxy cli-mcp-server; do
    if ! command -v "$bin" >/dev/null 2>&1; then
        missing_bins+=("$bin")
    fi
done

# The auth shim is needed only when MCP_HOST_BASH_BEARER is set. It
# ships alongside the launcher in examples/compose/bin/, so look it up
# beside this script first (handles the in-tree dev path), then fall
# back to a PATH lookup (handles a `make install` deployment).
SHIM_BIN=""
if [ -n "$BEARER" ]; then
    script_dir="$(cd "$(dirname "$0")" && pwd)"
    if [ -x "$script_dir/mcp-proxy-auth-shim" ]; then
        SHIM_BIN="$script_dir/mcp-proxy-auth-shim"
    elif command -v mcp-proxy-auth-shim >/dev/null 2>&1; then
        SHIM_BIN="$(command -v mcp-proxy-auth-shim)"
    else
        missing_bins+=("mcp-proxy-auth-shim")
    fi
    # Update the shim argv's first element to the resolved path so the
    # exec finds it without re-running PATH lookup.
    if [ -n "$SHIM_BIN" ]; then
        shim_argv[0]="$SHIM_BIN"
    fi
fi

if [ "${#missing_bins[@]}" -gt 0 ]; then
    cat >&2 <<EOF
mcp-host-bash: cannot find required binaries on PATH: ${missing_bins[*]}

These ship as PyPI packages and must be installed once (statically).
Run the bundled installer:

  examples/compose/bin/install-host-deps

That uses \`uv tool install mcp-proxy cli-mcp-server\` so the launcher
can exec them directly with no per-launch network fetch. Re-running the
installer is idempotent — pass \`--upgrade\` to force a refresh.

If \`uv tool install\` puts shims somewhere not on your PATH, add
\$HOME/.local/bin to PATH or run \`uv tool update-shell\`.
EOF
    exit 1
fi

# -----------------------------------------------------------------------------
# Logging setup
# -----------------------------------------------------------------------------

mkdir -p "$(dirname "$MCP_HOST_BASH_LOG")"

# Trap SIGTERM/SIGINT so Ctrl-C cleanly tears down mcp-proxy + the
# auth shim (when running) + their stdio children. mcp-proxy already
# SIGTERMs the cli-mcp-server child on its own exit; we just need to
# forward the signal to both top-level PIDs.
child_pid=""
shim_pid=""
# Exit code cleanup() uses when it ends the script. Defaults to 0 (the
# normal Ctrl-C / SIGTERM teardown path); the fatal-error branches in
# the probe set it to non-zero before invoking cleanup so the caller
# (e.g. launchd / KeepAlive, systemd, the entrypoint smoke test) sees
# the failure.
cleanup_exit_code=0
cleanup() {
    for pid in "$shim_pid" "$child_pid"; do
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill -TERM "$pid" 2>/dev/null || true
        fi
    done
    # Give them a beat to flush logs.
    sleep 0.5
    for pid in "$shim_pid" "$child_pid"; do
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            kill -KILL "$pid" 2>/dev/null || true
        fi
    done
    exit "$cleanup_exit_code"
}
# Flag flipped by the cleanup trap so wait_for_listener can bail out
# cleanly mid-poll if SIGTERM / SIGINT arrives during startup. Without
# this, a fast Ctrl-C while we're still probing the upstream port would
# spend up to the full timeout draining sleeps before cleanup runs.
shutting_down=0
trap 'shutting_down=1; cleanup' TERM INT

# -----------------------------------------------------------------------------
# Upstream listener probe (bearer mode only)
#
# Verifies that mcp-proxy is actually accepting TCP connections on
# 127.0.0.1:<UPSTREAM_PORT> BEFORE we spawn the auth shim in front of
# it. The previous shape used a bare `sleep 0.5` as a race-tolerance
# placeholder — that hid a real failure mode: when the upstream port
# was already bound by a stale prior instance (errno 48 "Address already
# in use"), mcp-proxy would crash silently on stderr and the shim would
# come up 0.5s later announcing itself bound on the operator-facing
# port. The operator saw a "running" launcher with every request 502'ing
# (or hanging until the connect timeout) because the shim was forwarding
# to a dead upstream.
#
# Return codes from wait_for_listener:
#   0 — port is in LISTEN, TCP connect succeeded
#   1 — timed out without a successful connect
#   2 — child mcp-proxy process exited before binding
#   3 — shutdown trap fired mid-poll (TERM/INT)
#
# Implementation: Python 3 is already a runtime dep (mcp-proxy and
# mcp-proxy-auth-shim are both stdlib Python). We use a 300ms-timeout
# TCP connect against 127.0.0.1:<port> in a tight 200ms-cadence poll.
# `kill -0 "$child_pid"` re-checked each iteration so a fast-failing
# mcp-proxy surfaces a clear "exited before binding" error instead of
# the operator watching the launcher spin to the timeout.
# -----------------------------------------------------------------------------

wait_for_listener() {
    local host=$1 port=$2 timeout=$3
    local deadline
    deadline=$(( $(date +%s) + timeout ))
    while [ "$(date +%s)" -lt "$deadline" ]; do
        if [ "$shutting_down" = "1" ]; then
            return 3
        fi
        if ! kill -0 "$child_pid" 2>/dev/null; then
            return 2
        fi
        if python3 -c "
import socket, sys
s = socket.socket()
s.settimeout(0.3)
try:
    s.connect(('$host', $port))
    s.close()
except OSError:
    sys.exit(1)
" 2>/dev/null; then
            # Confirm the connect didn't race past a child that died
            # mid-poll. If the child crashed (e.g. errno 48 EADDRINUSE
            # because a stale prior instance still owned the port), a
            # TCP connect to that port may still succeed against the
            # foreign listener. We require the child to still be alive
            # AFTER a successful connect; if not, return "child died
            # before binding" so the operator gets the accurate
            # diagnosis instead of a false-positive verify.
            sleep 0.2
            if [ "$shutting_down" = "1" ]; then
                return 3
            fi
            if ! kill -0 "$child_pid" 2>/dev/null; then
                return 2
            fi
            return 0
        fi
        sleep 0.2
    done
    return 1
}

# -----------------------------------------------------------------------------
# Banner + launch
#
# Print the effective policy to stderr at startup so the operator can
# eyeball what's about to be exposed before the bridge gets dialed.
# -----------------------------------------------------------------------------

{
    echo "mcp-host-bash: starting"
    echo "  port:                  $PORT"
    echo "  bind host:             $BIND_HOST${MCP_HOST_BASH_BIND:+ (MCP_HOST_BASH_BIND override)}"
    if [ -n "$BEARER" ]; then
        echo "  bearer auth:           ENABLED (shim on $BIND_HOST:$PORT -> mcp-proxy on 127.0.0.1:$UPSTREAM_PORT)"
    else
        echo "  bearer auth:           DISABLED (MCP_HOST_BASH_BEARER unset)"
        if [ "$BIND_HOST" != "127.0.0.1" ] && [ "$BIND_HOST" != "localhost" ]; then
            echo "  WARNING:               binding non-loopback ($BIND_HOST) WITHOUT bearer auth"
            echo "                         exposes the host shell-exec surface to every reachable"
            echo "                         caller, with no authentication. Set MCP_HOST_BASH_BEARER"
            echo "                         (see .env.example host-bash block) before running this"
            echo "                         shape in production."
        fi
    fi
    echo "  CW_PROFILE:            ${CW_PROFILE:-<unset; corp-dev default>}"
    if [ -n "$PROFILE_WARN" ]; then
        echo "  WARNING:               $PROFILE_WARN"
    fi
    if [ -n "$HOOK_BRIDGE_BINS" ]; then
        echo "  CLAUDE_HOOK_BRIDGE_BINS: $HOOK_BRIDGE_BINS"
    fi
    echo "  ALLOWED_COMMANDS:      $ALLOWED_COMMANDS"
    echo "  ALLOWED_FLAGS:         $ALLOWED_FLAGS"
    echo "  ALLOWED_DIR:           $ALLOWED_DIR"
    echo "  COMMAND_TIMEOUT:       $COMMAND_TIMEOUT"
    echo "  ALLOW_SHELL_OPERATORS: $ALLOW_SHELL_OPERATORS"
    echo "  log:                   $MCP_HOST_BASH_LOG"
    echo "  config:                $MCP_HOST_BASH_CONFIG (present: $([ -f "$MCP_HOST_BASH_CONFIG" ] && echo yes || echo no))"
    echo
    echo "In your .env, set:"
    echo "  CLAUDE_MCP_HTTP_BRIDGE=host-bash=http://host.docker.internal:${PORT}/mcp"
    if [ -n "$BEARER" ]; then
        echo "  CLAUDE_HOST_HOOK_BRIDGE_BEARER=<same value as MCP_HOST_BASH_BEARER>"
    fi
    echo
    echo "Ctrl-C to stop."
    echo
} >&2

# Run mcp-proxy in foreground; tee its stderr to the log file. `script`
# / `unbuffer` aren't portable on macOS without coreutils; we use
# `tee -a` on a stderr fd-swap pattern instead.
"${argv[@]}" 2> >(tee -a "$MCP_HOST_BASH_LOG" >&2) &
child_pid=$!

if [ -n "$BEARER" ]; then
    # Verify mcp-proxy is actually accepting TCP connections on its
    # internal loopback port BEFORE spawning the shim in front of it.
    # See wait_for_listener above for why a bare `sleep` was not safe.
    #
    # `|| probe_rc=$?` keeps set -e from killing the script on a
    # non-zero return — we want to handle the rc ourselves.
    probe_rc=0
    wait_for_listener 127.0.0.1 "$UPSTREAM_PORT" 10 || probe_rc=$?
    case "$probe_rc" in
        0)
            echo "  mcp-proxy upstream:    127.0.0.1:$UPSTREAM_PORT (bound, verified)" >&2
            ;;
        2)
            cat >&2 <<EOF
mcp-host-bash: FATAL: mcp-proxy exited before binding 127.0.0.1:$UPSTREAM_PORT.
       Common cause: port already owned by a stale prior instance
       (errno 48 "Address already in use"). On macOS this happens when
       a launchd-managed instance is still running.
       Check: lsof -nP -iTCP:$UPSTREAM_PORT -sTCP:LISTEN
       Kill the prior PID and re-launch, or wait ~30s for the kernel
       to release the port. Upstream stderr: $MCP_HOST_BASH_LOG
EOF
            cleanup_exit_code=1
            cleanup
            ;;
        3)
            # cleanup already fired from the trap; the trap left us
            # at exit "$cleanup_exit_code" — fall through to a final
            # non-zero exit in case we somehow re-enter.
            exit 1
            ;;
        *)
            cat >&2 <<EOF
mcp-host-bash: FATAL: mcp-proxy did not bind 127.0.0.1:$UPSTREAM_PORT within 10s.
       The process is still running but has not opened the listen
       socket. Check the log at $MCP_HOST_BASH_LOG for upstream stderr.
EOF
            cleanup_exit_code=1
            cleanup
            ;;
    esac

    # The shim handles the run_script MCP tool locally (script body fed on
    # the interpreter's STDIN, never tokenized — unlike cli-mcp-server's
    # run_command). Export the SAME policy fences cli-mcp-server enforces so
    # run_script and run_command stay in lockstep: the interpreter is
    # resolved against ALLOWED_COMMANDS, runs with cwd=ALLOWED_DIR, and is
    # capped by COMMAND_TIMEOUT.
    ALLOWED_COMMANDS="$ALLOWED_COMMANDS" \
    ALLOWED_DIR="$ALLOWED_DIR" \
    COMMAND_TIMEOUT="$COMMAND_TIMEOUT" \
    "${shim_argv[@]}" 2> >(tee -a "$MCP_HOST_BASH_LOG" >&2) &
    shim_pid=$!
    # Poll-wait on BOTH children. If EITHER dies, take the other down
    # too so we don't leak half a bridge to KeepAlive's respawn loop.
    # Avoids `wait -n` (bash 4.3+) for compatibility with macOS bash 3.2.
    while kill -0 "$child_pid" 2>/dev/null && kill -0 "$shim_pid" 2>/dev/null; do
        sleep 1
    done
    cleanup
else
    wait "$child_pid"
fi
