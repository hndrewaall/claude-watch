           f"CLAUDE_HOOK_BRIDGE_BINS: telemetry-hook missing from ALLOWED_COMMANDS, got {cmd_list}")
    expect("corp-trace-hook" in cmd_list,
           f"CLAUDE_HOOK_BRIDGE_BINS: corp-trace-hook missing from ALLOWED_COMMANDS, got {cmd_list}")
    # The conservative default floor must still be present.
    expect("git" in cmd_list,
           f"CLAUDE_HOOK_BRIDGE_BINS: profile default should still be present, got {cmd_list}")


