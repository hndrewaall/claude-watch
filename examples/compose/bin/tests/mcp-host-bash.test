#!/usr/bin/env python3
"""Tests for examples/compose/bin/mcp-host-bash — the host-side
mcp-proxy + cli-mcp-server launcher that exposes a generic
"run a bash command on the host" MCP server for the in-container
claude to dial via CLAUDE_MCP_HTTP_BRIDGE.

Exercises the script's argv construction WITHOUT actually invoking
mcp-proxy / cli-mcp-server by using the `--print-cmd` debug hook (the
script builds the planned exec argv and prints it one-per-line, then
exits 0). The hook also skips the binary-availability probe so the
test runs on any host with Python 3.

Coverage:
  - Default invocation: mcp-proxy --port 8766 --host 0.0.0.0
    --env <policy> -- cli-mcp-server (NO `uvx` prefix — both binaries
    are statically installed; see install-host-deps).
  - --port override: changes the port number in argv.
  - --port=N form: equals-sign argument shape.
  - Bad --port (missing value): exits 2.
  - Bad flag: exits 2.
  - --help: prints usage, exits 0.
  - Config-file override: ALLOWED_COMMANDS / ALLOWED_DIR etc. from the
    config file land in the argv's --env flags.
  - Default policy: ALLOWED_COMMANDS is conservative (no `bash` / `sh`),
    ALLOWED_DIR is "/" (path boundary disabled by default),
    COMMAND_TIMEOUT is 30, ALLOW_SHELL_OPERATORS is false. Guards
    against accidental relaxation in future edits.
  - MCP_HOST_BASH_DISABLED=1: refuses to start (--print-cmd flag means
    we still build the argv for inspection — but the live-launch path
    exits 0 before reaching exec).
  - Static install: the launcher script source must NOT contain `uvx
    mcp-proxy` / `uvx cli-mcp-server` invocations (regression guard
    against re-introducing dynamic per-launch fetches), and the
    pre-flight error message must point operators at install-host-deps.

Run:  ./mcp-host-bash.test
"""

from __future__ import annotations

import os
import socket
import subprocess
import sys
import tempfile
import textwrap
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "mcp-host-bash"

if not SCRIPT.exists():
    print(f"FAIL: cannot locate mcp-host-bash at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


def run_script(
    args: list[str] | None = None,
    env: dict | None = None,
    expect_rc: int = 0,
) -> tuple[list[str], str, str, int]:
    """Run mcp-host-bash with the given argv + env. Returns
    (stdout_lines, stdout, stderr, returncode)."""
    if args is None:
        args = []
    base_env = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "HOME": "/tmp/fake-home-mcp-host-bash",
        # Pin config / log to a fresh tmpdir per call so the suite
        # doesn't trip over operator config on the test host.
        "MCP_HOST_BASH_CONFIG": "/dev/null",
    }
    if env:
        base_env.update(env)
    result = subprocess.run(
        [str(SCRIPT), *args],
        env=base_env,
        capture_output=True,
        text=True,
        timeout=10,
    )
    if expect_rc is not None and result.returncode != expect_rc:
        raise AssertionError(
            f"mcp-host-bash exited {result.returncode}, expected {expect_rc}\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )
    return result.stdout.splitlines(), result.stdout, result.stderr, result.returncode


# ---------------------------------------------------------------------------
# Test cases
# ---------------------------------------------------------------------------

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def find_env_value(lines: list[str], key: str) -> str | None:
    """Return the value of an `--env KEY VALUE` triple in the printed
    argv, or None if no such triple exists.

    mcp-proxy 0.11.0 changed `--env` from `--env KEY=VALUE` (single
    arg, two-line printed form) to `--env KEY VALUE` (two args,
    three-line printed form). The argv builder in mcp-host-bash
    follows the new shape; this helper parses it back out."""
    for i, line in enumerate(lines):
        if line == "--env" and i + 2 < len(lines) and lines[i + 1] == key:
            return lines[i + 2]
    return None


def test_print_cmd_default_argv() -> None:
    """Default: mcp-proxy --port 8766 --host 127.0.0.1 --env ... --
    cli-mcp-server. NO `uvx` prefix — both binaries are statically
    installed via install-host-deps; the launcher exec's them
    directly so each start is offline (no per-launch PyPI fetch).

    The default bind is 127.0.0.1 (loopback only). Operators who need
    LAN / Docker-bridge reachability set MCP_HOST_BASH_BIND=0.0.0.0
    explicitly — see test_bind_env_override_widens_listener."""
    lines, _, _, _ = run_script(["--print-cmd"])
    expect(lines[0] == "mcp-proxy",
           f"default: argv[0] should be mcp-proxy (statically installed, "
           f"NOT uvx-wrapped), got {lines[0]!r}")
    expect("--port" in lines,
           f"default: argv should include --port, got {lines}")
    port_idx = lines.index("--port")
    expect(lines[port_idx + 1] == "8766",
           f"default: --port should be 8766, got {lines[port_idx + 1]!r}")
    expect("--host" in lines,
           f"default: argv should include --host, got {lines}")
    host_idx = lines.index("--host")
    expect(lines[host_idx + 1] == "127.0.0.1",
           f"default: --host should be 127.0.0.1 (loopback only — the "
           f"safe floor; operators set MCP_HOST_BASH_BIND=0.0.0.0 to "
           f"opt into LAN exposure), got {lines[host_idx + 1]!r}")
    expect("--" in lines,
           f"default: argv should include the stdio-subprocess separator '--', got {lines}")
    sep_idx = lines.index("--")
    expect(sep_idx + 1 < len(lines) and lines[sep_idx + 1] == "cli-mcp-server",
           f"default: after '--', argv should be `cli-mcp-server` (statically "
           f"installed, NOT uvx-wrapped), got {lines[sep_idx+1:sep_idx+2]}")
    # Guard against re-introducing the uvx wrapper anywhere in the argv.
    expect("uvx" not in lines,
           f"default: argv must NOT contain `uvx` (would re-fetch from PyPI "
           f"on every launch — slow, fragile, broken under corp-CA); "
           f"got {lines}")


def test_default_policy_conservative() -> None:
    """The default allow-list must NOT include arbitrary shell-exec
    binaries (bash, sh, zsh) and must enforce shell-operator blocking.
    Guards against future edits accidentally relaxing the floor."""
    lines, _, _, _ = run_script(["--print-cmd"])
    cmds = find_env_value(lines, "ALLOWED_COMMANDS") or ""
    cmd_list = [c.strip() for c in cmds.split(",")]
    for forbidden in ("bash", "sh", "zsh", "fish", "all"):
        expect(forbidden not in cmd_list,
               f"default ALLOWED_COMMANDS should NOT include {forbidden!r} "
               f"(would let the container exec arbitrary shell payloads); "
               f"got {cmd_list}")
    operators = find_env_value(lines, "ALLOW_SHELL_OPERATORS")
    expect(operators == "false",
           f"default ALLOW_SHELL_OPERATORS should be 'false' (block pipes / "
           f"&&  / redirects / etc.), got {operators!r}")
    timeout = find_env_value(lines, "COMMAND_TIMEOUT")
    expect(timeout == "30",
           f"default COMMAND_TIMEOUT should be 30s, got {timeout!r}")
    max_len = find_env_value(lines, "MAX_COMMAND_LENGTH")
    expect(max_len == "8192",
           f"default MAX_COMMAND_LENGTH should be 8192 (raised from "
           f"cli-mcp-server's 1024 default), got {max_len!r}")
    dir_ = find_env_value(lines, "ALLOWED_DIR")
    expect(dir_ == "/",
           f"default ALLOWED_DIR should be '/' (path boundary "
           f"disabled by default; the command allow-list stays the "
           f"safety floor), got {dir_!r}")


def test_port_override_space_form() -> None:
    """--port 9000 → argv reflects 9000."""
    lines, _, _, _ = run_script(["--print-cmd", "--port", "9000"])
    port_idx = lines.index("--port")
    expect(lines[port_idx + 1] == "9000",
           f"--port 9000: argv should have port 9000, got {lines[port_idx + 1]!r}")


def test_port_override_equals_form() -> None:
    """--port=9001 → argv reflects 9001."""
    lines, _, _, _ = run_script(["--print-cmd", "--port=9001"])
    port_idx = lines.index("--port")
    expect(lines[port_idx + 1] == "9001",
           f"--port=9001: argv should have port 9001, got {lines[port_idx + 1]!r}")


def test_missing_port_value() -> None:
    """--port with no following arg → exit 2."""
    _, _, stderr, rc = run_script(["--port"], expect_rc=2)
    expect(rc == 2, f"missing --port value: rc should be 2, got {rc}")
    expect("--port" in stderr,
           f"missing --port value: stderr should mention --port, got {stderr!r}")


def test_bad_flag() -> None:
    """--bogus → exit 2."""
    _, _, stderr, rc = run_script(["--bogus"], expect_rc=2)
    expect(rc == 2, f"bad flag: rc should be 2, got {rc}")
    expect("unknown argument" in stderr,
           f"bad flag: stderr should mention 'unknown argument', got {stderr!r}")


def test_help_exits_zero() -> None:
    """--help prints usage and exits 0."""
    lines, _, _, rc = run_script(["--help"])
    expect(rc == 0, f"--help: rc should be 0, got {rc}")
    expect(any("mcp-host-bash" in ln for ln in lines),
           f"--help: stdout should mention the script name, got {lines[:5]}")
    expect(any("Usage" in ln or "usage" in ln for ln in lines),
           f"--help: stdout should contain usage block, got first 30 lines:\n"
           f"{chr(10).join(lines[:30])}")


def test_config_file_overrides_defaults() -> None:
    """ALLOWED_COMMANDS / ALLOWED_DIR etc. from the config file land in
    the argv's --env flags (overrides the defaults)."""
    with tempfile.TemporaryDirectory() as td:
        cfg = Path(td) / "policy.env"
        cfg.write_text(
            "ALLOWED_COMMANDS=git,gh,make\n"
            "ALLOWED_DIR=/Users/me/work\n"
            "COMMAND_TIMEOUT=60\n"
            "MAX_COMMAND_LENGTH=4096\n"
            "ALLOW_SHELL_OPERATORS=true\n"
        )
        lines, _, _, _ = run_script(
            ["--print-cmd"],
            env={"MCP_HOST_BASH_CONFIG": str(cfg)},
        )
        cmds = find_env_value(lines, "ALLOWED_COMMANDS")
        expect(cmds == "git,gh,make",
               f"config override: ALLOWED_COMMANDS should be from file, got {cmds!r}")
        dir_ = find_env_value(lines, "ALLOWED_DIR")
        expect(dir_ == "/Users/me/work",
               f"config override: ALLOWED_DIR should be from file, got {dir_!r}")
        timeout = find_env_value(lines, "COMMAND_TIMEOUT")
        expect(timeout == "60",
               f"config override: COMMAND_TIMEOUT should be from file, got {timeout!r}")
        max_len = find_env_value(lines, "MAX_COMMAND_LENGTH")
        expect(max_len == "4096",
               f"config override: MAX_COMMAND_LENGTH should be from file, "
               f"got {max_len!r}")
        operators = find_env_value(lines, "ALLOW_SHELL_OPERATORS")
        expect(operators == "true",
               f"config override: ALLOW_SHELL_OPERATORS should be from file, "
               f"got {operators!r}")


def test_config_missing_falls_back_to_defaults() -> None:
    """If the config file doesn't exist, we fall back to defaults (no
    error). Already exercised by the default tests (MCP_HOST_BASH_CONFIG
    points at /dev/null which is not a regular file). This case
    pins a NON-existent path explicitly."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_CONFIG": "/nonexistent/path/to/policy.env"},
    )
    cmds = find_env_value(lines, "ALLOWED_COMMANDS")
    expect(cmds is not None and "git" in cmds,
           f"missing config: should fall back to defaults (git included), got {cmds!r}")


def test_disabled_kill_switch() -> None:
    """MCP_HOST_BASH_DISABLED=1 + no --print-cmd → exit 0 immediately
    with a stderr message."""
    _, _, stderr, rc = run_script(
        [],  # no --print-cmd, so the kill-switch path is exercised
        env={"MCP_HOST_BASH_DISABLED": "1"},
        expect_rc=0,
    )
    expect(rc == 0, f"kill switch: rc should be 0 (refused start), got {rc}")
    expect("MCP_HOST_BASH_DISABLED" in stderr,
           f"kill switch: stderr should mention MCP_HOST_BASH_DISABLED, got {stderr!r}")


def test_separator_position() -> None:
    """The `--` separator must come AFTER all --env / --port / --host
    flags and IMMEDIATELY BEFORE the stdio subprocess argv. mcp-proxy
    treats everything after `--` as the spawned subprocess, so a
    mis-positioned separator would either leak --env into the spawned
    binary or drop the bridge."""
    lines, _, _, _ = run_script(["--print-cmd"])
    sep_idx = lines.index("--")
    # All --env flags must come BEFORE the separator.
    env_indices = [i for i, ln in enumerate(lines) if ln == "--env"]
    for ei in env_indices:
        expect(ei < sep_idx,
               f"separator: --env at {ei} should precede '--' at {sep_idx}; "
               f"got {lines}")
    # Nothing after the separator should be a flag.
    after = lines[sep_idx + 1:]
    expect(after == ["cli-mcp-server"],
           f"separator: after '--', expected ['cli-mcp-server'] (statically "
           f"installed, NOT uvx-wrapped), got {after}")


# The expected default ALLOWED_COMMANDS string. Mirrors
# DEFAULT_ALLOWED_COMMANDS in mcp-host-bash. Bumped when the script's
# default widens — keep in sync, this is the load-bearing assertion.
EXPECTED_DEFAULT_ALLOWED = (
    "ls,cat,pwd,git,gh,head,tail,grep,find,echo,jq,yq,make,awk,sed,cut,tr,"
    "wc,xargs,which,printenv,env,sort,uniq,diff,file,stat,base64,uname,"
    "hostname,date,basename,dirname,node,npm,yarn,python,python3,pip,ping,"
    "host,dig,nslookup,envchain,jenkins-builds"
)


def test_cw_profile_unset_is_default() -> None:
    """CW_PROFILE unset => same default allow-list as the canonical string."""
    lines, _, _, _ = run_script(["--print-cmd"])
    # Find ALLOWED_COMMANDS value (line after the marker).
    idx = lines.index("ALLOWED_COMMANDS")
    val = lines[idx + 1]
    expect(
        val == EXPECTED_DEFAULT_ALLOWED,
        f"cw_profile unset: ALLOWED_COMMANDS should be the canonical "
        f"default, got {val!r}",
    )


def test_cw_profile_corp_dev_equals_default() -> None:
    """CW_PROFILE=corp-dev is explicit-equivalent to unset."""
    lines, _, _, _ = run_script(["--print-cmd"], env={"CW_PROFILE": "corp-dev"})
    idx = lines.index("ALLOWED_COMMANDS")
    val = lines[idx + 1]
    expect(
        val == EXPECTED_DEFAULT_ALLOWED,
        f"cw_profile=corp-dev: ALLOWED_COMMANDS should match default, "
        f"got {val!r}",
    )


def test_default_includes_corp_dev_tooling() -> None:
    """Default profile must include the example corp-dev tooling
    (envchain, jenkins-builds) plus the standard dev-language toolchains
    and read-y network probes so the day-to-day workflow doesn't need
    CW_PROFILE flips. Operator-specific CLIs (cloud SDKs, deploy tools)
    are added via an explicit ALLOWED_COMMANDS override, NOT the default."""
    lines, _, _, _ = run_script(["--print-cmd"])
    idx = lines.index("ALLOWED_COMMANDS")
    cmd_list = [c.strip() for c in lines[idx + 1].split(",")]
    # Example corp-dev binaries shipped in the default.
    for needed in ("envchain", "jenkins-builds"):
        expect(
            needed in cmd_list,
            f"default must include corp-dev tool {needed!r}; got {cmd_list}",
        )
    # Common dev-language toolchains.
    for needed in ("node", "npm", "yarn", "python", "python3", "pip", "make"):
        expect(
            needed in cmd_list,
            f"default must include dev toolchain {needed!r}; got {cmd_list}",
        )
    # Read-y network probes.
    for needed in ("ping", "host", "dig", "nslookup"):
        expect(
            needed in cmd_list,
            f"default must include read-y network probe {needed!r}; "
            f"got {cmd_list}",
        )
    # Pure-observation binaries.
    for needed in ("uname", "hostname", "date", "basename", "dirname",
                   "which", "env", "printenv"):
        expect(
            needed in cmd_list,
            f"default must include observation tool {needed!r}; "
            f"got {cmd_list}",
        )


def test_default_excludes_destructive_and_scheduling() -> None:
    """Destructive / privileged / scheduling / outbound-bytes binaries
    MUST stay out of the default — they live in CW_PROFILE=corp-dev-trusted.
    Guards against future drift collapsing the trust gradient."""
    lines, _, _, _ = run_script(["--print-cmd"])
    idx = lines.index("ALLOWED_COMMANDS")
    cmd_list = [c.strip() for c in lines[idx + 1].split(",")]
    # Destructive / mutating filesystem.
    for forbidden in ("rm", "chmod", "mv", "cp", "mkdir", "tee"):
        expect(
            forbidden not in cmd_list,
            f"default must NOT include destructive tool {forbidden!r} "
            f"(only in corp-dev-trusted); got {cmd_list}",
        )
    # Host scheduling.
    for forbidden in ("crontab", "launchctl", "systemctl", "schtasks",
                      "powershell", "pwsh"):
        expect(
            forbidden not in cmd_list,
            f"default must NOT include scheduling tool {forbidden!r} "
            f"(only in corp-dev-trusted); got {cmd_list}",
        )
    # Outbound bytes.
    for forbidden in ("curl", "wget", "scp"):
        expect(
            forbidden not in cmd_list,
            f"default must NOT include outbound-bytes tool {forbidden!r} "
            f"(only in corp-dev-trusted); got {cmd_list}",
        )
    # Key / cert tooling.
    for forbidden in ("openssl", "ssh-keygen"):
        expect(
            forbidden not in cmd_list,
            f"default must NOT include key/cert tool {forbidden!r} "
            f"(only in corp-dev-trusted); got {cmd_list}",
        )
    # Container management — destructive subcommands (docker rm / stop /
    # kill) share the binary with read-y ones (docker ps / logs), so the
    # binary is trusted-only.
    for forbidden in ("docker", "docker-compose"):
        expect(
            forbidden not in cmd_list,
            f"default must NOT include container mgmt tool {forbidden!r} "
            f"(only in corp-dev-trusted); got {cmd_list}",
        )


def test_cw_profile_trusted_widens() -> None:
    """CW_PROFILE=corp-dev-trusted adds host-scheduling, file-mutation,
    outbound-bytes, and key/cert tooling on top of the read-y default."""
    lines, _, _, _ = run_script(
        ["--print-cmd"], env={"CW_PROFILE": "corp-dev-trusted"}
    )
    idx = lines.index("ALLOWED_COMMANDS")
    val = lines[idx + 1]
    # Must contain the default PLUS the trusted extras.
    expect(
        val.startswith(EXPECTED_DEFAULT_ALLOWED + ","),
        f"cw_profile=corp-dev-trusted: should start with the canonical "
        f"default, got {val!r}",
    )
    cmd_list = val.split(",")
    # Spot-check trusted extras (scheduling, mutation, network, keys,
    # container mgmt).
    for extra in [
        "crontab",
        "launchctl",
        "systemctl",
        "schtasks",
        "powershell",
        "pwsh",
        "tee",
        "mkdir",
        "chmod",
        "rm",
        "cp",
        "mv",
        "curl",
        "wget",
        "scp",
        "openssl",
        "ssh-keygen",
        "sw_vers",
        "lsb_release",
        "docker",
        "docker-compose",
    ]:
        expect(
            extra in cmd_list,
            f"cw_profile=corp-dev-trusted: should include {extra!r}, "
            f"got {val!r}",
        )


def test_cw_profile_unknown_falls_back() -> None:
    """Unknown CW_PROFILE value => fall back to default + stderr warning."""
    lines, _, stderr, _ = run_script(
        ["--print-cmd"], env={"CW_PROFILE": "made-up-profile"}
    )
    idx = lines.index("ALLOWED_COMMANDS")
    val = lines[idx + 1]
    expect(
        val == EXPECTED_DEFAULT_ALLOWED,
        f"cw_profile=unknown: should fall back to canonical default, "
        f"got {val!r}",
    )


def test_launcher_source_has_no_uvx_invocations() -> None:
    """Regression guard: the launcher script must NOT invoke `uvx
    mcp-proxy` or `uvx cli-mcp-server` directly. Those forms re-fetch
    the package from PyPI on every launch (slow, fragile, broken under
    corp-CA). Both binaries are statically installed via the bundled
    `install-host-deps`; the launcher exec's them directly."""
    src = SCRIPT.read_text()
    # Strip comment lines so historical references in the header
    # documentation don't false-positive (we explain WHY uvx was
    # removed). Only flag actual code references.
    code_lines = [ln for ln in src.splitlines() if not ln.lstrip().startswith("#")]
    code = "\n".join(code_lines)
    for forbidden in ("uvx mcp-proxy", "uvx cli-mcp-server"):
        expect(forbidden not in code,
               f"launcher source: must not invoke {forbidden!r} (would "
               f"re-fetch from PyPI per launch). Run install-host-deps "
               f"once and exec the static binary instead.")


def test_preflight_error_points_to_installer() -> None:
    """When mcp-proxy / cli-mcp-server are missing on PATH, the
    pre-flight error must point the operator at install-host-deps so
    they know how to fix it. We exercise this by running the launcher
    with a PATH that excludes both binaries (and crucially, includes
    the standard /usr/bin so `command -v` itself still works)."""
    # Use a deliberately-empty PATH so neither binary resolves.
    _, _, stderr, rc = run_script(
        [],
        env={
            "PATH": "/usr/bin:/bin",  # standard utilities, but no mcp-proxy
            "HOME": "/tmp/fake-home-mcp-host-bash",
            "MCP_HOST_BASH_CONFIG": "/dev/null",
        },
        expect_rc=1,
    )
    expect(rc == 1, f"missing binaries: rc should be 1, got {rc}")
    expect("install-host-deps" in stderr,
           f"missing binaries: stderr should point at install-host-deps, "
           f"got {stderr!r}")
    expect("mcp-proxy" in stderr,
           f"missing binaries: stderr should mention mcp-proxy by name, "
           f"got {stderr!r}")


def test_install_host_deps_script_exists_and_parses() -> None:
    """The bundled installer must exist, be executable, and parse as
    valid bash. We don't actually run `uv tool install` (would hit
    PyPI in CI). Instead we smoke-check the script itself: shebang,
    bash -n parse, and that it lists both packages it's supposed to
    install."""
    installer = SCRIPT.parent / "install-host-deps"
    expect(installer.exists(),
           f"installer: install-host-deps should exist next to mcp-host-bash, "
           f"looked at {installer}")
    if installer.exists():
        expect(os.access(installer, os.X_OK),
               f"installer: install-host-deps should be executable")
        # bash -n: parse-only, no execution.
        result = subprocess.run(
            ["bash", "-n", str(installer)],
            capture_output=True, text=True, timeout=5,
        )
        expect(result.returncode == 0,
               f"installer: install-host-deps must parse cleanly under "
               f"bash -n; stderr:\n{result.stderr}")
        body = installer.read_text()
        # Both packages must appear in the script's package list.
        for pkg in ("mcp-proxy", "cli-mcp-server"):
            expect(pkg in body,
                   f"installer: install-host-deps must reference {pkg!r}")
        # And it must use `uv tool install` (the static-install verb).
        expect("uv tool install" in body or "uv \"${install_args" in body
               or "uv \"${install_args[@]}\"" in body
               or "tool install" in body,
               f"installer: install-host-deps must invoke `uv tool install` "
               f"(the static-install verb)")
        # --help must work.
        result = subprocess.run(
            [str(installer), "--help"],
            capture_output=True, text=True, timeout=5,
        )
        expect(result.returncode == 0,
               f"installer: --help should exit 0, got {result.returncode}; "
               f"stderr:\n{result.stderr}")


def test_install_host_deps_rejects_bad_flag() -> None:
    """Installer with an unknown flag must exit 2 with a usage hint."""
    installer = SCRIPT.parent / "install-host-deps"
    if not installer.exists():
        return  # covered by the existence test above
    result = subprocess.run(
        [str(installer), "--bogus"],
        capture_output=True, text=True, timeout=5,
    )
    expect(result.returncode == 2,
           f"installer: --bogus should exit 2, got {result.returncode}")
    expect("unknown argument" in result.stderr,
           f"installer: --bogus stderr should mention 'unknown argument', "
           f"got {result.stderr!r}")


def test_cw_profile_operator_override_wins() -> None:
    """Operator's ALLOWED_COMMANDS in config beats CW_PROFILE default."""
    with tempfile.TemporaryDirectory(prefix="mcp-host-bash-test-") as d:
        cfg = Path(d, "mcp-host-bash.env")
        cfg.write_text("ALLOWED_COMMANDS=only-this\n")
        lines, _, _, _ = run_script(
            ["--print-cmd"],
            env={
                "CW_PROFILE": "corp-dev-trusted",
                "MCP_HOST_BASH_CONFIG": str(cfg),
            },
        )
        idx = lines.index("ALLOWED_COMMANDS")
        val = lines[idx + 1]
        expect(
            val == "only-this",
            f"operator override should beat profile default; "
            f"got ALLOWED_COMMANDS={val!r}",
        )


def test_hook_bridge_bins_merged_into_allow_list() -> None:
    """CLAUDE_HOOK_BRIDGE_BINS adds operator-declared hook binary
    basenames to ALLOWED_COMMANDS so the in-container exec-hook bridge
    can invoke them via cli-mcp-server's run_command tool."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"CLAUDE_HOOK_BRIDGE_BINS": "telemetry-hook,corp-trace-hook"},
    )
