           f"trusted+bridge-bins: trusted-profile extras dropped, got {cmd_list}")


def test_bind_default_is_loopback() -> None:
    """Defense-in-depth: with MCP_HOST_BASH_BIND unset, --host MUST
    resolve to 127.0.0.1. Guards against a future edit accidentally
    restoring the 0.0.0.0 default (the C1 finding from the
    2026-05-14 internal mcp-proxy security audit).

    The audit found that the previous 0.0.0.0 default exposed the
    host shell-exec surface to every device on the LAN + every
    sibling Docker container + every local UID, with no
    authentication. Loopback default closes the LAN + sibling-uid
    surface; operators who need wider reach set MCP_HOST_BASH_BIND
    explicitly + (in a follow-up PR) bearer-auth their callers."""
    lines, _, _, _ = run_script(["--print-cmd"])
    host_idx = lines.index("--host")
    expect(
        lines[host_idx + 1] == "127.0.0.1",
        f"loopback default: --host MUST be 127.0.0.1 when "
        f"MCP_HOST_BASH_BIND is unset, got {lines[host_idx + 1]!r}",
    )


def test_bind_env_override_widens_listener() -> None:
    """MCP_HOST_BASH_BIND=0.0.0.0 in env => --host 0.0.0.0 in argv.
    Operator-explicit opt-in path for Linux Docker bridge-net
    containers that need host.docker.internal reachability."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_BIND": "0.0.0.0"},
    )
    host_idx = lines.index("--host")
    expect(
        lines[host_idx + 1] == "0.0.0.0",
        f"bind override: --host should be 0.0.0.0 when "
        f"MCP_HOST_BASH_BIND=0.0.0.0, got {lines[host_idx + 1]!r}",
    )


def test_bind_env_override_specific_interface() -> None:
    """MCP_HOST_BASH_BIND=172.17.0.1 => --host 172.17.0.1. The
    value is passed verbatim — operators can pin to a specific
    interface IP for a tighter listen surface than bare 0.0.0.0."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_BIND": "172.17.0.1"},
    )
    host_idx = lines.index("--host")
    expect(
        lines[host_idx + 1] == "172.17.0.1",
        f"bind specific IP: --host should pass through verbatim, "
        f"got {lines[host_idx + 1]!r}",
    )


def find_shim_value(lines: list[str], key: str) -> str | None:
    """Return the value of `--<key> VALUE` in the SHIM argv block of
    --print-cmd output. The launcher prints `SHIM:` header, then the
    shim argv one-per-line, then a blank line, then `MCP_PROXY:`,
    then the mcp-proxy argv. We scope this lookup to the SHIM block."""
    flag = f"--{key}"
    in_shim = False
    for i, line in enumerate(lines):
        if line == "SHIM:":
            in_shim = True
            continue
        if line == "MCP_PROXY:" or line == "":
            in_shim = False
            continue
        if in_shim and line == flag and i + 1 < len(lines):
            return lines[i + 1]
    return None


def find_mcp_proxy_index(lines: list[str], flag: str) -> int | None:
    """Find a flag inside the MCP_PROXY block of --print-cmd output.
    Returns the index of the flag (caller looks one line ahead for
    the value), or None if not found."""
    in_mcp = False
    for i, line in enumerate(lines):
        if line == "MCP_PROXY:":
            in_mcp = True
            continue
        if line == "SHIM:":
            in_mcp = False
            continue
        if in_mcp and line == flag:
            return i
    # If no SHIM/MCP_PROXY headers (bearer not set), the whole output
    # IS the mcp-proxy argv.
    if "SHIM:" not in lines and flag in lines:
        return lines.index(flag)
    return None


def test_bearer_mode_emits_shim_argv() -> None:
    """When MCP_HOST_BASH_BEARER is set, --print-cmd output includes a
    SHIM: block with the auth shim's argv, then a MCP_PROXY: block
    with mcp-proxy on the internal loopback port (PORT+1 by default).
    The shim binds the public-facing port; mcp-proxy binds
    127.0.0.1:<internal>."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_BEARER": "test-secret-not-real"},
    )
    expect(
        "SHIM:" in lines,
        f"bearer mode: --print-cmd should emit SHIM: header, got {lines!r}",
    )
    expect(
        "MCP_PROXY:" in lines,
        f"bearer mode: --print-cmd should emit MCP_PROXY: header, got {lines!r}",
    )
    listen_host = find_shim_value(lines, "listen-host")
    listen_port = find_shim_value(lines, "listen-port")
    upstream_host = find_shim_value(lines, "upstream-host")
    upstream_port = find_shim_value(lines, "upstream-port")
    expect(
        listen_host == "127.0.0.1",
        f"bearer mode: shim --listen-host should match default BIND "
        f"(127.0.0.1), got {listen_host!r}",
    )
    expect(
        listen_port == "8766",
        f"bearer mode: shim --listen-port should match the public PORT "
        f"(8766), got {listen_port!r}",
    )
    expect(
        upstream_host == "127.0.0.1",
        f"bearer mode: shim --upstream-host should be 127.0.0.1 (mcp-proxy "
        f"must stay loopback so only the shim reaches it), got "
        f"{upstream_host!r}",
    )
    expect(
        upstream_port == "8767",
        f"bearer mode: shim --upstream-port should default to PORT+1 "
        f"(8767), got {upstream_port!r}",
    )
    # mcp-proxy itself must be bound to the internal loopback port, NOT
    # the public-facing port — otherwise the shim and mcp-proxy race for
    # the public port AND the shim's auth gate is bypassable.
    mcp_port_idx = find_mcp_proxy_index(lines, "--port")
    mcp_host_idx = find_mcp_proxy_index(lines, "--host")
    expect(mcp_port_idx is not None, "bearer mode: MCP_PROXY block missing --port")
    expect(mcp_host_idx is not None, "bearer mode: MCP_PROXY block missing --host")
    if mcp_port_idx is not None:
        expect(
            lines[mcp_port_idx + 1] == "8767",
            f"bearer mode: mcp-proxy --port should be the internal port "
            f"(8767), got {lines[mcp_port_idx + 1]!r}",
        )
    if mcp_host_idx is not None:
        expect(
            lines[mcp_host_idx + 1] == "127.0.0.1",
            f"bearer mode: mcp-proxy --host should be 127.0.0.1 (so only "
            f"the shim can dial it), got {lines[mcp_host_idx + 1]!r}",
        )


def test_bearer_mode_with_bind_override() -> None:
    """MCP_HOST_BASH_BIND=0.0.0.0 + bearer set => shim binds 0.0.0.0
    (public-facing LAN listener gated by bearer), mcp-proxy still binds
    127.0.0.1 (internal loopback). The split-binding is the whole
    point of the shim — public surface authenticated, internal surface
    unreachable to non-shim callers."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={
            "MCP_HOST_BASH_BIND": "0.0.0.0",
            "MCP_HOST_BASH_BEARER": "test-secret-not-real",
        },
    )
    listen_host = find_shim_value(lines, "listen-host")
    expect(
        listen_host == "0.0.0.0",
        f"bearer+bind override: shim --listen-host should be 0.0.0.0 "
        f"(public-facing), got {listen_host!r}",
    )
    mcp_host_idx = find_mcp_proxy_index(lines, "--host")
    if mcp_host_idx is not None:
        expect(
            lines[mcp_host_idx + 1] == "127.0.0.1",
            f"bearer+bind override: mcp-proxy --host MUST stay 127.0.0.1 "
            f"(only the shim reaches it; LAN callers hit the shim's auth "
            f"gate), got {lines[mcp_host_idx + 1]!r}",
        )


def test_bearer_mode_with_custom_upstream_port() -> None:
    """MCP_HOST_BASH_UPSTREAM_PORT overrides the internal port (default
    PORT+1). Useful when PORT+1 is already bound by another service."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={
            "MCP_HOST_BASH_BEARER": "test-secret-not-real",
            "MCP_HOST_BASH_UPSTREAM_PORT": "9999",
        },
    )
    expect(
        find_shim_value(lines, "upstream-port") == "9999",
        f"upstream port override: shim --upstream-port should be 9999, "
        f"got {find_shim_value(lines, 'upstream-port')!r}",
    )
    mcp_port_idx = find_mcp_proxy_index(lines, "--port")
    if mcp_port_idx is not None:
        expect(
            lines[mcp_port_idx + 1] == "9999",
            f"upstream port override: mcp-proxy --port should be 9999, "
            f"got {lines[mcp_port_idx + 1]!r}",
        )


def test_bearer_unset_no_shim_in_argv() -> None:
    """No bearer => no SHIM: / MCP_PROXY: headers, just bare mcp-proxy
    argv binding the public-facing port directly. Matches the
    pre-bearer-auth launcher shape so existing operators see no
    behavior change until they opt into bearer auth."""
    lines, _, _, _ = run_script(["--print-cmd"])
    expect(
        "SHIM:" not in lines,
        f"no bearer: should NOT emit SHIM: header, got {lines!r}",
    )
    expect(
        "MCP_PROXY:" not in lines,
        f"no bearer: should NOT emit MCP_PROXY: header, got {lines!r}",
    )
    # First arg is mcp-proxy itself.
    expect(
        lines[0] == "mcp-proxy",
        f"no bearer: argv[0] should be mcp-proxy, got {lines[0]!r}",
    )


def test_bearer_empty_string_treated_as_unset() -> None:
    """MCP_HOST_BASH_BEARER="" (empty value) => no shim, no auth gate.
    Treats empty same as unset so an operator accidentally exporting
    an empty variable doesn't end up running the shim with an empty
    bearer (the shim would fail-closed at startup anyway, but
    treating empty as "no bearer mode" at the launcher level is the
    clearer contract)."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_BEARER": ""},
    )
    expect(
        "SHIM:" not in lines,
        f"empty bearer: should NOT emit SHIM: header, got {lines!r}",
    )


def test_bind_env_empty_falls_back_to_loopback() -> None:
    """MCP_HOST_BASH_BIND="" (empty string) => default to 127.0.0.1.
    Treats an empty value the same as unset — operators
    accidentally exporting an empty variable still get the safe
    floor."""
    lines, _, _, _ = run_script(
        ["--print-cmd"],
        env={"MCP_HOST_BASH_BIND": ""},
    )
    host_idx = lines.index("--host")
    expect(
        lines[host_idx + 1] == "127.0.0.1",
        f"empty bind env: --host should fall back to 127.0.0.1, "
        f"got {lines[host_idx + 1]!r}",
    )


def test_hook_bridge_bins_unset_no_effect() -> None:
    """No CLAUDE_HOOK_BRIDGE_BINS => ALLOWED_COMMANDS unchanged from profile default."""
    lines_with, _, _, _ = run_script(["--print-cmd"])
    cmds_default = find_env_value(lines_with, "ALLOWED_COMMANDS") or ""
    cmd_list_default = set(c.strip() for c in cmds_default.split(","))
    # Spot-check: telemetry-hook is NOT in the default list.
    expect("telemetry-hook" not in cmd_list_default,
           f"unset bridge-bins: telemetry-hook should NOT leak into default, got {cmd_list_default}")


# ---------------------------------------------------------------------------
# Bearer-mode upstream-listener probe tests
#
# The launcher used to fire `sleep 0.5` before spawning the auth shim
# in bearer mode. When mcp-proxy failed to bind its internal port (e.g.
# the port was already taken by a stale prior instance), the launcher
# silently announced the shim "started" while pointing it at a dead
# upstream — every request 502'd. The fix replaces the bare sleep with
# a real TCP-connect probe that times out cleanly, names the actual
# failure mode (port-already-bound vs upstream-died-early vs slow), and
# refuses to spawn the shim if mcp-proxy is not actually listening.
#
# These two tests live-launch the script (no --print-cmd) with mock
# mcp-proxy / mcp-proxy-auth-shim binaries on a temp PATH so we can
# control the bind behavior without depending on the real PyPI packages
# being installed in CI.
# ---------------------------------------------------------------------------


def free_port_pair() -> tuple[int, int]:
    """Reserve + release two ephemeral 127.0.0.1 ports. We hold both
    sockets open until both ports are picked so we don't accidentally
    pick the same number twice. The caller then races against the
    kernel + the rest of the system to use them — fine for serial
    tests."""
    s1 = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s2 = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    try:
        s1.bind(("127.0.0.1", 0))
        s2.bind(("127.0.0.1", 0))
        return s1.getsockname()[1], s2.getsockname()[1]
    finally:
        s1.close()
        s2.close()


def write_mock_mcp_proxy(bin_dir: Path, listen_port_var: str = "UPSTREAM_PORT") -> Path:
    """Drop a fake `mcp-proxy` script into bin_dir that binds the
    requested port (read from --port arg). Stays alive until killed.

    We deliberately do NOT consume any of the mcp-proxy-specific flags
    (--env, --host, --) — they're just argv noise. We only care about
    --port so the mock binds the same port the real one would."""
    path = bin_dir / "mcp-proxy"
    path.write_text(textwrap.dedent("""\
        #!/usr/bin/env python3
        # Fake mcp-proxy for mcp-host-bash launcher tests. Binds the
        # --port value on 127.0.0.1 and stays in accept() forever.
        import socket, sys, time, signal
        port = None
        argv = sys.argv[1:]
        for i, a in enumerate(argv):
            if a == "--port" and i + 1 < len(argv):
                port = int(argv[i + 1])
                break
        if port is None:
            sys.stderr.write("fake-mcp-proxy: no --port\\n")
            sys.exit(2)
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        try:
            s.bind(("127.0.0.1", port))
        except OSError as e:
            sys.stderr.write(f"fake-mcp-proxy: bind failed: {e}\\n")
            sys.exit(1)
        s.listen(8)
        signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
        while True:
            try:
                conn, _ = s.accept()
                conn.close()
            except OSError:
                break
    """))
    path.chmod(0o755)
    return path


def write_mock_shim(bin_dir: Path) -> Path:
    """Drop a fake `mcp-proxy-auth-shim` into bin_dir that binds the
    --listen-port and stays alive. Used to verify the shim DOES come
    up in the happy path."""
    path = bin_dir / "mcp-proxy-auth-shim"
    path.write_text(textwrap.dedent("""\
        #!/usr/bin/env python3
        # Fake mcp-proxy-auth-shim for mcp-host-bash launcher tests.
        # Binds --listen-port and prints a started banner to stderr,
        # then stays in accept() forever.
        import socket, sys, signal
        port = None
        host = "127.0.0.1"
        argv = sys.argv[1:]
        for i, a in enumerate(argv):
            if a == "--listen-port" and i + 1 < len(argv):
                port = int(argv[i + 1])
            if a == "--listen-host" and i + 1 < len(argv):
                host = argv[i + 1]
        if port is None:
            sys.stderr.write("fake-shim: no --listen-port\\n")
            sys.exit(2)
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        s.bind((host, port))
        s.listen(8)
        sys.stderr.write(f"[mcp-proxy-auth-shim] started: {host}:{port}\\n")
        sys.stderr.flush()
        signal.signal(signal.SIGTERM, lambda *_: sys.exit(0))
        while True:
            try:
                conn, _ = s.accept()
                conn.close()
            except OSError:
                break
    """))
    path.chmod(0o755)
    return path


def write_mock_cli_mcp_server(bin_dir: Path) -> Path:
    """Drop a stub `cli-mcp-server` into bin_dir. The launcher only
    needs it on PATH for the pre-flight check; the mock mcp-proxy
    above never actually exec's it."""
    path = bin_dir / "cli-mcp-server"
    path.write_text("#!/usr/bin/env python3\nimport sys, time\nwhile True: time.sleep(60)\n")
    path.chmod(0o755)
    return path


def test_bearer_mode_port_already_taken_fatal() -> None:
    """Bearer mode: when something else is already bound on
    127.0.0.1:$UPSTREAM_PORT, the fake mcp-proxy fails its bind() and
    exits non-zero on stderr. The launcher's probe MUST detect that
    the child died before binding, surface a FATAL message naming the
    actual problem (port-already-bound), and exit non-zero WITHOUT
    spawning the shim.

    Regression guard against the bare `sleep 0.5` shape that hid this
    failure mode behind a working-looking shim banner."""
    public_port, upstream_port = free_port_pair()
    with tempfile.TemporaryDirectory(prefix="mcp-host-bash-probe-") as tmp:
        tmp_path = Path(tmp)
        bin_dir = tmp_path / "bin"
        bin_dir.mkdir()
        write_mock_mcp_proxy(bin_dir)
        write_mock_shim(bin_dir)
        write_mock_cli_mcp_server(bin_dir)

        # Pre-occupy the upstream port so the fake mcp-proxy's bind()
        # fails. We hold the socket open for the duration of the
        # launcher run.
        squatter = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        squatter.bind(("127.0.0.1", upstream_port))
        squatter.listen(1)
        try:
            env = {
                "PATH": f"{bin_dir}:/usr/bin:/bin",
                "HOME": tmp,
                "MCP_HOST_BASH_CONFIG": "/dev/null",
                "MCP_HOST_BASH_LOG": str(tmp_path / "mcp-host-bash.log"),
                "MCP_HOST_BASH_BEARER": "test-secret-not-real",
                "MCP_HOST_BASH_UPSTREAM_PORT": str(upstream_port),
            }
            result = subprocess.run(
                [str(SCRIPT), "--port", str(public_port)],
                env=env,
                capture_output=True,
                text=True,
                timeout=15,
            )
        finally:
            squatter.close()

    expect(
        result.returncode != 0,
        f"port-already-taken: launcher must exit non-zero, got rc={result.returncode}\n"
        f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}",
    )
    expect(
        "FATAL" in result.stderr,
        f"port-already-taken: stderr must contain FATAL message, "
        f"got stderr:\n{result.stderr}",
    )
    expect(
        "exited before binding" in result.stderr
        or "did not bind" in result.stderr,
        f"port-already-taken: stderr must name the bind-failure "
        f"condition, got stderr:\n{result.stderr}",
    )
    expect(
        str(upstream_port) in result.stderr,
        f"port-already-taken: stderr must include the upstream port "
        f"number ({upstream_port}) so the operator knows which port "
        f"to check, got stderr:\n{result.stderr}",
    )
    # The shim must NOT have started. Mock shim prints
    # `[mcp-proxy-auth-shim] started:` on stderr when it binds — if
    # that appears, the launcher spawned it despite mcp-proxy being
    # dead (the exact bug we're fixing).
    expect(
        "[mcp-proxy-auth-shim] started" not in result.stderr,
        f"port-already-taken: shim must NOT have been spawned (its "
        f"banner appearing in stderr means the launcher spawned it "
        f"despite mcp-proxy dying), got stderr:\n{result.stderr}",
    )


def test_bearer_mode_normal_bind_verified() -> None:
    """Bearer mode happy path: with free ports for both mcp-proxy
    (internal) and the shim (public), the launcher must:
      1. Spawn mcp-proxy, wait for its internal port to LISTEN.
      2. Print the new 'bound, verified' banner line.
      3. Spawn the shim, which prints its own started banner.
      4. Keep both children alive.
    We start the launcher in the background, wait briefly for both
    children to come up, assert banners + listen sockets, then send
    SIGTERM and assert clean teardown."""
    public_port, upstream_port = free_port_pair()
    with tempfile.TemporaryDirectory(prefix="mcp-host-bash-probe-") as tmp:
        tmp_path = Path(tmp)
        bin_dir = tmp_path / "bin"
        bin_dir.mkdir()
        write_mock_mcp_proxy(bin_dir)
        write_mock_shim(bin_dir)
        write_mock_cli_mcp_server(bin_dir)

        env = {
            "PATH": f"{bin_dir}:/usr/bin:/bin",
            "HOME": tmp,
            "MCP_HOST_BASH_CONFIG": "/dev/null",
            "MCP_HOST_BASH_LOG": str(tmp_path / "mcp-host-bash.log"),
            "MCP_HOST_BASH_BEARER": "test-secret-not-real",
            "MCP_HOST_BASH_UPSTREAM_PORT": str(upstream_port),
        }
        proc = subprocess.Popen(
            [str(SCRIPT), "--port", str(public_port)],
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        try:
            # Give the launcher up to ~5s to come up — that covers the
            # 200ms-cadence probe + the mock processes' Python startup.
            deadline = time.time() + 5.0
            shim_listening = False
            mcp_listening = False
            while time.time() < deadline:
                # Probe public port (shim) and upstream port (mcp-proxy).
                try:
                    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                        s.settimeout(0.1)
                        s.connect(("127.0.0.1", public_port))
                    shim_listening = True
                except OSError:
                    pass
                try:
                    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                        s.settimeout(0.1)
                        s.connect(("127.0.0.1", upstream_port))
                    mcp_listening = True
                except OSError:
                    pass
                if shim_listening and mcp_listening:
                    break
                if proc.poll() is not None:
                    break
                time.sleep(0.1)

            expect(
                proc.poll() is None,
                f"normal-bind: launcher must still be running after "
                f"startup, got rc={proc.returncode}",
            )
            expect(
                mcp_listening,
                f"normal-bind: mcp-proxy must be LISTEN on "
                f"127.0.0.1:{upstream_port}",
            )
            expect(
                shim_listening,
                f"normal-bind: shim must be LISTEN on "
                f"127.0.0.1:{public_port} (proves the probe let the "
                f"launcher proceed past the bare sleep)",
            )
        finally:
            proc.terminate()
            try:
                stdout, stderr = proc.communicate(timeout=3)
            except subprocess.TimeoutExpired:
                proc.kill()
                stdout, stderr = proc.communicate(timeout=2)

    expect(
        "bound, verified" in stderr,
        f"normal-bind: banner must contain the new 'bound, verified' "
        f"line (proves the probe ran + succeeded), got stderr:\n{stderr}",
    )
    expect(
        f"127.0.0.1:{upstream_port}" in stderr,
        f"normal-bind: banner must reference the actual upstream "
        f"address (127.0.0.1:{upstream_port}), got stderr:\n{stderr}",
    )
    expect(
        "[mcp-proxy-auth-shim] started" in stderr,
        f"normal-bind: shim banner must appear AFTER the probe lets "
        f"the launcher proceed, got stderr:\n{stderr}",
    )


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

tests = [
    test_print_cmd_default_argv,
    test_default_policy_conservative,
    test_port_override_space_form,
    test_port_override_equals_form,
    test_missing_port_value,
    test_bad_flag,
    test_help_exits_zero,
    test_config_file_overrides_defaults,
    test_config_missing_falls_back_to_defaults,
    test_disabled_kill_switch,
    test_separator_position,
    test_cw_profile_unset_is_default,
    test_cw_profile_corp_dev_equals_default,
    test_default_includes_corp_dev_tooling,
    test_default_excludes_destructive_and_scheduling,
    test_cw_profile_trusted_widens,
    test_cw_profile_unknown_falls_back,
    test_cw_profile_operator_override_wins,
    test_hook_bridge_bins_merged_into_allow_list,
    test_hook_bridge_bins_works_with_trusted_profile,
    test_bind_default_is_loopback,
    test_bind_env_override_widens_listener,
    test_bind_env_override_specific_interface,
    test_bearer_mode_emits_shim_argv,
    test_bearer_mode_with_bind_override,
    test_bearer_mode_with_custom_upstream_port,
    test_bearer_unset_no_shim_in_argv,
    test_bearer_empty_string_treated_as_unset,
    test_bind_env_empty_falls_back_to_loopback,
    test_hook_bridge_bins_unset_no_effect,
    test_launcher_source_has_no_uvx_invocations,
    test_preflight_error_points_to_installer,
    test_install_host_deps_script_exists_and_parses,
    test_install_host_deps_rejects_bad_flag,
    test_bearer_mode_port_already_taken_fatal,
    test_bearer_mode_normal_bind_verified,
]

for t in tests:
    try:
        t()
        if not any(t.__name__ in f for f in failures[-len(tests):]):
            # crude — print PASS only when this test added no failures
            current_count = sum(1 for f in failures if t.__name__ in f)
            if current_count == 0:
                print(f"PASS  {t.__name__}")
            else:
                print(f"FAIL  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}")

if failures:
    print()
    print(f"FAILED: {len(failures)} failure(s).")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)
else:
    print()
    print(f"All {len(tests)} tests passed.")
    sys.exit(0)
