#!/usr/bin/env python3
"""Tests for examples/compose/bin/cw — the host-side shim that attaches
to the claude-container tmux session via `docker compose exec`.

Exercises the script's argv construction WITHOUT actually invoking docker
by using the `--print-cmd` debug hook (the script builds the exec argv it
would otherwise run and prints it one-per-line, then exits 0). The hook
also skips the docker probe so the test runs in CI without docker access.

Coverage:
  - Default invocation: `docker compose --project-directory <dir> exec -it
    claude-container tmux -u attach-session -t claude-container`.
  - CW_SERVICE override: changes the compose service name.
  - CW_SESSION override: changes the tmux session name.
  - CW_COMPOSE_DIR override: changes the --project-directory value.
  - Missing docker-compose.yml: clean exit 1 with a helpful message.
  - --help: prints usage, exits 0.
  - Bad flag: exits 2.
  - --no-reconnect: single-shot — first non-zero exit propagates.
  - Reconnect loop on transient failure: rc=1 first call, rc=0 second call
    => cw exits 0 after retrying.
  - Clean detach: rc=0 first call => cw exits 0 without retry.
  - Retry cap: rc=1 always => cw bails after MAX_ATTEMPTS with the
    documented message.

The reconnect tests use CW_DOCKER_EXEC to inject a stateful mock that
simulates docker exec behavior without needing an actual daemon. The
mock is a tiny shell script that reads/writes a counter file and
returns rc based on the current call number.

Run:  ./cw.test
"""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "cw"
COMPOSE_DIR = HERE.parent.parent  # examples/compose/

if not SCRIPT.exists():
    print(f"FAIL: cannot locate cw at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


def run_cw(
    args: list[str] | None = None,
    env: dict | None = None,
    expect_rc: int = 0,
) -> tuple[list[str], str, str, int]:
    """Run cw with the given argv + env. Returns (stdout_lines, stdout,
    stderr, returncode)."""
    if args is None:
        args = []
    base_env = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "HOME": "/tmp/fake-home",
    }
    if env:
        base_env.update(env)
    result = subprocess.run(
        [str(SCRIPT), *args],
        env=base_env,
        capture_output=True,
        text=True,
        timeout=10,
    )
    if expect_rc is not None and result.returncode != expect_rc:
        raise AssertionError(
            f"cw exited {result.returncode}, expected {expect_rc}\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )
    return result.stdout.splitlines(), result.stdout, result.stderr, result.returncode


# ---------------------------------------------------------------------------
# Test cases
# ---------------------------------------------------------------------------

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def test_print_cmd_default_invocation() -> None:
    """Default: docker compose --project-directory <compose> exec -it
    claude-container tmux -u attach-session -t claude-container."""
    lines, _, _, _ = run_cw(["--print-cmd"])
    # Find the trailing exec invocation by looking for 'exec' + service.
    joined = " ".join(lines)
    expect("docker" == lines[0],
           f"default: argv[0] should be docker, got {lines[0]!r}")
    expect("compose" in lines,
           f"default: argv should include 'compose', got {lines}")
    expect("--project-directory" in lines,
           f"default: argv should include --project-directory, got {lines}")
    # The compose dir resolves via the script's canonical path, so it
    # should end with examples/compose.
    pd_idx = lines.index("--project-directory")
    expect(lines[pd_idx + 1].endswith("examples/compose"),
           f"default: --project-directory should end with examples/compose, "
           f"got {lines[pd_idx + 1]!r}")
    expect("exec" in lines,
           f"default: argv should include 'exec', got {lines}")
    expect("-it" in lines,
           f"default: argv should include -it, got {lines}")
    expect("claude-container" in lines,
           f"default: service name should be claude-container, got {lines}")
    expect("tmux" in lines,
           f"default: argv should run tmux, got {lines}")
    expect("attach-session" in lines,
           f"default: argv should run attach-session, got {lines}")
    expect("-A" not in lines,
           f"default: argv should NOT include -A (no attach-or-create), got {lines}")
    # Session name appears AFTER `-t`.
    t_idx = lines.index("-t")
    expect(lines[t_idx + 1] == "claude-container",
           f"default: -t session name should be claude-container, "
           f"got {lines[t_idx + 1]!r}")
    # -u flag for UTF-8.
    expect("-u" in lines,
           f"default: tmux argv should include -u, got {lines}")


def test_print_cmd_service_override() -> None:
    """CW_SERVICE=foo => `exec -it foo tmux ...`."""
    lines, _, _, _ = run_cw(["--print-cmd"], env={"CW_SERVICE": "my-svc"})
    exec_idx = lines.index("exec")
    # exec -it <service>
    expect(lines[exec_idx + 1] == "-it",
           f"service-override: -it should follow exec, got {lines}")
    expect(lines[exec_idx + 2] == "my-svc",
           f"service-override: service name should be my-svc, got {lines}")


def test_print_cmd_session_override() -> None:
    """CW_SESSION=foo => `tmux -u attach-session -t foo`."""
    lines, _, _, _ = run_cw(["--print-cmd"], env={"CW_SESSION": "my-sess"})
    t_idx = lines.index("-t")
    expect(lines[t_idx + 1] == "my-sess",
           f"session-override: -t value should be my-sess, "
           f"got {lines[t_idx + 1]!r}")


def test_print_cmd_compose_dir_override() -> None:
    """CW_COMPOSE_DIR=<override> => --project-directory <override>."""
    with tempfile.TemporaryDirectory(prefix="cw-test-") as d:
        # Need a docker-compose.yml in the override dir for the script
        # to accept it.
        Path(d, "docker-compose.yml").write_text("services: {}\n")
        lines, _, _, _ = run_cw(["--print-cmd"], env={"CW_COMPOSE_DIR": d})
        pd_idx = lines.index("--project-directory")
        expect(lines[pd_idx + 1] == d,
               f"compose-dir-override: --project-directory should be {d}, "
               f"got {lines[pd_idx + 1]!r}")


def test_missing_compose_dir() -> None:
    """CW_COMPOSE_DIR with no docker-compose.yml => exit 1 + helpful msg."""
    with tempfile.TemporaryDirectory(prefix="cw-empty-") as d:
        _, _, stderr, rc = run_cw(
            ["--print-cmd"],
            env={"CW_COMPOSE_DIR": d},
            expect_rc=1,
        )
        expect("docker-compose.yml" in stderr,
               f"missing-compose-dir: stderr should name the missing file, "
               f"got {stderr!r}")
        expect("CW_COMPOSE_DIR" in stderr,
               f"missing-compose-dir: stderr should mention the env var, "
               f"got {stderr!r}")


def test_help_exits_zero() -> None:
    """--help prints usage and exits 0 (works offline / without docker)."""
    _, stdout, _, _ = run_cw(["--help"], expect_rc=0)
    expect("Usage:" in stdout,
           f"--help: stdout should include 'Usage:', got {stdout!r}")
    expect("cw" in stdout,
           f"--help: stdout should mention 'cw', got {stdout!r}")
    expect("attach" in stdout.lower(),
           f"--help: stdout should mention 'attach', got {stdout!r}")


def test_bad_flag_exits_two() -> None:
    """Unknown flag => exit 2 + usage to stderr."""
    _, _, stderr, _ = run_cw(["--no-such-flag"], expect_rc=2)
    expect("unknown" in stderr.lower(),
           f"bad-flag: stderr should mention 'unknown', got {stderr!r}")
    expect("Usage:" in stderr,
           f"bad-flag: stderr should include usage, got {stderr!r}")


# ---------------------------------------------------------------------------
# --clear (external self-clear) tests
#
# `cw --clear` runs a one-shot `docker compose exec <svc> self-clear [ARGS]`
# to trigger an in-container context reset from the host WITHOUT attaching —
# the context-reset analog of externally firing cwsr (which rolls the inner
# binary). The --print-cmd hook builds that exec argv and prints it.
# ---------------------------------------------------------------------------


def test_clear_default_invocation() -> None:
    """cw --clear => docker compose --project-directory <dir> exec
    claude-container self-clear (one-shot, no -it, no tmux attach).

    NOTE: `--print-cmd` is placed BEFORE `--clear` because `--clear`
    consumes all remaining args as self-clear pass-through — cw's own
    flags must precede it (matching real usage `cw --clear -- ARGS`)."""
    lines, _, _, _ = run_cw(["--print-cmd", "--clear"])
    expect("docker" == lines[0],
           f"clear: argv[0] should be docker, got {lines[0]!r}")
    expect("exec" in lines,
           f"clear: argv should include 'exec', got {lines}")
    expect("self-clear" in lines,
           f"clear: argv should invoke self-clear, got {lines}")
    exec_idx = lines.index("exec")
    # exec <service> self-clear  — NO -it (self-clear forks + returns).
    expect(lines[exec_idx + 1] == "claude-container",
           f"clear: service should follow exec, got {lines}")
    expect("-it" not in lines,
           f"clear: one-shot exec should NOT include -it, got {lines}")
    expect("attach-session" not in lines,
           f"clear: --clear should NOT attach a tmux session, got {lines}")


def test_clear_passthrough_args() -> None:
    """cw --clear -- --resume-prompt X --no-resume => args forwarded to
    self-clear verbatim, with the leading `--` separator dropped."""
    lines, _, _, _ = run_cw(
        ["--print-cmd", "--clear", "--", "--resume-prompt", "resume X",
         "--no-resume"]
    )
    sc_idx = lines.index("self-clear")
    tail = lines[sc_idx + 1:]
    expect("--resume-prompt" in tail,
           f"clear-passthrough: should forward --resume-prompt, got {tail}")
    expect("resume X" in tail,
           f"clear-passthrough: should forward the prompt value, got {tail}")
    expect("--no-resume" in tail,
           f"clear-passthrough: should forward --no-resume, got {tail}")
    expect("--" not in tail,
           f"clear-passthrough: the `--` separator should be dropped, "
           f"got {tail}")


def test_clear_passthrough_without_separator() -> None:
    """cw --clear --no-resume (no `--`) still forwards the arg to
    self-clear rather than treating it as a cw flag."""
    lines, _, _, _ = run_cw(["--print-cmd", "--clear", "--no-resume"])
    sc_idx = lines.index("self-clear")
    tail = lines[sc_idx + 1:]
    expect("--no-resume" in tail,
           f"clear-passthrough-nosep: --no-resume should forward to "
           f"self-clear, got {tail}")


def test_clear_service_override() -> None:
    """CW_SERVICE override applies to the --clear exec too."""
    lines, _, _, _ = run_cw(
        ["--print-cmd", "--clear"], env={"CW_SERVICE": "my-svc"}
    )
    exec_idx = lines.index("exec")
    expect(lines[exec_idx + 1] == "my-svc",
           f"clear-service-override: service should be my-svc, got {lines}")


def test_clear_runs_via_docker_exec_hook() -> None:
    """cw --clear executes the (mocked) inner exec exactly once and
    propagates its rc — proving it's one-shot fire-and-return, not the
    reconnect loop."""
    with tempfile.TemporaryDirectory(prefix="cw-clear-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("always_succeed", tmpdir)
        _, _, _, rc = run_cw(
            ["--clear"],
            env={"CW_DOCKER_EXEC": str(mock)},
            expect_rc=0,
        )
        expect(counter.read_text().strip() == "1",
               f"clear-exec: mock should be called exactly once, "
               f"got {counter.read_text().strip()!r}")


def test_clear_help_mentions_clear() -> None:
    """--help documents the --clear external self-clear path."""
    _, stdout, _, _ = run_cw(["--help"], expect_rc=0)
    expect("--clear" in stdout,
           f"help: should document --clear, got {stdout!r}")
    expect("self-clear" in stdout,
           f"help: should mention self-clear, got {stdout!r}")


# ---------------------------------------------------------------------------
# Reconnect-loop tests
#
# These exercise the CW_DOCKER_EXEC test hook to inject a stateful mock
# in place of `docker compose ... exec`. The mock is a small shell
# script written to a temp dir; it increments a counter file each
# invocation and exits with the rc dictated by the mode under test.
# ---------------------------------------------------------------------------


def _write_mock(mode: str, tmpdir: Path) -> tuple[Path, Path]:
    """Write a stateful mock 'docker exec' replacement and return
    (mock_path, counter_path). modes:
      - "fail_then_succeed": rc=1 on call 1, rc=0 on call 2+.
      - "always_succeed":   rc=0 every call.
      - "always_fail":      rc=1 every call.
    """
    counter = tmpdir / "calls"
    counter.write_text("0\n")
    mock = tmpdir / "mock-exec"
    body = f"""#!/usr/bin/env bash
set -u
counter='{counter}'
n=$(cat "$counter")
n=$((n + 1))
echo "$n" > "$counter"
mode='{mode}'
case "$mode" in
    fail_then_succeed)
        if [ "$n" = "1" ]; then exit 1; else exit 0; fi
        ;;
    always_succeed)
        exit 0
        ;;
    always_fail)
        exit 1
        ;;
    *)
        echo "mock: unknown mode $mode" >&2
        exit 99
        ;;
esac
"""
    mock.write_text(body)
    mock.chmod(0o755)
    return mock, counter


def test_no_reconnect_propagates_failure() -> None:
    """--no-reconnect: first non-zero exit propagates immediately, no
    retry."""
    with tempfile.TemporaryDirectory(prefix="cw-noreconn-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("always_fail", tmpdir)
        _, _, _, rc = run_cw(
            ["--no-reconnect"],
            env={"CW_DOCKER_EXEC": str(mock)},
            expect_rc=1,
        )
        expect(counter.read_text().strip() == "1",
               f"no-reconnect: mock should be called exactly once, "
               f"got {counter.read_text().strip()!r}")


def test_no_reconnect_passes_success() -> None:
    """--no-reconnect: rc=0 still propagates (no infinite loop)."""
    with tempfile.TemporaryDirectory(prefix="cw-noreconn-ok-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("always_succeed", tmpdir)
        _, _, _, rc = run_cw(
            ["--no-reconnect"],
            env={"CW_DOCKER_EXEC": str(mock)},
            expect_rc=0,
        )
        expect(counter.read_text().strip() == "1",
               f"no-reconnect-ok: mock called exactly once, "
               f"got {counter.read_text().strip()!r}")


def test_reconnect_on_transient_failure() -> None:
    """Default (reconnect on): rc=1 first call, rc=0 second call =>
    cw retries once + exits 0."""
    with tempfile.TemporaryDirectory(prefix="cw-reconn-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("fail_then_succeed", tmpdir)
        _, _, stderr, rc = run_cw(
            [],
            env={"CW_DOCKER_EXEC": str(mock)},
            expect_rc=0,
        )
        expect(counter.read_text().strip() == "2",
               f"reconnect: mock should be called twice (fail, then "
               f"success), got {counter.read_text().strip()!r}")
        expect("reconnecting" in stderr.lower(),
               f"reconnect: stderr should mention reconnecting, "
               f"got {stderr!r}")


def test_clean_detach_no_retry() -> None:
    """Default (reconnect on): rc=0 first call => cw exits 0 without
    retry (Ctrl-b d path)."""
    with tempfile.TemporaryDirectory(prefix="cw-detach-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("always_succeed", tmpdir)
        _, _, _, rc = run_cw(
            [],
            env={"CW_DOCKER_EXEC": str(mock)},
            expect_rc=0,
        )
        expect(counter.read_text().strip() == "1",
               f"clean-detach: mock should be called exactly once, "
               f"got {counter.read_text().strip()!r}")


def test_retry_cap_bails() -> None:
    """Default (reconnect on): rc=1 always => cw bails after
    MAX_ATTEMPTS with the documented stderr message. Use a small
    window/cap to keep the test fast (3 attempts in 10s)."""
    with tempfile.TemporaryDirectory(prefix="cw-cap-") as d:
        tmpdir = Path(d)
        mock, counter = _write_mock("always_fail", tmpdir)
        _, _, stderr, rc = run_cw(
            [],
            env={
                "CW_DOCKER_EXEC": str(mock),
                "CW_RECONNECT_MAX_ATTEMPTS": "3",
                "CW_RECONNECT_WINDOW_SECS": "10",
            },
            expect_rc=1,
        )
        expect(counter.read_text().strip() == "3",
               f"retry-cap: mock should be called exactly 3 times, "
               f"got {counter.read_text().strip()!r}")
        expect("bailing" in stderr.lower() or "daemon" in stderr.lower(),
               f"retry-cap: stderr should mention bailing / daemon, "
               f"got {stderr!r}")
        expect("3" in stderr,
               f"retry-cap: stderr should include the attempt count, "
               f"got {stderr!r}")


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

TESTS = [
    test_print_cmd_default_invocation,
    test_print_cmd_service_override,
    test_print_cmd_session_override,
    test_print_cmd_compose_dir_override,
    test_missing_compose_dir,
    test_help_exits_zero,
    test_bad_flag_exits_two,
    test_clear_default_invocation,
    test_clear_passthrough_args,
    test_clear_passthrough_without_separator,
    test_clear_service_override,
    test_clear_runs_via_docker_exec_hook,
    test_clear_help_mentions_clear,
    test_no_reconnect_propagates_failure,
    test_no_reconnect_passes_success,
    test_reconnect_on_transient_failure,
    test_clean_detach_no_retry,
    test_retry_cap_bails,
]

for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
