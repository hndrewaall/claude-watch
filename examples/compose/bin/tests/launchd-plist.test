#!/usr/bin/env python3
"""Tests for examples/compose/launchd/com.anthropic.claude-watch.mcp-host-bash.plist
— the macOS LaunchAgent template for persistent auto-start of
mcp-host-bash on operator-login.

Coverage:
  - File-level structural validation only (no `launchctl` invocation).
  - Plist parses cleanly via Python's stdlib `plistlib` (works on any
    host with Python 3 — Linux CI included).
  - When `plutil` is available (macOS hosts), also lint via that path
    so we catch macOS-specific structural complaints `plistlib` would
    silently accept.
  - `Label` matches the filename convention launchd enforces
    (basename minus `.plist`).
  - `ProgramArguments[0]` looks like an absolute path (the launcher
    binary launchd will exec).
  - `KeepAlive` and `RunAtLoad` are present and truthy (the whole
    point of the LaunchAgent — auto-restart + start-at-login).
  - `EnvironmentVariables`, `WorkingDirectory`, `StandardOutPath`,
    `StandardErrorPath` are present (the README walkthrough relies
    on each one).
  - The launcher path inside `ProgramArguments[0]` ends in
    `bin/mcp-host-bash` so a typo / refactor doesn't silently point
    launchd at a stale binary.

Run:  ./launchd-plist.test
"""

from __future__ import annotations

import os
import plistlib
import shutil
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
PLIST = (
    HERE.parent.parent
    / "launchd"
    / "com.anthropic.claude-watch.mcp-host-bash.plist"
)
LAUNCHD_README = HERE.parent.parent / "launchd" / "README.md"

if not PLIST.exists():
    print(f"FAIL: cannot locate launchd plist at {PLIST}", file=sys.stderr)
    sys.exit(2)


# ---------------------------------------------------------------------------
# Test runner scaffolding (mirrors mcp-host-bash.test / cw.test)
# ---------------------------------------------------------------------------

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# ---------------------------------------------------------------------------
# Parse the plist once at module level — every test reads from this dict.
# ---------------------------------------------------------------------------

with open(PLIST, "rb") as fp:
    PARSED = plistlib.load(fp)


# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------


def test_plistlib_parses() -> None:
    """plistlib accepted the file. (We re-assert here for explicit
    test reporting; the module-level load above already raised on
    parse failure.)"""
    expect(
        isinstance(PARSED, dict),
        f"plistlib should return a dict at the top level; got {type(PARSED)}",
    )


def test_plutil_lint_when_available() -> None:
    """If `plutil` is on PATH (macOS hosts), use it as a second
    parser. plistlib is permissive about some structural issues
    (e.g. unknown top-level keys) that real launchd-side `plutil`
    rejects. On Linux CI `plutil` is absent — we skip silently."""
    plutil = shutil.which("plutil")
    if not plutil:
        return  # not macOS — plistlib coverage is sufficient
    result = subprocess.run(
        [plutil, "-lint", str(PLIST)],
        capture_output=True,
        text=True,
        timeout=5,
    )
    expect(
        result.returncode == 0,
        f"plutil -lint should accept the plist; rc={result.returncode}\n"
        f"stdout: {result.stdout}\nstderr: {result.stderr}",
    )


def test_label_matches_filename() -> None:
    """launchd keys `bootstrap` / `bootout` / `print` off the filename
    minus `.plist`. The plist's `Label` MUST match or the operator's
    workflow (copy file in, then `bootstrap gui/$(id -u)/<label>`)
    breaks at the bootstrap step."""
    expected_label = PLIST.stem  # "com.anthropic.claude-watch.mcp-host-bash"
    actual = PARSED.get("Label")
    expect(
        actual == expected_label,
        f"Label should match plist filename stem; "
        f"expected {expected_label!r}, got {actual!r}",
    )


def test_label_present_and_nonempty() -> None:
    """Defense-in-depth: the value is a non-empty string. (Catches a
    stray `<key>Label</key><string></string>` regression that would
    parse fine but break launchd.)"""
    label = PARSED.get("Label")
    expect(
        isinstance(label, str) and label.strip() != "",
        f"Label must be a non-empty string; got {label!r}",
    )


def test_keep_alive_true() -> None:
    """KeepAlive = true → launchd respawns mcp-host-bash on any exit
    (clean or crash). Without this, a single Ctrl-C / OOM / crash
    leaves the bridge dead until the operator notices."""
    keep_alive = PARSED.get("KeepAlive")
    expect(
        keep_alive is True,
        f"KeepAlive should be the boolean true (auto-respawn); "
        f"got {keep_alive!r}",
    )


def test_run_at_load_true() -> None:
    """RunAtLoad = true → launchd fires the LaunchAgent the moment
    `bootstrap` registers it (and at every login thereafter). Without
    this the unit registers but never runs until something else dials
    it — which nothing does for a host-side bridge."""
    run_at_load = PARSED.get("RunAtLoad")
    expect(
        run_at_load is True,
        f"RunAtLoad should be the boolean true (start at login + on "
        f"bootstrap); got {run_at_load!r}",
    )


def test_program_arguments_present() -> None:
    """ProgramArguments[0] is the binary launchd exec's. Has to be
    a non-empty list of strings."""
    pa = PARSED.get("ProgramArguments")
    expect(
        isinstance(pa, list) and len(pa) >= 1,
        f"ProgramArguments must be a non-empty list; got {pa!r}",
    )
    if isinstance(pa, list) and pa:
        expect(
            all(isinstance(x, str) for x in pa),
            f"ProgramArguments entries must all be strings; got {pa!r}",
        )


def test_program_arguments_first_is_absolute() -> None:
    """ProgramArguments[0] must be an absolute path. launchd does NOT
    do PATH lookup or `~` expansion — relative / tilde paths fail at
    bootstrap. We assert the literal placeholder shape (`/PATH/TO/REPO`)
    OR a real absolute path so a downstream tester running this against
    a populated copy still passes."""
    pa = PARSED.get("ProgramArguments")
    if not (isinstance(pa, list) and pa):
        return  # covered by the previous test
    first = pa[0]
    expect(
        first.startswith("/"),
        f"ProgramArguments[0] must be an absolute path (launchd does "
        f"not expand ~ / ${{HOME}} / PATH); got {first!r}",
    )


def test_program_arguments_first_points_at_launcher() -> None:
    """ProgramArguments[0] must end in `bin/mcp-host-bash` — guards
    against a refactor renaming the launcher without updating the
    template (or a typo in the template itself)."""
    pa = PARSED.get("ProgramArguments")
    if not (isinstance(pa, list) and pa):
        return
    first = pa[0]
    expect(
        first.endswith("/bin/mcp-host-bash") or first.endswith("/mcp-host-bash"),
        f"ProgramArguments[0] should end with the launcher basename "
        f"(`bin/mcp-host-bash`); got {first!r}",
    )


def test_environment_variables_dict() -> None:
    """EnvironmentVariables exists and is a dict (even if empty).
    The README walkthrough talks about CW_PROFILE / PATH / SSL_CERT_FILE
    living here — a missing block silently strips the contract."""
    ev = PARSED.get("EnvironmentVariables")
    expect(
        isinstance(ev, dict),
        f"EnvironmentVariables must be a dict; got {ev!r}",
    )


def test_environment_variables_has_path() -> None:
    """The launcher needs `mcp-proxy` and `cli-mcp-server` on PATH.
    launchd's default PATH is `/usr/bin:/bin:/usr/sbin:/sbin` —
    Homebrew + ~/.local/bin are absent. The template MUST declare a
    PATH entry that adds at least ${HOME}/.local/bin (where
    install-host-deps drops the static binaries)."""
    ev = PARSED.get("EnvironmentVariables") or {}
    path = ev.get("PATH")
    expect(
        isinstance(path, str) and path.strip() != "",
        f"EnvironmentVariables.PATH must be a non-empty string "
        f"(launchd's default PATH does not include ~/.local/bin); "
        f"got {path!r}",
    )
    # The shipped template's placeholder includes /PATH/TO/HOME/.local/bin;
    # a populated copy substitutes that. Either way the suffix should
    # mention `.local/bin`.
    if isinstance(path, str):
        expect(
            ".local/bin" in path,
            f"EnvironmentVariables.PATH should include `.local/bin` so "
            f"the install-host-deps shims resolve; got {path!r}",
        )


def test_working_directory_present() -> None:
    """WorkingDirectory is set so operator config files referenced
    via relative paths resolve under HOME, not /."""
    wd = PARSED.get("WorkingDirectory")
    expect(
        isinstance(wd, str) and wd.startswith("/"),
        f"WorkingDirectory must be an absolute path; got {wd!r}",
    )


def test_log_paths_present_and_absolute() -> None:
    """StandardOutPath / StandardErrorPath are the launchd-captured
    log files. Both must be absolute paths (launchd quirk: relative
    paths under WorkingDirectory work on some macOS versions, but
    not all — absolute is the only contract). README step 6 names
    these explicitly."""
    for key in ("StandardOutPath", "StandardErrorPath"):
        val = PARSED.get(key)
        expect(
            isinstance(val, str) and val.startswith("/"),
            f"{key} must be an absolute path; got {val!r}",
        )


def test_throttle_interval_reasonable() -> None:
    """ThrottleInterval bounds the KeepAlive respawn cadence. Must
    be a positive integer; we assert a sane floor (>= 1s) so a
    typo'd `0` doesn't cause launchd to crashloop the launcher at
    full CPU."""
    ti = PARSED.get("ThrottleInterval")
    expect(
        isinstance(ti, int) and ti >= 1,
        f"ThrottleInterval must be a positive integer (>=1s); got {ti!r}",
    )


def test_no_disallowed_top_level_keys() -> None:
    """Catch obvious typos at the top level (e.g. someone added
    `KeepAllive` instead of `KeepAlive`). We allow a curated set
    and flag anything outside it. New keys land here intentionally
    after a deliberate test update — the goal is "noisy on
    accidental drift" not "exhaustive of every launchd key"."""
    allowed = {
        "Label",
        "ProgramArguments",
        "EnvironmentVariables",
        "KeepAlive",
        "RunAtLoad",
        "ThrottleInterval",
        "WorkingDirectory",
        "StandardOutPath",
        "StandardErrorPath",
        "ProcessType",
    }
    actual = set(PARSED.keys())
    extras = actual - allowed
    expect(
        not extras,
        f"Unexpected top-level keys in plist (likely typos / accidental "
        f"adds — update the allowed set in launchd-plist.test if "
        f"intentional): {sorted(extras)}",
    )


def test_readme_exists() -> None:
    """The companion README walkthrough must ship alongside the plist.
    The plist's leading comment + examples/compose/README.md both
    point at it."""
    expect(
        LAUNCHD_README.exists(),
        f"launchd/README.md must exist next to the plist; looked at {LAUNCHD_README}",
    )


def test_readme_references_label() -> None:
    """The README must reference the LaunchAgent label so operators
    can copy/paste the bootstrap / bootout commands without
    cross-referencing the plist filename."""
    if not LAUNCHD_README.exists():
        return  # covered by the previous test
    body = LAUNCHD_README.read_text()
    label = PARSED.get("Label", "")
    expect(
        label and label in body,
        f"launchd/README.md must reference the Label {label!r} "
        f"(operators copy/paste bootstrap commands from there)",
    )


def test_readme_documents_required_steps() -> None:
    """Spot-check that the README hits the major operator steps
    (copy / edit paths / bootstrap / verify / logs / uninstall).
    Looser than per-section asserts so cosmetic edits don't churn
    the test, but tight enough to catch a wholesale section drop."""
    if not LAUNCHD_README.exists():
        return
    body = LAUNCHD_README.read_text()
    for needle in (
        "~/Library/LaunchAgents",  # step 1: copy target
        "/PATH/TO/REPO",  # step 2: search/replace placeholder (repo)
        "/PATH/TO/HOME",  # step 2: search/replace placeholder (home)
        "launchctl bootstrap",  # step 3: bootstrap verb
        "launchctl print",  # step 4: verify
        "lsof",  # step 4: port-ownership check
        "launchctl bootout",  # step 5 + 7 + 8: unload verb
        "~/Library/Logs",  # step 6: log paths
    ):
        expect(
            needle in body,
            f"launchd/README.md must mention {needle!r} (operator "
            f"walkthrough relies on it)",
        )


# ---------------------------------------------------------------------------
# Compose README references
# ---------------------------------------------------------------------------


def test_compose_readme_links_to_launchd() -> None:
    """The main compose README must link to the launchd subfolder so
    operators discover the persistent-launch path without grepping
    the tree."""
    compose_readme = HERE.parent.parent / "README.md"
    if not compose_readme.exists():
        failures.append(
            f"examples/compose/README.md not found at {compose_readme}"
        )
        return
    body = compose_readme.read_text()
    expect(
        "launchd/README.md" in body or "launchd/com.anthropic" in body,
        "examples/compose/README.md should link to the launchd "
        "subdirectory so operators find the persistent-launch path",
    )


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

tests = [
    test_plistlib_parses,
    test_plutil_lint_when_available,
    test_label_matches_filename,
    test_label_present_and_nonempty,
    test_keep_alive_true,
    test_run_at_load_true,
    test_program_arguments_present,
    test_program_arguments_first_is_absolute,
    test_program_arguments_first_points_at_launcher,
    test_environment_variables_dict,
    test_environment_variables_has_path,
    test_working_directory_present,
    test_log_paths_present_and_absolute,
    test_throttle_interval_reasonable,
    test_no_disallowed_top_level_keys,
    test_readme_exists,
    test_readme_references_label,
    test_readme_documents_required_steps,
    test_compose_readme_links_to_launchd,
]

for t in tests:
    pre = len(failures)
    try:
        t()
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
    if len(failures) == pre:
        print(f"PASS  {t.__name__}")
    else:
        print(f"FAIL  {t.__name__}")

if failures:
    print()
    print(f"FAILED: {len(failures)} failure(s).")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)
else:
    print()
    print(f"All {len(tests)} tests passed.")
    sys.exit(0)
