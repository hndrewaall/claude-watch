#!/usr/bin/env python3
"""mcp-proxy-auth-shim — bearer-token reverse proxy in front of mcp-proxy.

WHY THIS EXISTS

mcp-proxy upstream has no inbound authentication knob (verified via
README + proxy_server.py source read 2026-05-14 — the only auth-adjacent
flag is `--allow-origin`, which is browser-side CORS, not a server-side
gate). So even with the loopback-only default bind landed in the
sibling PR, anything that shares the host's network namespace
(sibling local UIDs, in-host malware running under any uid, a browser
landing SSRF, etc.) can still POST `tools/call run_command` and exec
binaries on the host.

This shim closes that surface by sitting between callers and mcp-proxy:

  caller  ──HTTP──►  shim (public port, e.g. 8766)
                       │
                       │  validates Authorization: Bearer <secret>
                       │  on every request; strips the header before
                       │  forwarding so mcp-proxy never sees it.
                       │
                       ▼
                    mcp-proxy (loopback-only internal port, e.g. 8767)
                       │
                       ▼  (stdio)
                    cli-mcp-server

The bearer secret is loaded from the `MCP_HOST_BASH_BEARER` env var at
shim startup. The shim FAILS CLOSED:

  - Empty / unset bearer env var: shim refuses to start (exits 2). No
    silent fall-through to no-auth.
  - Missing Authorization header on a request: 401, log, no forward.
  - Wrong header value: 401, log, no forward.

Stateless-mode and streamable-HTTP both flow through transparently —
the shim copies response headers (including `mcp-session-id`), body,
and status code verbatim. Both JSON and text/event-stream content
types pass through.

run_script TOOL (locally handled)

The shim also adds a `run_script` MCP tool alongside cli-mcp-server's
`run_command`. `run_command` shlex-tokenizes its command string, so it
rejects complex inline quoting (perl `qw(...)` + `;`, nested quotes,
multi-line heredocs) even with `ALLOWED_COMMANDS=all` +
`ALLOW_SHELL_OPERATORS=true`. `run_script(interpreter, script)` takes the
script as a structured JSON string and feeds it to the interpreter on
STDIN — the body never traverses a shell or tokenizer at any layer.

The shim handles `run_script` itself (it does NOT forward those
tools/call requests to mcp-proxy) and injects the tool def into
`tools/list` responses on the way back. It reuses the SAME policy fences
cli-mcp-server enforces for `run_command`: the interpreter is resolved
against ALLOWED_COMMANDS, runs with cwd = ALLOWED_DIR, and is capped by
COMMAND_TIMEOUT (the launcher exports these into the shim's env). Every
other tool, including `run_command`, is untouched and forwards normally.

Because `run_script` lives in the shim, it is available ONLY in
bearer-auth mode (MCP_HOST_BASH_BEARER set, shim in the request path).
When the bearer is unset the launcher binds mcp-proxy directly with no
shim, and only cli-mcp-server's `run_command` is exposed — unchanged.

USAGE

  mcp-proxy-auth-shim \\
      --listen-host 0.0.0.0 \\
      --listen-port 8766 \\
      --upstream-host 127.0.0.1 \\
      --upstream-port 8767

  # Or just print the resolved config + exit 0 (no socket bind, no
  # bearer probe — test hook only):
  mcp-proxy-auth-shim --print-config

ENVIRONMENT

  MCP_HOST_BASH_BEARER — REQUIRED. The shared-secret bearer token. Must
      match what callers (e.g. exec-hook-bridge inside the container)
      send as `Authorization: Bearer <token>`. Recommended: 32+ bytes
      base64-encoded from a CSPRNG. Generate once:

          head -c 32 /dev/urandom | base64

      Empty / unset = shim refuses to start. NO default value (a
      hardcoded default is a backdoor — every operator with the
      defaults gets the same "secret").

  MCP_PROXY_AUTH_SHIM_DEBUG — optional. Set to `1` for verbose stderr
      logging of every forwarded request / response. Default off.

EXIT CODES

  0   normal shutdown (Ctrl-C)
  1   upstream unreachable at startup health-check
  2   misconfigured (bearer env var unset/empty, bad argv, missing
      required flag)

DESIGN NOTES

- Stdlib only: `http.server.ThreadingHTTPServer` + `urllib.request`.
  Adding aiohttp would pull a PyPI dep into install-host-deps; the
  shim's request volume is low (one hook fire = three POSTs), so
  thread-per-request is plenty.

- Constant-time compare (`hmac.compare_digest`) on the bearer secret
  so timing-attack reconnaissance can't winnow the token byte by byte.

- We bind the public port and connect outbound to the upstream
  loopback port via TCP. We do NOT proxy a Unix socket — operators
  who want one can bind --upstream-host 127.0.0.1 and add their own
  firewall rules. The internal port is a normal localhost TCP listener
  that mcp-proxy already supports natively.

- The shim does NOT terminate TLS. It speaks plain HTTP both
  directions; protect the transport at a higher layer (host firewall,
  WireGuard, etc.) if you need it on an untrusted segment.
"""

from __future__ import annotations

import argparse
import hmac
import http.client
import http.server
import json
import os
import shutil
import socketserver
import subprocess
import sys
import threading
from typing import Any, Optional

BEARER_ENV = "MCP_HOST_BASH_BEARER"
DEBUG_ENV = "MCP_PROXY_AUTH_SHIM_DEBUG"

# Env vars that scope the locally-handled `run_script` tool. These are the
# SAME knobs cli-mcp-server enforces for `run_command` — the launcher
# (mcp-host-bash) resolves them once and exports them into BOTH the
# mcp-proxy --env pairs (for cli-mcp-server / run_command) AND this shim's
# own environment (for run_script). Reusing the identical fences keeps the
# two tools' policy in lockstep.
#   ALLOWED_COMMANDS — comma-separated allow-list of interpreter basenames.
#       "all" disables the name gate (matches cli-mcp-server semantics).
#       Unset/empty => run_script refuses every interpreter (fail-closed).
#   ALLOWED_DIR      — cwd for the spawned interpreter (default: $HOME).
#   COMMAND_TIMEOUT  — per-script wall-clock cap in seconds (default: 30).
ALLOWED_COMMANDS_ENV = "ALLOWED_COMMANDS"
ALLOWED_DIR_ENV = "ALLOWED_DIR"
COMMAND_TIMEOUT_ENV = "COMMAND_TIMEOUT"

RUN_SCRIPT_TOOL_NAME = "run_script"

# Headers we never want to forward verbatim across the proxy boundary.
# - `Authorization` is the secret itself; strip on forward (the shim is
#   the only authenticator; mcp-proxy must NEVER see the bearer).
# - `Host` gets recomputed by http.client for the upstream hop.
# - `Content-Length` is recomputed when we re-emit the body to upstream
#   (urllib/http.client handles this).
# - hop-by-hop headers per RFC 7230 §6.1 — these don't survive a proxy
#   semantically.
_HOP_BY_HOP = frozenset(
    h.lower()
    for h in (
        "connection",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailers",
        "transfer-encoding",
        "upgrade",
    )
)
_STRIP_REQUEST_HEADERS = _HOP_BY_HOP | {"authorization", "host", "content-length"}
_STRIP_RESPONSE_HEADERS = _HOP_BY_HOP | {"content-length", "transfer-encoding"}


def _debug_enabled() -> bool:
    return os.environ.get(DEBUG_ENV) == "1"


def _emit(msg: str) -> None:
    """One-line stderr emit with a stable prefix so operators can grep
    the shim's noise out of mcp-proxy's noise."""
    print(f"[mcp-proxy-auth-shim] {msg}", file=sys.stderr, flush=True)


def _debug(msg: str) -> None:
    if _debug_enabled():
        _emit(msg)


def load_bearer_or_die() -> str:
    """Load the bearer secret from env. FAIL CLOSED on missing/empty.

    We deliberately do NOT fall back to "no auth required" on a missing
    env var — a misconfiguration must be loud, not silently insecure.
    """
    bearer = os.environ.get(BEARER_ENV, "")
    if not bearer:
        _emit(
            f"FATAL: {BEARER_ENV} env var is unset or empty. The shim refuses "
            f"to start without a bearer secret — silently falling through "
            f"to no-auth would defeat the purpose of the shim. Generate a "
            f"secret with `head -c 32 /dev/urandom | base64` and export "
            f"{BEARER_ENV} before launching."
        )
        sys.exit(2)
    return bearer


def constant_time_eq(a: str, b: str) -> bool:
    """Compare two strings in constant time. hmac.compare_digest is the
    stdlib idiom for this — encodes to bytes first to dodge unicode
    normalization surprises."""
    return hmac.compare_digest(a.encode("utf-8"), b.encode("utf-8"))


def extract_bearer(header_value: Optional[str]) -> Optional[str]:
    """Pull the token out of `Authorization: Bearer <token>`. Returns
    None on missing header, wrong scheme, or empty token."""
    if not header_value:
        return None
    parts = header_value.split(None, 1)
    if len(parts) != 2:
        return None
    scheme, token = parts
    if scheme.lower() != "bearer":
        return None
    token = token.strip()
    if not token:
        return None
    return token


# ---------------------------------------------------------------------------
# run_script — locally-handled MCP tool
#
# `cli-mcp-server`'s `run_command` shlex-tokenizes the command string before
# exec, so it chokes on complex inline quoting (perl `qw(...)`, `;`, nested
# quotes, multi-line heredocs) even with ALLOWED_COMMANDS=all +
# ALLOW_SHELL_OPERATORS=true. `run_script` takes the script as a structured
# JSON string and feeds it to the interpreter on STDIN — the script body
# never traverses a shell or tokenizer at any layer.
#
# This is the ONLY tool the shim handles locally; every other JSON-RPC
# method (incl. run_command) forwards to mcp-proxy unchanged. The shim also
# injects the run_script definition into the tools/list response so callers
# discover it alongside run_command.
# ---------------------------------------------------------------------------

RUN_SCRIPT_TOOL_DEF = {
    "name": RUN_SCRIPT_TOOL_NAME,
    "description": (
        "Run a script with a chosen interpreter, feeding the script body on "
        "STDIN. Unlike run_command, the script is NEVER shell-parsed or "
        "tokenized — pass multi-line bodies, nested quotes, heredocs, perl "
        "qw(...), semicolons, etc. verbatim. The interpreter is resolved "
        "against the same allow-list as run_command; the script runs with "
        "cwd = ALLOWED_DIR and the same per-command timeout."
    ),
    "inputSchema": {
        "type": "object",
        "properties": {
            "interpreter": {
                "type": "string",
                "description": (
                    "Interpreter basename to exec (e.g. 'bash', 'perl', "
                    "'python3'). Must be on the allow-list."
                ),
            },
            "script": {
                "type": "string",
                "description": (
                    "Script body, fed to the interpreter on STDIN verbatim. "
                    "No escaping or encoding required."
                ),
            },
        },
        "required": ["interpreter", "script"],
    },
}


def _allowed_commands() -> Optional[set[str]]:
    """Parse ALLOWED_COMMANDS into a set of basenames, or None for the
    'all' wildcard. Empty/unset => empty set (fail-closed: nothing allowed)."""
    raw = os.environ.get(ALLOWED_COMMANDS_ENV, "").strip()
    if raw.lower() == "all":
        return None  # wildcard — no name gate
    return {c.strip() for c in raw.split(",") if c.strip()}


def _command_timeout() -> int:
    raw = os.environ.get(COMMAND_TIMEOUT_ENV, "").strip()
    try:
        val = int(raw)
        return val if val > 0 else 30
    except ValueError:
        return 30


def _allowed_dir() -> str:
    return os.environ.get(ALLOWED_DIR_ENV, "").strip() or os.environ.get(
        "HOME", os.getcwd()
    )


def _tool_result(text: str, is_error: bool = False) -> dict:
    """Build a standard MCP tool-result content block."""
    return {
        "content": [{"type": "text", "text": text}],
        "isError": is_error,
    }


def run_script(interpreter: str, script: str) -> dict:
    """Execute `interpreter` with `script` on STDIN. Returns an MCP
    tool-result dict. Reuses the same fences cli-mcp-server enforces for
    run_command: ALLOWED_COMMANDS name gate, ALLOWED_DIR cwd, COMMAND_TIMEOUT
    wall-clock cap. The script body is never tokenized or shell-parsed."""
    if not isinstance(interpreter, str) or not interpreter.strip():
        return _tool_result("run_script: 'interpreter' is required", is_error=True)
    if not isinstance(script, str):
        return _tool_result("run_script: 'script' must be a string", is_error=True)

    interpreter = interpreter.strip()

    # Reject anything that looks like a path or argv — the allow-list is
    # by basename, mirroring cli-mcp-server's per-binary gate.
    if os.path.basename(interpreter) != interpreter or "/" in interpreter:
        return _tool_result(
            f"run_script: interpreter must be a bare basename, got {interpreter!r}",
            is_error=True,
        )

    allowed = _allowed_commands()
    if allowed is not None and interpreter not in allowed:
        return _tool_result(
            f"run_script: interpreter {interpreter!r} is not in the allow-list "
            f"(ALLOWED_COMMANDS). Refused.",
            is_error=True,
        )

    resolved = shutil.which(interpreter)
    if not resolved:
        return _tool_result(
            f"run_script: interpreter {interpreter!r} not found on PATH",
            is_error=True,
        )

    timeout = _command_timeout()
    cwd = _allowed_dir()

    try:
        proc = subprocess.run(
            [resolved],
            input=script,
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except subprocess.TimeoutExpired:
        return _tool_result(
            f"run_script: {interpreter} timed out after {timeout}s",
            is_error=True,
        )
    except OSError as e:
        return _tool_result(
            f"run_script: failed to exec {interpreter}: {type(e).__name__}: {e}",
            is_error=True,
        )

    out = (
        f"exit_code: {proc.returncode}\n"
        f"--- stdout ---\n{proc.stdout}\n"
        f"--- stderr ---\n{proc.stderr}"
    )
    return _tool_result(out, is_error=(proc.returncode != 0))


def inject_run_script_into_tools_list(payload: Any) -> Any:
    """Given a parsed JSON-RPC response object, if it's a tools/list result,
    append the run_script tool def (idempotent). Returns the (possibly
    mutated) object; returns it unchanged if the shape doesn't match."""
    if not isinstance(payload, dict):
        return payload
    result = payload.get("result")
    if not isinstance(result, dict):
        return payload
    tools = result.get("tools")
    if not isinstance(tools, list):
        return payload
    if any(
        isinstance(t, dict) and t.get("name") == RUN_SCRIPT_TOOL_NAME for t in tools
    ):
        return payload  # already present — don't duplicate
    tools.append(RUN_SCRIPT_TOOL_DEF)
    return payload


class AuthShimHandler(http.server.BaseHTTPRequestHandler):
    """Per-request handler. Reads the bearer + upstream config from
    class attributes set at server boot.

    The class-attribute pattern matches the stdlib http.server idiom —
    BaseHTTPRequestHandler doesn't natively support instance config,
    so we wire it through the class.
    """

    expected_bearer: str = ""
    upstream_host: str = "127.0.0.1"
    upstream_port: int = 0

    # Quiet down BaseHTTPRequestHandler's default per-request logging
    # (which goes to stderr unconditionally) — our _emit/_debug
    # functions are the one true output path.
    def log_message(self, fmt: str, *args) -> None:  # noqa: N802
        return

    # --- helpers ----------------------------------------------------------

    def _send_401(self, reason: str) -> None:
        body = f"Unauthorized: {reason}\n".encode("utf-8")
        self.send_response(401)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        # WWW-Authenticate is the spec-correct response for a 401 to a
        # bearer-protected resource (RFC 6750 §3). The realm is the
        # MCP host adapter — operators looking at network captures /
        # browser dev tools can match the challenge to this shim.
        self.send_header("WWW-Authenticate", 'Bearer realm="mcp-host-bash"')
        self.end_headers()
        self.wfile.write(body)

    def _check_auth(self) -> bool:
        """Return True iff the request carries a valid bearer header.
        Logs the failure reason and sends 401 on rejection."""
        header = self.headers.get("Authorization")
        token = extract_bearer(header)
        if token is None:
            _emit(
                f"reject: missing or malformed Authorization header "
                f"from {self.client_address[0]} on {self.command} {self.path}"
            )
            self._send_401("missing or malformed Authorization header")
            return False
        if not constant_time_eq(token, self.expected_bearer):
            _emit(
                f"reject: wrong bearer from {self.client_address[0]} "
                f"on {self.command} {self.path}"
            )
            self._send_401("invalid bearer token")
            return False
        return True

    def _read_body(self) -> bytes:
        """Read the request body (if any). Content-Length is the only
        body-framing shape mcp-proxy clients use today (urllib's POST writes
        Content-Length, not Transfer-Encoding: chunked), so we don't need
        streaming support. Body is read exactly once per request."""
        content_length = int(self.headers.get("Content-Length", "0") or "0")
        return self.rfile.read(content_length) if content_length > 0 else b""

    def _send_json(self, status: int, obj: Any) -> None:
        """Serialize `obj` as JSON and send it as the HTTP response. Used
        for shim-handled (non-forwarded) responses like run_script results."""
        body = json.dumps(obj).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _try_handle_run_script(self, body: bytes) -> bool:
        """If `body` is a JSON-RPC tools/call for run_script, handle it
        locally and reply — returning True. Otherwise return False so the
        caller forwards the request to mcp-proxy unchanged.

        Parse failures / non-matching shapes return False (forward as-is);
        we only intercept the exact run_script call shape."""
        if not body:
            return False
        try:
            req = json.loads(body)
        except (ValueError, UnicodeDecodeError):
            return False
        if not isinstance(req, dict) or req.get("method") != "tools/call":
            return False
        params = req.get("params")
        if not isinstance(params, dict) or params.get("name") != RUN_SCRIPT_TOOL_NAME:
            return False

        args = params.get("arguments") or {}
        if not isinstance(args, dict):
            args = {}
        result = run_script(args.get("interpreter", ""), args.get("script", ""))

        _emit(
            f"run_script: interpreter={args.get('interpreter')!r} "
            f"(isError={result.get('isError')})"
        )
        self._send_json(
            200,
            {"jsonrpc": "2.0", "id": req.get("id"), "result": result},
        )
        return True

    def _maybe_inject_run_script(self, resp_body: bytes, content_type: str) -> bytes:
        """If `resp_body` is a JSON tools/list result, inject the run_script
        tool def so callers discover it alongside run_command. Returns the
        (possibly rewritten) body. Non-JSON / non-tools-list bodies (incl.
        SSE) pass through unchanged — run_command's discovery path is JSON
        in the mcp-proxy stateless transport, which is what the bridge uses."""
        if "application/json" not in content_type.lower():
            return resp_body
        try:
            payload = json.loads(resp_body)
        except (ValueError, UnicodeDecodeError):
            return resp_body
        injected = inject_run_script_into_tools_list(payload)
        if injected is payload and not (
            isinstance(payload, dict)
            and isinstance(payload.get("result"), dict)
            and isinstance(payload["result"].get("tools"), list)
        ):
            return resp_body
        return json.dumps(injected).encode("utf-8")

    def _forward(self, body: bytes) -> None:
        """Forward the verified request upstream + relay the response.

        `body` is read once by the caller (so run_script interception can
        peek at it first) and handed in here.
        """
        content_length = len(body)

        # Build the forward request: strip the Authorization header so
        # mcp-proxy never sees the secret, plus hop-by-hop headers per
        # RFC 7230.
        fwd_headers: dict[str, str] = {}
        for k, v in self.headers.items():
            if k.lower() in _STRIP_REQUEST_HEADERS:
                continue
            fwd_headers[k] = v
        if content_length > 0:
            fwd_headers["Content-Length"] = str(content_length)

        _debug(
            f"forward: {self.command} {self.path} -> "
            f"{self.upstream_host}:{self.upstream_port} "
            f"(body={content_length}B, headers={list(fwd_headers.keys())})"
        )

        try:
            conn = http.client.HTTPConnection(
                self.upstream_host, self.upstream_port, timeout=60
            )
            conn.request(self.command, self.path, body=body, headers=fwd_headers)
            resp = conn.getresponse()
            resp_body = resp.read()
        except (OSError, http.client.HTTPException) as e:
            _emit(
                f"upstream error: {self.command} {self.path} -> "
                f"{self.upstream_host}:{self.upstream_port}: {type(e).__name__}: {e}"
            )
            err_body = (
                f"Bad Gateway: upstream mcp-proxy unreachable "
                f"({type(e).__name__})\n"
            ).encode("utf-8")
            try:
                self.send_response(502)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.send_header("Content-Length", str(len(err_body)))
                self.end_headers()
                self.wfile.write(err_body)
            except Exception:  # pragma: no cover — last-resort safety
                pass
            return

        # Inject the run_script tool def into a tools/list response so
        # callers discover it alongside run_command. No-op for every other
        # response shape (incl. non-tools-list JSON and SSE bodies).
        content_type = resp.getheader("Content-Type", "") or ""
        if resp.status == 200:
            resp_body = self._maybe_inject_run_script(resp_body, content_type)

        # Relay response. send_response writes status + the HTTP/1.1
        # Server header; we then append the upstream headers (sans
        # hop-by-hop / re-computed framing). Body framing is
        # re-emitted from the bytes we actually have.
        self.send_response(resp.status)
        for k, v in resp.getheaders():
            if k.lower() in _STRIP_RESPONSE_HEADERS:
                continue
            self.send_header(k, v)
        self.send_header("Content-Length", str(len(resp_body)))
        self.end_headers()
        self.wfile.write(resp_body)

        _debug(
            f"forwarded: {self.command} {self.path} -> "
            f"{resp.status} ({len(resp_body)}B body)"
        )

    # --- HTTP verb dispatch ---------------------------------------------

    def _dispatch(self) -> None:
        if not self._check_auth():
            return
        # Read the body once. run_script calls are handled locally (never
        # forwarded to mcp-proxy / cli-mcp-server); everything else forwards.
        body = self._read_body()
        if self._try_handle_run_script(body):
            return
        self._forward(body)

    # mcp-proxy speaks JSON-RPC over POST; in practice that's the only
    # verb the bridge uses. We also accept GET / OPTIONS / etc. for
    # forward-compat (mcp-proxy may add SSE GET endpoints in future);
    # the auth gate applies to every method.
    def do_GET(self) -> None:  # noqa: N802
        self._dispatch()

    def do_POST(self) -> None:  # noqa: N802
        self._dispatch()

    def do_PUT(self) -> None:  # noqa: N802
        self._dispatch()

    def do_DELETE(self) -> None:  # noqa: N802
        self._dispatch()

    def do_OPTIONS(self) -> None:  # noqa: N802
        self._dispatch()

    def do_HEAD(self) -> None:  # noqa: N802
        self._dispatch()


class ThreadingHTTPServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    """ThreadingMixIn + HTTPServer = thread-per-request HTTP server.

    `daemon_threads = True` ensures handler threads don't block process
    shutdown on Ctrl-C. `allow_reuse_address = True` lets us re-bind
    immediately on restart without TIME_WAIT delay (the launcher
    relaunches after Ctrl-C/SIGTERM, and mcp-host-bash's KeepAlive
    in the launchd plist relaunches after any crash).
    """

    daemon_threads = True
    allow_reuse_address = True


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="bearer-token reverse proxy in front of mcp-proxy",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--listen-host",
        default="127.0.0.1",
        help="public bind address (default: 127.0.0.1; mcp-host-bash sets "
        "this from MCP_HOST_BASH_BIND)",
    )
    parser.add_argument(
        "--listen-port",
        type=int,
        default=8766,
        help="public bind port (default: 8766)",
    )
    parser.add_argument(
        "--upstream-host",
        default="127.0.0.1",
        help="upstream mcp-proxy address (default: 127.0.0.1 — should stay "
        "loopback so only the shim can reach it)",
    )
    parser.add_argument(
        "--upstream-port",
        type=int,
        required=True,
        help="upstream mcp-proxy port (the launcher picks an internal port "
        "above the public one — typically public+1)",
    )
    parser.add_argument(
        "--print-config",
        action="store_true",
        help="resolve config + print to stdout, exit 0. No socket bind, "
        "no bearer probe — test hook only.",
    )
    return parser.parse_args(argv)


def main(argv: list[str]) -> None:
    args = parse_args(argv)

    if args.print_config:
        # Test hook — no bearer probe, no socket bind. Just print the
        # resolved config one-per-line so the test suite can assert
        # mcp-host-bash wires the shim's argv correctly.
        print(f"listen-host {args.listen_host}")
        print(f"listen-port {args.listen_port}")
        print(f"upstream-host {args.upstream_host}")
        print(f"upstream-port {args.upstream_port}")
        sys.exit(0)

    bearer = load_bearer_or_die()

    AuthShimHandler.expected_bearer = bearer
    AuthShimHandler.upstream_host = args.upstream_host
    AuthShimHandler.upstream_port = args.upstream_port

    try:
        server = ThreadingHTTPServer(
            (args.listen_host, args.listen_port), AuthShimHandler
        )
    except OSError as e:
        _emit(
            f"FATAL: cannot bind {args.listen_host}:{args.listen_port}: {e}. "
            f"Another process may already own the port — `lsof -i "
            f":{args.listen_port}` to find it."
        )
        sys.exit(1)

    _emit(
        f"started: listening on {args.listen_host}:{args.listen_port}, "
        f"forwarding authenticated requests to "
        f"{args.upstream_host}:{args.upstream_port}. "
        f"Bearer required (len={len(bearer)} chars)."
    )

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        _emit("shutdown: received Ctrl-C, stopping")
        server.shutdown()
        sys.exit(0)


if __name__ == "__main__":
    main(sys.argv[1:])
