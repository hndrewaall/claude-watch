#!/usr/bin/env python3
"""mcp-proxy-auth-shim — bearer-token reverse proxy in front of mcp-proxy.

WHY THIS EXISTS

mcp-proxy upstream has no inbound authentication knob (verified via
README + proxy_server.py source read 2026-05-14 — the only auth-adjacent
flag is `--allow-origin`, which is browser-side CORS, not a server-side
gate). So even with the loopback-only default bind landed in the
sibling PR, anything that shares the host's network namespace
(sibling local UIDs, in-host malware running under any uid, a browser
landing SSRF, etc.) can still POST `tools/call run_command` and exec
binaries on the host.

This shim closes that surface by sitting between callers and mcp-proxy:

  caller  ──HTTP──►  shim (public port, e.g. 8766)
                       │
                       │  validates Authorization: Bearer <secret>
                       │  on every request; strips the header before
                       │  forwarding so mcp-proxy never sees it.
                       │
                       ▼
                    mcp-proxy (loopback-only internal port, e.g. 8767)
                       │
                       ▼  (stdio)
                    cli-mcp-server

The bearer secret is loaded from the `MCP_HOST_BASH_BEARER` env var at
shim startup. The shim FAILS CLOSED:

  - Empty / unset bearer env var: shim refuses to start (exits 2). No
    silent fall-through to no-auth.
  - Missing Authorization header on a request: 401, log, no forward.
  - Wrong header value: 401, log, no forward.

Stateless-mode and streamable-HTTP both flow through transparently —
the shim copies response headers (including `mcp-session-id`), body,
and status code verbatim. Both JSON and text/event-stream content
types pass through.

USAGE

  mcp-proxy-auth-shim \\
      --listen-host 0.0.0.0 \\
      --listen-port 8766 \\
      --upstream-host 127.0.0.1 \\
      --upstream-port 8767

  # Or just print the resolved config + exit 0 (no socket bind, no
  # bearer probe — test hook only):
  mcp-proxy-auth-shim --print-config

ENVIRONMENT

  MCP_HOST_BASH_BEARER — REQUIRED. The shared-secret bearer token. Must
      match what callers (e.g. exec-hook-bridge inside the container)
      send as `Authorization: Bearer <token>`. Recommended: 32+ bytes
      base64-encoded from a CSPRNG. Generate once:

          head -c 32 /dev/urandom | base64

      Empty / unset = shim refuses to start. NO default value (a
      hardcoded default is a backdoor — every operator with the
      defaults gets the same "secret").

  MCP_PROXY_AUTH_SHIM_DEBUG — optional. Set to `1` for verbose stderr
      logging of every forwarded request / response. Default off.

EXIT CODES

  0   normal shutdown (Ctrl-C)
  1   upstream unreachable at startup health-check
  2   misconfigured (bearer env var unset/empty, bad argv, missing
      required flag)

DESIGN NOTES

- Stdlib only: `http.server.ThreadingHTTPServer` + `urllib.request`.
  Adding aiohttp would pull a PyPI dep into install-host-deps; the
  shim's request volume is low (one hook fire = three POSTs), so
  thread-per-request is plenty.

- Constant-time compare (`hmac.compare_digest`) on the bearer secret
  so timing-attack reconnaissance can't winnow the token byte by byte.

- We bind the public port and connect outbound to the upstream
  loopback port via TCP. We do NOT proxy a Unix socket — operators
  who want one can bind --upstream-host 127.0.0.1 and add their own
  firewall rules. The internal port is a normal localhost TCP listener
  that mcp-proxy already supports natively.

- The shim does NOT terminate TLS. It speaks plain HTTP both
  directions; protect the transport at a higher layer (host firewall,
  WireGuard, etc.) if you need it on an untrusted segment.
"""

from __future__ import annotations

import argparse
import hmac
import http.client
import http.server
import os
import socketserver
import sys
import threading
from typing import Optional

BEARER_ENV = "MCP_HOST_BASH_BEARER"
DEBUG_ENV = "MCP_PROXY_AUTH_SHIM_DEBUG"

# Headers we never want to forward verbatim across the proxy boundary.
# - `Authorization` is the secret itself; strip on forward (the shim is
#   the only authenticator; mcp-proxy must NEVER see the bearer).
# - `Host` gets recomputed by http.client for the upstream hop.
# - `Content-Length` is recomputed when we re-emit the body to upstream
#   (urllib/http.client handles this).
# - hop-by-hop headers per RFC 7230 §6.1 — these don't survive a proxy
#   semantically.
_HOP_BY_HOP = frozenset(
    h.lower()
    for h in (
        "connection",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailers",
        "transfer-encoding",
        "upgrade",
    )
)
_STRIP_REQUEST_HEADERS = _HOP_BY_HOP | {"authorization", "host", "content-length"}
_STRIP_RESPONSE_HEADERS = _HOP_BY_HOP | {"content-length", "transfer-encoding"}


def _debug_enabled() -> bool:
    return os.environ.get(DEBUG_ENV) == "1"


def _emit(msg: str) -> None:
    """One-line stderr emit with a stable prefix so operators can grep
    the shim's noise out of mcp-proxy's noise."""
    print(f"[mcp-proxy-auth-shim] {msg}", file=sys.stderr, flush=True)


def _debug(msg: str) -> None:
    if _debug_enabled():
        _emit(msg)


def load_bearer_or_die() -> str:
    """Load the bearer secret from env. FAIL CLOSED on missing/empty.

    We deliberately do NOT fall back to "no auth required" on a missing
    env var — a misconfiguration must be loud, not silently insecure.
    """
    bearer = os.environ.get(BEARER_ENV, "")
    if not bearer:
        _emit(
            f"FATAL: {BEARER_ENV} env var is unset or empty. The shim refuses "
            f"to start without a bearer secret — silently falling through "
            f"to no-auth would defeat the purpose of the shim. Generate a "
            f"secret with `head -c 32 /dev/urandom | base64` and export "
            f"{BEARER_ENV} before launching."
        )
        sys.exit(2)
    return bearer


def constant_time_eq(a: str, b: str) -> bool:
    """Compare two strings in constant time. hmac.compare_digest is the
    stdlib idiom for this — encodes to bytes first to dodge unicode
    normalization surprises."""
    return hmac.compare_digest(a.encode("utf-8"), b.encode("utf-8"))


def extract_bearer(header_value: Optional[str]) -> Optional[str]:
    """Pull the token out of `Authorization: Bearer <token>`. Returns
    None on missing header, wrong scheme, or empty token."""
    if not header_value:
        return None
    parts = header_value.split(None, 1)
    if len(parts) != 2:
        return None
    scheme, token = parts
    if scheme.lower() != "bearer":
        return None
    token = token.strip()
    if not token:
        return None
    return token


class AuthShimHandler(http.server.BaseHTTPRequestHandler):
    """Per-request handler. Reads the bearer + upstream config from
    class attributes set at server boot.

    The class-attribute pattern matches the stdlib http.server idiom —
    BaseHTTPRequestHandler doesn't natively support instance config,
    so we wire it through the class.
    """

    expected_bearer: str = ""
    upstream_host: str = "127.0.0.1"
    upstream_port: int = 0

    # Quiet down BaseHTTPRequestHandler's default per-request logging
    # (which goes to stderr unconditionally) — our _emit/_debug
    # functions are the one true output path.
    def log_message(self, fmt: str, *args) -> None:  # noqa: N802
        return

    # --- helpers ----------------------------------------------------------

    def _send_401(self, reason: str) -> None:
        body = f"Unauthorized: {reason}\n".encode("utf-8")
        self.send_response(401)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        # WWW-Authenticate is the spec-correct response for a 401 to a
        # bearer-protected resource (RFC 6750 §3). The realm is the
        # MCP host adapter — operators looking at network captures /
        # browser dev tools can match the challenge to this shim.
        self.send_header("WWW-Authenticate", 'Bearer realm="mcp-host-bash"')
        self.end_headers()
        self.wfile.write(body)

    def _check_auth(self) -> bool:
        """Return True iff the request carries a valid bearer header.
        Logs the failure reason and sends 401 on rejection."""
        header = self.headers.get("Authorization")
        token = extract_bearer(header)
        if token is None:
            _emit(
                f"reject: missing or malformed Authorization header "
                f"from {self.client_address[0]} on {self.command} {self.path}"
            )
            self._send_401("missing or malformed Authorization header")
            return False
        if not constant_time_eq(token, self.expected_bearer):
            _emit(
                f"reject: wrong bearer from {self.client_address[0]} "
                f"on {self.command} {self.path}"
            )
            self._send_401("invalid bearer token")
            return False
        return True

    def _forward(self) -> None:
        """Forward the verified request upstream + relay the response."""
        # Read the request body (if any). Content-Length is the
        # only body-framing shape mcp-proxy clients use today
        # (urllib's POST writes Content-Length, not Transfer-Encoding:
        # chunked), so we don't need streaming support.
        content_length = int(self.headers.get("Content-Length", "0") or "0")
        body = self.rfile.read(content_length) if content_length > 0 else b""

        # Build the forward request: strip the Authorization header so
        # mcp-proxy never sees the secret, plus hop-by-hop headers per
        # RFC 7230.
        fwd_headers: dict[str, str] = {}
        for k, v in self.headers.items():
            if k.lower() in _STRIP_REQUEST_HEADERS:
                continue
            fwd_headers[k] = v
        if content_length > 0:
            fwd_headers["Content-Length"] = str(content_length)

        _debug(
            f"forward: {self.command} {self.path} -> "
            f"{self.upstream_host}:{self.upstream_port} "
            f"(body={content_length}B, headers={list(fwd_headers.keys())})"
        )

        try:
            conn = http.client.HTTPConnection(
                self.upstream_host, self.upstream_port, timeout=60
            )
            conn.request(self.command, self.path, body=body, headers=fwd_headers)
            resp = conn.getresponse()
            resp_body = resp.read()
        except (OSError, http.client.HTTPException) as e:
            _emit(
                f"upstream error: {self.command} {self.path} -> "
                f"{self.upstream_host}:{self.upstream_port}: {type(e).__name__}: {e}"
            )
            err_body = (
                f"Bad Gateway: upstream mcp-proxy unreachable "
                f"({type(e).__name__})\n"
            ).encode("utf-8")
            try:
                self.send_response(502)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.send_header("Content-Length", str(len(err_body)))
                self.end_headers()
                self.wfile.write(err_body)
            except Exception:  # pragma: no cover — last-resort safety
                pass
            return

        # Relay response. send_response writes status + the HTTP/1.1
        # Server header; we then append the upstream headers (sans
        # hop-by-hop / re-computed framing). Body framing is
        # re-emitted from the bytes we actually have.
        self.send_response(resp.status)
        for k, v in resp.getheaders():
            if k.lower() in _STRIP_RESPONSE_HEADERS:
                continue
            self.send_header(k, v)
        self.send_header("Content-Length", str(len(resp_body)))
        self.end_headers()
        self.wfile.write(resp_body)

        _debug(
            f"forwarded: {self.command} {self.path} -> "
            f"{resp.status} ({len(resp_body)}B body)"
        )

    # --- HTTP verb dispatch ---------------------------------------------

    def _dispatch(self) -> None:
        if not self._check_auth():
            return
        self._forward()

    # mcp-proxy speaks JSON-RPC over POST; in practice that's the only
    # verb the bridge uses. We also accept GET / OPTIONS / etc. for
    # forward-compat (mcp-proxy may add SSE GET endpoints in future);
    # the auth gate applies to every method.
    def do_GET(self) -> None:  # noqa: N802
        self._dispatch()

    def do_POST(self) -> None:  # noqa: N802
        self._dispatch()

    def do_PUT(self) -> None:  # noqa: N802
        self._dispatch()

    def do_DELETE(self) -> None:  # noqa: N802
        self._dispatch()

    def do_OPTIONS(self) -> None:  # noqa: N802
        self._dispatch()

    def do_HEAD(self) -> None:  # noqa: N802
        self._dispatch()


class ThreadingHTTPServer(socketserver.ThreadingMixIn, http.server.HTTPServer):
    """ThreadingMixIn + HTTPServer = thread-per-request HTTP server.

    `daemon_threads = True` ensures handler threads don't block process
    shutdown on Ctrl-C. `allow_reuse_address = True` lets us re-bind
    immediately on restart without TIME_WAIT delay (the launcher
    relaunches after Ctrl-C/SIGTERM, and mcp-host-bash's KeepAlive
    in the launchd plist relaunches after any crash).
    """

    daemon_threads = True
    allow_reuse_address = True


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="bearer-token reverse proxy in front of mcp-proxy",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "--listen-host",
        default="127.0.0.1",
        help="public bind address (default: 127.0.0.1; mcp-host-bash sets "
        "this from MCP_HOST_BASH_BIND)",
    )
    parser.add_argument(
        "--listen-port",
        type=int,
        default=8766,
        help="public bind port (default: 8766)",
    )
    parser.add_argument(
        "--upstream-host",
        default="127.0.0.1",
        help="upstream mcp-proxy address (default: 127.0.0.1 — should stay "
        "loopback so only the shim can reach it)",
    )
    parser.add_argument(
        "--upstream-port",
        type=int,
        required=True,
        help="upstream mcp-proxy port (the launcher picks an internal port "
        "above the public one — typically public+1)",
    )
    parser.add_argument(
        "--print-config",
        action="store_true",
        help="resolve config + print to stdout, exit 0. No socket bind, "
        "no bearer probe — test hook only.",
    )
    return parser.parse_args(argv)


def main(argv: list[str]) -> None:
    args = parse_args(argv)

    if args.print_config:
        # Test hook — no bearer probe, no socket bind. Just print the
        # resolved config one-per-line so the test suite can assert
        # mcp-host-bash wires the shim's argv correctly.
        print(f"listen-host {args.listen_host}")
        print(f"listen-port {args.listen_port}")
        print(f"upstream-host {args.upstream_host}")
        print(f"upstream-port {args.upstream_port}")
        sys.exit(0)

    bearer = load_bearer_or_die()

    AuthShimHandler.expected_bearer = bearer
    AuthShimHandler.upstream_host = args.upstream_host
    AuthShimHandler.upstream_port = args.upstream_port

    try:
        server = ThreadingHTTPServer(
            (args.listen_host, args.listen_port), AuthShimHandler
        )
    except OSError as e:
        _emit(
            f"FATAL: cannot bind {args.listen_host}:{args.listen_port}: {e}. "
            f"Another process may already own the port — `lsof -i "
            f":{args.listen_port}` to find it."
        )
        sys.exit(1)

    _emit(
        f"started: listening on {args.listen_host}:{args.listen_port}, "
        f"forwarding authenticated requests to "
        f"{args.upstream_host}:{args.upstream_port}. "
        f"Bearer required (len={len(bearer)} chars)."
    )

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        _emit("shutdown: received Ctrl-C, stopping")
        server.shutdown()
        sys.exit(0)


if __name__ == "__main__":
    main(sys.argv[1:])
