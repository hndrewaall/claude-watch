# Environment file for examples/compose/ — copy to .env and edit.
#
# `docker compose up` (in this directory) auto-loads .env. The values
# below mirror the env vars referenced in docker-compose.yml.
#
# Most fields are optional. Anthropic API key is required only if you
# want the claude-container service to talk to the real API.

# --- claude-container --------------------------------------------------

# Anthropic API key. Leave empty to bring the container up without
# making API calls (useful for testing the tmux entrypoint).
ANTHROPIC_API_KEY=

# Optional: VSCode IDE integration port (HTTP/SSE on host loopback).
# Set if you want the in-container claude binary to dial your host's
# VSCode SSE listener; otherwise leave unset.
# CLAUDE_CODE_SSE_PORT=

# --- queue-minisite branding (optional) -------------------------------
#
# The public image renders as generic "queue" with the bundled
# claude-watch eye-glyph if QUEUE_SITE_LOGO_DEFAULT=1. Override these
# to brand the deployment. Empty = bundled default.

# QUEUE_SITE_TITLE=queue
# QUEUE_SITE_LOGO_URL=
# QUEUE_SITE_LOGO_DEFAULT=1
# QUEUE_SITE_BRAND=
# QUEUE_SITE_FAVICON_URL=

# --- eichi search-minisite branding (optional) ------------------------

# SEARCH_SITE_TITLE=eichi search
# SEARCH_SITE_LOGO_URL=
# SEARCH_SITE_LOGO_DEFAULT=1
# SEARCH_SITE_BRAND=
# SEARCH_SITE_FAVICON_URL=
