# claude-watch monitoring stack — env overrides. Copy to `.env` and edit.
# All have sane Linux defaults in docker-compose.yml; override per host.

# --- Exporter data sources (bind-mounted read-only into the exporters) ---
# session-task queue dir holding queue.json (work-queue-exporter).
# CW_QUEUE_DIR=$HOME/.config/session
# claude-watch active-agents.json state dir (owner liveness).
# CW_STATE_PATH=$HOME/.local/share/claude-watch
# claude-events spool (claude-events-exporter).
# CW_EVENTS_DIR=$HOME/claude-events
# Per-workload progress heartbeat dir (claude-watch workload wrapper).
# CW_WORKLOAD_HEARTBEAT_DIR=/run/claude/workloads
# Per-hostjob progress heartbeat dir (examples/compose/bin/hostjob runner).
# CW_HOSTJOB_HEARTBEAT_DIR=$HOME/.cache/hostjob

# --- node-exporter profile (claude-watch daemon textfile metrics) ---
# Dir that `claude-watch metrics` cron writes claude_watch.prom into.
# CW_TEXTFILE_DIR=/var/lib/node-exporter/textfile

# --- grafana profile ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=admin
