{
  "title": "Claude Watch",
  "uid": "claude-watch",
  "tags": [
    "claude"
  ],
  "timezone": "browser",
  "editable": true,
  "style": "dark",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_watch_up",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "#859900"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#dc322f"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#dc322f",
                "value": null
              },
              {
                "color": "#859900",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "title": "Heartbeat Age",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 3,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "time() - claude_mainloop_heartbeat_timestamp_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#859900",
                "value": null
              },
              {
                "color": "#b58900",
                "value": 360
              },
              {
                "color": "#dc322f",
                "value": 600
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Context Tokens",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 7,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_context_tokens",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#859900",
                "value": null
              },
              {
                "color": "#b58900",
                "value": 500000
              },
              {
                "color": "#dc322f",
                "value": 800000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 8,
      "title": "Watchers",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_watchers_total",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "claude_watchers_missing",
          "legendFormat": "Missing",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#268bd2",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Missing"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#dc322f",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 10,
      "title": "Failures & Dead Checks",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_consecutive_failures",
          "legendFormat": "Consecutive Failures",
          "refId": "A"
        },
        {
          "expr": "claude_consecutive_dead_checks",
          "legendFormat": "Dead Checks",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Consecutive Failures"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#b58900",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Dead Checks"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#dc322f",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "title": "Interruptions Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "increase(claude_watcher_inject_total[5m])",
          "legendFormat": "Watcher Inject",
          "refId": "A"
        },
        {
          "expr": "increase(claude_thinking_interrupt_total[5m])",
          "legendFormat": "Thinking Interrupt",
          "refId": "B"
        },
        {
          "expr": "increase(claude_auto_update_total[5m])",
          "legendFormat": "Auto Update",
          "refId": "C"
        },
        {
          "expr": "increase(claude_heartbeat_stale_total[5m])",
          "legendFormat": "Heartbeat Stale",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Watcher Inject"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#2aa198",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Thinking Interrupt"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#b58900",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Auto Update"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#268bd2",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Heartbeat Stale"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#dc322f",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 12,
      "title": "Heartbeat Staleness",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "time() - claude_mainloop_heartbeat_timestamp_seconds",
          "legendFormat": "Heartbeat Staleness",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#859900",
                "value": null
              },
              {
                "color": "#b58900",
                "value": 360
              },
              {
                "color": "#dc322f",
                "value": 600
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Consecutive Failures"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#b58900",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Dead Checks"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#dc322f",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 13,
      "title": "Claude Code Version",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_version_info",
          "legendFormat": "current: {{current}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "claude_version_info",
          "legendFormat": "latest: {{latest}}",
          "refId": "B",
          "instant": true,
          "hide": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#268bd2"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "name",
        "orientation": "vertical"
      }
    },
    {
      "id": 15,
      "title": "Since Last Clear",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 13,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "time() - claude_last_context_clear_timestamp_seconds",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#b58900"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#859900",
                "value": null
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 20,
      "title": "Hybrid Hooks",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "panels": []
    },
    {
      "id": 21,
      "title": "Reminder Fires by Type (rate / 5m)",
      "type": "timeseries",
      "description": "Rate of hook-driven reminder fires. context_high fires when context % crosses the high threshold; version_update fires when a new claude version is detected; pre_compact fires before a compaction.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 41
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(claude_watch_reminder_fires_total[5m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 22,
      "title": "Fallback Injections by Type (rate / 5m)",
      "type": "timeseries",
      "description": "Rate of daemon-driven fallback injections. When nonzero, Claude ignored the corresponding reminder and the daemon had to intervene (force /clear or /restart).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 41
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(claude_watch_fallback_injections_total[5m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisSoftMin": 0,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 23,
      "title": "Cooperation Ratio (30m)",
      "type": "gauge",
      "description": "Fraction of context_high reminders that Claude acted on autonomously (did NOT require fallback). Computed as 1 - (fallback clear rate / context_high reminder rate) over 30m. Target >= 0.8. Falls back to 1.0 when no reminders fired in the window.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 49
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "clamp_min(1 - (rate(claude_watch_fallback_injections_total{type=\"clear\"}[30m]) / on(instance, job) clamp_min(rate(claude_watch_reminder_fires_total{type=\"context_high\"}[30m]), 1e-12)), 0)",
          "legendFormat": "cooperation",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#dc322f",
                "value": null
              },
              {
                "color": "#b58900",
                "value": 0.5
              },
              {
                "color": "#859900",
                "value": 0.8
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 24,
      "title": "Reminder\u2192Action Latency (avg)",
      "type": "timeseries",
      "description": "Average time from reminder fire to Claude action (self-/clear or /restart), split by type. Computed as sum/count since the exporter ships counter pairs rather than a true histogram -- this is an AVERAGE, not a real quantile. Samples only when Claude acted within 1h (context) / 6h (version).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 49
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_watch_reminder_to_action_latency_seconds_sum / clamp_min(claude_watch_reminder_to_action_latency_seconds_count, 1)",
          "legendFormat": "{{type}} avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": true,
            "axisSoftMin": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 25,
      "title": "Counter Values (debug)",
      "type": "table",
      "description": "Raw counter values for debugging: reminder_fires and fallback_injections by type, plus latency sum/count pairs.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 49
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "claude_watch_reminder_fires_total",
          "legendFormat": "fires {{type}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "claude_watch_fallback_injections_total",
          "legendFormat": "fallback {{type}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "claude_watch_reminder_to_action_latency_seconds_sum",
          "legendFormat": "latency_sum {{type}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "claude_watch_reminder_to_action_latency_seconds_count",
          "legendFormat": "latency_count {{type}}",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true
            }
          }
        }
      ]
    },
    {
      "id": 30,
      "title": "Interrupt Activity",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 57
      },
      "panels": []
    },
    {
      "id": 31,
      "title": "Total Interrupts (24h)",
      "type": "stat",
      "description": "Sum of all claude_interrupts_total increases across every kind over the last 24h. Red above 50 (wedge-state territory), yellow above 20.",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 58
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(claude_interrupts_total[24h]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
