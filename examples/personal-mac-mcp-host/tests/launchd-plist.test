#!/usr/bin/env python3
"""Tests for the examples/personal-mac-mcp-host/launchd/ LaunchAgent
templates — the macOS units that bring up personal-mcp-host.sh for the
on-demand reverse-tunnelled MCP host bridge.

Two templates are validated with the SAME structural checks:

  - org.gbre.personal-mcp.host.plist    — bundled: launches both
    mcp-host-bash AND the reverse SSH tunnel.
  - org.gbre.personal-mcp.tunnel.plist  — tunnel-only: launches ONLY
    the reverse SSH tunnel (mcp-host-bash assumed already running
    locally, e.g. the always-on compose-stack LaunchAgent). Invokes
    the wrapper with `--tunnel-only`.

Coverage (run against BOTH plists):
  - File-level structural validation only (no `launchctl` invocation).
  - Plist parses cleanly via Python's stdlib `plistlib`.
  - When `plutil` is available (macOS hosts), lint via that too.
  - `Label` matches the filename convention launchd enforces.
  - `ProgramArguments[0]` looks like an absolute path and points at
    personal-mcp-host.sh.
  - `RunAtLoad=false` (this is the on-demand pattern — operator runs
    `launchctl kickstart` to start a session).
  - `KeepAlive=true` (while running, respawn on exit).
  - `EnvironmentVariables` has a `PATH` entry that includes
    `.local/bin`.
  - `WorkingDirectory`, `StandardOutPath`, `StandardErrorPath`,
    `ThrottleInterval`, `ProcessType` all present + sane.

Plus tunnel-only specific checks:
  - The tunnel plist passes `--tunnel-only` in ProgramArguments.
  - README walkthrough hits the major operator steps + references both
    Labels.

Run:  ./launchd-plist.test
"""

from __future__ import annotations

import plistlib
import shutil
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
LAUNCHD_DIR = HERE.parent / "launchd"
PLIST = LAUNCHD_DIR / "org.gbre.personal-mcp.host.plist"
TUNNEL_PLIST = LAUNCHD_DIR / "org.gbre.personal-mcp.tunnel.plist"
LAUNCHD_README = LAUNCHD_DIR / "README.md"
MAIN_README = HERE.parent / "README.md"
WRAPPER = HERE.parent / "personal-mcp-host.sh"

# All plists subject to the shared structural checks.
ALL_PLISTS = [PLIST, TUNNEL_PLIST]

for _p in ALL_PLISTS:
    if not _p.exists():
        print(f"FAIL: cannot locate launchd plist at {_p}", file=sys.stderr)
        sys.exit(2)


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def load(path: Path) -> dict:
    with open(path, "rb") as fp:
        return plistlib.load(fp)


# Default parsed plist (the bundled one) for the back-compat single-plist
# tests that still reference PARSED directly.
PARSED = load(PLIST)


def test_plistlib_parses() -> None:
    """plistlib accepted every template file."""
    for p in ALL_PLISTS:
        parsed = load(p)
        expect(
            isinstance(parsed, dict),
            f"{p.name}: plistlib should return a dict at the top level; "
            f"got {type(parsed)}",
        )


def test_plutil_lint_when_available() -> None:
    """If `plutil` is on PATH (macOS), use it as a second parser.
    plistlib is permissive about issues real launchd-side plutil
    rejects. On Linux CI plutil is absent — skip silently."""
    plutil = shutil.which("plutil")
    if not plutil:
        return
    for p in ALL_PLISTS:
        result = subprocess.run(
            [plutil, "-lint", str(p)],
            capture_output=True,
            text=True,
            timeout=5,
        )
        expect(
            result.returncode == 0,
            f"{p.name}: plutil -lint should accept the plist; "
            f"rc={result.returncode}\n"
            f"stdout: {result.stdout}\nstderr: {result.stderr}",
        )


def test_label_matches_filename() -> None:
    """launchd keys bootstrap / bootout / print / kickstart off the
    filename minus `.plist`. The plist's `Label` MUST match."""
    for p in ALL_PLISTS:
        parsed = load(p)
        expected_label = p.stem  # e.g. "org.gbre.personal-mcp.host"
        actual = parsed.get("Label")
        expect(
            actual == expected_label,
            f"{p.name}: Label should match plist filename stem; "
            f"expected {expected_label!r}, got {actual!r}",
        )


def test_label_uses_org_gbre_namespace() -> None:
    """Per the claude-watch naming convention, operator-owned launchd
    Labels live under the `org.gbre.*` namespace (NOT `com.anthropic.*`,
    which implies vendor ownership). Guards against a regression that
    renames the unit under the wrong namespace."""
    for p in ALL_PLISTS:
        label = load(p).get("Label", "")
        expect(
            isinstance(label, str) and label.startswith("org.gbre."),
            f"{p.name}: Label must use the org.gbre.* reverse-DNS namespace "
            f"(operator-owned); got {label!r}",
        )


def test_keep_alive_true() -> None:
    """KeepAlive=true → while the unit is running, launchd respawns
    on exit. Combined with RunAtLoad=false, that means `kickstart`
    starts it + tunnel-death respawns it, but `bootout` stops it for
    good."""
    for p in ALL_PLISTS:
        keep_alive = load(p).get("KeepAlive")
        expect(
            keep_alive is True,
            f"{p.name}: KeepAlive should be the boolean true; got {keep_alive!r}",
        )


def test_run_at_load_false() -> None:
    """RunAtLoad=false: this is the ON-DEMAND pattern. The unit
    registers via `bootstrap` but does NOT fire — operator runs
    `launchctl kickstart` to start a session. Without this, every
    login would auto-open the remote-access tunnel, which inverts
    the "only run as needed" intent."""
    for p in ALL_PLISTS:
        run_at_load = load(p).get("RunAtLoad")
        expect(
            run_at_load is False,
            f"{p.name}: RunAtLoad should be the boolean false (on-demand "
            f"bring-up); got {run_at_load!r}",
        )


def test_program_arguments_present() -> None:
    """ProgramArguments[0] is the binary launchd exec's. Non-empty
    list of strings."""
    for p in ALL_PLISTS:
        pa = load(p).get("ProgramArguments")
        expect(
            isinstance(pa, list) and len(pa) >= 1,
            f"{p.name}: ProgramArguments must be a non-empty list; got {pa!r}",
        )
        if isinstance(pa, list) and pa:
            expect(
                all(isinstance(x, str) for x in pa),
                f"{p.name}: ProgramArguments entries must all be strings; "
                f"got {pa!r}",
            )


def test_program_arguments_first_is_absolute() -> None:
    """ProgramArguments[0] must be an absolute path. launchd does NOT
    do PATH lookup or `~` expansion."""
    for p in ALL_PLISTS:
        pa = load(p).get("ProgramArguments")
        if not (isinstance(pa, list) and pa):
            continue
        first = pa[0]
        expect(
            first.startswith("/"),
            f"{p.name}: ProgramArguments[0] must be an absolute path; "
            f"got {first!r}",
        )


def test_program_arguments_first_points_at_wrapper() -> None:
    """ProgramArguments[0] must point at personal-mcp-host.sh. Guards
    against typo / refactor renaming the wrapper without updating the
    template."""
    for p in ALL_PLISTS:
        pa = load(p).get("ProgramArguments")
        if not (isinstance(pa, list) and pa):
            continue
        first = pa[0]
        expect(
            first.endswith("/personal-mcp-host.sh"),
            f"{p.name}: ProgramArguments[0] should end with "
            f"`/personal-mcp-host.sh`; got {first!r}",
        )


def test_environment_variables_dict() -> None:
    """EnvironmentVariables exists and is a dict."""
    for p in ALL_PLISTS:
        ev = load(p).get("EnvironmentVariables")
        expect(
            isinstance(ev, dict),
            f"{p.name}: EnvironmentVariables must be a dict; got {ev!r}",
        )


def test_environment_variables_has_path() -> None:
    """Launchd's default PATH does not include ~/.local/bin. The plist
    MUST declare a PATH entry that adds it (both templates carry it for
    parity / so `ssh` resolves)."""
    for p in ALL_PLISTS:
        ev = load(p).get("EnvironmentVariables") or {}
        path = ev.get("PATH")
        expect(
            isinstance(path, str) and path.strip() != "",
            f"{p.name}: EnvironmentVariables.PATH must be a non-empty string; "
            f"got {path!r}",
        )
        if isinstance(path, str):
            expect(
                ".local/bin" in path,
                f"{p.name}: EnvironmentVariables.PATH should include "
                f"`.local/bin`; got {path!r}",
            )


def test_working_directory_present() -> None:
    """WorkingDirectory is set so the wrapper finds its sibling .env
    via the default `${script_dir}/.env` resolution."""
    for p in ALL_PLISTS:
        wd = load(p).get("WorkingDirectory")
        expect(
            isinstance(wd, str) and wd.startswith("/"),
            f"{p.name}: WorkingDirectory must be an absolute path; got {wd!r}",
        )


def test_log_paths_present_and_absolute() -> None:
    """StandardOutPath / StandardErrorPath capture wrapper stdout /
    stderr. Both must be absolute paths."""
    for p in ALL_PLISTS:
        parsed = load(p)
        for key in ("StandardOutPath", "StandardErrorPath"):
            val = parsed.get(key)
            expect(
                isinstance(val, str) and val.startswith("/"),
                f"{p.name}: {key} must be an absolute path; got {val!r}",
            )


def test_throttle_interval_reasonable() -> None:
    """ThrottleInterval bounds the KeepAlive respawn cadence. Must
    be a positive integer."""
    for p in ALL_PLISTS:
        ti = load(p).get("ThrottleInterval")
        expect(
            isinstance(ti, int) and ti >= 1,
            f"{p.name}: ThrottleInterval must be a positive integer (>=1s); "
            f"got {ti!r}",
        )


def test_process_type_present() -> None:
    """ProcessType controls launchd's scheduling class. Interactive is
    the right default for a low-latency synchronous bridge."""
    for p in ALL_PLISTS:
        pt = load(p).get("ProcessType")
        expect(
            isinstance(pt, str) and pt != "",
            f"{p.name}: ProcessType must be a non-empty string; got {pt!r}",
        )


def test_no_disallowed_top_level_keys() -> None:
    """Catch obvious typos / accidental adds at the top level. New
    keys land here intentionally."""
    allowed = {
        "Label",
        "ProgramArguments",
        "EnvironmentVariables",
        "KeepAlive",
        "RunAtLoad",
        "ThrottleInterval",
        "WorkingDirectory",
        "StandardOutPath",
        "StandardErrorPath",
        "ProcessType",
    }
    for p in ALL_PLISTS:
        actual = set(load(p).keys())
        extras = actual - allowed
        expect(
            not extras,
            f"{p.name}: Unexpected top-level keys (likely typos / accidental "
            f"adds — update the allowed set if intentional): {sorted(extras)}",
        )


def test_tunnel_plist_passes_tunnel_only_flag() -> None:
    """The tunnel-only template MUST invoke the wrapper with
    `--tunnel-only` (otherwise it would launch mcp-host-bash too,
    defeating the always-on-MCP + on-demand-tunnel split). The bundled
    template MUST NOT pass it."""
    tunnel_pa = load(TUNNEL_PLIST).get("ProgramArguments") or []
    expect(
        "--tunnel-only" in tunnel_pa,
        f"{TUNNEL_PLIST.name}: ProgramArguments must include `--tunnel-only`; "
        f"got {tunnel_pa!r}",
    )
    host_pa = load(PLIST).get("ProgramArguments") or []
    expect(
        "--tunnel-only" not in host_pa,
        f"{PLIST.name}: bundled template must NOT pass `--tunnel-only` "
        f"(it owns both pieces); got {host_pa!r}",
    )


def test_tunnel_plist_distinct_log_paths() -> None:
    """The two units run side by side; their log paths must differ so
    they don't clobber each other."""
    host = load(PLIST)
    tunnel = load(TUNNEL_PLIST)
    for key in ("StandardOutPath", "StandardErrorPath"):
        expect(
            host.get(key) != tunnel.get(key),
            f"{key} must differ between the bundled and tunnel-only units; "
            f"both are {host.get(key)!r}",
        )


def test_wrapper_exists_and_executable() -> None:
    """The wrapper script must exist alongside the plist subdirectory
    and be executable. launchd won't chmod +x ProgramArguments at
    bootstrap time."""
    import os

    expect(
        WRAPPER.exists(),
        f"personal-mcp-host.sh must exist; looked at {WRAPPER}",
    )
    if WRAPPER.exists():
        expect(
            os.access(str(WRAPPER), os.X_OK),
            f"personal-mcp-host.sh must be executable (chmod +x); "
            f"got mode {oct(WRAPPER.stat().st_mode)}",
        )


def test_readme_exists() -> None:
    expect(
        LAUNCHD_README.exists(),
        f"launchd/README.md must exist next to the plist; looked at {LAUNCHD_README}",
    )


def test_readme_references_label() -> None:
    """The README walks operators through copy/paste commands keyed
    off the Label — drift breaks the on-ramp."""
    if not LAUNCHD_README.exists():
        return
    body = LAUNCHD_README.read_text()
    label = PARSED.get("Label", "")
    expect(
        label and label in body,
        f"launchd/README.md must reference the Label {label!r}",
    )


def test_readme_documents_required_steps() -> None:
    """Spot-check the README hits the major operator steps."""
    if not LAUNCHD_README.exists():
        return
    body = LAUNCHD_README.read_text()
    for needle in (
        "~/Library/LaunchAgents",  # step 1: copy target
        "/PATH/TO/REPO",  # step 2: search/replace placeholder
        "/PATH/TO/HOME",  # step 2: search/replace placeholder
        "launchctl bootstrap",  # step 3: bootstrap verb
        "launchctl kickstart",  # step 4: per-session start
        "launchctl bootout",  # step 5: per-session stop
        "~/Library/Logs",  # step 7: log paths
        "PERSONAL_MCP_DISABLED",  # soft kill switch path
    ):
        expect(
            needle in body,
            f"launchd/README.md must mention {needle!r} (operator "
            f"walkthrough relies on it)",
        )


def test_readme_documents_on_demand_pattern() -> None:
    """The README must call out that this is the ON-DEMAND pattern,
    not start-at-login. Operators landing here without context should
    immediately see the difference vs the compose-stack LaunchAgent."""
    if not LAUNCHD_README.exists():
        return
    body = LAUNCHD_README.read_text()
    expect(
        "on-demand" in body.lower() or "on demand" in body.lower(),
        "launchd/README.md must call out the on-demand pattern (vs "
        "the persistent compose-stack LaunchAgent)",
    )
    expect(
        "RunAtLoad" in body or "RunAtLoad=false" in body,
        "launchd/README.md should mention RunAtLoad to explain why "
        "the unit registers without firing",
    )


def test_main_readme_links_to_launchd() -> None:
    """The directory's main README must link to the launchd
    subfolder."""
    if not MAIN_README.exists():
        failures.append(
            f"examples/personal-mac-mcp-host/README.md not found at {MAIN_README}"
        )
        return
    body = MAIN_README.read_text()
    expect(
        "launchd/README.md" in body,
        "examples/personal-mac-mcp-host/README.md should link to "
        "launchd/README.md so operators find the persistent-launch path",
    )


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

tests = [
    test_plistlib_parses,
    test_plutil_lint_when_available,
    test_label_matches_filename,
    test_label_uses_org_gbre_namespace,
    test_keep_alive_true,
    test_run_at_load_false,
    test_program_arguments_present,
    test_program_arguments_first_is_absolute,
    test_program_arguments_first_points_at_wrapper,
    test_environment_variables_dict,
    test_environment_variables_has_path,
    test_working_directory_present,
    test_log_paths_present_and_absolute,
    test_throttle_interval_reasonable,
    test_process_type_present,
    test_no_disallowed_top_level_keys,
    test_wrapper_exists_and_executable,
    test_readme_exists,
    test_readme_references_label,
    test_readme_documents_required_steps,
    test_readme_documents_on_demand_pattern,
    test_main_readme_links_to_launchd,
]

for t in tests:
    pre = len(failures)
    try:
        t()
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
    if len(failures) == pre:
        print(f"PASS  {t.__name__}")
    else:
        print(f"FAIL  {t.__name__}")

if failures:
    print()
    print(f"FAILED: {len(failures)} failure(s).")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)
else:
    print()
    print(f"All {len(tests)} tests passed.")
    sys.exit(0)
