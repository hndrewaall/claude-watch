#!/usr/bin/env python3
"""Tests for examples/personal-mac-mcp-host/personal-mcp-host.sh —
the wrapper that spawns mcp-host-bash + the reverse SSH tunnel.

Exercises the script's argv construction WITHOUT actually invoking
mcp-host-bash / ssh by using the `--print-cmd` debug hook (the script
builds the planned argv and prints it block-formatted, then exits 0).
The hook also skips the binary-availability + listener-probe paths so
the test runs on any host with Python 3 + bash.

Coverage:
  - Required-env enforcement: missing .env file → exit 2.
  - Required-env enforcement: missing keys in .env → bash exits via
    `: "${KEY:?...}"` (non-zero).
  - Default invocation: planned argv has both an `MCP_HOST_BASH_BIN:`
    block (with --port $MCP_LOCAL_PORT) and an `SSH:` block.
  - SSH argv contains the expected hardening options
    (ExitOnForwardFailure=yes, BatchMode=yes, etc.).
  - SSH argv reflects the values from .env (REMOTE_USER@REMOTE_HOST,
    REMOTE_PORT:127.0.0.1:MCP_LOCAL_PORT, -i SSH_KEY_PATH).
  - PERSONAL_MCP_SSH_EXTRA gets appended to the ssh argv.
  - Tunnel-only mode (--tunnel-only / PERSONAL_MCP_TUNNEL_ONLY=1):
    --print-cmd emits ONLY the SSH: block, NOT the MCP_HOST_BASH_BIN:
    launch block, and the ssh argv is otherwise unchanged.
  - Bad flag exits 2.
  - --help exits 0 with the usage block + documents --enable.
  - PERSONAL_MCP_DISABLED=1 (without --print-cmd) exits 0 immediately.
  - PERSONAL_MCP_ENV_FILE override is honored.
  - Default status gate, RED: nothing listening on MCP_LOCAL_PORT →
    error + ready-to-copy --enable rerun command + exit 3.
  - Default status gate, GREEN: a listener on MCP_LOCAL_PORT → detects
    the service is up, proceeds to start the reverse tunnel (fake ssh
    stand-in), then SIGTERM actively tears the tunnel down.
  - --enable --print-cmd emits the MCP_HOST_BASH_BIN: launch block.

Run:  ./personal-mcp-host.test
"""

from __future__ import annotations

import os
import socket
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "personal-mcp-host.sh"
ENV_EXAMPLE = HERE.parent / ".env.example"

if not SCRIPT.exists():
    print(f"FAIL: cannot locate personal-mcp-host.sh at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------


def write_env(
    path: Path,
    *,
    remote_host: str = "remote.example.com",
    remote_user: str = "operator",
    remote_port: str = "18766",
    mcp_local_port: str = "8766",
    ssh_key_path: str | None = None,
    extra_lines: list[str] | None = None,
) -> None:
    """Write a valid .env file for the wrapper to source. If ssh_key_path
    is None, default to the script-test fake key path created by the
    caller (whatever they pass in extra_lines must match)."""
    if ssh_key_path is None:
        ssh_key_path = str(path.parent / "fake-ssh-key")
    lines = [
        f'REMOTE_HOST="{remote_host}"',
        f'REMOTE_USER="{remote_user}"',
        f'REMOTE_PORT="{remote_port}"',
        f'MCP_LOCAL_PORT="{mcp_local_port}"',
        f'SSH_KEY_PATH="{ssh_key_path}"',
    ]
    if extra_lines:
        lines.extend(extra_lines)
    path.write_text("\n".join(lines) + "\n")


def run_script(
    args: list[str] | None = None,
    env: dict | None = None,
    env_file: Path | None = None,
    expect_rc: int | None = 0,
) -> tuple[list[str], str, str, int]:
    """Run personal-mcp-host.sh and return (stdout_lines, stdout, stderr, rc).

    If env_file is given, PERSONAL_MCP_ENV_FILE points there so the
    wrapper sources our test fixture instead of looking next to the
    script (which would pick up the operator's real .env on
    interactive hosts)."""
    if args is None:
        args = []
    base_env = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "HOME": os.environ.get("HOME", "/tmp"),
    }
    if env_file is not None:
        base_env["PERSONAL_MCP_ENV_FILE"] = str(env_file)
    if env:
        base_env.update(env)
    result = subprocess.run(
        [str(SCRIPT), *args],
        env=base_env,
        capture_output=True,
        text=True,
        timeout=10,
    )
    if expect_rc is not None and result.returncode != expect_rc:
        raise AssertionError(
            f"personal-mcp-host.sh exited {result.returncode}, expected {expect_rc}\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )
    return result.stdout.splitlines(), result.stdout, result.stderr, result.returncode


def parse_blocks(lines: list[str]) -> dict[str, list[str]]:
    """Parse `--print-cmd` output: blocks delimited by `KEY:` header
    lines and blank-line separators."""
    blocks: dict[str, list[str]] = {}
    current_key: str | None = None
    for line in lines:
        if line.endswith(":") and not line.startswith(("-", "/")):
            current_key = line[:-1]
            blocks[current_key] = []
        elif line == "":
            current_key = None
        elif current_key is not None:
            blocks[current_key].append(line)
    return blocks


# ---------------------------------------------------------------------------
# Test cases
# ---------------------------------------------------------------------------

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def test_help_exits_zero() -> None:
    """--help prints usage and exits 0."""
    lines, _, _, rc = run_script(["--help"])
    expect(rc == 0, f"--help: rc should be 0, got {rc}")
    expect(
        any("personal-mcp-host" in ln for ln in lines),
        f"--help: stdout should mention the script name, got first 5 lines: {lines[:5]}",
    )


def test_bad_flag_exits_two() -> None:
    """--bogus → exit 2."""
    _, _, stderr, rc = run_script(["--bogus"], expect_rc=2)
    expect(
        "unknown argument" in stderr,
        f"bad flag: stderr should mention 'unknown argument', got {stderr!r}",
    )


def test_missing_env_file_exits_two() -> None:
    """No .env at the configured path → exit 2 with operator
    walkthrough in stderr."""
    with tempfile.TemporaryDirectory() as td:
        nonexistent = Path(td) / "does-not-exist.env"
        _, _, stderr, rc = run_script(
            ["--print-cmd"],
            env_file=nonexistent,
            expect_rc=2,
        )
        expect(
            "missing .env" in stderr,
            f"missing env: stderr should mention 'missing .env', got {stderr!r}",
        )
        expect(
            ".env.example" in stderr,
            f"missing env: stderr should point operator at .env.example, "
            f"got {stderr!r}",
        )


def test_missing_required_key_in_env_fails() -> None:
    """An .env that omits a required key triggers bash's `${KEY:?...}`
    parameter expansion error → non-zero exit, message names the key."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / "incomplete.env"
        # Deliberately omit REMOTE_HOST.
        env_path.write_text(
            'REMOTE_USER="operator"\n'
            'REMOTE_PORT="18766"\n'
            'MCP_LOCAL_PORT="8766"\n'
            'SSH_KEY_PATH="/tmp/fake-key"\n'
        )
        _, _, stderr, rc = run_script(
            ["--print-cmd"],
            env_file=env_path,
            expect_rc=None,
        )
        expect(
            rc != 0,
            f"missing required key: rc should be non-zero, got {rc}",
        )
        expect(
            "REMOTE_HOST" in stderr,
            f"missing required key: stderr should mention REMOTE_HOST, "
            f"got {stderr!r}",
        )


def test_print_cmd_emits_two_blocks() -> None:
    """--print-cmd output has both MCP_HOST_BASH_BIN: and SSH: blocks."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        blocks = parse_blocks(lines)
        expect(
            "MCP_HOST_BASH_BIN" in blocks,
            f"--print-cmd: should emit MCP_HOST_BASH_BIN: block; got blocks {sorted(blocks)}",
        )
        expect(
            "SSH" in blocks,
            f"--print-cmd: should emit SSH: block; got blocks {sorted(blocks)}",
        )


def test_mcp_host_bash_bin_block_contains_port() -> None:
    """The MCP_HOST_BASH_BIN: block has the launcher path + --port
    MCP_LOCAL_PORT."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path, mcp_local_port="9876")
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        blocks = parse_blocks(lines)
        mcp = blocks.get("MCP_HOST_BASH_BIN", [])
        expect(
            len(mcp) >= 3,
            f"MCP_HOST_BASH_BIN block should have 3 entries "
            f"(path, --port, value); got {mcp}",
        )
        if len(mcp) >= 3:
            expect(
                mcp[0].endswith("/mcp-host-bash"),
                f"MCP_HOST_BASH_BIN[0] should end in /mcp-host-bash; got {mcp[0]!r}",
            )
            expect(
                mcp[1] == "--port",
                f"MCP_HOST_BASH_BIN[1] should be '--port'; got {mcp[1]!r}",
            )
            expect(
                mcp[2] == "9876",
                f"MCP_HOST_BASH_BIN[2] should be the MCP_LOCAL_PORT (9876); got {mcp[2]!r}",
            )


def test_ssh_block_first_token_is_ssh() -> None:
    """The SSH: block argv starts with `ssh`."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        blocks = parse_blocks(lines)
        ssh = blocks.get("SSH", [])
        expect(
            ssh and ssh[0] == "ssh",
            f"SSH argv should start with 'ssh'; got {ssh[:3] if ssh else ssh}",
        )


def test_ssh_block_contains_minus_N() -> None:
    """ssh -N: no remote command, just hold the tunnel."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        expect(
            "-N" in ssh,
            f"SSH argv should include `-N` (no remote command); got {ssh}",
        )


def test_ssh_block_reverse_forward_shape() -> None:
    """ssh -R REMOTE_PORT:127.0.0.1:MCP_LOCAL_PORT."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path, remote_port="20001", mcp_local_port="20002")
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        expect(
            "-R" in ssh,
            f"SSH argv should include `-R` (reverse forward); got {ssh}",
        )
        if "-R" in ssh:
            r_idx = ssh.index("-R")
            expect(
                r_idx + 1 < len(ssh) and ssh[r_idx + 1] == "20001:127.0.0.1:20002",
                f"SSH -R value should be REMOTE_PORT:127.0.0.1:MCP_LOCAL_PORT "
                f"(20001:127.0.0.1:20002); got {ssh[r_idx + 1] if r_idx + 1 < len(ssh) else None!r}",
            )


def test_ssh_block_has_hardening_options() -> None:
    """ssh argv MUST include the hardening options the wrapper sets:
    ExitOnForwardFailure=yes, ServerAliveInterval=30,
    ServerAliveCountMax=3, BatchMode=yes,
    StrictHostKeyChecking=accept-new. Guards against future edits
    accidentally relaxing the floor (e.g. someone dropping
    ExitOnForwardFailure and turning the tunnel into a silent no-op
    when the remote bind fails)."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        for option in (
            "ExitOnForwardFailure=yes",
            "ServerAliveInterval=30",
            "ServerAliveCountMax=3",
            "BatchMode=yes",
            "StrictHostKeyChecking=accept-new",
        ):
            expect(
                option in ssh,
                f"SSH argv should include {option!r} (hardening default); "
                f"got {ssh}",
            )


def test_ssh_block_has_key_path() -> None:
    """ssh -i SSH_KEY_PATH."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        key_path = Path(td) / "tunnel-key"
        write_env(env_path, ssh_key_path=str(key_path))
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        expect(
            "-i" in ssh,
            f"SSH argv should include `-i`; got {ssh}",
        )
        if "-i" in ssh:
            i_idx = ssh.index("-i")
            expect(
                i_idx + 1 < len(ssh) and ssh[i_idx + 1] == str(key_path),
                f"SSH -i value should be SSH_KEY_PATH ({key_path}); "
                f"got {ssh[i_idx + 1] if i_idx + 1 < len(ssh) else None!r}",
            )


def test_ssh_block_ends_with_remote_target() -> None:
    """Last ssh argv element is REMOTE_USER@REMOTE_HOST."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path, remote_user="bob", remote_host="bastion.example.com")
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        expect(
            ssh and ssh[-1] == "bob@bastion.example.com",
            f"SSH argv last token should be REMOTE_USER@REMOTE_HOST "
            f"(bob@bastion.example.com); got {ssh[-1] if ssh else None!r}",
        )


def test_personal_mcp_ssh_extra_appended() -> None:
    """PERSONAL_MCP_SSH_EXTRA tokens land in the ssh argv before the
    REMOTE_USER@REMOTE_HOST tail. Lets operators set ProxyJump /
    custom ServerAliveInterval / etc. without editing the wrapper."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(
            env_path,
            extra_lines=[
                'PERSONAL_MCP_SSH_EXTRA="-o ProxyJump=bastion.example.com -o ServerAliveInterval=15"',
            ],
        )
        lines, _, _, _ = run_script(["--print-cmd"], env_file=env_path)
        ssh = parse_blocks(lines).get("SSH", [])
        # Both tokens should appear, in order, before the remote target.
        expect(
            "ProxyJump=bastion.example.com" in ssh,
            f"PERSONAL_MCP_SSH_EXTRA: ProxyJump value missing from ssh argv; got {ssh}",
        )
        # ServerAliveInterval=15 (the override) should also be there,
        # even though the default block already sets ServerAliveInterval=30.
        # ssh's CLI semantics: first value wins, so the operator's
        # override would need to come BEFORE the default to take effect.
        # We don't reorder here — that's a documented operator
        # responsibility. Just assert the token landed in the argv.
        expect(
            "ServerAliveInterval=15" in ssh,
            f"PERSONAL_MCP_SSH_EXTRA: ServerAliveInterval=15 missing from ssh argv; got {ssh}",
        )
        # The remote-target tail must still be last.
        expect(
            ssh[-1].endswith("@remote.example.com"),
            f"PERSONAL_MCP_SSH_EXTRA: remote target should still be last; got {ssh[-3:]}",
        )


def test_tunnel_only_flag_omits_mcp_block() -> None:
    """--tunnel-only --print-cmd emits ONLY the SSH: block — no
    MCP_HOST_BASH_BIN: block — because the wrapper does not launch
    mcp-host-bash in tunnel-only mode."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(
            ["--tunnel-only", "--print-cmd"], env_file=env_path
        )
        blocks = parse_blocks(lines)
        expect(
            "SSH" in blocks,
            f"--tunnel-only --print-cmd: should still emit SSH: block; "
            f"got blocks {sorted(blocks)}",
        )
        expect(
            "MCP_HOST_BASH_BIN" not in blocks,
            f"--tunnel-only --print-cmd: MUST NOT emit MCP_HOST_BASH_BIN: "
            f"block (wrapper does not launch mcp-host-bash in this mode); "
            f"got blocks {sorted(blocks)}",
        )


def test_tunnel_only_env_var_omits_mcp_block() -> None:
    """PERSONAL_MCP_TUNNEL_ONLY=1 is equivalent to --tunnel-only: the
    --print-cmd output has no MCP_HOST_BASH_BIN: block."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(
            ["--print-cmd"],
            env={"PERSONAL_MCP_TUNNEL_ONLY": "1"},
            env_file=env_path,
        )
        blocks = parse_blocks(lines)
        expect(
            "MCP_HOST_BASH_BIN" not in blocks,
            f"PERSONAL_MCP_TUNNEL_ONLY=1: MUST NOT emit MCP_HOST_BASH_BIN: "
            f"block; got blocks {sorted(blocks)}",
        )
        expect(
            "SSH" in blocks,
            f"PERSONAL_MCP_TUNNEL_ONLY=1: should still emit SSH: block; "
            f"got blocks {sorted(blocks)}",
        )


def test_tunnel_only_ssh_argv_intact() -> None:
    """Tunnel-only mode does NOT change the ssh argv — same hardening
    options, reverse-forward shape, and remote target as bundled
    mode."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(
            env_path,
            remote_user="bob",
            remote_host="bastion.example.com",
            remote_port="20001",
            mcp_local_port="20002",
        )
        lines, _, _, _ = run_script(
            ["--tunnel-only", "--print-cmd"], env_file=env_path
        )
        ssh = parse_blocks(lines).get("SSH", [])
        expect(ssh and ssh[0] == "ssh", f"ssh argv should start with ssh; got {ssh[:3]}")
        expect("-N" in ssh, f"ssh argv should include -N; got {ssh}")
        expect(
            "20001:127.0.0.1:20002" in ssh,
            f"ssh argv should carry the reverse-forward spec; got {ssh}",
        )
        for option in (
            "ExitOnForwardFailure=yes",
            "BatchMode=yes",
            "StrictHostKeyChecking=accept-new",
        ):
            expect(option in ssh, f"ssh argv should include {option!r}; got {ssh}")
        expect(
            ssh and ssh[-1] == "bob@bastion.example.com",
            f"ssh argv last token should be the remote target; got {ssh[-1:] }",
        )


def test_disabled_kill_switch_exits_zero() -> None:
    """PERSONAL_MCP_DISABLED=1 (no --print-cmd) → exit 0 immediately
    with stderr message."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        # No --print-cmd here — exercise the kill-switch path.
        _, _, stderr, rc = run_script(
            [],
            env={"PERSONAL_MCP_DISABLED": "1"},
            env_file=env_path,
            expect_rc=0,
        )
        expect(
            "PERSONAL_MCP_DISABLED" in stderr,
            f"kill switch: stderr should mention PERSONAL_MCP_DISABLED; got {stderr!r}",
        )


def test_env_example_exists_and_has_required_keys() -> None:
    """The committed .env.example template must exist + name every
    required key so operators can `cp .env.example .env` and fill
    in. Guards against a refactor dropping a key from the template."""
    expect(
        ENV_EXAMPLE.exists(),
        f".env.example must exist at {ENV_EXAMPLE}",
    )
    if ENV_EXAMPLE.exists():
        body = ENV_EXAMPLE.read_text()
        for key in (
            "REMOTE_HOST",
            "REMOTE_USER",
            "REMOTE_PORT",
            "MCP_LOCAL_PORT",
            "SSH_KEY_PATH",
        ):
            expect(
                key in body,
                f".env.example must mention required key {key!r}",
            )


def test_gitignore_excludes_env() -> None:
    """The directory's .gitignore must exclude the operator's real
    `.env` so a secret-bearing copy doesn't get committed by accident."""
    gitignore = HERE.parent / ".gitignore"
    expect(
        gitignore.exists(),
        f".gitignore must exist at {gitignore}",
    )
    if gitignore.exists():
        body = gitignore.read_text()
        # Either bare `.env` or a glob covering it.
        expect(
            any(
                line.strip() in (".env", "*.env", "/.env")
                for line in body.splitlines()
            ),
            f".gitignore must exclude `.env`; got:\n{body}",
        )


def _free_port() -> int:
    """Grab a port the OS hands us, then release it so the script (or our
    stand-in listener) can bind it."""
    s = socket.socket()
    s.bind(("127.0.0.1", 0))
    port = s.getsockname()[1]
    s.close()
    return port


def _make_fake_ssh(dirpath: Path) -> Path:
    """Write a fake `ssh` that just sleeps, so the GREEN path can spawn a
    'tunnel' without a real remote. Returns the bin dir to prepend to
    PATH."""
    bindir = dirpath / "fakebin"
    bindir.mkdir(exist_ok=True)
    ssh = bindir / "ssh"
    ssh.write_text("#!/usr/bin/env bash\nexec sleep 600\n")
    ssh.chmod(0o755)
    return bindir


def test_enable_flag_in_help() -> None:
    """--help documents the new --enable flag + the default status-gate
    behavior."""
    lines, _, _, rc = run_script(["--help"])
    expect(rc == 0, f"--help: rc should be 0, got {rc}")
    body = "\n".join(lines)
    expect("--enable" in body, "--help should document the --enable flag")
    expect(
        "status-gate" in body or "status gate" in body.lower(),
        "--help should describe the default status-gate behavior",
    )


def test_default_red_path_service_down_exits_three() -> None:
    """Default mode with NOTHING listening on MCP_LOCAL_PORT → RED:
    prints the service-not-running error, prints a ready-to-copy
    --enable rerun command, and exits non-zero (3)."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        key_path = Path(td) / "fake-key"
        key_path.write_text("")
        port = _free_port()
        write_env(env_path, mcp_local_port=str(port), ssh_key_path=str(key_path))
        # No flags → default mode. Nothing is bound on `port`.
        _, stdout, stderr, rc = run_script([], env_file=env_path, expect_rc=None)
        out = stdout + stderr
        expect(rc == 3, f"RED path: rc should be 3, got {rc}\n{out}")
        expect(
            "NOT running" in out or "not running" in out,
            f"RED path: should say the host MCP service is not running; got {out!r}",
        )
        expect(
            "--enable" in out,
            f"RED path: should print a --enable rerun command; got {out!r}",
        )
        expect(
            str(SCRIPT) in out or SCRIPT.name in out,
            f"RED path: rerun command should reference this script; got {out!r}",
        )


def test_default_green_path_detects_service_up() -> None:
    """Default mode with a listener bound on MCP_LOCAL_PORT → GREEN:
    detects the service is up and proceeds toward tunnel setup (spawns
    the fake ssh stand-in). We assert it got PAST the status gate by
    looking for the 'service is UP' line, then SIGTERM it and confirm
    the tunnel teardown runs."""
    with tempfile.TemporaryDirectory() as td:
        tdp = Path(td)
        env_path = tdp / ".env"
        key_path = tdp / "fake-key"
        key_path.write_text("")
        port = _free_port()
        write_env(env_path, mcp_local_port=str(port), ssh_key_path=str(key_path))
        bindir = _make_fake_ssh(tdp)

        listener = socket.socket()
        listener.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        listener.bind(("127.0.0.1", port))
        listener.listen(1)
        proc = None
        try:
            env = {
                "PATH": str(bindir) + ":" + os.environ.get("PATH", "/usr/bin:/bin"),
                "HOME": os.environ.get("HOME", "/tmp"),
                "PERSONAL_MCP_ENV_FILE": str(env_path),
                "MCP_HOST_BASH_LOG": str(tdp / "mcp.log"),
            }
            proc = subprocess.Popen(
                [str(SCRIPT)],
                env=env,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
            )
            # Wait for the gate + tunnel-start lines to appear.
            deadline = time.time() + 8
            seen = ""
            got_gate = False
            while time.time() < deadline:
                if proc.poll() is not None:
                    seen += proc.stdout.read()
                    break
                # Non-blocking-ish drain via short reads.
                line = proc.stdout.readline()
                if line:
                    seen += line
                    if "service is UP" in line:
                        got_gate = True
                    if "reverse SSH tunnel started" in line:
                        break
            expect(
                got_gate,
                f"GREEN path: should report service is UP and pass the gate; "
                f"got:\n{seen}",
            )
            expect(
                "reverse SSH tunnel started" in seen,
                f"GREEN path: should proceed to start the reverse tunnel; "
                f"got:\n{seen}",
            )
            # Now tear it down via SIGTERM and confirm the teardown path runs.
            proc.terminate()
            try:
                rest = proc.communicate(timeout=8)[0]
            except subprocess.TimeoutExpired:
                proc.kill()
                rest = proc.communicate()[0]
            combined = seen + (rest or "")
            expect(
                "tearing down reverse SSH tunnel" in combined,
                f"GREEN path: SIGTERM should trigger active tunnel teardown; "
                f"got:\n{combined}",
            )
            expect(
                "reverse SSH tunnel torn down" in combined,
                f"GREEN path: teardown should confirm the tunnel is gone; "
                f"got:\n{combined}",
            )
        finally:
            listener.close()
            if proc is not None and proc.poll() is None:
                proc.kill()
                proc.wait(timeout=5)
            # Reap any orphaned fake-ssh sleep children.
            subprocess.run(["pkill", "-f", "sleep 600"], check=False)


def test_enable_print_cmd_emits_mcp_block() -> None:
    """--enable --print-cmd emits the MCP_HOST_BASH_BIN: launch block
    (the --enable path brings the server up), plus the SSH: block."""
    with tempfile.TemporaryDirectory() as td:
        env_path = Path(td) / ".env"
        write_env(env_path)
        lines, _, _, _ = run_script(
            ["--enable", "--print-cmd"], env_file=env_path
        )
        blocks = parse_blocks(lines)
        expect(
            "MCP_HOST_BASH_BIN" in blocks,
            f"--enable --print-cmd: should emit MCP_HOST_BASH_BIN: block; "
            f"got {sorted(blocks)}",
        )
        expect(
            "SSH" in blocks,
            f"--enable --print-cmd: should emit SSH: block; got {sorted(blocks)}",
        )


def _pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def _pgid(pid: int) -> int | None:
    try:
        return os.getpgid(pid)
    except OSError:
        return None


def _make_fake_mcp_host(dirpath: Path, port: int, pidfile: Path) -> Path:
    """Write a fake `mcp-host-bash` stand-in that binds `port`, records
    its own pid to `pidfile`, and sleeps forever. Stands in for the real
    launcher so the --enable path runs on a host without mcp-proxy /
    cli-mcp-server installed. Returns its absolute path."""
    bindir = dirpath / "fakebin"
    bindir.mkdir(exist_ok=True)
    host = bindir / "mcp-host-bash"
    host.write_text(
        "#!/usr/bin/env python3\n"
        "import socket, time, os, sys\n"
        "s = socket.socket()\n"
        "s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)\n"
        f"s.bind(('127.0.0.1', {port}))\n"
        "s.listen(5)\n"
        f"open({str(pidfile)!r}, 'w').write(str(os.getpid()))\n"
        "sys.stderr.write('fake-mcp-host-bash: listening\\n')\n"
        "sys.stderr.flush()\n"
        "while True:\n"
        "    time.sleep(1)\n"
    )
    host.chmod(0o755)
    return host


def test_enable_ctrlc_leaves_host_service_running() -> None:
    """REGRESSION (the bug this fix targets): in --enable mode, a real
    Ctrl-C (SIGINT delivered to the wrapper's foreground process group
    via a PTY) must tear down ONLY the reverse SSH tunnel + the log
    tail, and LEAVE the host MCP service running. The service must be
    started detached (its own session / process group) so the
    terminal-delivered SIGINT never reaches it and the wrapper's exit
    doesn't take it down.

    Asserts:
      - before: the host service pid is alive AND in a DIFFERENT process
        group than the wrapper (proof it was detached).
      - after Ctrl-C: host service STILL alive; ssh tunnel pid GONE;
        tail pid GONE; wrapper exited.
    """
    import pty
    import select

    with tempfile.TemporaryDirectory() as td:
        tdp = Path(td)
        port = _free_port()
        key_path = tdp / "fake-key"
        key_path.write_text("")
        env_path = tdp / ".env"
        write_env(env_path, mcp_local_port=str(port), ssh_key_path=str(key_path))

        host_pidfile = tdp / "host.pid"
        fake_host = _make_fake_mcp_host(tdp, port, host_pidfile)

        # Fake ssh stand-in that records its pid then sleeps.
        bindir = fake_host.parent
        ssh = bindir / "ssh"
        ssh_pidfile = tdp / "ssh.pid"
        ssh.write_text(
            "#!/usr/bin/env bash\n"
            f'echo $$ > "{ssh_pidfile}"\n'
            "exec sleep 600\n"
        )
        ssh.chmod(0o755)

        env = {
            "PATH": str(bindir) + ":" + os.environ.get("PATH", "/usr/bin:/bin"),
            "HOME": os.environ.get("HOME", "/tmp"),
            "PERSONAL_MCP_ENV_FILE": str(env_path),
            "MCP_HOST_BASH_LOG": str(tdp / "mcp.log"),
            "MCP_HOST_BASH_BIN": str(fake_host),
        }

        master, slave = pty.openpty()
        proc = subprocess.Popen(
            [str(SCRIPT), "--enable"],
            env=env,
            stdin=slave,
            stdout=slave,
            stderr=slave,
            preexec_fn=os.setsid,
            close_fds=True,
        )
        os.close(slave)

        buf = b""
        host_pid = None
        ssh_pid = None
        try:
            # Wait until the tunnel + tail are up.
            deadline = time.time() + 15
            while time.time() < deadline:
                r, _, _ = select.select([master], [], [], 0.5)
                if r:
                    try:
                        chunk = os.read(master, 4096)
                    except OSError:
                        break
                    if not chunk:
                        break
                    buf += chunk
                if b"reverse SSH tunnel started" in buf and b"following" in buf:
                    break
            time.sleep(1.0)  # let pids settle

            expect(
                host_pidfile.exists(),
                f"--enable: fake host service should have recorded its pid; "
                f"output:\n{buf.decode(errors='replace')}",
            )
            expect(
                ssh_pidfile.exists(),
                f"--enable: fake ssh should have recorded its pid; "
                f"output:\n{buf.decode(errors='replace')}",
            )
            if host_pidfile.exists():
                host_pid = int(host_pidfile.read_text().strip())
            if ssh_pidfile.exists():
                ssh_pid = int(ssh_pidfile.read_text().strip())

            # BEFORE: service alive + detached into its own process group.
            if host_pid is not None:
                expect(
                    _pid_alive(host_pid),
                    "--enable: host service should be alive before Ctrl-C",
                )
                expect(
                    _pgid(host_pid) != _pgid(proc.pid),
                    f"--enable: host service (pid {host_pid}, pgid "
                    f"{_pgid(host_pid)}) MUST be in a DIFFERENT process group "
                    f"than the wrapper (pid {proc.pid}, pgid {_pgid(proc.pid)}) "
                    f"— it must be started detached so a terminal Ctrl-C "
                    f"doesn't reach it",
                )
            if ssh_pid is not None:
                expect(_pid_alive(ssh_pid), "--enable: ssh tunnel should be alive before Ctrl-C")

            # Send a REAL Ctrl-C: the ^C byte makes the PTY deliver SIGINT
            # to the foreground process group, exactly like an operator
            # pressing Ctrl-C in their terminal.
            os.write(master, b"\x03")

            try:
                proc.wait(timeout=12)
            except subprocess.TimeoutExpired:
                os.killpg(os.getpgid(proc.pid), 9)
                proc.wait(timeout=5)
                failures.append("--enable: wrapper did not exit after Ctrl-C")

            # Drain remaining output.
            time.sleep(0.6)
            while True:
                r, _, _ = select.select([master], [], [], 0.4)
                if not r:
                    break
                try:
                    chunk = os.read(master, 4096)
                except OSError:
                    break
                if not chunk:
                    break
                buf += chunk

            out = buf.decode(errors="replace")

            # AFTER: service survives; tunnel + tail gone.
            if host_pid is not None:
                expect(
                    _pid_alive(host_pid),
                    f"--enable: host MCP service (pid {host_pid}) MUST STILL "
                    f"BE RUNNING after Ctrl-C — cleanup tears down only the "
                    f"tunnel + tail, never the service.\nOutput:\n{out}",
                )
            if ssh_pid is not None:
                expect(
                    not _pid_alive(ssh_pid),
                    f"--enable: ssh tunnel (pid {ssh_pid}) should be torn down "
                    f"by Ctrl-C.\nOutput:\n{out}",
                )
            expect(
                "reverse SSH tunnel torn down" in out,
                f"--enable: teardown should confirm the tunnel is gone; got:\n{out}",
            )
            expect(
                "leaving host MCP service running" in out,
                f"--enable: cleanup should announce it left the service "
                f"running; got:\n{out}",
            )
        finally:
            # Reap the surviving service + any strays we spawned.
            for pid in (host_pid, ssh_pid):
                if pid is not None and _pid_alive(pid):
                    try:
                        os.kill(pid, 9)
                    except OSError:
                        pass
            if proc.poll() is None:
                try:
                    os.killpg(os.getpgid(proc.pid), 9)
                except OSError:
                    pass
                proc.wait(timeout=5)
            try:
                os.close(master)
            except OSError:
                pass
            subprocess.run(["pkill", "-f", "sleep 600"], check=False)


def test_script_uses_ssh_minus_capital_R_not_lowercase() -> None:
    """Regression guard: confirm the wrapper uses `-R` (reverse
    forward), not `-L` (local forward). A typo here would send the
    tunnel the wrong direction — local Mac dials remote, instead of
    remote-side loopback reaching local Mac."""
    body = SCRIPT.read_text()
    expect(
        "-R " in body or '"-R"' in body,
        "wrapper script should use `ssh -R` (reverse forward) — "
        "remote-side loopback reaches local Mac. Found neither '-R ' "
        "nor '\"-R\"' in the wrapper.",
    )
    expect(
        "ssh -L" not in body and '"-L"' not in body,
        "wrapper script should NOT use `ssh -L` (would forward Mac "
        "loopback to remote, opposite of the intended direction)",
    )


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

tests = [
    test_help_exits_zero,
    test_bad_flag_exits_two,
    test_missing_env_file_exits_two,
    test_missing_required_key_in_env_fails,
    test_print_cmd_emits_two_blocks,
    test_mcp_host_bash_bin_block_contains_port,
    test_ssh_block_first_token_is_ssh,
    test_ssh_block_contains_minus_N,
    test_ssh_block_reverse_forward_shape,
    test_ssh_block_has_hardening_options,
    test_ssh_block_has_key_path,
    test_ssh_block_ends_with_remote_target,
    test_personal_mcp_ssh_extra_appended,
    test_tunnel_only_flag_omits_mcp_block,
    test_tunnel_only_env_var_omits_mcp_block,
    test_tunnel_only_ssh_argv_intact,
    test_disabled_kill_switch_exits_zero,
    test_enable_flag_in_help,
    test_default_red_path_service_down_exits_three,
    test_default_green_path_detects_service_up,
    test_enable_print_cmd_emits_mcp_block,
    test_enable_ctrlc_leaves_host_service_running,
    test_env_example_exists_and_has_required_keys,
    test_gitignore_excludes_env,
    test_script_uses_ssh_minus_capital_R_not_lowercase,
]

for t in tests:
    pre = len(failures)
    try:
        t()
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
    if len(failures) == pre:
        print(f"PASS  {t.__name__}")
    else:
        print(f"FAIL  {t.__name__}")

if failures:
    print()
    print(f"FAILED: {len(failures)} failure(s).")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)
else:
    print()
    print(f"All {len(tests)} tests passed.")
    sys.exit(0)
