#!/usr/bin/env python3
"""Tests for the in-container native claude install + /usr/bin/claude symlink.

Background (2026-07-10, #1158): claude-code is installed via the NATIVE
managed installer (`curl -fsSL https://claude.ai/install.sh | bash`), NOT
`npm install -g` (operator directive: "i dont want to use npm to install
claude-code ever ... npm should just be used to manage deps"). The native
installer lays the binary out under

    ~/.local/share/claude/versions/<ver>     the native binary (a FILE)
    ~/.local/bin/claude -> versions/<ver>     the launcher symlink

and `~/.local/share/claude` is backed by the claude-container-versions named
VOLUME, so in-app auto-updates PERSIST across `docker compose up
--force-recreate` (the versions-volume self-updater design). The prior npm
shape wrote into the EPHEMERAL ~/.npm-global (rolled back every redeploy).

This test asserts the file-level wiring of the native shape. It does NOT
spin up a container.

Coverage:
  1. Dockerfile installs via the native installer (curl .../install.sh | bash,
     or the equivalent bash install.sh invocation), NOT `npm install -g
     @anthropic-ai/claude-code`.
  2. The native install runs as uid 1000 (via `su - hndrewaall -c '...'` or a
     preceding `USER hndrewaall`) so the versions tree + launcher land
     uid-1000-owned — the same uid the in-app auto-updater runs as.
  3. Dockerfile contains a `chown -h ... /usr/bin/claude` line setting the
     symlink ownership to uid 1000.
  4. The /usr/bin/claude symlink points at the native launcher
     (~/.local/bin/claude), not at an npm-global path.
  5. The chown -h line is ordered AFTER the native-install invocation.
  6. NO `npm install -g @anthropic-ai/claude-code` anywhere in the Dockerfile
     (npm must not install claude-code).

Run:  ./claude-bin-symlink-uid.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
DOCKERFILE = CONTAINER_DIR / "Dockerfile"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")

if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")
    df_no_comments = "\n".join(
        line for line in df.splitlines() if not line.lstrip().startswith("#")
    )

    # 1. Native installer is used. Accept either the piped form
    #    (`curl ... install.sh | bash`) or the download-then-run form
    #    (`... install.sh ...; bash ... install.sh`).
    native_install = re.search(
        r"claude\.ai/install\.sh", df_no_comments
    )
    expect(
        native_install is not None,
        "Dockerfile: missing the native installer (expected a "
        "`https://claude.ai/install.sh` invocation). claude-code must be "
        "installed via the native managed installer so versions land under "
        "~/.local/share/claude/versions/ (the volume-backed path the in-app "
        "auto-updater writes to), not via npm.",
    )

    # 2. The native install runs as uid 1000.
    if native_install:
        preceding = df_no_comments[max(0, native_install.start() - 600) : native_install.start()]
        runs_as_uid_1000 = (
            re.search(r"su\s+-\s+hndrewaall\s+-c\b", preceding) is not None
            or re.search(r"^USER\s+hndrewaall\b", preceding, re.MULTILINE) is not None
        )
        expect(
            runs_as_uid_1000,
            "Dockerfile: the native install must run as uid 1000 (wrap in "
            "`su - hndrewaall -c '...'` or precede with `USER hndrewaall`). "
            "The install must run as the same uid that later runs the in-app "
            "auto-updater, so the native versions/ tree is uid-1000-writable.",
        )

    # 3. chown -h /usr/bin/claude to uid 1000.
    chown_pat = re.compile(
        r"chown\s+-h\s+(?:hndrewaall:hndrewaall|1000:1000)\s+/usr/bin/claude\b"
    )
    chown_match = chown_pat.search(df_no_comments)
    expect(
        chown_match is not None,
        "Dockerfile: missing `chown -h 1000:1000 /usr/bin/claude` (or the "
        "hndrewaall:hndrewaall equivalent). The /usr/bin/claude symlink must "
        "be uid-1000-owned.",
    )

    # 4. /usr/bin/claude symlink points at the native launcher, NOT npm-global.
    native_symlink = re.search(
        r"ln\s+-sf\s+/home/hndrewaall/\.local/bin/claude\s+/usr/bin/claude\b",
        df_no_comments,
    )
    expect(
        native_symlink is not None,
        "Dockerfile: /usr/bin/claude must be `ln -sf "
        "/home/hndrewaall/.local/bin/claude /usr/bin/claude` (pointing at the "
        "native launcher). The old npm-global target "
        "(~/.npm-global/bin/claude) is gone.",
    )
    expect(
        re.search(r"ln\s+-sf\s+/home/hndrewaall/\.npm-global/bin/claude", df_no_comments) is None,
        "Dockerfile: still symlinks /usr/bin/claude at the npm-global path. "
        "The native install replaced npm-global; point it at "
        "~/.local/bin/claude instead.",
    )

    # 5. chown ordered after the native install.
    if chown_match and native_install:
        expect(
            chown_match.start() > native_install.start(),
            "Dockerfile: `chown -h ... /usr/bin/claude` must appear AFTER the "
            "native install line that creates the /usr/bin/claude symlink.",
        )

    # 6. No `npm install -g @anthropic-ai/claude-code` anywhere (build target).
    npm_claude = re.search(
        r"npm\s+install\s+-g\s+@anthropic-ai/claude-code\b", df_no_comments
    )
    expect(
        npm_claude is None,
        "Dockerfile: found `npm install -g @anthropic-ai/claude-code`. npm "
        "must NOT install claude-code — use the native installer. npm is "
        "retained for dependency management only.",
    )


if failures:
    print("FAIL claude-bin-symlink-uid.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS claude-bin-symlink-uid.test")
sys.exit(0)
