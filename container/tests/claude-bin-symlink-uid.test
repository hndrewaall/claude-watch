#!/usr/bin/env python3
"""Tests for the in-container claude install + /usr/bin/claude symlink.

Background: workbot-validated 2026-05-15 — the in-container claude-code
was stuck at 2.1.142 while the host successfully auto-updated to 2.1.143.
`claude update` reported:

  Insufficient permissions to install update
  Try running with sudo or fix npm permissions

The autoupdate-v2 fix (2026-05-15) is to run `npm install -g` as uid
1000 with a uid-1000-owned npm prefix at /home/hndrewaall/.npm-global
(the canonical "unprivileged npm-global" pattern from npm docs). With
this shape, both the build-time install AND every subsequent
in-process `claude update` write to the same $HOME-rooted directory
tree, no chown gymnastics, no /usr/local-vs-/usr/lib split. The
/usr/bin/claude symlink stays as a stable entry point for
`docker compose exec` invocations that don't pre-resolve
$HOME/.npm-global/bin on PATH; it points at the npm-global bindir
under $HOME and is chowned -h to uid 1000 so `npm install -g`'s
symlink unlink+relink step has permission to update it.

This test asserts the file-level wiring of that fix. It does NOT spin
up a container (the runtime assertion is the operator's per-deploy
`docker compose exec claude-container claude update` check; this
test guards against the npm-install / npm-prefix / chown -h lines
being deleted or refactored away in a future commit).

Coverage:
  1. Dockerfile sets npm prefix to /home/hndrewaall/.npm-global via
     `npm config set prefix ...` (the canonical unprivileged npm-global
     pattern).
  2. Dockerfile runs the `npm install -g @anthropic-ai/claude-code`
     line as uid 1000 (via `su - hndrewaall -c '...'` or USER
     hndrewaall — either acceptable).
  3. Dockerfile contains a `chown -h ... /usr/bin/claude` line that
     sets ownership to uid 1000 (`hndrewaall:hndrewaall` OR a numeric
     `1000:1000` — both acceptable).
  4. The chown -h line is ordered AFTER the `npm install -g
     @anthropic-ai/claude-code` invocation. A chown that runs before
     the install would target a path that doesn't exist yet.

Run:  ./claude-bin-symlink-uid.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
DOCKERFILE = CONTAINER_DIR / "Dockerfile"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")

if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")

    # 1. npm prefix is set to /home/hndrewaall/.npm-global (the
    #    uid-1000-owned canonical "unprivileged npm-global" path). The
    #    autoupdate-v2 fix MUST configure this prefix so both build-time
    #    and self-update-time `npm install -g` writes land in the same
    #    uid-1000-writable tree.
    npm_prefix_match = re.search(
        r"npm\s+config\s+set\s+prefix\s+/home/hndrewaall/\.npm-global\b",
        df,
    )
    expect(
        npm_prefix_match is not None,
        "Dockerfile: missing `npm config set prefix /home/hndrewaall/.npm-global`. "
        "Without this, npm's default global prefix is /usr/local which is "
        "root-owned, and `claude update` fails with 'Insufficient permissions "
        "to install update' on every in-process self-update attempt "
        "(workbot v68 validation 2026-05-15). The fix runs the build-time "
        "npm install as uid 1000 with a uid-1000-writable prefix under "
        "$HOME (the npm docs' canonical pattern).",
    )

    # 2. The `npm install -g @anthropic-ai/claude-code` line must run
    #    as uid 1000 — either via USER hndrewaall preceding it or via
    #    `su - hndrewaall -c '...'` wrapping it. The whole point of the
    #    autoupdate-v2 fix is that the install runs as the same uid
    #    that will later run `claude update`, so npm doesn't need to
    #    change ownership of the install tree.
    npm_install_match = re.search(
        r"npm\s+install\s+-g\s+@anthropic-ai/claude-code\b",
        df,
    )
    expect(
        npm_install_match is not None,
        "Dockerfile: cannot locate the `npm install -g "
        "@anthropic-ai/claude-code` line. If the package install moved "
        "elsewhere, update this test to match.",
    )

    if npm_install_match:
        # Search a 400-char window preceding the install for either
        # `su - hndrewaall -c` or a `USER hndrewaall` directive.
        preceding = df[max(0, npm_install_match.start() - 400) : npm_install_match.start()]
        runs_as_uid_1000 = (
            re.search(r"su\s+-\s+hndrewaall\s+-c\b", preceding) is not None
            or re.search(r"^USER\s+hndrewaall\b", preceding, re.MULTILINE) is not None
        )
        expect(
            runs_as_uid_1000,
            "Dockerfile: `npm install -g @anthropic-ai/claude-code` must "
            "run as uid 1000 (the autoupdate-v2 fix). Wrap the install in "
            "`su - hndrewaall -c '...'` or precede it with `USER hndrewaall`. "
            "Without this, the install runs as root and lands in a "
            "root-owned tree that subsequent `claude update` invocations "
            "(as uid 1000) cannot write to.",
        )

    # 3. The /usr/bin/claude symlink is chowned -h to uid 1000 so npm's
    #    in-process symlink unlink+relink step (during update) doesn't
    #    fail with EACCES on a root-owned symlink. PR #204 rationale
    #    stands; only the symlink TARGET changed (now points at
    #    $HOME/.npm-global/bin/claude instead of /usr/lib/...).
    chown_pat = re.compile(
        r"chown\s+-h\s+(?:hndrewaall:hndrewaall|1000:1000)\s+/usr/bin/claude\b"
    )
    chown_match = chown_pat.search(df)
    expect(
        chown_match is not None,
        "Dockerfile: missing `chown -h hndrewaall:hndrewaall /usr/bin/claude` "
        "(or the equivalent `chown -h 1000:1000 /usr/bin/claude`). Without "
        "this, the /usr/bin/claude symlink is owned by root, `npm install "
        "-g` upgrades fail with EACCES on the symlink unlink+relink step, "
        "and `claude update` reports 'Insufficient permissions to install "
        "update'. The -h flag changes the symlink's ownership, not its "
        "target. PR #204 rationale stands under autoupdate-v2.",
    )

    if chown_match and npm_install_match:
        expect(
            chown_match.start() > npm_install_match.start(),
            "Dockerfile: `chown -h ... /usr/bin/claude` must appear AFTER "
            "the `npm install -g @anthropic-ai/claude-code` line that "
            "creates (or recreates, via ln -sf) the symlink. Reordering "
            "would target a not-yet-existing path and either fail the "
            "build or silently no-op depending on shell semantics.",
        )


if failures:
    print("FAIL claude-bin-symlink-uid.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS claude-bin-symlink-uid.test")
sys.exit(0)
