#!/usr/bin/env python3
"""File-level test that the in-container cron daemon is wired into
process-compose's service set.

The Dockerfile installs cron + grants the sudoers carve-out (see
cron-installed.test) so the uid-1000 supervisor can start the daemon
as root via `sudo -n /usr/sbin/cron`. With the migration to
process-compose as PID 1, the cron daemon launch lives in
process-compose.yml (the declarative service config), not in
entrypoint.sh. The entrypoint only exports the env-var passthrough
that disables the process when operators opt out via
CLAUDE_CONTAINER_CRON=0.

Asserts:

  1. process-compose.yml declares a `crond` process.
  2. The process invokes /usr/sbin/cron via `sudo -n` (passwordless
     via the Dockerfile's sudoers carve-out).
  3. cron is invoked with `-f` (foreground; otherwise process-compose
     would lose track of the daemonized child) and `-L 15`
     (LOG_INFO+LOG_NOTICE+LOG_WARNING — routes scheduling decisions
     to stderr where process-compose's log_location captures them).
  4. The process declares `restart: on_failure` so a daemon crash
     triggers a restart.
  5. entrypoint.sh maps the legacy CLAUDE_CONTAINER_CRON=0 opt-out
     to the process-compose-style *_DISABLED env var, so operators
     with existing .env files don't see a behaviour change.

Run:  ./entrypoint-launches-cron.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

ENTRYPOINT = CONTAINER_DIR / "entrypoint.sh"
PC_CONFIG = CONTAINER_DIR / "process-compose.yml"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# ---------------------------------------------------------------------------
# 1-4. process-compose.yml declares the cron daemon process.
# ---------------------------------------------------------------------------
expect(PC_CONFIG.is_file(), f"process-compose.yml missing at {PC_CONFIG}")
if PC_CONFIG.is_file():
    pc_text = PC_CONFIG.read_text(encoding="utf-8")

    # 1. Service block exists.
    pat = re.compile(r"(?m)^  crond:\s*$")
    expect(
        pat.search(pc_text) is not None,
        "process-compose.yml must declare a `crond` process. Without "
        "it the cron daemon never starts inside the container, "
        "/etc/cron.d/ entries silently never fire, and operators "
        "wondering 'why isn't my baked cron job running' have no "
        "obvious failure mode to debug.",
    )

    # Extract the crond block body for further checks.
    crond_block = re.search(
        r"(?ms)^  crond:\s*$(.+?)(?=^  \w|^\Z)",
        pc_text,
    )
    if crond_block:
        body = crond_block.group(1)

        # 2. Invokes /usr/sbin/cron via sudo -n.
        expect(
            re.search(r"sudo\s+-n\s+/usr/sbin/cron\b", body) is not None,
            "process-compose.yml: crond must invoke /usr/sbin/cron "
            "via `sudo -n` — the supervisor process runs as uid 1000 "
            "but the cron daemon must run as root to setuid() into "
            "the user named in each crontab line. The `-n` flag fails "
            "fast instead of prompting for a password (the Dockerfile "
            "ships a NOPASSWD sudoers carve-out for this path).",
        )

        # 3. cron flags: -f (foreground) + -L 15 (log level).
        expect(
            re.search(r"/usr/sbin/cron\s+-f\b", body) is not None,
            "process-compose.yml: crond must invoke cron with `-f` "
            "(foreground) so cron does NOT self-daemonize. "
            "process-compose tracks process lifetime via the spawned "
            "PID; if cron forks and detaches, process-compose loses "
            "the child and can't restart on failure.",
        )
        expect(
            re.search(r"/usr/sbin/cron[^\n]*\s-L\s+15\b", body) is not None,
            "process-compose.yml: crond must invoke cron with `-L 15` "
            "(LOG_INFO+LOG_NOTICE+LOG_WARNING). Without it cron logs "
            "scheduling decisions only to syslog, which the container "
            "doesn't run; process-compose's log_location captures "
            "stderr, so without -L the logs are blank and debugging a "
            "broken cron job becomes guesswork.",
        )

        # 4. Restart policy.
        expect(
            re.search(r"restart:\s*on_failure", body) is not None,
            "process-compose.yml: crond must declare `restart: on_failure` "
            "so a cron daemon crash triggers a restart instead of "
            "leaving the container with a dead scheduler.",
        )


# ---------------------------------------------------------------------------
# 5. entrypoint.sh maps legacy opt-out env var → process-compose disabled var.
# ---------------------------------------------------------------------------
expect(ENTRYPOINT.is_file(), f"entrypoint.sh missing at {ENTRYPOINT}")
if ENTRYPOINT.is_file():
    text = ENTRYPOINT.read_text(encoding="utf-8")

    expect(
        "CLAUDE_CONTAINER_CRON" in text,
        "entrypoint.sh: must reference CLAUDE_CONTAINER_CRON (the "
        "legacy opt-out env var) so the post-process-compose "
        "entrypoint preserves the old contract.",
    )
    expect(
        "CLAUDE_CONTAINER_CRON_DISABLED" in text,
        "entrypoint.sh: must export CLAUDE_CONTAINER_CRON_DISABLED "
        "when the legacy opt-out env var is set to 0. "
        "process-compose.yml's `disabled:` field reads the *_DISABLED "
        "variant; mapping at the entrypoint preserves backwards "
        "compatibility with operator .env files.",
    )


if failures:
    print("FAIL entrypoint-launches-cron.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS entrypoint-launches-cron.test")
sys.exit(0)
