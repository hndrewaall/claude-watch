#!/usr/bin/env python3
"""File-level test that entrypoint.sh launches the cron daemon at
container boot.

The Dockerfile installs cron + grants the sudoers carve-out (see
cron-installed.test) so the uid-1000 entrypoint can start the daemon
as root via `sudo -n /usr/sbin/cron`. Without the entrypoint-side
launch the daemon never starts, /etc/cron.d/ entries silently never
fire, and operators wondering "why isn't my bind-mounted cron job
running" have no obvious failure mode to debug. This test pins the
wiring in source so a refactor that drops the launch line fails CI
here instead of at runtime.

Asserts:

  1. entrypoint.sh contains a CLAUDE_CONTAINER_CRON env check that
     gates the launch (default ON so a stock container starts cron
     by default, opt-out via CLAUDE_CONTAINER_CRON=0 for stripped-
     down harnesses).
  2. The gate defaults to ON (`:-1`, not `:-0`). A future refactor
     that flips the default would silently kill scheduled jobs for
     every existing operator.
  3. entrypoint.sh invokes /usr/sbin/cron via `sudo -n` (passwordless
     because the entrypoint is non-interactive; the sudoers carve-out
     in the Dockerfile provides the NOPASSWD grant).
  4. cron is launched in the background with setsid (detached PG so
     the subsequent `exec tmux attach-session` doesn't block on it).
  5. cron is invoked with `-f` (foreground; otherwise its built-in
     daemonize fork would lose the PID we need for the cleanup trap)
     and `-L 15` (LOG_INFO+LOG_NOTICE+LOG_WARNING — routes scheduling
     decisions to stderr so the log file actually captures them
     without requiring an in-container syslogd).
  6. The cron daemon's log path lives at /tmp/claude-container-cron.log
     (matches the per-watcher log_path convention; uid-1000-writable
     under /tmp/).
  7. The launch captures the cron PID into CLAUDE_CRON_PID so the
     cleanup trap can signal it on docker stop.
  8. The cleanup() function references CLAUDE_CRON_PID and uses
     `sudo -n kill` to signal it (the daemon runs as root; uid 1000
     can't signal root without CAP_KILL).

Run:  ./entrypoint-launches-cron.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

ENTRYPOINT = CONTAINER_DIR / "entrypoint.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


expect(ENTRYPOINT.is_file(), f"entrypoint.sh missing at {ENTRYPOINT}")
if ENTRYPOINT.is_file():
    text = ENTRYPOINT.read_text(encoding="utf-8")

    # 1. Env-gated launch.
    expect(
        "CLAUDE_CONTAINER_CRON" in text,
        "entrypoint.sh: missing CLAUDE_CONTAINER_CRON env gate. The "
        "cron daemon launch must be opt-out (default ON) via this "
        "env var so validation harnesses can disable it with "
        "CLAUDE_CONTAINER_CRON=0 in .env.",
    )

    # 2. Default ON.
    expect(
        re.search(r"CLAUDE_CONTAINER_CRON:-1", text) is not None,
        "entrypoint.sh: CLAUDE_CONTAINER_CRON must default to ON "
        "(`${CLAUDE_CONTAINER_CRON:-1}`). Default OFF would silently "
        "kill scheduled jobs for every existing operator who relies "
        "on /etc/cron.d/-bind-mounted recurring jobs.",
    )

    # 3. `sudo -n /usr/sbin/cron` invocation.
    expect(
        re.search(r"sudo\s+-n\s+/usr/sbin/cron\b", text) is not None,
        "entrypoint.sh: must invoke /usr/sbin/cron via `sudo -n` "
        "(passwordless via the Dockerfile's sudoers carve-out). The "
        "`-n` flag fails fast instead of prompting for a password "
        "(the entrypoint is non-interactive — a password prompt "
        "would hang the container boot).",
    )

    # 4. Background launch (setsid + & or nohup). We anchor on the
    #    `setsid sudo cron` token, then look for a `&\n` on its own
    #    (immediately after `</dev/null `) to confirm the command
    #    actually ends with a backgrounding ampersand. The middle
    #    `[\s\S]*?` is non-greedy so it doesn't eat past the real
    #    end-of-command; `2>&1` inside the redirect is fine because
    #    we're not trying to match its `&`.
    cron_launch_re = re.search(
        r"setsid\s+sudo\s+-n\s+/usr/sbin/cron[\s\S]*?</dev/null\s*&",
        text,
    )
    expect(
        cron_launch_re is not None,
        "entrypoint.sh: cron must be launched in the background with "
        "setsid (detached PG so the entrypoint's subsequent `exec "
        "tmux attach-session` doesn't block). Expected shape: "
        "`nohup setsid sudo -n /usr/sbin/cron -f -L 15 >>/log 2>&1 "
        "</dev/null &`.",
    )

    # 5. cron flags: -f (foreground) and -L 15 (log level).
    expect(
        re.search(r"/usr/sbin/cron\s+-f\b", text) is not None,
        "entrypoint.sh: cron must be invoked with `-f` (foreground) "
        "so cron does NOT self-daemonize and fork — otherwise the "
        "PID captured into CLAUDE_CRON_PID would point at the parent "
        "wrapper, not the actual daemon, and the cleanup trap "
        "couldn't signal it correctly.",
    )
    expect(
        re.search(r"/usr/sbin/cron[^\n]*\s-L\s+15\b", text) is not None,
        "entrypoint.sh: cron must be invoked with `-L 15` "
        "(LOG_INFO+LOG_NOTICE+LOG_WARNING). Without it cron logs "
        "scheduling decisions only to syslog, which the container "
        "doesn't run; the log file would be empty and debugging a "
        "broken cron job becomes guesswork.",
    )

    # 6. Log path.
    expect(
        "/tmp/claude-container-cron.log" in text,
        "entrypoint.sh: cron log path should land at "
        "/tmp/claude-container-cron.log — matches the per-watcher "
        "/tmp/claude-container-watchers/*.log convention (uid-1000-"
        "writable under /tmp/, captured-able by `docker compose "
        "exec <c> cat /tmp/claude-container-cron.log`).",
    )

    # 7. PID capture.
    expect(
        "CLAUDE_CRON_PID" in text,
        "entrypoint.sh: must capture cron's PID into CLAUDE_CRON_PID "
        "(mirrors CLAUDE_WATCH_DAEMON_PID / CW_WATCHER_SUPERVISOR_PID "
        "patterns) so the cleanup trap can signal it on docker stop.",
    )

    # 8. Cleanup trap signals via sudo (cron runs as root).
    cleanup_match = re.search(
        r"cleanup\(\)\s*\{(.+?)^\}",
        text,
        re.MULTILINE | re.DOTALL,
    )
    expect(
        cleanup_match is not None,
        "entrypoint.sh: cleanup() function missing or not parseable",
    )
    if cleanup_match:
        body = cleanup_match.group(1)
        expect(
            "CLAUDE_CRON_PID" in body,
            "entrypoint.sh: cleanup() must reference CLAUDE_CRON_PID "
            "so the cron daemon drains in-flight scheduled jobs on "
            "docker stop instead of getting SIGKILLed cold.",
        )
        expect(
            re.search(
                r"sudo\s+-n\s+kill\s+\"?\$\{?CLAUDE_CRON_PID",
                body,
            )
            is not None,
            "entrypoint.sh: cleanup() must signal cron via `sudo -n "
            "kill` — the cron daemon runs as root and uid 1000 can't "
            "signal root processes without CAP_KILL. Without the sudo "
            "wrapper the kill silently fails and cron sticks around "
            "as a zombie.",
        )


if failures:
    print("FAIL entrypoint-launches-cron.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS entrypoint-launches-cron.test")
sys.exit(0)
