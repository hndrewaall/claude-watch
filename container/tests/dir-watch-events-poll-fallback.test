#!/usr/bin/env python3
"""dir-watch.sh: poll-fallback path covers create/modify/delete.

Runs the watcher with `WATCH_DISABLE_INOTIFY=1` so the script bypasses
the inotifywait branch even when the binary is on PATH. Exercises
the (filename, mtime, inode) state-file diff implementation
end-to-end:

  1. Drop file -> snapshot diff finds new filename -> fire `created`.
  2. Modify file -> snapshot diff finds same filename + newer mtime
     -> fire `modified`.
  3. Delete file -> snapshot diff finds prior filename no longer in
     the glob -> fire `deleted`.

Run:  ./dir-watch-events-poll-fallback.test
"""

from __future__ import annotations

import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
SCRIPT = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def start_watcher(watch_dir: Path, pattern: str, callback: str,
                  state_file: Path, log_path: Path, events: str) -> subprocess.Popen:
    # Force the poll path via the script's own escape hatch. Tries to
    # mask inotifywait off PATH break unrelated tools (stat, dirname,
    # awk, …) on Debian where /usr/bin owns both — the explicit env
    # var sidesteps the ambiguity.
    env = {
        **os.environ,
        "WATCH_DISABLE_INOTIFY": "1",
        "WATCH_DIR": str(watch_dir),
        "WATCH_PATTERN": pattern,
        "WATCH_CALLBACK": callback,
        "WATCH_STATE_FILE": str(state_file),
        "WATCH_EVENTS": events,
        # Short poll so the test doesn't take forever.
        "POLL_INTERVAL_SECS": "1",
    }
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        [str(SCRIPT)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=2)


def test_poll_fallback_full_lifecycle() -> None:
    """Without inotifywait on PATH, the poll fallback must still
    cover create / modify / delete."""
    with tempfile.TemporaryDirectory(prefix="dwe-poll-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'
        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="all",
        )

        try:
            # Sanity: the script logs whether it went down the poll path.
            # Give the watcher a moment to write its preamble.
            ok = wait_for(
                lambda: log_path.exists()
                and "polling every" in log_path.read_text(),
                timeout=5,
            )
            expect(
                ok,
                f"watcher did not log the poll-fallback preamble — PATH "
                f"masking may have failed. watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            target = watch_dir / "poll.json"
            target.write_text('{"v":1}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "created poll.json" in fired_log.read_text(),
                    # Poll interval is 1s — give the diff a bit of slack.
                    timeout=10,
                ),
                f"poll fallback missed `created`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            # Distinct mtime second so the poll diff sees a change.
            time.sleep(1.2)
            target.write_text('{"v":2}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "modified poll.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"poll fallback missed `modified`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            time.sleep(0.3)
            target.unlink()

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "deleted poll.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"poll fallback missed `deleted`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            content = fired_log.read_text()
            ci = content.find("created poll.json")
            mi = content.find("modified poll.json")
            di = content.find("deleted poll.json")
            expect(
                ci != -1 and mi != -1 and di != -1 and ci < mi < di,
                f"poll fallback event ordering wrong. content={content!r}",
            )
        finally:
            stop(proc)


def test_poll_state_legacy_migration() -> None:
    """A state file in the pre-events format (plain filenames, no
    tabs) should be migrated quietly on startup. No spurious fires for
    files that were already in the legacy state."""
    with tempfile.TemporaryDirectory(prefix="dwe-legacy-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        # Pre-seed: a file already in the dir + a legacy-format state
        # file that already records it. The pre-events watcher used
        # plain "<basename>\n" lines.
        legacy_file = watch_dir / "old.json"
        legacy_file.write_text('{"legacy":1}')
        state_file.write_text("old.json\n")

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'
        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="all",
        )

        try:
            # Let the watcher run a couple of poll cycles so any
            # spurious fire would have surfaced.
            time.sleep(3)

            content = fired_log.read_text() if fired_log.exists() else ""
            expect(
                "created old.json" not in content
                and "modified old.json" not in content
                and "deleted old.json" not in content,
                f"legacy migration leaked an event for old.json. "
                f"fired_log={content!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            # State file should now be in the new tab-separated format.
            state_text = state_file.read_text()
            expect(
                "\t" in state_text,
                f"state file was not migrated to tabbed format. "
                f"state={state_text!r}",
            )
            # And it should still record old.json (so a re-create
            # under the same name doesn't refire).
            expect(
                any(line.split("\t", 1)[0] == "old.json"
                    for line in state_text.splitlines()
                    if line.strip()),
                f"migrated state file lost old.json. state={state_text!r}",
            )

            # Now drop a fresh file -> should fire `created`. This
            # proves the migration didn't break the diff loop.
            (watch_dir / "fresh.json").write_text('{"v":1}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "created fresh.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"post-migration create lost. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )
        finally:
            stop(proc)


TESTS = [
    test_poll_fallback_full_lifecycle,
    test_poll_state_legacy_migration,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
