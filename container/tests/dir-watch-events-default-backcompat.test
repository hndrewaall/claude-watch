#!/usr/bin/env python3
"""dir-watch.sh: default WATCH_EVENTS (unset) fires ONLY `created`.

Regression guard: pre-events consumers (claude-event-tail.sh + any
out-of-tree wrappers) must keep seeing exactly the events they saw
before. With WATCH_EVENTS unset we MUST NOT fire on modify or delete.

Run:  ./dir-watch-events-default-backcompat.test
"""

from __future__ import annotations

import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
SCRIPT = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def start_watcher(watch_dir: Path, pattern: str, callback: str,
                  state_file: Path, log_path: Path) -> subprocess.Popen:
    # Deliberately do NOT set WATCH_EVENTS — defaulting is the contract
    # under test.
    env = {
        **os.environ,
        "WATCH_DIR": str(watch_dir),
        "WATCH_PATTERN": pattern,
        "WATCH_CALLBACK": callback,
        "WATCH_STATE_FILE": str(state_file),
        "POLL_INTERVAL_SECS": "1",
    }
    env.pop("WATCH_EVENTS", None)
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        [str(SCRIPT)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=2)


def test_default_fires_only_created() -> None:
    """Drop file -> fires `created`. Modify -> no fire. Delete -> no fire."""
    with tempfile.TemporaryDirectory(prefix="dwe-default-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
        )

        try:
            target = watch_dir / "compat.json"
            target.write_text('{"v":1}')

            got_create = wait_for(
                lambda: fired_log.exists()
                and "created compat.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                got_create,
                f"default WATCH_EVENTS dropped the `created` event. "
                f"fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            # Modify — wait longer than POLL_INTERVAL_SECS to catch any
            # spurious `modified` fire.
            time.sleep(1.2)
            target.write_text('{"v":2}')
            time.sleep(3)

            content = fired_log.read_text() if fired_log.exists() else ""
            expect(
                "modified" not in content,
                f"default WATCH_EVENTS leaked a `modified` event. "
                f"fired_log={content!r}",
            )

            # Delete — give the watcher time to (incorrectly) react.
            target.unlink()
            time.sleep(3)

            content = fired_log.read_text() if fired_log.exists() else ""
            expect(
                "deleted" not in content,
                f"default WATCH_EVENTS leaked a `deleted` event. "
                f"fired_log={content!r}",
            )

            # Exactly one fire total: the `created` line for compat.json.
            non_empty_lines = [
                line for line in content.splitlines() if line.strip()
            ]
            expect(
                len(non_empty_lines) == 1,
                f"default WATCH_EVENTS fired {len(non_empty_lines)} "
                f"event(s); expected exactly 1 (the create). "
                f"lines={non_empty_lines!r}",
            )
        finally:
            stop(proc)


def test_default_callback_one_positional_arg_still_works() -> None:
    """A pre-events callback that only reads $1 must keep working
    unchanged (the new $2 is additive)."""
    with tempfile.TemporaryDirectory(prefix="dwe-default-cb-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        # Old-style callback: only references $1.
        callback = f'printf "%s\\n" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
        )

        try:
            (watch_dir / "old-style.json").write_text("{}")
            ok = wait_for(
                lambda: fired_log.exists()
                and "old-style.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                ok,
                f"single-arg legacy callback regressed. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )
        finally:
            stop(proc)


TESTS = [
    test_default_fires_only_created,
    test_default_callback_one_positional_arg_still_works,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
