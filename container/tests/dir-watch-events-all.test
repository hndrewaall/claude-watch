#!/usr/bin/env python3
"""dir-watch.sh: WATCH_EVENTS=all — full lifecycle (create + modify + delete).

Drops a file, modifies its content, removes it; asserts the callback
fires `created` -> `modified` -> `deleted` in that order for the
same basename.

Also covers the symmetric `moved-in` / `moved-out` rename shape via
`mv` into/out of the watched dir.

Run:  ./dir-watch-events-all.test
"""

from __future__ import annotations

import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
SCRIPT = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def start_watcher(watch_dir: Path, pattern: str, callback: str,
                  state_file: Path, log_path: Path,
                  events: str) -> subprocess.Popen:
    env = {
        **os.environ,
        "WATCH_DIR": str(watch_dir),
        "WATCH_PATTERN": pattern,
        "WATCH_CALLBACK": callback,
        "WATCH_STATE_FILE": str(state_file),
        "WATCH_EVENTS": events,
        "POLL_INTERVAL_SECS": "1",
    }
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        [str(SCRIPT)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=2)


def test_full_lifecycle_with_all_shorthand() -> None:
    """WATCH_EVENTS=all covers create + modify + delete in order."""
    with tempfile.TemporaryDirectory(prefix="dwe-all-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="all",
        )

        try:
            target = watch_dir / "life.json"
            target.write_text('{"v":1}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "created life.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"missing `created life.json`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            time.sleep(1.2)
            target.write_text('{"v":2}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "modified life.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"missing `modified life.json`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            time.sleep(0.3)
            target.unlink()

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "deleted life.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"missing `deleted life.json`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            # Ordering: created < modified < deleted.
            content = fired_log.read_text()
            ci = content.find("created life.json")
            mi = content.find("modified life.json")
            di = content.find("deleted life.json")
            expect(
                ci != -1 and mi != -1 and di != -1 and ci < mi < di,
                f"Lifecycle ordering wrong. fired_log={content!r}",
            )
        finally:
            stop(proc)


def test_moved_in_fires_as_created() -> None:
    """mv <outside>/foo.json <watched>/foo.json -> `created` event.
    `moved-in` is an alias for `created` in the WATCH_EVENTS schema."""
    with tempfile.TemporaryDirectory(prefix="dwe-mv-in-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        outside = td_path / "outside"
        outside.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="all",
        )

        try:
            # Create outside the watch dir; rename in.
            tmp = outside / "import.json"
            tmp.write_text('{"i":1}')
            tmp.rename(watch_dir / "import.json")

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "created import.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"moved-in did not surface as `created`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )
        finally:
            stop(proc)


def test_moved_out_fires_as_deleted() -> None:
    """mv <watched>/foo.json <outside>/foo.json -> `deleted` event."""
    with tempfile.TemporaryDirectory(prefix="dwe-mv-out-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        outside = td_path / "outside"
        outside.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="all",
        )

        try:
            target = watch_dir / "export.json"
            target.write_text('{"e":1}')

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "created export.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"setup: created export.json missing. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )

            time.sleep(0.3)
            target.rename(outside / "export.json")

            expect(
                wait_for(
                    lambda: fired_log.exists()
                    and "deleted export.json" in fired_log.read_text(),
                    timeout=10,
                ),
                f"moved-out did not surface as `deleted`. fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )
        finally:
            stop(proc)


def test_unknown_event_token_exits_2() -> None:
    """Garbage in WATCH_EVENTS -> exit 2 with a clear error."""
    env = {
        **os.environ,
        "WATCH_DIR": "/tmp",
        "WATCH_PATTERN": "*",
        "WATCH_CALLBACK": "true",
        "WATCH_EVENTS": "bogus-token",
    }
    result = subprocess.run(
        [str(SCRIPT)],
        env=env,
        capture_output=True,
        text=True,
        timeout=5,
    )
    expect(
        result.returncode == 2,
        f"expected exit 2 for unknown WATCH_EVENTS token, got "
        f"{result.returncode} (stderr={result.stderr!r})",
    )
    expect(
        "bogus-token" in result.stderr or "WATCH_EVENTS" in result.stderr,
        f"stderr should mention the bad token. got {result.stderr!r}",
    )


TESTS = [
    test_full_lifecycle_with_all_shorthand,
    test_moved_in_fires_as_created,
    test_moved_out_fires_as_deleted,
    test_unknown_event_token_exits_2,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
