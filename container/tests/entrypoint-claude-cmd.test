#!/usr/bin/env python3
"""Tests for container/entrypoint.sh's CLAUDE_CMD construction.

The entrypoint builds the `claude` invocation conditionally on
CLAUDE_CONTAINER_REWRITE_HOOKS / CLAUDE_SHIM_SETTINGS_PATH. We test
that branch without actually invoking docker / tmux by extracting
the relevant block, simulating the surrounding state with shell
fixtures, and asserting the final `CLAUDE_CMD` value.

The block under test (from container/entrypoint.sh, near the bottom):

    CLAUDE_CMD="exec claude"
    if [ -n "${CLAUDE_SHIM_SETTINGS_PATH:-}" ]; then
        CLAUDE_CMD="exec claude --setting-sources project,local --settings ${CLAUDE_SHIM_SETTINGS_PATH}"
    fi

Coverage:
  - CLAUDE_SHIM_SETTINGS_PATH unset            -> "exec claude" only
  - CLAUDE_SHIM_SETTINGS_PATH empty            -> "exec claude" only
  - CLAUDE_SHIM_SETTINGS_PATH=/tmp/foo.json    -> includes
        "--setting-sources project,local"
        "--settings /tmp/foo.json"
    in that ORDER. The order matters: `--setting-sources` filters the
    user tier OUT of the cascade and `--settings` then loads the shim
    file. (Functionally Claude Code is order-insensitive for these two
    flags, but the order-of-appearance is the contract the code review
    + readers walk through left-to-right.)

The v19 regression that motivated this test: PR #143's entrypoint
emitted `exec claude --settings <shim>` only, without
`--setting-sources project,local`. Claude Code's settings merge is
ADDITIVE, so it loaded BOTH the bind-mounted host
`~/.claude/settings.json` (bare hooks, hit "Exec format error") AND
the shim (wrapped hooks). Both fired on every event; the bare ones
still spammed the log. This test asserts the v20 fix: the
`--setting-sources project,local` filter MUST be present whenever a
shim path is.

Run:  ./entrypoint-claude-cmd.test
"""

from __future__ import annotations

import re
import subprocess
import sys
import tempfile
from pathlib import Path

HERE = Path(__file__).resolve().parent
ENTRYPOINT = HERE.parent / "entrypoint.sh"

if not ENTRYPOINT.exists():
    print(f"FAIL: cannot locate entrypoint at {ENTRYPOINT}", file=sys.stderr)
    sys.exit(2)


# Extract the CLAUDE_CMD-building block. We anchor on the well-known
# block opener (`CLAUDE_CMD="exec claude"`) and end at the LAST `fi`
# in the consecutive run of `if [...]; then ... fi` blocks below it.
# This keeps the regex resilient against new conditional appends (e.g.
# CLAUDE_AUTO_CONTINUE) as long as they share the same block shape.
def extract_claude_cmd_block(path: Path) -> str:
    src = path.read_text(encoding="utf-8")
    # Greedy match through the final `fi\n` immediately followed by a
    # blank line — that's the documented contract for new appenders:
    # add another `if [...]; then ...; fi` before the trailing blank.
    m = re.search(
        r'(CLAUDE_CMD="exec claude"\n(?:if \[.*?fi\n)+)',
        src,
        re.DOTALL,
    )
    if not m:
        raise AssertionError(
            "could not locate CLAUDE_CMD block in entrypoint.sh "
            "(this test extracts it by regex; update the regex if "
            "the block shape changes)"
        )
    return m.group(1)


def run_block(block: str, env: dict) -> str:
    """Run the extracted bash block under bash -c with the given env,
    then echo $CLAUDE_CMD. Returns the printed value."""
    script = f"set -u\n{block}\nprintf '%s\\n' \"$CLAUDE_CMD\"\n"
    # The block reads CLAUDE_SHIM_SETTINGS_PATH; bash needs it set or
    # unset depending on the test case. We pass via env.
    result = subprocess.run(
        ["bash", "-c", script],
        env=env,
        capture_output=True,
        text=True,
        timeout=5,
    )
    if result.returncode != 0:
        raise AssertionError(
            f"bash exited {result.returncode}\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )
    # Last line is the CLAUDE_CMD value.
    lines = [ln for ln in result.stdout.splitlines() if ln.strip()]
    if not lines:
        raise AssertionError(f"no output from block; stdout was:\n{result.stdout}")
    return lines[-1]


# ---------------------------------------------------------------------------
# Test cases
# ---------------------------------------------------------------------------

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


BLOCK = extract_claude_cmd_block(ENTRYPOINT)


def test_unset_shim_path_bare_claude() -> None:
    """CLAUDE_SHIM_SETTINGS_PATH unset → exec claude (no flags)."""
    env = {"PATH": "/usr/bin:/bin"}
    cmd = run_block(BLOCK, env)
    expect(cmd == "exec claude",
           f"unset shim path: expected bare 'exec claude', got {cmd!r}")


def test_empty_shim_path_bare_claude() -> None:
    """CLAUDE_SHIM_SETTINGS_PATH='' → exec claude (no flags)."""
    env = {"PATH": "/usr/bin:/bin", "CLAUDE_SHIM_SETTINGS_PATH": ""}
    cmd = run_block(BLOCK, env)
    expect(cmd == "exec claude",
           f"empty shim path: expected bare 'exec claude', got {cmd!r}")


def test_set_shim_path_includes_setting_sources() -> None:
    """CLAUDE_SHIM_SETTINGS_PATH=/tmp/foo.json + CLAUDE_SHIM_FILTER_USER=1 →
    includes --setting-sources project,local. The filter-user flag tracks
    REWRITE_HOOKS=1 mode where the shim contains wrapped copies of the
    host hooks; without filtering the user tier we'd get duplicate (bare
    + wrapped) host hooks. Obligations-only mode (FILTER_USER unset)
    layers additively without the filter."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/foo.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
    }
    cmd = run_block(BLOCK, env)
    expect("--setting-sources project,local" in cmd,
           f"set shim path: missing --setting-sources flag, got {cmd!r}")
    expect("--settings /tmp/foo.json" in cmd,
           f"set shim path: missing --settings <path>, got {cmd!r}")


def test_set_shim_path_order() -> None:
    """--setting-sources must appear BEFORE --settings (left-to-right
    readability contract; functionally equivalent either order)."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/foo.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
    }
    cmd = run_block(BLOCK, env)
    ss_idx = cmd.find("--setting-sources")
    s_idx = cmd.find("--settings ")
    expect(ss_idx >= 0 and s_idx >= 0,
           f"order: both flags should be present, got {cmd!r}")
    expect(ss_idx < s_idx,
           f"order: --setting-sources should come before --settings, got {cmd!r}")


def test_set_shim_path_exact_form() -> None:
    """Exact match against the documented contract — guard against drift
    (e.g. someone changes the source list to include 'user' or drops the
    --setting-sources flag entirely). Tests the REWRITE_HOOKS=1 path
    (FILTER_USER=1)."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
    }
    cmd = run_block(BLOCK, env)
    expected = (
        "exec claude --setting-sources project,local "
        "--settings /tmp/claude-shim/settings.json"
    )
    expect(cmd == expected,
           f"exact form: expected {expected!r}, got {cmd!r}")


def test_sanitized_user_farm_switches_to_user_local() -> None:
    """PROJECT-tier devbar-hook leak fix: when the snapshot farm's
    user-tier settings.json has been sanitized in place
    (CLAUDE_SHIM_SANITIZED_USER_FARM=1), the launch flips from
    `--setting-sources project,local` to `--setting-sources user,local`.
    Dropping the project tier stops the cwd-bound host
    <cwd>/.claude/settings.json (raw bare cross-arch hooks) from loading;
    the sanitized farm now supplies the user tier."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
        "CLAUDE_SHIM_SANITIZED_USER_FARM": "1",
    }
    cmd = run_block(BLOCK, env)
    expect("--setting-sources user,local" in cmd,
           f"sanitized farm: expected --setting-sources user,local, got {cmd!r}")
    expect("project,local" not in cmd,
           f"sanitized farm: project tier MUST be dropped (it re-reads the "
           f"poison host settings.json), got {cmd!r}")
    expect("--settings /tmp/claude-shim/settings.json" in cmd,
           f"sanitized farm: shim (flagSettings) still loads for obligations, "
           f"got {cmd!r}")


def test_sanitized_user_farm_adds_mcp_config() -> None:
    """When the sanitized farm switch is active AND a project .mcp.json
    path is supplied, --mcp-config re-supplies the MCP servers that
    dropping the project tier removed."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
        "CLAUDE_SHIM_SANITIZED_USER_FARM": "1",
        "CLAUDE_MCP_CONFIG_PATH": "/Users/me/repos/.mcp.json",
    }
    cmd = run_block(BLOCK, env)
    expect("--mcp-config /Users/me/repos/.mcp.json" in cmd,
           f"sanitized farm: expected --mcp-config, got {cmd!r}")
    expect("--setting-sources user,local" in cmd,
           f"sanitized farm + mcp: still user,local, got {cmd!r}")


def test_sanitized_user_farm_mcp_config_absent_no_flag() -> None:
    """No --mcp-config when the path env is unset (e.g. no
    CLAUDE_HOST_PROJECT_DIR / no .mcp.json), even with the farm switch on."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
        "CLAUDE_SHIM_SANITIZED_USER_FARM": "1",
    }
    cmd = run_block(BLOCK, env)
    expect("--mcp-config" not in cmd,
           f"no mcp path: --mcp-config should not appear, got {cmd!r}")


def test_unsanitized_farm_keeps_project_local() -> None:
    """Fail-safe: WITHOUT CLAUDE_SHIM_SANITIZED_USER_FARM (snapshot off /
    sanitization failed), the launch keeps the existing
    `--setting-sources project,local` behaviour unchanged — no user-tier
    switch, no --mcp-config."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
    }
    cmd = run_block(BLOCK, env)
    expect("--setting-sources project,local" in cmd,
           f"unsanitized farm: must keep project,local, got {cmd!r}")
    expect("user,local" not in cmd,
           f"unsanitized farm: must NOT switch to user,local, got {cmd!r}")
    expect("--mcp-config" not in cmd,
           f"unsanitized farm: must NOT add --mcp-config, got {cmd!r}")


def test_obligations_only_additive_no_filter() -> None:
    """Obligations-only path: CLAUDE_SHIM_SETTINGS_PATH set BUT
    CLAUDE_SHIM_FILTER_USER unset → claude loads the shim ADDITIVELY
    on top of the user tier (no `--setting-sources project,local`
    filter). The shim contains only the obligations gate hooks; the
    host's user-tier hooks (claude-watch hook-fire,
    inject-signal-context-hook, etc.) keep loading normally and the
    obligations gates layer on top. Filtering the user tier here
    would silently drop the host's other hooks, which is the wrong
    shape for Linux hosts that don't suffer the cross-arch Mach-O
    pain."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/claude-shim/settings.json",
    }
    cmd = run_block(BLOCK, env)
    expect("--setting-sources" not in cmd,
           f"obligations-only: --setting-sources should NOT appear "
           f"(we want the user tier to keep loading), got {cmd!r}")
    expect("--settings /tmp/claude-shim/settings.json" in cmd,
           f"obligations-only: --settings should still load the shim "
           f"additively, got {cmd!r}")


def test_auto_continue_unset_no_flag() -> None:
    """CLAUDE_AUTO_CONTINUE unset → no --continue in the command."""
    env = {"PATH": "/usr/bin:/bin"}
    cmd = run_block(BLOCK, env)
    expect("--continue" not in cmd,
           f"auto-continue unset: --continue should NOT appear, got {cmd!r}")


def test_auto_continue_empty_no_flag() -> None:
    """CLAUDE_AUTO_CONTINUE='' → no --continue (empty treated as unset)."""
    env = {"PATH": "/usr/bin:/bin", "CLAUDE_AUTO_CONTINUE": ""}
    cmd = run_block(BLOCK, env)
    expect("--continue" not in cmd,
           f"auto-continue empty: --continue should NOT appear, got {cmd!r}")


def test_auto_continue_single_word() -> None:
    """CLAUDE_AUTO_CONTINUE=1 + CLAUDE_AUTO_CONTINUE_PROMPT=resume →
    exec claude --continue 'resume'."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_AUTO_CONTINUE": "1",
        "CLAUDE_AUTO_CONTINUE_PROMPT": "resume",
    }
    cmd = run_block(BLOCK, env)
    expect(cmd == "exec claude --continue 'resume'",
           f"auto-continue 'resume': expected exec claude --continue 'resume', "
           f"got {cmd!r}")


def test_auto_continue_with_shim() -> None:
    """Both CLAUDE_AUTO_CONTINUE and CLAUDE_SHIM_SETTINGS_PATH set
    (FILTER_USER=1 path): --setting-sources + --settings come first,
    --continue last."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/foo.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
        "CLAUDE_AUTO_CONTINUE": "1",
        "CLAUDE_AUTO_CONTINUE_PROMPT": "resume",
    }
    cmd = run_block(BLOCK, env)
    expect("--setting-sources project,local" in cmd,
           f"both: --setting-sources should be present, got {cmd!r}")
    expect("--settings /tmp/foo.json" in cmd,
           f"both: --settings should be present, got {cmd!r}")
    expect("--continue 'resume'" in cmd,
           f"both: --continue 'resume' should be present, got {cmd!r}")
    # Order: --settings appears before --continue (settings are construction-
    # time, --continue is invocation-time).
    expect(cmd.index("--settings ") < cmd.index("--continue"),
           f"both: --settings should precede --continue, got {cmd!r}")


def test_auto_continue_multiword_quoted() -> None:
    """CLAUDE_AUTO_CONTINUE_PROMPT='hello world' → value survives as a
    single quoted argv element so tmux's command-string shell parse
    doesn't split it."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_AUTO_CONTINUE": "1",
        "CLAUDE_AUTO_CONTINUE_PROMPT": "hello world",
    }
    cmd = run_block(BLOCK, env)
    expect("--continue 'hello world'" in cmd,
           f"auto-continue multiword: should be single-quoted as one argv "
           f"element, got {cmd!r}")


def test_auto_continue_value_with_single_quote() -> None:
    """A literal apostrophe in the value must be escape-quoted via the
    standard '\\'' trick so the surrounding single-quote pair stays
    balanced under shell parsing."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_AUTO_CONTINUE": "1",
        "CLAUDE_AUTO_CONTINUE_PROMPT": "it's me",
    }
    cmd = run_block(BLOCK, env)
    # The value 'it's me' becomes 'it'\''s me' inside single quotes.
    expect("--continue 'it'\\''s me'" in cmd,
           f"auto-continue with apostrophe: should be escape-quoted, "
           f"got {cmd!r}")
    # Sanity: re-parse via `bash -c "echo --continue $value"` and
    # confirm we get back the original.
    result = subprocess.run(
        ["bash", "-c", f"set -- {cmd}; printf '%s\\n' \"$@\""],
        capture_output=True,
        text=True,
        timeout=5,
    )
    expect("it's me" in result.stdout,
           f"auto-continue roundtrip: shell should parse value back as "
           f"\"it's me\", got stdout {result.stdout!r}")


def test_auto_continue_default_prompt() -> None:
    """CLAUDE_AUTO_CONTINUE=1 without CLAUDE_AUTO_CONTINUE_PROMPT →
    uses the built-in default session-start instruction."""
    env = {"PATH": "/usr/bin:/bin", "CLAUDE_AUTO_CONTINUE": "1"}
    cmd = run_block(BLOCK, env)
    expect("--continue" in cmd,
           f"auto-continue default: --continue should appear, got {cmd!r}")
    expect("session-start checklist" in cmd,
           f"auto-continue default: should contain default prompt text, "
           f"got {cmd!r}")


def test_plugin_dir_absent_no_flag() -> None:
    """When /opt/claude-container/plugin/.claude-plugin does NOT exist, the
    --plugin-dir flag must not appear (defensive no-op for older images
    pre-dating the baked container plugin)."""
    env = {"PATH": "/usr/bin:/bin"}
    cmd = run_block(BLOCK, env)
    expect(
        "--plugin-dir" not in cmd,
        f"plugin-dir absent: --plugin-dir should not appear, got {cmd!r}",
    )


def test_plugin_dir_present_appends_flag() -> None:
    """When /opt/claude-container/plugin/.claude-plugin exists, --plugin-dir
    /opt/claude-container/plugin is appended unconditionally — the baked
    container plugin (skills + agents) loads at session start.

    We can't create /opt/claude-container/plugin without root, but the test
    can still verify the conditional fires by re-extracting the block
    with the dir literal substituted to an existing tmpdir, then
    re-running."""
    with tempfile.TemporaryDirectory() as td:
        plug = Path(td) / "plugin"
        (plug / ".claude-plugin").mkdir(parents=True)
        # Substitute the hard-coded path in the extracted block. The block
        # references the path twice (once in the test, once in the assignment).
        patched_block = BLOCK.replace(
            "/opt/claude-container/plugin/.claude-plugin",
            str(plug / ".claude-plugin"),
        ).replace(
            "/opt/claude-container/plugin", str(plug)
        )
        env = {"PATH": "/usr/bin:/bin"}
        cmd = run_block(patched_block, env)
        expect(
            f"--plugin-dir {plug}" in cmd,
            f"plugin-dir present: should append --plugin-dir <plug>, "
            f"got {cmd!r}",
        )


def test_user_tier_not_in_source_list() -> None:
    """Regression guard for the v19 bug: when the FILTER_USER path fires
    (REWRITE_HOOKS=1 / shim contains wrapped host hooks), the source list
    MUST NOT include 'user' — otherwise the bind-mounted host
    settings.json's bare hooks would still load and fire 'Exec format
    error' on every event."""
    env = {
        "PATH": "/usr/bin:/bin",
        "CLAUDE_SHIM_SETTINGS_PATH": "/tmp/foo.json",
        "CLAUDE_SHIM_FILTER_USER": "1",
    }
    cmd = run_block(BLOCK, env)
    # Pull the comma-separated source list out and verify 'user' isn't there.
    m = re.search(r"--setting-sources\s+([^\s]+)", cmd)
    expect(m is not None,
           f"user-tier guard: --setting-sources flag missing, got {cmd!r}")
    if m:
        sources = m.group(1).split(",")
        expect("user" not in sources,
               f"user-tier guard: 'user' must not be in source list, got {sources}")


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

TESTS = [
    test_unset_shim_path_bare_claude,
    test_empty_shim_path_bare_claude,
    test_set_shim_path_includes_setting_sources,
    test_set_shim_path_order,
    test_set_shim_path_exact_form,
    test_sanitized_user_farm_switches_to_user_local,
    test_sanitized_user_farm_adds_mcp_config,
    test_sanitized_user_farm_mcp_config_absent_no_flag,
    test_unsanitized_farm_keeps_project_local,
    test_obligations_only_additive_no_filter,
    test_plugin_dir_absent_no_flag,
    test_plugin_dir_present_appends_flag,
    test_user_tier_not_in_source_list,
    test_auto_continue_unset_no_flag,
    test_auto_continue_empty_no_flag,
    test_auto_continue_single_word,
    test_auto_continue_with_shim,
    test_auto_continue_multiword_quoted,
    test_auto_continue_value_with_single_quote,
    test_auto_continue_default_prompt,
]

for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
