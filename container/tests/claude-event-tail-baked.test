#!/usr/bin/env python3
"""File-level test for the claude-event-watch watcher bake.

Asserts the fire-and-exit event watcher ships into the image:
  1. container/watchers/claude-event-watch.sh exists and is executable.
  2. container/watchers/claude-event-watch.toml exists, parses, and
     has all five required schema keys with the expected values.
  3. The .sh wrapper execs into /usr/local/bin/claude-event-watch.
  4. Dockerfile chmod-bakes the launcher path.

Does NOT execute the watcher (the runtime fire path is tested by
claude-event-watch's own test suite in tools/watchers/). The test
surface here is "the .sh + .toml pair lands in the image with the
right shape so /start-watchers can discover and launch it."

Run:  ./claude-event-tail-baked.test
"""

from __future__ import annotations

import os
import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
WATCHERS_DIR = CONTAINER_DIR / "watchers"

LAUNCHER = WATCHERS_DIR / "claude-event-watch.sh"
METADATA = WATCHERS_DIR / "claude-event-watch.toml"
DOCKERFILE = CONTAINER_DIR / "Dockerfile"

# Expected baked paths (what the metadata declares + what
# /start-watchers will probe).
BAKED_LAUNCHER = "/etc/claude-code/watchers/claude-event-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def parse_toml(path: Path) -> dict:
    """Minimal TOML parser for the schema we use (string-only
    top-level keys). Prefer tomllib (3.11+) when available, fall back
    to a hand-rolled key=value parser so the test runs on 3.10 too.

    The watcher .toml is a flat key = "value" file by spec — no
    tables, no arrays, no nested types — so the fallback is
    sufficient."""
    try:
        import tomllib  # type: ignore[import]
        with open(path, "rb") as fp:
            return tomllib.load(fp)
    except ImportError:
        out: dict = {}
        for line in path.read_text(encoding="utf-8").splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#"):
                continue
            m = re.match(
                r'^([A-Za-z_][A-Za-z0-9_]*)\s*=\s*"((?:[^"\\]|\\.)*)"\s*$',
                stripped,
            )
            if not m:
                raise AssertionError(
                    f"TOML fallback parser: cannot parse line {line!r}"
                )
            out[m.group(1)] = m.group(2)
        return out


# 1. Launcher: exists + executable.
expect(LAUNCHER.is_file(), f"claude-event-watch.sh missing at {LAUNCHER}")
if LAUNCHER.is_file():
    expect(
        os.access(LAUNCHER, os.X_OK),
        f"claude-event-watch.sh at {LAUNCHER} not executable — "
        f"recursive Dockerfile COPY preserves source perms, source "
        f"must have +x",
    )

    text = LAUNCHER.read_text(encoding="utf-8")

    # Bash shebang.
    first_line = text.splitlines()[0] if text else ""
    expect(
        first_line.startswith("#!") and "bash" in first_line,
        f"claude-event-watch.sh first line must be a bash shebang, got "
        f"{first_line!r}",
    )

    # Must exec into the baked binary at /usr/local/bin/claude-event-watch.
    expect(
        "/usr/local/bin/claude-event-watch" in text,
        f"claude-event-watch.sh must exec into /usr/local/bin/claude-event-watch "
        f"(the baked binary the Dockerfile COPYs from tools/watchers/)",
    )

# 2. Metadata: present + schema valid.
expect(METADATA.is_file(), f"claude-event-watch.toml missing at {METADATA}")
if METADATA.is_file():
    try:
        meta = parse_toml(METADATA)
    except Exception as e:
        failures.append(f"claude-event-watch.toml parse error: {e}")
        meta = {}

    # Required keys per container/watchers/README.md schema.
    REQUIRED_KEYS = (
        "name", "description", "launcher", "restart_policy", "log_path"
    )
    for k in REQUIRED_KEYS:
        expect(
            k in meta,
            f"claude-event-watch.toml missing required key {k!r}. "
            f"Schema (per container/watchers/README.md): {REQUIRED_KEYS}",
        )

    if meta:
        expect(
            meta.get("name") == "claude-event-watch",
            f"claude-event-watch.toml name must be 'claude-event-watch', "
            f"got {meta.get('name')!r}",
        )
        expect(
            meta.get("launcher") == BAKED_LAUNCHER,
            f"claude-event-watch.toml launcher must be {BAKED_LAUNCHER!r} "
            f"(the baked image path /start-watchers probes), got "
            f"{meta.get('launcher')!r}",
        )
        expect(
            meta.get("restart_policy") in ("session", "always", "on-failure", "never"),
            f"claude-event-watch.toml restart_policy must be one of "
            f"session/always/on-failure/never, got {meta.get('restart_policy')!r}",
        )
        # Fire-and-exit watchers use restart_policy = "session" — the
        # supervisor restarts them on each exit because that's how
        # delivery works (block, print, exit, restart).
        expect(
            meta.get("restart_policy") == "session",
            f"claude-event-watch.toml restart_policy expected 'session' "
            f"(the watcher follows fire-and-exit; supervisor restarts on "
            f"each exit), got {meta.get('restart_policy')!r}",
        )
        log_path = meta.get("log_path") or ""
        expect(
            log_path.startswith("/tmp/") or log_path.startswith("/var/log"),
            f"claude-event-watch.toml log_path should live under /tmp/ "
            f"or /var/log (uid-1000-writable paths inside the "
            f"container), got {log_path!r}",
        )

# 3. Dockerfile bake.
if DOCKERFILE.is_file():
    df = DOCKERFILE.read_text(encoding="utf-8")
    # Match the chmod across line continuations (`\` newline).
    chmod_pat = re.compile(
        r"chmod\s+\+x\s+(?:[^\n]|\\\n)*"
        r"/etc/claude-code/watchers/claude-event-watch\.sh",
    )
    expect(
        chmod_pat.search(df) is not None,
        f"Dockerfile: missing `chmod +x {BAKED_LAUNCHER}` after the "
        f"watchers COPY. Mirrors the defence-in-depth pattern every "
        f"other baked-script bake uses (cwsr, exec-hook, self-clear).",
    )


if failures:
    print("FAIL claude-event-watch-baked.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS claude-event-watch-baked.test")
sys.exit(0)
