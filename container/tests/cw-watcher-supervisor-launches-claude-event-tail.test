#!/usr/bin/env python3
"""Runtime test: cw-watcher-supervisor launches + respawns a watcher.

The supervisor reads /etc/claude-code/watchers/*.toml and launches
each watcher's launcher script with respawn-on-exit semantics. This
test exercises that path end-to-end against a synthetic watchers dir
that mirrors the source-tree's claude-event-tail wiring:

  - Build a temp watchers dir.
  - Copy lib/dir-watch.sh + claude-event-tail.sh into it.
  - Write a claude-event-tail.toml pointing at the temp launcher.
  - Point the launcher's CLAUDE_EVENT_QUEUE + DIR_WATCH_LIB at temp
    paths so the watcher fires inside our sandbox.
  - Launch the supervisor (via CW_WATCHERS_DIR override) against the
    temp dir, wait for the launcher process to appear.
  - SIGTERM the launcher; assert the supervisor respawns it
    (restart_policy = always).
  - SIGTERM the supervisor; assert it reaps the launcher cleanly.

We can't run the entrypoint-spawned supervisor here (no container);
we run the supervisor binary directly with an env override.

Run:  ./cw-watcher-supervisor-launches-claude-event-tail.test
"""

from __future__ import annotations

import os
import shutil
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

SUPERVISOR = CONTAINER_DIR / "bin" / "cw-watcher-supervisor"
DIR_WATCH_LIB = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"
CLAUDE_EVENT_TAIL = CONTAINER_DIR / "watchers" / "claude-event-tail.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def find_launcher_pids(launcher_path: Path, primitive_path: Path) -> list[int]:
    """Find PIDs whose cmdline matches the launcher OR the primitive
    that the launcher exec's into. We use /proc rather than pgrep so
    the test works without procps installed.

    Note: claude-event-tail.sh ends with `exec "$DIR_WATCH_LIB"`, so
    the PID we record at spawn time keeps its identity but its cmdline
    flips from the launcher path to the primitive path. The supervisor
    still owns it via its Popen handle, but match against either path
    so the test sees the running child either way."""
    pids: list[int] = []
    launcher_bytes = str(launcher_path).encode()
    primitive_bytes = str(primitive_path).encode()
    for entry in Path("/proc").iterdir():
        if not entry.name.isdigit():
            continue
        cmdline_path = entry / "cmdline"
        try:
            cmdline = cmdline_path.read_bytes()
        except (FileNotFoundError, PermissionError, ProcessLookupError):
            continue
        argv = cmdline.split(b"\x00")
        # Match either the launcher script (before exec) or the
        # primitive (after exec).
        if any(launcher_bytes in a or primitive_bytes in a for a in argv):
            pids.append(int(entry.name))
    return pids


def setup_temp_watchers(td: Path) -> tuple[Path, Path, Path, Path]:
    """Build a temp watchers dir with claude-event-tail wired up.
    Returns (watchers_dir, launcher_path, primitive_path,
    event_queue_dir)."""
    watchers = td / "watchers"
    watchers.mkdir()
    lib_dir = watchers / "lib"
    lib_dir.mkdir()

    # Copy primitives + launcher.
    shutil.copy2(DIR_WATCH_LIB, lib_dir / "dir-watch.sh")
    shutil.copy2(CLAUDE_EVENT_TAIL, watchers / "claude-event-tail.sh")
    (lib_dir / "dir-watch.sh").chmod(0o755)
    (watchers / "claude-event-tail.sh").chmod(0o755)

    # Event queue + log dirs.
    event_queue = td / "claude-events"
    event_queue.mkdir()
    event_log = td / "config-claude-events"
    event_log.mkdir()
    log_dir = td / "claude-container-watchers"
    log_dir.mkdir()

    launcher = watchers / "claude-event-tail.sh"
    primitive = lib_dir / "dir-watch.sh"
    toml = watchers / "claude-event-tail.toml"
    toml.write_text(
        f'name = "claude-event-tail"\n'
        f'description = "test wiring"\n'
        f'launcher = "{launcher}"\n'
        f'restart_policy = "always"\n'
        f'log_path = "{log_dir / "claude-event-tail.log"}"\n'
    )

    return watchers, launcher, primitive, event_queue


def start_supervisor(
    watchers_dir: Path, event_queue: Path, log_path: Path
) -> subprocess.Popen:
    """Launch cw-watcher-supervisor against the temp watchers dir.
    Returns the Popen handle. We set DIR_WATCH_LIB so the
    claude-event-tail launcher exec's the temp primitive (not the
    hard-coded /etc/claude-code/watchers/lib/dir-watch.sh path)."""
    env = {
        **os.environ,
        "CW_WATCHERS_DIR": str(watchers_dir),
        "CLAUDE_EVENT_QUEUE": str(event_queue),
        "DIR_WATCH_LIB": str(watchers_dir / "lib" / "dir-watch.sh"),
    }
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        ["python3", str(SUPERVISOR)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        # New process group so SIGTERM propagates to children.
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen, timeout: float = 5.0) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=timeout)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        try:
            proc.wait(timeout=2)
        except subprocess.TimeoutExpired:
            pass


def test_supervisor_present() -> None:
    """Sanity: supervisor + claude-event-tail launcher both exist."""
    assert SUPERVISOR.is_file(), f"supervisor missing at {SUPERVISOR}"
    assert CLAUDE_EVENT_TAIL.is_file(), \
        f"claude-event-tail.sh missing at {CLAUDE_EVENT_TAIL}"
    assert DIR_WATCH_LIB.is_file(), \
        f"dir-watch.sh missing at {DIR_WATCH_LIB}"


def test_supervisor_launches_and_respawns() -> None:
    """End-to-end: supervisor launches claude-event-tail, respawns it
    after a SIGTERM (restart_policy = always)."""
    with tempfile.TemporaryDirectory(prefix="cw-supervisor-") as td:
        td_path = Path(td)
        watchers_dir, launcher, primitive, event_queue = setup_temp_watchers(td_path)
        sup_log = td_path / "supervisor.log"
        proc = start_supervisor(watchers_dir, event_queue, sup_log)

        try:
            # Wait for the launcher process to be alive. The launcher
            # exec's into the dir-watch primitive, so match on either
            # script's path in /proc/<pid>/cmdline.
            got_first = wait_for(
                lambda: len(find_launcher_pids(launcher, primitive)) > 0,
                timeout=15,
            )
            initial_pids = find_launcher_pids(launcher, primitive)
            expect(
                got_first,
                f"supervisor did not launch claude-event-tail within "
                f"15s. supervisor_log="
                f"{sup_log.read_text(errors='replace') if sup_log.exists() else '<missing>'!r}",
            )
            expect(
                len(initial_pids) > 0,
                f"no launcher PIDs visible in /proc after supervisor "
                f"start; pids={initial_pids!r}",
            )

            if not initial_pids:
                return

            # Kill the launcher process. The supervisor must respawn it.
            first_pid = initial_pids[0]
            try:
                os.kill(first_pid, signal.SIGTERM)
            except ProcessLookupError:
                pass

            # Wait for a new PID to appear (different from the one we
            # killed). The supervisor's poll loop runs every ~0.5s and
            # the default backoff for the first failure is 1s, so we
            # need at least ~2-3s budget; allow 20s for safety.
            def respawned() -> bool:
                pids = find_launcher_pids(launcher, primitive)
                return any(p != first_pid for p in pids)

            got_respawn = wait_for(respawned, timeout=20)
            new_pids = find_launcher_pids(launcher, primitive)
            expect(
                got_respawn,
                f"supervisor did not respawn claude-event-tail after "
                f"killing pid {first_pid}. New pids: {new_pids!r}. "
                f"Supervisor log:\n"
                f"{sup_log.read_text(errors='replace') if sup_log.exists() else '<missing>'}",
            )

            # The supervisor itself must still be running.
            expect(
                proc.poll() is None,
                f"supervisor exited (rc={proc.poll()!r}) after a "
                f"single watcher exit; restart_policy=always means it "
                f"must keep supervising. Log:\n"
                f"{sup_log.read_text(errors='replace') if sup_log.exists() else '<missing>'}",
            )

        finally:
            stop(proc)

        # After supervisor exit, the launcher process must also be
        # gone (clean reap via SIGTERM to the launcher's process group).
        deadline = time.monotonic() + 8.0
        while time.monotonic() < deadline:
            if not find_launcher_pids(launcher, primitive):
                break
            time.sleep(0.2)
        remaining = find_launcher_pids(launcher, primitive)
        expect(
            not remaining,
            f"after supervisor SIGTERM, launcher processes still alive: "
            f"{remaining!r}. Supervisor must drain children on shutdown.",
        )


def test_supervisor_handles_empty_watchers_dir() -> None:
    """Supervisor exits cleanly when the watchers dir has no .tomls."""
    with tempfile.TemporaryDirectory(prefix="cw-supervisor-empty-") as td:
        td_path = Path(td)
        watchers = td_path / "empty"
        watchers.mkdir()
        sup_log = td_path / "supervisor.log"

        env = {
            **os.environ,
            "CW_WATCHERS_DIR": str(watchers),
        }
        result = subprocess.run(
            ["python3", str(SUPERVISOR)],
            env=env,
            capture_output=True,
            text=True,
            timeout=10,
        )
        expect(
            result.returncode == 0,
            f"supervisor empty-dir rc={result.returncode}, "
            f"stderr={result.stderr!r}",
        )
        expect(
            "no watchers to supervise" in result.stderr,
            f"supervisor empty-dir should announce 'no watchers to "
            f"supervise'; stderr={result.stderr!r}",
        )


TESTS = [
    test_supervisor_present,
    test_supervisor_launches_and_respawns,
    test_supervisor_handles_empty_watchers_dir,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
