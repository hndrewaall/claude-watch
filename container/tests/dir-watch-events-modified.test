#!/usr/bin/env python3
"""dir-watch.sh: WATCH_EVENTS=created modified — modify fires after create.

Drops a file (expecting `created`), waits, modifies it (expecting
`modified`), confirms the callback receives the right $2 action label
for each phase.

The callback writes one `<action> <basename>` line per fire to a log,
so the test can assert on exact action-per-event ordering.

Run:  ./dir-watch-events-modified.test
"""

from __future__ import annotations

import os
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
SCRIPT = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def start_watcher(watch_dir: Path, pattern: str, callback: str,
                  state_file: Path, log_path: Path,
                  events: str) -> subprocess.Popen:
    env = {
        **os.environ,
        "WATCH_DIR": str(watch_dir),
        "WATCH_PATTERN": pattern,
        "WATCH_CALLBACK": callback,
        "WATCH_STATE_FILE": str(state_file),
        "WATCH_EVENTS": events,
        "POLL_INTERVAL_SECS": "1",
    }
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        [str(SCRIPT)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=2)


def test_create_then_modify_fires_both_actions() -> None:
    """create file -> fires `created`; modify file -> fires `modified`.
    Pre-events callers (WATCH_EVENTS unset) wouldn't see the second
    event; opting into `modified` does."""
    with tempfile.TemporaryDirectory(prefix="dwe-modified-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        # Callback logs "<action> <basename>" per fire.
        callback = f'printf "%s %s\\n" "$2" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
            events="created modified",
        )

        try:
            target = watch_dir / "live.json"
            target.write_text('{"v":1}')

            got_create = wait_for(
                lambda: fired_log.exists()
                and "created live.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                got_create,
                f"`created` event for live.json did not arrive within 10s. "
                f"fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            # mtime granularity on most filesystems is 1s; sleep a bit
            # more than that so the modify produces a distinct mtime
            # from the create.
            time.sleep(1.2)
            target.write_text('{"v":2}')

            got_modify = wait_for(
                lambda: fired_log.exists()
                and "modified live.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                got_modify,
                f"`modified` event for live.json did not arrive within 10s. "
                f"fired_log="
                f"{fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log="
                f"{log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            # Order check: the `created` line must appear before the
            # `modified` line.
            content = fired_log.read_text()
            ci = content.find("created live.json")
            mi = content.find("modified live.json")
            expect(
                ci != -1 and mi != -1 and ci < mi,
                f"Event order wrong — created should precede modified. "
                f"fired_log={content!r}",
            )

            # The watcher must still be alive.
            expect(
                proc.poll() is None,
                f"watcher exited after firing (rc={proc.poll()})",
            )
        finally:
            stop(proc)


TESTS = [
    test_create_then_modify_fires_both_actions,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
