#!/usr/bin/env python3
"""End-to-end test for container/watchers/lib/dir-watch.sh.

Drops two files into a temp dir, asserts the callback fires for each.
The point is to prove the re-arm contract: a single watcher process
fires the callback per matching file and KEEPS WATCHING — never exits
after the first event.

We isolate from the operator's real ~/claude-events/ by using a fresh
temp dir for both WATCH_DIR and the state file. The script runs as a
background subprocess so we can drop files into the watched dir mid-
test and observe the stdout stream.

Behaviour matrix:
  - Both inotifywait-backed and poll-fallback paths must re-arm.
    Detected at runtime: if `inotifywait` is on PATH the script uses
    it; otherwise it polls every 3s (POLL_INTERVAL_SECS).
  - The callback is invoked once per file. The state file prevents
    re-fire on the same basename across restarts (covered by the
    state-file persistence subtest).

Run:  ./dir-watch-rearms.test
"""

from __future__ import annotations

import os
import shutil
import signal
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
SCRIPT = CONTAINER_DIR / "watchers" / "lib" / "dir-watch.sh"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def wait_for(predicate, timeout: float, interval: float = 0.1) -> bool:
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if predicate():
            return True
        time.sleep(interval)
    return False


def start_watcher(watch_dir: Path, pattern: str, callback: str,
                  state_file: Path, log_path: Path) -> subprocess.Popen:
    """Launch dir-watch.sh as a background subprocess. The callback
    writes to a file (the test reads it back to see what fired)."""
    env = {
        **os.environ,
        "WATCH_DIR": str(watch_dir),
        "WATCH_PATTERN": pattern,
        "WATCH_CALLBACK": callback,
        "WATCH_STATE_FILE": str(state_file),
        # Short poll interval so the fallback path completes
        # within the test's timeout budget.
        "POLL_INTERVAL_SECS": "1",
    }
    log_fp = open(log_path, "wb")
    proc = subprocess.Popen(
        [str(SCRIPT)],
        env=env,
        stdout=log_fp,
        stderr=subprocess.STDOUT,
        # Detach from this script's tty so we can kill via PG.
        preexec_fn=os.setsid,
    )
    return proc


def stop(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        return
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=2)


def test_script_exists_and_executable() -> None:
    """The primitive lives at container/watchers/lib/dir-watch.sh and
    is executable (the Dockerfile bakes the +x bit; the test mirrors
    that contract on the source side)."""
    assert SCRIPT.is_file(), f"dir-watch.sh missing at {SCRIPT}"
    assert os.access(SCRIPT, os.X_OK), f"dir-watch.sh not executable at {SCRIPT}"


def test_required_env_validation() -> None:
    """Missing WATCH_DIR / WATCH_PATTERN / WATCH_CALLBACK each => exit 2."""
    base_env = {**os.environ}
    # Drop any of these that might leak from the test runner.
    for k in ("WATCH_DIR", "WATCH_PATTERN", "WATCH_CALLBACK"):
        base_env.pop(k, None)

    cases = [
        # Missing all → first check (WATCH_DIR) fires.
        ({}, "WATCH_DIR"),
        # WATCH_DIR set, missing pattern.
        ({"WATCH_DIR": "/tmp"}, "WATCH_PATTERN"),
        # WATCH_DIR + pattern, missing callback.
        ({"WATCH_DIR": "/tmp", "WATCH_PATTERN": "*"}, "WATCH_CALLBACK"),
    ]
    for extra, expected_token in cases:
        env = {**base_env, **extra}
        result = subprocess.run(
            [str(SCRIPT)],
            env=env,
            capture_output=True,
            text=True,
            timeout=5,
        )
        expect(
            result.returncode == 2,
            f"missing-env case {extra!r}: expected exit 2, got "
            f"{result.returncode} (stderr={result.stderr!r})",
        )
        expect(
            expected_token in result.stderr,
            f"missing-env case {extra!r}: stderr should mention "
            f"{expected_token!r}, got {result.stderr!r}",
        )


def test_fires_per_new_file_and_rearms() -> None:
    """Drop two files, get two fires. Same watcher process, no exit
    between events. This is the core re-arm assertion."""
    with tempfile.TemporaryDirectory(prefix="dir-watch-test-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        # Callback appends the file's BASENAME to fired_log. We read
        # fired_log to verify which files fired the callback.
        callback = f'printf "%s\\n" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
        )

        try:
            # Drop file #1.
            (watch_dir / "alpha.json").write_text('{"ok":1}')

            # Wait for the first fire. inotifywait should pick this up
            # in well under 1s; the poll fallback takes up to
            # POLL_INTERVAL_SECS=1s + the script's own scheduling
            # latency. Give 10s either way.
            got_first = wait_for(
                lambda: fired_log.exists()
                and "alpha.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                got_first,
                f"first fire did not arrive within 10s. "
                f"fired_log={fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log={log_path.read_text() if log_path.exists() else '<missing>'!r}",
            )

            # Drop file #2 AFTER the first fire. This is the re-arm
            # test: the watcher must still be alive and listening.
            (watch_dir / "bravo.json").write_text('{"ok":2}')

            got_second = wait_for(
                lambda: fired_log.exists()
                and "bravo.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                got_second,
                f"second fire (re-arm) did not arrive within 10s. "
                f"fired_log={fired_log.read_text() if fired_log.exists() else '<missing>'!r} "
                f"watcher_log={log_path.read_text() if log_path.exists() else '<missing>'!r} "
                f"proc.poll={proc.poll()!r}",
            )

            # Process must STILL be running. The watcher never exits
            # on a successful fire — it loops back to inotifywait.
            expect(
                proc.poll() is None,
                f"watcher exited after firing (proc.poll={proc.poll()}); "
                f"re-arm contract is 'never exit on success'",
            )

            # Pattern non-match: drop a file that doesn't match *.json
            # and confirm it does NOT fire.
            (watch_dir / "ignored.txt").write_text("noise")
            time.sleep(2)
            fired = fired_log.read_text()
            expect(
                "ignored.txt" not in fired,
                f"non-matching file ignored.txt fired the callback; "
                f"WATCH_PATTERN gating broken. fired_log={fired!r}",
            )

        finally:
            stop(proc)


def test_state_file_prevents_refire() -> None:
    """Re-create the same basename after marking it seen → no second fire.
    This guards against double-deliveries when a peer process re-drops
    a file under the same name."""
    with tempfile.TemporaryDirectory(prefix="dir-watch-state-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        callback = f'printf "%s\\n" "$(basename "$1")" >> "{fired_log}"'

        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
        )

        try:
            (watch_dir / "same.json").write_text('{"x":1}')
            wait_for(
                lambda: fired_log.exists()
                and fired_log.read_text().count("same.json") == 1,
                timeout=10,
            )

            # Remove and re-create. State file should still have
            # "same.json" recorded.
            (watch_dir / "same.json").unlink()
            time.sleep(0.5)
            (watch_dir / "same.json").write_text('{"x":2}')

            # Wait long enough that a buggy implementation would fire
            # a second time (longer than POLL_INTERVAL_SECS).
            time.sleep(3)

            count = fired_log.read_text().count("same.json")
            expect(
                count == 1,
                f"state-file re-fire suppression broken: same.json "
                f"fired {count} times, expected 1. fired_log="
                f"{fired_log.read_text()!r}",
            )
        finally:
            stop(proc)


def test_drain_picks_up_pending_files() -> None:
    """Files that exist BEFORE the watcher starts must be drained on
    startup — events landing pre-start aren't lost."""
    with tempfile.TemporaryDirectory(prefix="dir-watch-drain-") as td:
        td_path = Path(td)
        watch_dir = td_path / "watch"
        watch_dir.mkdir()
        state_file = td_path / "state"
        log_path = td_path / "watcher.log"
        fired_log = td_path / "fired.log"

        # Drop files BEFORE starting the watcher.
        (watch_dir / "preexist1.json").write_text("{}")
        (watch_dir / "preexist2.json").write_text("{}")

        callback = f'printf "%s\\n" "$(basename "$1")" >> "{fired_log}"'
        proc = start_watcher(
            watch_dir,
            "*.json",
            callback,
            state_file,
            log_path,
        )

        try:
            ok = wait_for(
                lambda: fired_log.exists()
                and "preexist1.json" in fired_log.read_text()
                and "preexist2.json" in fired_log.read_text(),
                timeout=10,
            )
            expect(
                ok,
                f"drain on startup missed pre-existing files. "
                f"fired_log={fired_log.read_text() if fired_log.exists() else '<missing>'!r}",
            )
        finally:
            stop(proc)


TESTS = [
    test_script_exists_and_executable,
    test_required_env_validation,
    test_fires_per_new_file_and_rearms,
    test_state_file_prevents_refire,
    test_drain_picks_up_pending_files,
]


for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")


if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
