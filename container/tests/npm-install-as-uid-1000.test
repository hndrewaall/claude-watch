#!/usr/bin/env python3
"""Tests for the autoupdate-v2 in-container npm-install shape.

Background: PR #204 (chown the /usr/bin/claude symlink to uid 1000)
was NOT enough to make in-container `claude update` succeed. Workbot
v68 validation 2026-05-15 showed `claude update` still failed with:

    Current version: 2.1.142
    ...
    Using global installation update method...
    Error: Insufficient permissions to install update
    Try running with sudo or fix npm permissions

Diagnosis: Claude Code's in-process `npm install -g
@anthropic-ai/claude-code@latest` runs as uid 1000 and writes to
npm's CONFIGURED prefix, not to the historical install location.
With npm's stock default prefix of `/usr/local`, every self-update
attempt tried to write to `/usr/local/lib/node_modules/` (root-owned)
and failed. The chown on the original install tree at /usr/lib/...
didn't help — npm wasn't trying to write there.

Fix (autoupdate-v2): set npm's prefix to /home/hndrewaall/.npm-global
(canonical "unprivileged npm-global" pattern per npm docs) and run
the build-time install as uid 1000 from the start. Both build-time
AND self-update-time installs land in the same uid-1000-owned tree.

This test asserts the file-level wiring guarantees from a different
angle than claude-bin-symlink-uid.test:

  1. The Dockerfile must NOT reference /usr/local/lib/node_modules
     as a write target. /usr/local is root-owned in the base image
     and any RUN/COPY that depends on it would re-introduce the v68
     failure mode.

  2. The Dockerfile must NOT chown `/usr/lib/node_modules/` (the
     PRE-autoupdate-v2 install location). Lingering chown lines
     against the old path would be dead code — a refactor smell that
     suggests someone tried to half-revert the v2 fix.

  3. The npm prefix value referenced in the Dockerfile must match
     the CONTAINER_CLAUDE_EXE_PREFIX constant in src/agent.rs (modulo
     the `/bin/...` vs `/lib/node_modules/...` split). The
     find_claude_pid_with_paths(container_mode=true) probe in
     claude-watch reads /proc/<pid>/exe and matches against this
     constant — if the Dockerfile install path drifts from the Rust
     constant, container-mode PID detection breaks silently on fresh
     container boots until the in-container claude self-updates and
     lands a versions/<ver>/ entry into the named volume.

  4. The PATH env in the Dockerfile must include
     /home/hndrewaall/.npm-global/bin so the entrypoint, tmux panes,
     and `docker compose exec` invocations all resolve `claude` from
     the uid-1000-owned npm prefix rather than relying on the
     /usr/bin/claude symlink as the only entry point.

Run:  ./npm-install-as-uid-1000.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
REPO_ROOT = CONTAINER_DIR.parent
DOCKERFILE = CONTAINER_DIR / "Dockerfile"
AGENT_RS = REPO_ROOT / "src" / "agent.rs"

EXPECTED_NPM_PREFIX = "/home/hndrewaall/.npm-global"
EXPECTED_NPM_LIB = f"{EXPECTED_NPM_PREFIX}/lib/node_modules/@anthropic-ai/claude-code/"

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")
expect(AGENT_RS.exists(), f"src/agent.rs missing at {AGENT_RS}")

if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")

    # Strip comment-only lines (whitespace + `#`) so explanatory paragraphs
    # describing the OLD shape don't false-positive against the
    # "no /usr/local/lib/node_modules write target" check. We still want
    # the comments in the file (they explain the autoupdate-v2 fix
    # rationale); we just don't want them to count as build-time refs.
    df_no_comments = "\n".join(
        line for line in df.splitlines() if not line.lstrip().startswith("#")
    )

    # 1. No write target under /usr/local/lib/node_modules. The
    #    stock-npm default prefix landing point is exactly the location
    #    the v68 failure observed; we MUST stay off it.
    bad_usr_local = re.search(r"/usr/local/lib/node_modules\b", df_no_comments)
    expect(
        bad_usr_local is None,
        "Dockerfile: must NOT reference /usr/local/lib/node_modules as a "
        "write target (comments allowed for historical context). That's "
        "npm's stock default prefix and the exact location workbot v68 saw "
        "`claude update` fail to write to (2026-05-15). The autoupdate-v2 "
        f"fix configures npm prefix to {EXPECTED_NPM_PREFIX} instead.",
    )

    # 2. No `chown ... /usr/lib/node_modules/` lines. The old install
    #    path was /usr/lib/node_modules/@anthropic-ai/; lingering chown
    #    against it would be dead code suggesting an incomplete refactor.
    stale_chown = re.search(
        r"chown\s+[^\n]+/usr/lib/node_modules/@anthropic-ai\b",
        df_no_comments,
    )
    expect(
        stale_chown is None,
        "Dockerfile: contains a stale `chown ... /usr/lib/node_modules/"
        "@anthropic-ai` line. The autoupdate-v2 fix moved the install "
        f"to {EXPECTED_NPM_PREFIX}; any lingering chown of the old "
        "path is dead code and should be removed.",
    )

    # 3. PATH includes the npm-global bindir. Without it, the entrypoint
    #    and tmux panes fall back to /usr/bin/claude (the symlink). The
    #    symlink works as a stable entry point but the canonical PATH
    #    resolution should land directly on the npm-global binary.
    path_match = re.search(r"^ENV\s+PATH=([^\s]+)", df, re.MULTILINE)
    expect(
        path_match is not None,
        "Dockerfile: missing `ENV PATH=...` directive. This shouldn't "
        "happen — every container image needs PATH baked.",
    )
    if path_match:
        path_value = path_match.group(1)
        expect(
            f"{EXPECTED_NPM_PREFIX}/bin" in path_value,
            f"Dockerfile: PATH does not include `{EXPECTED_NPM_PREFIX}/bin`. "
            "Without it, the baked claude binary at "
            f"{EXPECTED_NPM_PREFIX}/bin/claude is only reachable via the "
            "/usr/bin/claude symlink, not via direct PATH resolution. "
            f"Found PATH={path_value!r}.",
        )

if AGENT_RS.exists():
    rs = AGENT_RS.read_text(encoding="utf-8")

    # 4. CONTAINER_CLAUDE_EXE_PREFIX in agent.rs must match the npm
    #    prefix configured in the Dockerfile. Drift between the two
    #    silently breaks claude-watch's container-mode PID probe.
    const_match = re.search(
        r'pub const CONTAINER_CLAUDE_EXE_PREFIX:\s*&str\s*=\s*"([^"]+)"',
        rs,
    )
    expect(
        const_match is not None,
        "src/agent.rs: cannot find `pub const CONTAINER_CLAUDE_EXE_PREFIX: "
        "&str = \"...\"`. Did the constant get renamed?",
    )
    if const_match:
        value = const_match.group(1)
        expect(
            value == EXPECTED_NPM_LIB,
            "src/agent.rs: CONTAINER_CLAUDE_EXE_PREFIX must match the "
            "Dockerfile's npm prefix path. Expected "
            f"{EXPECTED_NPM_LIB!r}, found {value!r}. The constant feeds "
            "find_claude_pid_with_paths(container_mode=true), which reads "
            "/proc/<pid>/exe to identify the in-container claude PID; "
            "drift between the Dockerfile install path and this constant "
            "silently breaks PID detection until self-update lands a "
            "versions/<ver>/ entry in the named volume.",
        )


if failures:
    print("FAIL npm-install-as-uid-1000.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS npm-install-as-uid-1000.test")
sys.exit(0)
