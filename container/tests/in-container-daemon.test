#!/usr/bin/env python3
"""Tests for the in-container claude-watch daemon wiring.

Background — claude-watch-container-diagnostic.md (q-e1c1, 2026-05-14)
found the host's claude-watch.service is tmux-bound to the host tmux
server and CANNOT reach the container's tmux server at all. Without an
in-container daemon, every claude-watch feature (activity / token
monitor, fresh-/clear detection, resume injection, self-clear,
prolonged-thinking interrupt, auto-respawn) silently no-ops for the cw
container. The fix: run `claude-watch` as a supervised process under
process-compose, gated by the CLAUDE_CONTAINER_DAEMON_DISABLED env var
(default OFF — daemon runs by default).

This test verifies the FILE-LEVEL wiring (process-compose.yml +
Dockerfile + claude-watch.config.toml). It does NOT spawn a container
or shell into one — runtime exercise lives in workbot v-prompts.

Coverage:
  1. process-compose.yml declares a `claude-watch` long-running process
     that invokes the cw-claude-watch-launch wrapper (which exports
     CLAUDE_WATCH_CONTAINER_MODE=1 + writes to /tmp/claude-watch.log).
  2. The process declares `restart: on_failure` so a daemon crash
     triggers a restart.
  3. Dockerfile bakes container/bin/self-clear at /usr/local/bin/self-clear
     so the daemon's `Command::new("self-clear")` (policy.rs
     spawn_immediate_clear / spawn_deferred_clear) resolves regardless
     of whether the operator bind-mounts host ~/bin.
  4. claude-watch.config.toml has [auto_respawn_on_hang] with
     respawn_command = ["cwsr", "--no-upgrade"] so when an operator opts
     IN to auto-respawn, the daemon rolls the inner pane via cwsr.
  5. tools/watchers/self-clear is a symlink to ../../container/bin/self-clear
     so the host's `~/bin/self-clear -> tools/watchers/self-clear` chain
     and the container build (whose context is container/) end up running
     the same bytes.
  6. cw-claude-watch-launch baked + exports CLAUDE_WATCH_CONTAINER_MODE=1.

Run:  ./in-container-daemon.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent
REPO_ROOT = CONTAINER_DIR.parent

ENTRYPOINT = CONTAINER_DIR / "entrypoint.sh"
DOCKERFILE = CONTAINER_DIR / "Dockerfile"
CONFIG_TOML = CONTAINER_DIR / "claude-watch.config.toml"
SELF_CLEAR_BIN = CONTAINER_DIR / "bin" / "self-clear"
TOOLS_SELF_CLEAR = REPO_ROOT / "tools" / "watchers" / "self-clear"
PC_CONFIG = CONTAINER_DIR / "process-compose.yml"
CW_LAUNCH = CONTAINER_DIR / "bin" / "cw-claude-watch-launch"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# ---------------------------------------------------------------------------
# 1-2. process-compose.yml declares the claude-watch process.
# ---------------------------------------------------------------------------
expect(PC_CONFIG.exists(), f"process-compose.yml missing at {PC_CONFIG}")
if PC_CONFIG.exists():
    pc_text = PC_CONFIG.read_text(encoding="utf-8")

    cw_block = re.search(
        r"(?ms)^  claude-watch:\s*$(.+?)(?=^  \w|^\Z)",
        pc_text,
    )
    expect(
        cw_block is not None,
        "process-compose.yml must declare a `claude-watch` process. "
        "Without it the in-container daemon never starts and every "
        "claude-watch feature silently no-ops (the diagnostic-flagged "
        "regression).",
    )
    if cw_block:
        body = cw_block.group(1)
        # Must invoke the cw-claude-watch-launch wrapper (which sets
        # CLAUDE_WATCH_CONTAINER_MODE=1).
        expect(
            "cw-claude-watch-launch" in body,
            "process-compose.yml: claude-watch process must invoke the "
            "/usr/local/bin/cw-claude-watch-launch wrapper. The wrapper "
            "exports CLAUDE_WATCH_CONTAINER_MODE=1 before exec'ing the "
            "daemon, which enables the npm-global exe-path fallback "
            "for find_claude_pid().",
        )
        expect(
            re.search(r"restart:\s*on_failure", body) is not None,
            "process-compose.yml: claude-watch process must declare "
            "`restart: on_failure` so a daemon crash triggers a restart.",
        )

# 1b. Entrypoint preserves the legacy CLAUDE_CONTAINER_DAEMON=0 opt-out.
expect(ENTRYPOINT.exists(), f"entrypoint.sh missing at {ENTRYPOINT}")
if ENTRYPOINT.exists():
    text = ENTRYPOINT.read_text(encoding="utf-8")
    expect(
        "CLAUDE_CONTAINER_DAEMON_DISABLED" in text,
        "entrypoint.sh: must export CLAUDE_CONTAINER_DAEMON_DISABLED "
        "when the legacy opt-out env var is set to 0. "
        "process-compose.yml's `disabled:` field reads the *_DISABLED "
        "variant; mapping preserves backwards compat with operator "
        ".env files that set CLAUDE_CONTAINER_DAEMON=0.",
    )

# 6. cw-claude-watch-launch wrapper exists and exports CONTAINER_MODE.
expect(CW_LAUNCH.exists(), f"cw-claude-watch-launch missing at {CW_LAUNCH}")
if CW_LAUNCH.exists():
    launch_text = CW_LAUNCH.read_text(encoding="utf-8")
    expect(
        "export CLAUDE_WATCH_CONTAINER_MODE=1" in launch_text,
        "cw-claude-watch-launch must `export CLAUDE_WATCH_CONTAINER_MODE=1` "
        "so the daemon's find_claude_pid() walks the npm-global "
        "exe-path fallback. Without this the daemon misses the in-"
        "container claude PID until a self-update lands a versions/<ver>/ "
        "entry in the named volume.",
    )

# ---------------------------------------------------------------------------
# 2. Dockerfile bakes self-clear at /usr/local/bin/self-clear.
# ---------------------------------------------------------------------------
expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")
if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")
    # The Dockerfile build context is the repo root (so it can COPY from
    # sibling tools/hooks/), so the source path is `container/bin/self-clear`.
    # Tolerate either prefix to keep the test stable across the
    # build-context migration.
    self_clear_copy = re.search(
        r'^\s*COPY\s+(?:container/)?bin/self-clear\s+/usr/local/bin/self-clear\s*$',
        df,
        re.MULTILINE,
    )
    expect(
        self_clear_copy is not None,
        "Dockerfile missing `COPY [container/]bin/self-clear /usr/local/bin/self-clear` "
        "— the in-container claude-watch daemon's wedged-pane recovery "
        "path (claude-watch/src/policy.rs spawn_immediate_clear) calls "
        "`Command::new(\"self-clear\")`. Without the baked copy at "
        "/usr/local/bin/self-clear the call falls through to "
        "operator-supplied bind-mounts, and operator-stripped containers "
        "(no ~/bin mount) silently lose recovery",
    )

# ---------------------------------------------------------------------------
# 3. claude-watch.config.toml has the auto-respawn override pointed at cwsr.
# ---------------------------------------------------------------------------
expect(CONFIG_TOML.exists(), f"claude-watch.config.toml missing at {CONFIG_TOML}")
if CONFIG_TOML.exists():
    cfg = CONFIG_TOML.read_text(encoding="utf-8")

    # The section header must be present (TOML parser otherwise would
    # accept the keys at the top level).
    expect(
        re.search(r'^\[auto_respawn_on_hang\]', cfg, re.MULTILINE) is not None,
        "claude-watch.config.toml missing the `[auto_respawn_on_hang]` "
        "section header",
    )

    # respawn_command must point at cwsr (with --no-upgrade — we don't
    # want auto-respawn to also trigger an unsolicited npm install).
    cwsr_command = re.search(
        r'^\s*respawn_command\s*=\s*\[\s*"cwsr"\s*,\s*"--no-upgrade"\s*\]',
        cfg,
        re.MULTILINE,
    )
    expect(
        cwsr_command is not None,
        "claude-watch.config.toml [auto_respawn_on_hang] missing "
        "`respawn_command = [\"cwsr\", \"--no-upgrade\"]` — without "
        "this override the daemon falls back to the host's "
        "`dashboard --detach` script (which doesn't exist in the "
        "container, so respawn would always fall through to "
        "LaunchFailed)",
    )

# ---------------------------------------------------------------------------
# 4. tools/watchers/self-clear is a symlink into container/bin/self-clear
#    so host + container both run the same bytes.
# ---------------------------------------------------------------------------
expect(SELF_CLEAR_BIN.exists(), f"container/bin/self-clear missing at {SELF_CLEAR_BIN}")
if SELF_CLEAR_BIN.exists():
    expect(
        SELF_CLEAR_BIN.is_file() and not SELF_CLEAR_BIN.is_symlink(),
        "container/bin/self-clear must be a regular file (the source "
        "of truth) — if it's a symlink the Docker COPY can't reach the "
        "target (build context is container/, can't traverse out)",
    )

expect(
    TOOLS_SELF_CLEAR.is_symlink(),
    "tools/watchers/self-clear must be a symlink into "
    "container/bin/self-clear so the host's `~/bin/self-clear -> "
    "tools/watchers/self-clear` chain and the container build run the "
    "same bytes — drift between the two would silently break either "
    "host or container recovery",
)
if TOOLS_SELF_CLEAR.is_symlink():
    target = TOOLS_SELF_CLEAR.readlink()
    expect(
        str(target) in (
            "../../container/bin/self-clear",
            "../../../container/bin/self-clear",
        ),
        f"tools/watchers/self-clear symlink target must point at "
        f"container/bin/self-clear (got {target!r})",
    )
    # The target must resolve.
    resolved = (TOOLS_SELF_CLEAR.parent / target).resolve()
    expect(
        resolved == SELF_CLEAR_BIN.resolve(),
        f"tools/watchers/self-clear symlink resolves to {resolved}, "
        f"expected {SELF_CLEAR_BIN.resolve()}",
    )

if failures:
    print("FAIL in-container-daemon.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS in-container-daemon.test")
sys.exit(0)
