#!/usr/bin/env python3
"""Tests for the container/skills/, container/agents/, container/watchers/
source dirs and the Dockerfile wiring that bakes them into the image.

The PR introducing these dirs (q-2026-05-14-f966) establishes the
convention: each top-level dir gets a README.md describing the on-disk
schema, the bake path, and the discovery mechanism. This test asserts
the convention holds at commit-time:

  1. container/skills/, container/agents/, container/watchers/ all exist
     in the repo.
  2. Each dir has a non-empty README.md.
  3. container/skills/restart.md exists, references `cwsr` (the
     in-container self-restart binary; the host's /restart skill calls
     `claude-watch update --force` against systemd, the container variant
     calls cwsr against tmux).
  4. container/skills/start-watchers.md exists, references the watchers
     dir AND honestly tells the agent there are no built-in watchers
     today.
  5. container/agents/ ships only its README.md (stub for future agent
     ports; see the dir's README "Future plan" section).
  6. container/watchers/ ships its README.md and the fire-and-exit
     event watcher (`claude-event-watch.{sh,toml}`). Per-watcher
     coverage lives in dedicated test files in container/tests/.
  7. container/plugin/.claude-plugin/plugin.json exists with name
     `claude-container`. This sets the plugin namespace; baked skills
     land as /claude-container:<name>.
  8. Dockerfile COPY lines wire the source dirs into the right targets:
       - skills/   -> /opt/claude-container/skills/
                   -> /opt/claude-container/plugin/commands/   (loader path)
       - agents/   -> /opt/claude-container/agents/
                   -> /opt/claude-container/plugin/agents/      (loader path)
       - watchers/ -> /opt/claude-container/watchers/           (no loader path)
       - plugin.json -> /opt/claude-container/plugin/.claude-plugin/plugin.json
  9. baked-CLAUDE.md session-start checklist references the new dirs so
     a fresh in-container session discovers them on every start.

Run:  ./baked-dirs.test
"""

from __future__ import annotations

import json
import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

SKILLS_DIR = CONTAINER_DIR / "skills"
AGENTS_DIR = CONTAINER_DIR / "agents"
WATCHERS_DIR = CONTAINER_DIR / "watchers"
PLUGIN_JSON = CONTAINER_DIR / "plugin" / ".claude-plugin" / "plugin.json"
DOCKERFILE = CONTAINER_DIR / "Dockerfile"
BAKED = CONTAINER_DIR / "baked-CLAUDE.md"

failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# 1. The three top-level dirs exist.
for d in (SKILLS_DIR, AGENTS_DIR, WATCHERS_DIR):
    expect(d.is_dir(), f"directory missing: {d}")

# 2. Each dir has a non-empty README.md.
for d in (SKILLS_DIR, AGENTS_DIR, WATCHERS_DIR):
    readme = d / "README.md"
    expect(readme.is_file(), f"README.md missing in {d}")
    if readme.is_file():
        text = readme.read_text(encoding="utf-8")
        expect(
            len(text) > 200,
            f"{readme} is suspiciously short (<200 chars)",
        )
        # Each README must explain bake target + add-a-new-entry shape.
        expect(
            "/opt/claude-container/" in text,
            f"{readme} should reference the /opt/claude-container/ bake path so "
            f"operators know where the files actually land in the image",
        )

# 3. restart.md present + references cwsr.
restart = SKILLS_DIR / "restart.md"
expect(restart.is_file(), f"{restart} missing — required by PR")
if restart.is_file():
    text = restart.read_text(encoding="utf-8")
    expect(len(text) > 200, f"{restart} suspiciously short (<200 chars)")
    expect(
        "cwsr" in text,
        f"{restart} should reference cwsr (the in-container self-restart "
        f"binary). Without cwsr, /claude-container:restart has no backing "
        f"tool — it's the container counterpart to the host's "
        f"`claude-watch update --force` invocation.",
    )
    # The host's /restart skill description is "Restart the Claude Code
    # process to pick up a new binary version" — the container variant
    # mirrors that intent. Sanity-check the opening line carries the
    # same idea so operators aren't confused about scope.
    first_line = text.splitlines()[0].lower()
    expect(
        "restart" in first_line and "claude" in first_line.lower(),
        f"{restart} first line should describe restarting the in-container "
        f"claude process (host parity), got: {text.splitlines()[0]!r}",
    )

# 3b. edit-host-mounts.md present + references host-bash and the
#     override file. The skill is the canonical way to generate /
#     update the operator's docker-compose.override.yml.
edit_host_mounts = SKILLS_DIR / "edit-host-mounts.md"
expect(
    edit_host_mounts.is_file(),
    f"{edit_host_mounts} missing — the operator-specific bind-mount "
    f"override pattern needs an automated path or operators end up "
    f"hand-editing YAML for every host-state change",
)
if edit_host_mounts.is_file():
    text = edit_host_mounts.read_text(encoding="utf-8")
    expect(
        len(text) > 200,
        f"{edit_host_mounts} suspiciously short (<200 chars)",
    )
    expect(
        "host-bash" in text,
        f"{edit_host_mounts} should reference `host-bash` — the skill "
        f"needs it to probe the host filesystem + write the override",
    )
    expect(
        "docker-compose.override.yml" in text,
        f"{edit_host_mounts} should reference "
        f"`docker-compose.override.yml` — the file the skill writes",
    )

# 4. start-watchers.md present + references the watchers dir + honest
#    "no watchers today" framing.
start_watchers = SKILLS_DIR / "start-watchers.md"
expect(start_watchers.is_file(), f"{start_watchers} missing — required by PR")
if start_watchers.is_file():
    text = start_watchers.read_text(encoding="utf-8")
    expect(len(text) > 200, f"{start_watchers} suspiciously short (<200 chars)")
    expect(
        "/opt/claude-container/watchers" in text,
        f"{start_watchers} should reference /opt/claude-container/watchers/ — "
        f"the path it probes via `ls`",
    )
    # Honest "no watchers today" framing — the skill must NOT lie about
    # what's available in a fresh image. Look for either an explicit
    # "no watchers" callout or a "ships zero" / "empty" framing.
    has_honest_framing = re.search(
        r"no (long-running )?watchers|zero (long-running )?watchers|"
        r"watcher.{0,5}light|empty|nothing to start",
        text,
        re.IGNORECASE,
    )
    expect(
        has_honest_framing is not None,
        f"{start_watchers} should honestly report that the container ships "
        f"no built-in watchers today (don't pretend the dir is populated)",
    )

# 5. agents/ only ships README.md today.
agent_files = sorted(p.name for p in AGENTS_DIR.iterdir() if p.is_file())
expect(
    agent_files == ["README.md"],
    f"container/agents/ should ship only README.md today (stub for future "
    f"agent ports), got: {agent_files}",
)

# 6. watchers/ ships README.md + claude-event-watch.{sh,toml}.
#    Per-file shape (executable, parseable toml, contract assertions)
#    is covered by dedicated test files so this test stays focused on
#    dir-level convention.
watcher_files = sorted(p.name for p in WATCHERS_DIR.iterdir() if p.is_file())
expect(
    "README.md" in watcher_files,
    f"container/watchers/README.md missing — required to document the "
    f"on-disk schema. Got: {watcher_files}",
)
expect(
    "claude-event-watch.sh" in watcher_files,
    f"container/watchers/claude-event-watch.sh missing — the fire-and-exit "
    f"event watcher launcher. Got: {watcher_files}",
)
expect(
    "claude-event-watch.toml" in watcher_files,
    f"container/watchers/claude-event-watch.toml missing — required metadata "
    f"for the /start-watchers skill to discover the watcher. Got: "
    f"{watcher_files}",
)
expect(
    "botchat-wait.sh" in watcher_files,
    f"container/watchers/botchat-wait.sh missing — the thin launcher for the "
    f"botchat repo's bind-mounted inbound chat watcher. Got: {watcher_files}",
)
expect(
    "botchat-wait.toml" in watcher_files,
    f"container/watchers/botchat-wait.toml missing — required metadata for the "
    f"/start-watchers skill to discover the botchat-wait watcher. Got: "
    f"{watcher_files}",
)

# 7. plugin.json present, name=claude-container.
expect(PLUGIN_JSON.is_file(), f"{PLUGIN_JSON} missing — required to register "
       f"the plugin namespace for baked skills + agents")
if PLUGIN_JSON.is_file():
    try:
        manifest = json.loads(PLUGIN_JSON.read_text(encoding="utf-8"))
        expect(
            manifest.get("name") == "claude-container",
            f"plugin.json `name` must be 'claude-container' (sets the "
            f"namespace; skills land as /claude-container:<name>), got: "
            f"{manifest.get('name')!r}",
        )
        expect(
            "version" in manifest and isinstance(manifest["version"], str),
            f"plugin.json must have a string `version`, got: "
            f"{manifest.get('version')!r}",
        )
    except json.JSONDecodeError as e:
        failures.append(f"plugin.json is not valid JSON: {e}")

# 8. Dockerfile COPY wiring — six lines, exact targets.
expect(DOCKERFILE.is_file(), f"{DOCKERFILE} missing")
if DOCKERFILE.is_file():
    df = DOCKERFILE.read_text(encoding="utf-8")
    required_copy_lines = [
        # source pattern, destination. The Dockerfile build context is
        # the repo root (so it can COPY from sibling tools/hooks/), so
        # the source paths are prefixed with `container/`. The regex
        # below tolerates either prefix to keep the test stable across
        # the build-context migration.
        ("skills/", "/opt/claude-container/skills/"),
        ("skills/", "/opt/claude-container/plugin/commands/"),
        ("agents/", "/opt/claude-container/agents/"),
        ("agents/", "/opt/claude-container/plugin/agents/"),
        ("watchers/", "/opt/claude-container/watchers/"),
        ("plugin/.claude-plugin/plugin.json",
         "/opt/claude-container/plugin/.claude-plugin/plugin.json"),
    ]
    for src, dst in required_copy_lines:
        # Tolerate any whitespace; require both src and dst on the same
        # COPY line. The optional `container/` prefix accommodates the
        # repo-root build context.
        pat = re.compile(
            rf"^\s*COPY\s+(?:container/)?{re.escape(src)}\s+{re.escape(dst)}\s*$",
            re.MULTILINE,
        )
        expect(
            pat.search(df) is not None,
            f"Dockerfile missing `COPY [container/]{src} {dst}` — required "
            f"to bake the {src.rstrip('/')} dir into the image at {dst}",
        )

# 9. baked-CLAUDE.md session-start checklist references the new dirs.
expect(BAKED.is_file(), f"{BAKED} missing")
if BAKED.is_file():
    text = BAKED.read_text(encoding="utf-8")
    # The checklist should mention all three dirs by name so a fresh
    # session knows to enumerate them.
    expect(
        "/opt/claude-container/skills" in text,
        "baked-CLAUDE.md should reference /opt/claude-container/skills/ in the "
        "session-start checklist so the agent enumerates baked skills on "
        "every fresh session",
    )
    expect(
        "/opt/claude-container/agents" in text,
        "baked-CLAUDE.md should reference /opt/claude-container/agents/ in the "
        "session-start checklist",
    )
    expect(
        "/opt/claude-container/watchers" in text,
        "baked-CLAUDE.md should reference /opt/claude-container/watchers/ in "
        "the session-start checklist",
    )
    expect(
        "claude-container:" in text,
        "baked-CLAUDE.md should reference the `claude-container:` plugin "
        "namespace so the agent knows how to invoke baked skills "
        "(e.g. /claude-container:restart)",
    )


if failures:
    print("FAIL baked-dirs.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS baked-dirs.test")
sys.exit(0)
