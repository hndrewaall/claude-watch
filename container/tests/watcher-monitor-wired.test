#!/usr/bin/env python3
"""Tests for the in-container watcher_monitor alert layer.

Background: the cw-watcher-supervisor (entrypoint-spawned) is the
PRIMARY restart mechanism for in-container watchers — it reads every
*.toml under /etc/claude-code/watchers/ and respawns each watcher per
its restart_policy. But supervision can fail: if a watcher crashes
fast enough that the supervisor marks it "stuck" (>=5 restarts in
60s), or the supervisor itself dies, there's nothing telling the
main loop the watcher is gone. Investigation 2026-05-15 found this
gap.

Fix: enable claude-watch's existing `[watcher_monitor]` section,
point it at an in-container watchers.conf, and symlink watcher-ctl
so the alert prompt's restart command resolves. The two layers
stack:

  - supervisor: respawn-on-exit (seconds, common case)
  - watcher_monitor: pgrep check, fires
        [CLAUDE-WATCH] WATCHER(S) DOWN: <name>
    via tmux-inject when the watcher's process is missing for
    `inject_threshold` consecutive checks (the supervision-failed
    case)

This test verifies the FILE-LEVEL wiring (Dockerfile +
claude-watch.config.toml + the baked watchers.conf). It does NOT
spawn a container or shell into one — that path is exercised by the
v66 workbot prompt.

Coverage:
  1. container/watchers.conf exists, parses, has exactly one entry
     `claude-event-tail` pointing at the baked launcher script with
     min_count=1 and enabled=true.
  2. Dockerfile bakes the watchers.conf at the canonical
     /etc/claude-code/watchmen/watchers.conf path (mirrors host's
     ~/.config/watchmen/watchers.conf convention).
  3. Dockerfile symlinks /usr/local/bin/watcher-ctl ->
     /usr/local/bin/claude-watch so the alert prompt's restart
     command resolves inside the container (multicall alias —
     verified via src/main.rs line 1173).
  4. claude-watch.config.toml [watcher_monitor] is ENABLED,
     watchers_config points at the baked path, and
     event_consumer_watcher_name matches the in-container watcher
     name (`claude-event-tail`, not the host's
     `claude-event-watch`).
  5. The configured watchers_config path's referenced launcher
     pattern matches the path the cw-watcher-supervisor actually
     spawns (so pgrep finds the running process). Cross-check
     against container/watchers/claude-event-tail.toml's `launcher`
     key.

Run:  ./watcher-monitor-wired.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

WATCHERS_CONF = CONTAINER_DIR / "watchers.conf"
DOCKERFILE = CONTAINER_DIR / "Dockerfile"
CONFIG_TOML = CONTAINER_DIR / "claude-watch.config.toml"
EVENT_TAIL_TOML = CONTAINER_DIR / "watchers" / "claude-event-tail.toml"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def parse_watchers_conf(text: str) -> list[dict]:
    """Mirror src/status.rs::parse_watchers_config_str — pipe-separated,
    skip blank + # lines, fields: name|pattern|min_count|enabled|start_cmd.
    """
    out = []
    for line in text.splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split("|")
        if len(parts) < 2:
            continue
        out.append({
            "name": parts[0],
            "pattern": parts[1],
            "min_count": int(parts[2]) if len(parts) > 2 and parts[2] else 1,
            "enabled": (parts[3].strip().lower() == "true") if len(parts) > 3 else True,
            "start_cmd": parts[4].strip() if len(parts) > 4 else "",
        })
    return out


# ---------------------------------------------------------------------------
# 1. container/watchers.conf exists and parses.
# ---------------------------------------------------------------------------
expect(WATCHERS_CONF.exists(), f"container/watchers.conf missing at {WATCHERS_CONF}")
entries: list[dict] = []
if WATCHERS_CONF.exists():
    text = WATCHERS_CONF.read_text(encoding="utf-8")
    entries = parse_watchers_conf(text)
    expect(
        len(entries) >= 1,
        f"container/watchers.conf must declare at least one watcher "
        f"(got {len(entries)}). Without an entry the daemon's "
        f"watcher_monitor has nothing to check and silently no-ops.",
    )

    # Must have claude-event-tail.
    names = [e["name"] for e in entries]
    expect(
        "claude-event-tail" in names,
        f"container/watchers.conf must include `claude-event-tail` "
        f"(the in-container equivalent of host claude-event-watch). "
        f"Got names: {names}",
    )

    if "claude-event-tail" in names:
        ent = next(e for e in entries if e["name"] == "claude-event-tail")
        expect(
            ent["enabled"] is True,
            f"claude-event-tail entry must be enabled=true, got "
            f"enabled={ent['enabled']!r}",
        )
        expect(
            ent["min_count"] >= 1,
            f"claude-event-tail entry must have min_count >= 1, got "
            f"min_count={ent['min_count']!r}",
        )
        # The pattern must reference the absolute launcher path. The
        # daemon runs `pgrep -fc -- <pattern>` against process argv;
        # the supervisor spawns `bash /etc/claude-code/watchers/claude-event-tail.sh`
        # so an anchored path-prefix match is the right shape (avoids
        # false-positives from coincidental shell name matches).
        expect(
            "/etc/claude-code/watchers/claude-event-tail.sh" in ent["pattern"],
            f"claude-event-tail pattern must include the absolute "
            f"launcher path /etc/claude-code/watchers/claude-event-tail.sh "
            f"so pgrep matches the supervisor-spawned process. Got "
            f"pattern={ent['pattern']!r}",
        )

# ---------------------------------------------------------------------------
# 2. Dockerfile bakes watchers.conf at /etc/claude-code/watchmen/watchers.conf.
# ---------------------------------------------------------------------------
expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")
df = ""
if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")
    copy_line = re.search(
        r'^\s*COPY\s+container/watchers\.conf\s+'
        r'/etc/claude-code/watchmen/watchers\.conf\s*$',
        df,
        re.MULTILINE,
    )
    expect(
        copy_line is not None,
        "Dockerfile missing "
        "`COPY container/watchers.conf /etc/claude-code/watchmen/watchers.conf` "
        "— without the bake, the daemon's watcher_monitor reads a "
        "nonexistent file, parse_watchers_config returns empty, and "
        "the alert layer silently no-ops",
    )

# ---------------------------------------------------------------------------
# 3. Dockerfile symlinks watcher-ctl -> claude-watch.
# ---------------------------------------------------------------------------
if df:
    symlink_line = re.search(
        r'^\s*RUN\s+ln\s+-s\s+/usr/local/bin/claude-watch\s+'
        r'/usr/local/bin/watcher-ctl\s*$',
        df,
        re.MULTILINE,
    )
    expect(
        symlink_line is not None,
        "Dockerfile missing the `watcher-ctl -> claude-watch` symlink — "
        "the WATCHER(S) DOWN alert prompt injects "
        "`watcher-ctl run <name>` into the main loop's pane (the "
        "canonical cardinal-rule restart shape). Without the symlink "
        "the main loop hits `command not found` when following the alert",
    )

# ---------------------------------------------------------------------------
# 3b. Dockerfile bakes WATCHERS_CONFIG env var at image level.
# ---------------------------------------------------------------------------
if df:
    # The watcher-ctl CLI (via src/watcher.rs config_path()) honors
    # WATCHERS_CONFIG env override. Without it, `watcher-ctl run
    # <name>` defaults to $HOME/.config/watchmen/watchers.conf, which
    # doesn't exist in the container, so the CLI errors with "watcher
    # not found in config" when the main loop follows the alert.
    env_line = re.search(
        r'^\s*ENV\s+WATCHERS_CONFIG=/etc/claude-code/watchmen/watchers\.conf\s*$',
        df,
        re.MULTILINE,
    )
    expect(
        env_line is not None,
        "Dockerfile missing "
        "`ENV WATCHERS_CONFIG=/etc/claude-code/watchmen/watchers.conf` "
        "— without this image-level env, `watcher-ctl run <name>` "
        "defaults to ~/.config/watchmen/watchers.conf (which doesn't "
        "exist in the container) and fails with 'watcher not found "
        "in config' when the main loop follows the alert",
    )

# ---------------------------------------------------------------------------
# 4. claude-watch.config.toml [watcher_monitor] is enabled + wired.
# ---------------------------------------------------------------------------
expect(CONFIG_TOML.exists(), f"claude-watch.config.toml missing at {CONFIG_TOML}")
if CONFIG_TOML.exists():
    cfg = CONFIG_TOML.read_text(encoding="utf-8")

    # Section header present.
    section = re.search(r'^\[watcher_monitor\]', cfg, re.MULTILINE)
    expect(
        section is not None,
        "claude-watch.config.toml missing the `[watcher_monitor]` "
        "section header — without it the config defaults apply and "
        "watchers_config points at the host's "
        "~/.config/watchmen/watchers.conf (which doesn't exist in the "
        "container)",
    )

    # Extract the [watcher_monitor] section body so we can check keys
    # without false-matching the [auto_respawn_on_hang] or any later
    # section's keys.
    section_body = ""
    if section is not None:
        # From [watcher_monitor] to the next ^[xxx] or end-of-file.
        m = re.search(
            r'^\[watcher_monitor\]\s*\n(.*?)(?=^\[|\Z)',
            cfg,
            re.MULTILINE | re.DOTALL,
        )
        if m:
            section_body = m.group(1)

    # enabled must be true (the whole point of this fix).
    enabled_line = re.search(
        r'^\s*enabled\s*=\s*true\b',
        section_body,
        re.MULTILINE,
    )
    expect(
        enabled_line is not None,
        "claude-watch.config.toml [watcher_monitor].enabled must be true "
        "— defaulting OFF leaves the alert layer disabled and the "
        "supervisor's crash-loop-stuck state is invisible to the main loop",
    )

    # watchers_config must point at the baked path.
    watchers_config_line = re.search(
        r'^\s*watchers_config\s*=\s*"/etc/claude-code/watchmen/watchers\.conf"',
        section_body,
        re.MULTILINE,
    )
    expect(
        watchers_config_line is not None,
        "claude-watch.config.toml [watcher_monitor].watchers_config "
        "must point at /etc/claude-code/watchmen/watchers.conf (the "
        "in-container baked path). Pointing at the host's "
        "~/.config/watchmen/watchers.conf reads a file the container "
        "doesn't have",
    )

    # event_consumer_watcher_name must match the in-container watcher.
    # Host default is "claude-event-watch"; we ship "claude-event-tail"
    # in container/watchers/. The consumer-self-feedback guard in
    # policy.rs (filter_consumer_for_event_emit) suppresses emitting a
    # `watcher-down` event when only the consumer itself is missing
    # — without this override the guard would never fire because the
    # default name doesn't match.
    consumer_line = re.search(
        r'^\s*event_consumer_watcher_name\s*=\s*"claude-event-tail"',
        section_body,
        re.MULTILINE,
    )
    expect(
        consumer_line is not None,
        "claude-watch.config.toml [watcher_monitor]."
        "event_consumer_watcher_name must be \"claude-event-tail\" — "
        "the host's default of \"claude-event-watch\" doesn't match "
        "the in-container watcher name, so the consumer-self-feedback "
        "guard in policy.rs never fires and the watcher's own restart "
        "alert would self-feedback through itself",
    )

# ---------------------------------------------------------------------------
# 5. The watchers.conf pattern matches the supervisor's launcher path.
# ---------------------------------------------------------------------------
expect(
    EVENT_TAIL_TOML.exists(),
    f"container/watchers/claude-event-tail.toml missing at {EVENT_TAIL_TOML}",
)
if EVENT_TAIL_TOML.exists() and entries:
    toml_text = EVENT_TAIL_TOML.read_text(encoding="utf-8")
    launcher_match = re.search(
        r'^\s*launcher\s*=\s*"([^"]+)"',
        toml_text,
        re.MULTILINE,
    )
    expect(
        launcher_match is not None,
        "container/watchers/claude-event-tail.toml missing the "
        "`launcher = \"...\"` key — the supervisor needs it to spawn",
    )
    if launcher_match is not None:
        supervisor_launcher = launcher_match.group(1)
        ent = next(
            (e for e in entries if e["name"] == "claude-event-tail"),
            None,
        )
        if ent is not None:
            expect(
                supervisor_launcher in ent["pattern"]
                or ent["pattern"] in supervisor_launcher,
                f"watchers.conf pattern ({ent['pattern']!r}) must match "
                f"the supervisor's launcher path "
                f"({supervisor_launcher!r}) so pgrep finds the running "
                f"process. If the supervisor spawns "
                f"/etc/claude-code/watchers/claude-event-tail.sh and "
                f"the watchers.conf pattern is a different path, pgrep "
                f"returns 0 and the daemon fires a spurious "
                f"watcher-down alert on every check.",
            )

if failures:
    print("FAIL watcher-monitor-wired.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS watcher-monitor-wired.test")
sys.exit(0)
