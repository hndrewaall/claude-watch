#!/usr/bin/env python3
"""Tests for the tini PID 1 supervisor wiring.

Background — without an explicit PID 1 init, `entrypoint.sh` runs as PID
1 itself. Bash inherits no zombie-reap behaviour and no kernel-level
default signal handlers, so:

  * The headless claude-watch daemon (spawned via `nohup setsid
    claude-watch ... &` in entrypoint.sh) re-parents orphaned
    grandchildren to PID 1. With bash as PID 1, those grandchildren
    accumulate as <defunct> entries because bash never handles SIGCHLD.
  * `docker stop` sends SIGTERM to PID 1. Bash's signal handling around
    `exec tmux attach-session` is fragile — the signal can race against
    tmux or get dropped under exec, leaving the entrypoint's
    `trap cleanup TERM INT` handler un-run.

Fix: install tini from the Debian bookworm apt repo and run it as PID 1
via `ENTRYPOINT ["/usr/bin/tini", "--", ".../claude-tmux-entrypoint"]`.
tini handles SIGCHLD (reaping zombie grandchildren), forwards SIGTERM /
SIGINT cleanly to its child, and exits with its child's status. The
entrypoint script's existing `trap cleanup TERM INT` block continues
to fire as the signal-handling layer ABOVE tini, so cleanup behaviour
is unchanged.

This test verifies the FILE-LEVEL wiring (Dockerfile apt layer +
ENTRYPOINT directive). It does NOT spin up a container or exec into
one — the runtime assertion (`cat /proc/1/comm` reports `tini`, zero
zombies after `docker stop --time=5`) is exercised by a workbot
v-prompt against an actual `docker compose up` (matching the split
established by container/tests/in-container-daemon.test).

Coverage:
  1. Dockerfile apt-get install layer includes `tini` on its own line
     in the `--no-install-recommends` list (so a future refactor that
     reorders or condenses the layer surfaces here instead of silently
     dropping the package).
  2. Dockerfile ENTRYPOINT is exec-form JSON with `/usr/bin/tini`,
     `--`, then `/usr/local/bin/claude-tmux-entrypoint`. Shell-form
     (`ENTRYPOINT /usr/bin/tini ...`) or missing the `--` separator
     would defeat tini's argv-vs-flags split.
  3. entrypoint.sh STILL has the `trap cleanup TERM INT` block — tini
     forwards signals INTO the entrypoint, so the existing trap is the
     layer that runs `tmux kill-session` + signals the claude-watch
     daemon. Removing the trap (or moving it under an `if`) would
     break clean shutdown even with tini in place.
  4. container/README.md describes the PID 1 layer + the future-tier
     candidates (process-compose, s6-overlay) so an operator scanning
     the README understands why tini is there and what the next step
     looks like when the container grows past two long-running
     services.

Run:  ./tini-pid1.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

DOCKERFILE = CONTAINER_DIR / "Dockerfile"
ENTRYPOINT = CONTAINER_DIR / "entrypoint.sh"
README = CONTAINER_DIR / "README.md"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# ---------------------------------------------------------------------------
# 1. Dockerfile: tini is in the apt-get install layer.
# ---------------------------------------------------------------------------
expect(DOCKERFILE.exists(), f"Dockerfile missing at {DOCKERFILE}")
if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")

    # Find the multi-line `RUN apt-get update && apt-get install -y
    # --no-install-recommends ...` block in stage 2 (the runtime image,
    # not the builder). We anchor on `--no-install-recommends \` to
    # avoid false matches in commented-out alternatives. The package
    # name `tini` must appear as its own token on its own continuation
    # line so a future apt layer cleanup that drops the package
    # surfaces here.
    apt_layer_match = re.search(
        r"RUN\s+apt-get update\s*&&\s*apt-get install\s+-y\s+"
        r"--no-install-recommends\s*\\\n"
        r"((?:\s+\S+\s*\\\n)+)"
        r"(?:\s+\S+\s*)?"
        r"\s+&&\s+rm\s+-rf\s+/var/lib/apt/lists/\*",
        df,
    )
    expect(
        apt_layer_match is not None,
        "Dockerfile: could not locate the runtime apt-get install layer "
        "(expected `RUN apt-get update && apt-get install -y "
        "--no-install-recommends \\` followed by a list of packages "
        "ending in `&& rm -rf /var/lib/apt/lists/*`)",
    )
    if apt_layer_match:
        packages_block = apt_layer_match.group(0)
        # Look for `tini` as a standalone package line (not a
        # substring of another package). Each continuation line is
        # `<whitespace>tini<whitespace>\`.
        tini_line = re.search(
            r"(?m)^\s+tini\s*\\\s*$",
            packages_block,
        )
        expect(
            tini_line is not None,
            "Dockerfile apt-get layer: `tini` is not installed. The "
            "package must appear on its own line (`        tini \\`) "
            "between the existing entries (e.g. between `tmux \\` and "
            "`git \\`). Without tini in the image, the "
            "`ENTRYPOINT [\"/usr/bin/tini\", ...]` directive will fail "
            "at container start with 'no such file or directory'.",
        )


# ---------------------------------------------------------------------------
# 2. Dockerfile: ENTRYPOINT is exec-form JSON with tini, --, then the script.
# ---------------------------------------------------------------------------
if DOCKERFILE.exists():
    df = DOCKERFILE.read_text(encoding="utf-8")

    # Find the (last, non-commented) ENTRYPOINT directive. Dockerfile
    # semantics: a later ENTRYPOINT wins, and ENTRYPOINT only takes
    # effect in the final stage. We accept the exec-form JSON only.
    entrypoint_lines = []
    for line in df.splitlines():
        stripped = line.lstrip()
        if stripped.startswith("#"):
            continue
        m = re.match(r"ENTRYPOINT\s+(.+)$", stripped)
        if m:
            entrypoint_lines.append(m.group(1).rstrip())

    expect(
        len(entrypoint_lines) >= 1,
        "Dockerfile: no non-commented ENTRYPOINT directive found.",
    )
    if entrypoint_lines:
        entrypoint = entrypoint_lines[-1].strip()
        # Exec-form: ENTRYPOINT ["bin", "arg1", "arg2", ...]
        expect(
            entrypoint.startswith("["),
            "Dockerfile ENTRYPOINT must be exec-form JSON "
            "(`ENTRYPOINT [\"...\", ...]`), not shell-form. Shell-form "
            "would wrap the whole command in a `/bin/sh -c '...'`, "
            "which defeats both tini's PID-1 status AND argv parsing.",
        )
        if entrypoint.startswith("["):
            # Parse the JSON list. Use a simple ast.literal_eval fallback
            # via json after normalising single quotes — the Dockerfile
            # convention is double-quotes inside the JSON list, so we
            # parse straight.
            import json
            try:
                argv = json.loads(entrypoint)
            except json.JSONDecodeError as e:
                argv = None
                failures.append(
                    f"Dockerfile ENTRYPOINT: could not parse argv JSON "
                    f"({entrypoint!r}): {e}",
                )
            if argv is not None:
                expect(
                    isinstance(argv, list) and len(argv) >= 3,
                    f"Dockerfile ENTRYPOINT argv must have at least 3 "
                    f"elements (tini, --, script), got {argv!r}",
                )
                if isinstance(argv, list) and len(argv) >= 3:
                    expect(
                        argv[0] == "/usr/bin/tini",
                        f"Dockerfile ENTRYPOINT argv[0] must be "
                        f"`/usr/bin/tini` (the Debian bookworm install "
                        f"path for the tini package), got {argv[0]!r}",
                    )
                    expect(
                        argv[1] == "--",
                        f"Dockerfile ENTRYPOINT argv[1] must be `--` "
                        f"to tell tini to stop parsing its own flags and "
                        f"treat the rest as the child argv, got "
                        f"{argv[1]!r}. Without the `--` separator, tini "
                        f"could swallow a child-script flag as its own.",
                    )
                    expect(
                        argv[2] == "/usr/local/bin/claude-tmux-entrypoint",
                        f"Dockerfile ENTRYPOINT argv[2] must be "
                        f"`/usr/local/bin/claude-tmux-entrypoint` (the "
                        f"path the Dockerfile installs the entrypoint "
                        f"script at via `COPY container/entrypoint.sh "
                        f"/usr/local/bin/claude-tmux-entrypoint`), got "
                        f"{argv[2]!r}",
                    )


# ---------------------------------------------------------------------------
# 3. entrypoint.sh still traps TERM/INT so cleanup runs under tini.
# ---------------------------------------------------------------------------
expect(ENTRYPOINT.exists(), f"entrypoint.sh missing at {ENTRYPOINT}")
if ENTRYPOINT.exists():
    text = ENTRYPOINT.read_text(encoding="utf-8")
    # tini forwards signals INTO the child (the entrypoint script).
    # The entrypoint's existing `trap cleanup TERM INT` block is what
    # actually runs `tmux kill-session` + signals the claude-watch
    # daemon. If the trap is removed, `docker stop` still kills the
    # container (because tini exits) but the in-container teardown is
    # skipped, leaving the daemon to die un-journalled.
    trap_line = re.search(
        r"^trap\s+cleanup\s+TERM\s+INT\s*$",
        text,
        re.MULTILINE,
    )
    expect(
        trap_line is not None,
        "entrypoint.sh: `trap cleanup TERM INT` directive missing. tini "
        "forwards signals to the entrypoint script as its child, and "
        "the script's trap is what fires `tmux kill-session` + "
        "`kill ${CLAUDE_WATCH_DAEMON_PID}` for clean teardown. Without "
        "the trap, docker stop kills the container but skips the "
        "in-container cleanup (daemon doesn't journal a clean stop "
        "event, tmux server gets SIGKILLed without a clean detach).",
    )


# ---------------------------------------------------------------------------
# 4. README documents the PID 1 layer + future-tier candidates.
# ---------------------------------------------------------------------------
expect(README.exists(), f"container/README.md missing at {README}")
if README.exists():
    text = README.read_text(encoding="utf-8")
    # Section anchor: a heading that names tini.
    expect(
        re.search(r"##\s+PID 1 supervisor.*tini", text) is not None,
        "container/README.md: missing a `## PID 1 supervisor (tini)` "
        "section. The operator needs a single place to read why tini "
        "is in the image (zombie reap, signal forwarding) and how it "
        "interacts with the entrypoint's existing trap.",
    )
    # Future-tier candidates: both must be named so the doc captures
    # the s6-overlay vs process-compose evaluation rather than silently
    # picking one. Andrew's explicit ask on the spawn: list BOTH with
    # process-compose as the default lean.
    expect(
        "process-compose" in text,
        "container/README.md: missing reference to `process-compose` "
        "in the future-tier supervisor candidates. process-compose is "
        "the single-static-Go-binary docker-compose-style supervisor "
        "that's the default lean for the next tier.",
    )
    expect(
        "s6-overlay" in text,
        "container/README.md: missing reference to `s6-overlay` in the "
        "future-tier supervisor candidates. s6-overlay is the "
        "docker-community-standard maturity fallback if process-compose "
        "hits a gap.",
    )
    # The section should explicitly say tini is sufficient until the
    # service count grows — so an operator reading the doc doesn't
    # preemptively migrate.
    has_dont_migrate_yet = re.search(
        r"sufficient until|don't migrate preemptively|preemptive",
        text,
        re.IGNORECASE,
    )
    expect(
        has_dont_migrate_yet is not None,
        "container/README.md: future-tier section should explicitly "
        "tell the operator NOT to migrate preemptively (e.g. "
        "`tini is sufficient until the service count grows`). Without "
        "that framing the section reads like a TODO and invites "
        "unnecessary churn.",
    )


# ---------------------------------------------------------------------------
# Report
# ---------------------------------------------------------------------------
if failures:
    print("FAIL tini-pid1.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS tini-pid1.test")
sys.exit(0)
