#!/usr/bin/env python3
"""File-level test that the in-container watcher supervisor is wired
into process-compose's service set.

Without the entrypoint-side launch the supervisor never runs inside
the container — watchers fall back to session-scoped lifetimes (the
pre-supervisor behaviour). With the migration to process-compose as
PID 1, the supervisor's launch lives in process-compose.yml (the
declarative service config), not in entrypoint.sh. The entrypoint
only exports the env-var passthrough that disables the process when
operators opt out via CLAUDE_CONTAINER_WATCHER_SUPERVISOR=0.

Asserts:
  1. process-compose.yml declares a `cw-watcher-supervisor` process.
  2. The supervisor process invokes /usr/local/bin/cw-watcher-supervisor
     (the baked path).
  3. The supervisor process declares `restart: on_failure` so a
     crash triggers a restart.
  4. entrypoint.sh maps the legacy CLAUDE_CONTAINER_WATCHER_SUPERVISOR=0
     opt-out to the process-compose-style *_DISABLED env var, so
     operators with existing .env files don't see a behaviour change.

Run:  ./entrypoint-launches-supervisor.test
"""

from __future__ import annotations

import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONTAINER_DIR = HERE.parent

ENTRYPOINT = CONTAINER_DIR / "entrypoint.sh"
PC_CONFIG = CONTAINER_DIR / "process-compose.yml"


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


# ---------------------------------------------------------------------------
# 1-3. process-compose.yml declares the supervisor process.
# ---------------------------------------------------------------------------
expect(PC_CONFIG.is_file(), f"process-compose.yml missing at {PC_CONFIG}")
if PC_CONFIG.is_file():
    pc_text = PC_CONFIG.read_text(encoding="utf-8")

    # 1. Service block exists.
    pat = re.compile(r"(?m)^  cw-watcher-supervisor:\s*$")
    expect(
        pat.search(pc_text) is not None,
        "process-compose.yml must declare a `cw-watcher-supervisor` "
        "process. Without it the supervisor never runs inside the "
        "container and watchers fall back to session-scoped lifetimes.",
    )

    # 2. Invokes the baked supervisor binary. Find the block body and
    # check the `command:` line within it.
    sup_block = re.search(
        r"(?ms)^  cw-watcher-supervisor:\s*$(.+?)(?=^  \w|^\Z)",
        pc_text,
    )
    if sup_block:
        body = sup_block.group(1)
        expect(
            "/usr/local/bin/cw-watcher-supervisor" in body,
            "process-compose.yml: cw-watcher-supervisor must invoke "
            "/usr/local/bin/cw-watcher-supervisor (the path the "
            "Dockerfile bakes the supervisor at). Without this the "
            "supervisor never starts.",
        )
        expect(
            re.search(r"restart:\s*on_failure", body) is not None,
            "process-compose.yml: cw-watcher-supervisor must declare "
            "`restart: on_failure` so a supervisor crash triggers a "
            "restart instead of a half-dead container.",
        )


# ---------------------------------------------------------------------------
# 4. entrypoint.sh maps legacy opt-out env var → process-compose disabled var.
# ---------------------------------------------------------------------------
expect(ENTRYPOINT.is_file(), f"entrypoint.sh missing at {ENTRYPOINT}")
if ENTRYPOINT.is_file():
    text = ENTRYPOINT.read_text(encoding="utf-8")

    # The mapping `CLAUDE_CONTAINER_WATCHER_SUPERVISOR=0` →
    # `export CLAUDE_CONTAINER_WATCHER_SUPERVISOR_DISABLED=true` must
    # be present so operators with existing .env files don't see a
    # behaviour change post-migration.
    expect(
        "CLAUDE_CONTAINER_WATCHER_SUPERVISOR" in text,
        "entrypoint.sh: must reference CLAUDE_CONTAINER_WATCHER_SUPERVISOR "
        "(the legacy opt-out env var) so the post-process-compose "
        "entrypoint preserves the old contract.",
    )
    expect(
        "CLAUDE_CONTAINER_WATCHER_SUPERVISOR_DISABLED" in text,
        "entrypoint.sh: must export CLAUDE_CONTAINER_WATCHER_SUPERVISOR_DISABLED "
        "when the legacy opt-out env var is set to 0. "
        "process-compose.yml's `disabled:` field reads the *_DISABLED "
        "variant; mapping at the entrypoint preserves backwards "
        "compatibility with operator .env files.",
    )


if failures:
    print("FAIL entrypoint-launches-supervisor.test")
    for f in failures:
        print(f"  - {f}")
    sys.exit(1)

print("PASS entrypoint-launches-supervisor.test")
sys.exit(0)
