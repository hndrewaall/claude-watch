#!/usr/bin/env bash
# cwsr — claude-watch self-restart for in-container Claude Code.
#
# Rolls the in-container `claude` CLI via the NATIVE managed installer and
# respawns the pane-0 process in the tmux session that entrypoint.sh created,
# so the operator gets a freshly-installed claude WITHOUT having to
# `docker compose restart` the whole container.
#
# claude-code is installed + updated EXCLUSIVELY through the native installer
# (`claude install <target>`), NEVER `npm install -g @anthropic-ai/claude-code`
# (operator directive 2026-07-10: npm is for deps only). The native installer
# writes into ~/.local/share/claude/versions/<ver>, which is backed by the
# `claude-container-versions` named volume — so a cwsr roll PERSISTS across a
# later `docker compose up --force-recreate` instead of rolling back.
#
# Use cases:
#   - Anthropic ships a new claude-code version and the in-container session
#     needs to pick it up.
#   - A long-lived container session (tmux survives detach/reattach, MCP
#     state survives, volume-backed versions/ dir persists) wants to roll the
#     inner process without losing the wrapping container.
#
# What it does:
#   1. Optionally `claude install <target>` (default: latest; a version arg
#      pins an exact version, e.g. 2.1.206). This downloads the native binary
#      into ~/.local/share/claude/versions/<ver> and re-points the
#      ~/.local/bin/claude launcher — the volume carries it across recreates.
#   2. Uses `tmux respawn-pane -k -t claude-container:0.0 <cmd>` to kill
#      whatever process pane 0 currently runs (the old claude) and start the
#      new claude in its place. The pane, window, and session all survive —
#      only the inner process rolls.
#   3. Reconstructs the claude argv from the same env vars entrypoint.sh uses:
#      CLAUDE_SHIM_SETTINGS_PATH (set by entrypoint when
#      CLAUDE_CONTAINER_REWRITE_HOOKS=1 produced a shim file) and
#      CLAUDE_AUTO_CONTINUE (so the resume flag survives the roll). Any
#      operator-side change requiring a *different* claude argv shape (e.g.
#      toggling REWRITE_HOOKS, changing AUTO_CONTINUE) still needs a real
#      `docker compose up -d --force-recreate`.
#
# Usage:
#   cwsr                       # install latest (native) and respawn
#   cwsr --version 2.1.206     # install a specific native version
#   cwsr --no-upgrade          # respawn current claude (no install)
#   cwsr --upgrade-only        # native install without respawning
#   cwsr --print               # print the planned install + tmux argv, don't run
#   cwsr --help                # usage + exit
#
# Exit codes:
#   0   success (or --print)
#   1   native install failed / tmux respawn failed / tmux session not found
#   2   usage / bad flag

set -euo pipefail

SESSION="${CWSR_SESSION:-claude-container}"
PANE="${SESSION}:0.0"
# CWSR_CLAUDE_BIN lets tests / callers point at a specific claude entry point;
# defaults to bare `claude` (resolved on PATH — the native launcher).
CLAUDE_BIN="${CWSR_CLAUDE_BIN:-claude}"

usage() {
    cat <<'EOF'
cwsr — install (native) + respawn the in-container claude process.

Usage:
  cwsr                      Install the latest native claude then respawn pane 0.
  cwsr --version <ver>      Install a specific native version (e.g. 2.1.206).
  cwsr --no-upgrade         Respawn pane 0 without installing.
  cwsr --upgrade-only       Native install only, no respawn.
  cwsr --print              Print planned commands and exit (no side effects).
  cwsr --help               Show this help.

claude-code is rolled via the NATIVE managed installer (`claude install`),
which writes into the volume-backed ~/.local/share/claude/versions/ dir — so
the roll persists across a later container recreate. npm is NOT used to
install claude-code.

The tmux session (claude-container) and the wrapping container both survive —
only the inner claude process rolls. Operator's shell, env, and volume-backed
state persist across the roll.

Re-execs claude with the same argv shape entrypoint.sh built (honors
CLAUDE_SHIM_SETTINGS_PATH and CLAUDE_AUTO_CONTINUE). To change those shape
variables you still need a real docker compose recreate.

Env overrides (mostly for testing):
  CWSR_SESSION     tmux session name (default: claude-container)
  CWSR_CLAUDE_BIN  claude entry point for `claude install` (default: claude)
EOF
}

UPGRADE=1
RESPAWN=1
PRINT_ONLY=0
INSTALL_TARGET="latest"

while [ "$#" -gt 0 ]; do
    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --no-upgrade)
            UPGRADE=0
            shift
            ;;
        --upgrade-only)
            RESPAWN=0
            shift
            ;;
        --version)
            if [ "$#" -lt 2 ]; then
                printf 'cwsr: --version requires an argument\n' >&2
                exit 2
            fi
            INSTALL_TARGET="$2"
            shift 2
            ;;
        --print)
            PRINT_ONLY=1
            shift
            ;;
        *)
            printf 'cwsr: unknown argument %q\n' "$1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [ "$UPGRADE" = "0" ] && [ "$RESPAWN" = "0" ]; then
    printf 'cwsr: --no-upgrade and --upgrade-only together is a no-op\n' >&2
    exit 2
fi

# Build the claude argv the same way entrypoint.sh does. When
# CLAUDE_SHIM_SETTINGS_PATH is set (REWRITE_HOOKS produced a shim file), append
# the --setting-sources / --settings flags; when CLAUDE_AUTO_CONTINUE is
# non-empty, append --continue. Both flags are shape-stable across a
# self-restart because the env vars are exported by entrypoint.sh and inherited
# by the tmux server, which then exports them to every pane.
build_claude_cmd() {
    local cmd="exec claude"
    if [ -n "${CLAUDE_SHIM_SETTINGS_PATH:-}" ] && [ -z "${CLAUDE_SHIM_SANITIZED_USER_FARM:-}" ]; then
        cmd="$cmd --setting-sources project,local --settings ${CLAUDE_SHIM_SETTINGS_PATH}"
    fi
    # PROJECT-tier devbar-hook leak fix (mirror entrypoint.sh): when the
    # snapshot farm's user-tier settings.json was sanitized in place
    # (CLAUDE_SHIM_SANITIZED_USER_FARM=1, exported by entrypoint.sh), drop
    # the cwd-bound poison PROJECT tier by switching to
    # `--setting-sources user,local` and re-supply the project-tier MCP
    # servers via --mcp-config. Without this a cwsr respawn would revert to
    # `project,local` and the bare host hooks would spam "Exec format error"
    # again. See container/entrypoint.sh's CLAUDE_SHIM_SANITIZED_USER_FARM
    # block for the full rationale.
    if [ -n "${CLAUDE_SHIM_SETTINGS_PATH:-}" ] && [ -n "${CLAUDE_SHIM_SANITIZED_USER_FARM:-}" ]; then
        cmd="$cmd --setting-sources user,local --settings ${CLAUDE_SHIM_SETTINGS_PATH}"
        if [ -n "${CLAUDE_MCP_CONFIG_PATH:-}" ]; then
            cmd="$cmd --mcp-config ${CLAUDE_MCP_CONFIG_PATH}"
        fi
    fi
    # Mirror entrypoint.sh: append --plugin-dir for the baked container plugin
    # (skills + agents) when it's present. Without this, a cwsr respawn would
    # silently drop the baked /claude-container:<name> commands until the next
    # docker compose recreate. The dir check falls back gracefully on older
    # images that pre-date the plugin bake (no plugin dir => no flag).
    local plugin_dir="${CWSR_PLUGIN_DIR:-/opt/claude-container/plugin}"
    if [ -d "$plugin_dir/.claude-plugin" ]; then
        cmd="$cmd --plugin-dir $plugin_dir"
    fi
    if [ "${CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS:-}" = "1" ]; then
        cmd="$cmd --dangerously-skip-permissions"
    fi
    if [ -n "${CLAUDE_AUTO_CONTINUE:-}" ]; then
        local q="'${CLAUDE_AUTO_CONTINUE//\'/\'\\\'\'}'"
        cmd="$cmd --continue $q"
    fi
    printf '%s' "$cmd"
}

CLAUDE_CMD="$(build_claude_cmd)"

# Native install: `claude install <target>` downloads the versioned binary
# into ~/.local/share/claude/versions/<target> and re-points the launcher.
INSTALL_ARGV=("$CLAUDE_BIN" install "$INSTALL_TARGET")
TMUX_ARGV=(tmux respawn-pane -k -t "$PANE" "$CLAUDE_CMD")

if [ "$PRINT_ONLY" = "1" ]; then
    if [ "$UPGRADE" = "1" ]; then
        printf 'INSTALL: %s\n' "${INSTALL_ARGV[*]}"
    fi
    if [ "$RESPAWN" = "1" ]; then
        printf 'TMUX: %s\n' "${TMUX_ARGV[*]}"
    fi
    exit 0
fi

# Sanity: refuse to respawn if the tmux session doesn't exist. Without this the
# respawn fails with a confusing "can't find pane" error.
if [ "$RESPAWN" = "1" ]; then
    if ! tmux has-session -t "$SESSION" 2>/dev/null; then
        cat >&2 <<EOF
cwsr: tmux session '$SESSION' is not running.

cwsr only rolls the inner claude inside an already-running container.
If the container itself is down, run \`docker compose up -d\` (or
\`cw --up\` from the host) to bring it up — that path already installs
the freshest baked claude version.
EOF
        exit 1
    fi
fi

if [ "$UPGRADE" = "1" ]; then
    printf '[cwsr] installing (native): %s\n' "${INSTALL_ARGV[*]}" >&2
    if ! "${INSTALL_ARGV[@]}"; then
        printf '[cwsr] native install failed; not respawning pane\n' >&2
        exit 1
    fi
    # Sanity: confirm claude binary is invocable post-install. A failed install
    # leaving a half-written launcher would surface as a broken respawn.
    if ! command -v claude >/dev/null 2>&1; then
        printf '[cwsr] post-install: claude not on PATH; not respawning\n' >&2
        exit 1
    fi
fi

if [ "$RESPAWN" = "1" ]; then
    printf '[cwsr] respawning pane: %s\n' "$CLAUDE_CMD" >&2
    if ! "${TMUX_ARGV[@]}"; then
        printf '[cwsr] tmux respawn-pane failed\n' >&2
        exit 1
    fi
fi

printf '[cwsr] done.\n' >&2
exit 0
