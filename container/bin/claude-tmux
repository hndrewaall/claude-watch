#!/usr/bin/env bash
# claude-tmux — host-side wrapper that launches the claude-container image
# with the right bind mounts, env passthrough, signal handling, and tty.
#
# See container/README.md "Blast radius" for the full mount + env surface.
#
# Usage:
#   claude-tmux                 # launch the tmux session via image ENTRYPOINT
#   claude-tmux bash            # debug shell inside the container
#   claude-tmux verify          # post-up sanity check: forwarded env vars
#                               # / mounts visible AND resolvable inside the
#                               # running container. Pairs with `up -d` for
#                               # operators to catch silent CA / hook misconfig.
#   claude-tmux --help          # show usage and exit (no docker invoked)
#
# Env var overrides:
#   CLAUDE_CONTAINER_IMAGE      # image tag (default: claude-container:dev)
#   CLAUDE_HOST_PROJECT_DIR     # ABSOLUTE host path that should also be the
#                               # in-container cwd. Bind-mounted at the SAME
#                               # path inside the container so Claude Code's
#                               # cwd-derived project key (~/.claude/projects/
#                               # <urlencoded-cwd>/) resolves to the same key
#                               # the host would use. Without this, the
#                               # in-container claude lands at /workspace and
#                               # never finds the host-side project memory
#                               # tree even though ~/.claude is bind-mounted.
#                               # Missing dir = silently skipped (falls back
#                               # to the /workspace default).
#   CLAUDE_CONTAINER_REWRITE_HOOKS  # When "1" (default off), the entrypoint
#                               # generates a container-local settings.json
#                               # that wraps every hook command in
#                               # /usr/local/bin/exec-hook so cross-arch
#                               # Mach-O / unknown binaries no-op silently
#                               # instead of spamming "Exec format error".
#                               # Off by default to preserve existing
#                               # behaviour; opt-in for Mac-host operators.
#   CLAUDE_AUTO_CONTINUE        # When non-empty, the entrypoint appends
#                               # `--continue "$CLAUDE_AUTO_CONTINUE"` to
#                               # the in-container claude invocation so the
#                               # prior conversation auto-resumes with the
#                               # value as the seed prompt. Matches a host
#                               # alias of shape `claude --continue resume`.
#                               # Default unset = bare claude. Forwarded
#                               # via the wildcard CLAUDE_* passthrough
#                               # below.
#
# Env vars passed through to the container (only if set on the host):
#   CLAUDE_CODE_SSE_PORT        # load-bearing for VSCode IDE integration
#   CLAUDE_CODE_IDE_HOST_OVERRIDE  # host the claude binary connects to for SSE
#   ANTHROPIC_API_KEY           # API key, if not using Pro auth via ~/.claude
#   CLAUDE_* / ANTHROPIC_*      # any other matching env vars
#   NODE_EXTRA_CA_CERTS         # extra CA bundle for Node (Claude Code is Node);
#                               # if it points at an existing file, that file is
#                               # auto bind-mounted at the same path inside the
#                               # container (read-only) so the path resolves.
#   SSL_CERT_FILE               # OpenSSL CA bundle (curl, Python requests, etc.)
#                               # auto bind-mounted same as NODE_EXTRA_CA_CERTS.
#   REQUESTS_CA_BUNDLE          # Python requests/urllib3 CA bundle, auto bind-mounted.
#   CURL_CA_BUNDLE              # curl CA bundle override, auto bind-mounted.
#   HTTPS_PROXY / HTTP_PROXY / NO_PROXY / https_proxy / http_proxy / no_proxy
#                               # Corporate proxy settings (VPN'd into SF / similar).
#                               # Forwarded verbatim; the proxy host needs to be
#                               # reachable from inside the container's netns
#                               # (bridge networking + host-gateway alias usually
#                               # handles a host-loopback proxy).
#
# Bind mounts (rw):
#   ~/.claude  -> /home/hndrewaall/.claude    (session state, credentials)
#   ~/repos    -> /home/hndrewaall/repos      (code; needed for in-container git)
#   $PWD       -> /workspace                  (the cwd you invoked from)
#
# Named volume (Phase 1d, q-2026-05-11-c0b9):
#   claude-container-versions -> /home/hndrewaall/.local/share/claude
#     Persists the in-container claude binary's auto-updated versions/<ver>/
#     across `--rm`. Without this, every container restart resets to the
#     image-baked claude. Inspect: `docker volume inspect
#     claude-container-versions`. Nuke: `docker volume rm
#     claude-container-versions`.
#
# Network policy — bridge networking with explicit host-loopback plumbing:
#   bridge mode           — default docker networking, container in its own netns
#   --add-host alias      — host.docker.internal resolves to the host-gateway IP
#   IDE_HOST_OVERRIDE env — claude binary skips its 127.0.0.1 default and dials
#                           host.docker.internal:$CLAUDE_CODE_SSE_PORT for SSE
# Empirically verified by Phase 0d's 4-test matrix (q-4acf); see project doc
# §8 "Phase 0d". Docker Desktop on macOS/Windows provides host.docker.internal
# natively; on Linux the --add-host=host.docker.internal:host-gateway flag is
# what makes it resolvable (Docker Engine 20.10+).
#
# Docker invocation: tries bare `docker` first, falls back to `sudo docker` for
# hosts where the invoking user is not in the docker group. `sudo docker` with
# NOPASSWD is the supported fallback path.

set -euo pipefail

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------

IMAGE="${CLAUDE_CONTAINER_IMAGE:-claude-container:dev}"
CONTAINER_NAME="claude-tmux-$$"

# -----------------------------------------------------------------------------
# --help / -h handling — runs BEFORE any docker probe so it works offline.
# -----------------------------------------------------------------------------

usage() {
    cat <<'EOF'
claude-tmux — launch the claude-container image with host bind mounts.

Usage:
  claude-tmux              Launch the tmux session via the image ENTRYPOINT.
  claude-tmux bash         Debug shell inside the container (skips entrypoint).
  claude-tmux --help       Show this help and exit.

Environment overrides:
  CLAUDE_CONTAINER_IMAGE   Image tag (default: claude-container:dev).
  CLAUDE_HOST_HOOKS_DIR    Host directory of settings.json hook scripts to
                           bind-mount at the SAME path inside the container,
                           read-only. Required when ~/.claude/settings.json
                           references a host-only path (e.g. corp telemetry
                           hook at /Users/<you>/.devbar/bin/telemetry-hook).
                           Missing dir = silently skipped.
  CLAUDE_HOST_PROJECT_DIR  Absolute host path to make the in-container cwd.
                           Bind-mounted at the SAME path inside the container
                           and set as the container WORKDIR so Claude Code's
                           cwd-derived project key matches the host. Without
                           this the in-container cwd is /workspace and project
                           memory under ~/.claude/projects/-<host-path-key>/
                           is invisible. Missing dir = silently skipped (the
                           wrapper falls back to the default /workspace).
  CLAUDE_CONTAINER_REWRITE_HOOKS  When "1", the entrypoint generates a
                           container-local settings.json that wraps every
                           hook command in /usr/local/bin/exec-hook so
                           cross-arch Mach-O / unknown binaries no-op
                           silently instead of spamming "Exec format error"
                           on every hook event. Default off to preserve
                           existing behaviour.

Environment passthrough (only if set on the host):
  CLAUDE_CODE_SSE_PORT     VSCode IDE integration port (load-bearing).
  ANTHROPIC_API_KEY        API key if not using ~/.claude credentials.
  CLAUDE_* / ANTHROPIC_*   Any other matching env vars.
  NODE_EXTRA_CA_CERTS      Node CA bundle. If the var points at an existing
                           file, that file is auto bind-mounted (read-only)
                           at the same path inside the container so corporate
                           SSL chains resolve.
  SSL_CERT_FILE            OpenSSL CA bundle, same auto-mount treatment.
  REQUESTS_CA_BUNDLE       Python requests/urllib3 CA bundle, same.
  CURL_CA_BUNDLE           curl CA bundle override, same.
  HTTPS_PROXY / HTTP_PROXY / NO_PROXY (and lowercase variants)
                           Corporate proxy settings, forwarded verbatim.

Bind mounts (read-write):
  ~/.claude   -> /home/hndrewaall/.claude    Session state, credentials.
  ~/repos     -> /home/hndrewaall/repos      Code, all git repos.
  $PWD        -> /workspace                  Workspace at invoking cwd.

Named volume (Phase 1d):
  claude-container-versions -> /home/hndrewaall/.local/share/claude
    Persists in-container claude auto-updated versions/<ver>/ across --rm.
    Inspect: docker volume inspect claude-container-versions
    Nuke:    docker volume rm claude-container-versions

Network: bridge + --add-host=host.docker.internal:host-gateway, with
         CLAUDE_CODE_IDE_HOST_OVERRIDE=host.docker.internal forwarded so the
         in-container claude binary dials the host for SSE (Phase 1c).
User:    container runs as uid 1000 / gid 1000 (matches a UID-1000 host user).

Docker: uses `docker` if accessible, else `sudo docker`. If neither works,
add your user to the docker group OR ensure `sudo -n docker` works (NOPASSWD).
EOF
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
fi

# Flag parsing — order-independent: each flag is checked in a loop so the
# caller can pass --print-docker-args / --suppress-warnings / verify in any
# order. Each match consumes one argv element via `shift`.
PRINT_DOCKER_ARGS=0
SUPPRESS_WARNINGS=0
VERIFY_MODE=0
while [ "$#" -gt 0 ]; do
    case "${1:-}" in
        --print-docker-args)
            # Testing hook: build the docker invocation but emit the argv
            # (one-per-line, no docker actually run) instead of executing.
            # Used by container/bin/tests/claude-tmux-env.test to verify
            # env / mount forwarding without spinning up a container or
            # requiring docker.
            PRINT_DOCKER_ARGS=1
            shift
            ;;
        --suppress-warnings)
            # Testing hook + escape valve: silence the set-but-missing CA
            # / hooks-dir stderr warnings emitted later. Tests that pass
            # /nonexistent/path values to exercise the *forwarding* logic
            # (e.g. test_ssl_ca_missing_file_no_mount) set this so their
            # stderr capture stays clean. Operators can also pass it on
            # the command line if they prefer to ignore warnings they've
            # already acknowledged.
            SUPPRESS_WARNINGS=1
            shift
            ;;
        verify)
            # `verify` subcommand: post-up sanity check. Re-uses the same
            # env-passthrough detection logic the wrapper uses for `docker
            # run`, but instead of starting a fresh container it
            # `docker exec`s into a running one to confirm every forwarded
            # env var is visible AND every mount path resolves inside the
            # container. Handled BELOW after we've parsed all env state.
            VERIFY_MODE=1
            shift
            ;;
        *)
            break
            ;;
    esac
done


# -----------------------------------------------------------------------------
# Pick a docker invocation that works: bare first, sudo fallback.
# -----------------------------------------------------------------------------

DOCKER_CMD=()
if [ "$PRINT_DOCKER_ARGS" = "1" ]; then
    # Skip the docker probe entirely under the testing hook — the test runs
    # in CI / on dev machines without docker access. Use a placeholder so
    # the rest of the script behaves identically.
    DOCKER_CMD=(docker)
elif docker ps >/dev/null 2>&1; then
    DOCKER_CMD=(docker)
elif sudo -n docker ps >/dev/null 2>&1; then
    DOCKER_CMD=(sudo docker)
else
    cat >&2 <<'EOF'
claude-tmux: cannot reach the Docker daemon.

Tried `docker ps` (failed) and `sudo -n docker ps` (failed).

Fix one of:
  - Add your user to the docker group:  sudo usermod -aG docker $USER  (then re-login)
  - Ensure sudo docker works without a password (NOPASSWD entry in sudoers).
EOF
    exit 1
fi

# -----------------------------------------------------------------------------
# Build env-passthrough list. Only forwards vars that are SET in the calling
# shell — empty/unset stays empty/unset inside the container.
# -----------------------------------------------------------------------------

env_args=()

# Explicit named pass-throughs (always try, only forward if set).
for v in CLAUDE_CODE_SSE_PORT ANTHROPIC_API_KEY; do
    if [ -n "${!v-}" ]; then
        env_args+=(-e "$v=${!v}")
    fi
done

# CLAUDE_CODE_IDE_HOST_OVERRIDE — load-bearing for bridge networking. Default to
# host.docker.internal so the in-container claude binary dials the host over the
# --add-host alias below; if the caller set it explicitly, preserve their value.
env_args+=(-e "CLAUDE_CODE_IDE_HOST_OVERRIDE=${CLAUDE_CODE_IDE_HOST_OVERRIDE:-host.docker.internal}")

# Wildcard CLAUDE_* / ANTHROPIC_* — capture any other branded vars without
# duplicating ones already forwarded above.
while IFS= read -r name; do
    case "$name" in
        CLAUDE_CODE_SSE_PORT|ANTHROPIC_API_KEY|CLAUDE_CODE_IDE_HOST_OVERRIDE) continue ;;
    esac
    if [ -n "${!name-}" ]; then
        env_args+=(-e "$name=${!name}")
    fi
done < <(env | grep -E '^(CLAUDE|ANTHROPIC)_' | cut -d= -f1 | sort -u || true)

# -----------------------------------------------------------------------------
# Corporate-network passthrough: SSL CA bundles + proxy settings.
#
# Why: operators on enterprise VPNs (Salesforce, etc.) inject a corp CA into
# their host's NODE_EXTRA_CA_CERTS / SSL_CERT_FILE / etc. so HTTPS to corp
# endpoints validates. Without forwarding, the in-container claude binary
# trips on "Unable to connect to API: SSL certificate verification failed.
# Check your proxy or corporate SSL certificates" against any TLS endpoint
# behind the corp MITM proxy.
#
# Two things have to happen:
#   1. Forward the env var into the container so Node / OpenSSL / requests
#      / curl pick up the override.
#   2. Bind-mount the CA file at the SAME path inside the container so the
#      env var's path resolves. The bookworm-slim runtime image has its
#      own /etc/ssl/certs/ tree but doesn't know about your corp root.
#
# Proxy vars (HTTPS_PROXY / HTTP_PROXY / NO_PROXY + lowercase) are just
# forwarded — the proxy hostname needs to be reachable from the container's
# netns. host.docker.internal is wired via --add-host below, so a
# host-loopback corp proxy works without extra config.
# -----------------------------------------------------------------------------

ssl_mount_args=()
# Newline-separated dedup list of absolute paths already mounted (so two
# env vars pointing at the same bundle don't generate two -v args).
# Newline-delimited because absolute paths can contain spaces but not
# newlines on every supported OS. Using a plain string instead of a
# bash-4 associative array keeps the script portable to bash 3.2.
ssl_mounted_paths=""

ssl_passthrough_var() {
    # Forward $1 into the container; if its value names an existing file,
    # also bind-mount that file read-only at the same path. Dedup by
    # absolute path so two env vars pointing at the same bundle only
    # mount once.
    local name="$1"
    local val="${!name-}"
    if [ -z "$val" ]; then
        return 0
    fi
    env_args+=(-e "$name=$val")
    # Only attempt the bind mount when the value looks like a real file
    # path on the host (skip URLs, "1"/"true"/etc, missing paths).
    if [ -f "$val" ]; then
        local abs
        abs="$(cd "$(dirname "$val")" && pwd)/$(basename "$val")"
        # Dedup: only mount if we haven't already mounted this absolute path.
        case $'\n'"$ssl_mounted_paths"$'\n' in
            *$'\n'"$abs"$'\n'*) ;;
            *)
                ssl_mounted_paths="${ssl_mounted_paths}${abs}"$'\n'
                # Read-only so the container can't mutate the host's CA bundle.
                ssl_mount_args+=(-v "$abs:$abs:ro")
                ;;
        esac
    fi
}

for v in NODE_EXTRA_CA_CERTS SSL_CERT_FILE REQUESTS_CA_BUNDLE CURL_CA_BUNDLE; do
    ssl_passthrough_var "$v"
done

# Proxy env vars: forward verbatim. Both uppercase and lowercase variants —
# Node honors uppercase; many Linux CLIs (curl, python requests) check
# lowercase first.
for v in HTTPS_PROXY HTTP_PROXY NO_PROXY https_proxy http_proxy no_proxy; do
    if [ -n "${!v-}" ]; then
        env_args+=(-e "$v=${!v}")
    fi
done

# -----------------------------------------------------------------------------
# Host hook-script bind mount.
#
# When ~/.claude/settings.json (which IS bind-mounted into the container)
# references hook scripts by absolute host path — e.g. a corporate
# telemetry hook at /Users/<you>/.devbar/bin/telemetry-hook — the path
# doesn't exist inside the container and Claude Code surfaces
# "SessionStart:startup hook error — /bin/sh: 1: <path>: not found".
#
# Setting CLAUDE_HOST_HOOKS_DIR on the host tells the wrapper to bind-mount
# that directory at the SAME path inside the container so the hook resolves.
# The mount is read-only — hooks shouldn't mutate themselves.
#
# Missing / empty / non-directory = silently skipped (graceful no-op for
# operators without hooks).
# -----------------------------------------------------------------------------

hooks_mount_args=()
if [ -n "${CLAUDE_HOST_HOOKS_DIR:-}" ] && [ -d "$CLAUDE_HOST_HOOKS_DIR" ]; then
    hooks_abs="$(cd "$CLAUDE_HOST_HOOKS_DIR" && pwd)"
    hooks_mount_args+=(-v "$hooks_abs:$hooks_abs:ro")
fi

# -----------------------------------------------------------------------------
# Host-project-dir bind mount + cwd override.
#
# Claude Code derives its project-memory tree key from the cwd at launch:
#   ~/.claude/projects/<urlencoded-cwd>/memory/MEMORY.md
# On the host, cwd is the operator's actual project dir, e.g.
#   /Users/<you>/repos/eichi -> project key "-Users-<you>-repos-eichi".
# In the container, the default cwd is /workspace -> project key "-workspace",
# which does not exist on the host, so the in-container claude reports "No
# previous memories found" even though ~/.claude is bind-mounted with the
# real tree.
#
# CLAUDE_HOST_PROJECT_DIR is the escape hatch: bind-mount the host path at
# the SAME absolute path inside the container AND override the container's
# WORKDIR so Claude lands there. The project key then matches the host key
# exactly and project memory loads. Read-write because operators expect to
# edit code from inside Claude.
#
# Missing-dir handling matches CLAUDE_HOST_HOOKS_DIR: silently skipped with
# a stderr WARNING via the fail-loud guard below.
# -----------------------------------------------------------------------------

project_dir_mount_args=()
project_dir_workdir=""
if [ -n "${CLAUDE_HOST_PROJECT_DIR:-}" ] && [ -d "$CLAUDE_HOST_PROJECT_DIR" ]; then
    project_abs="$(cd "$CLAUDE_HOST_PROJECT_DIR" && pwd)"
    project_dir_mount_args+=(-v "$project_abs:$project_abs")
    project_dir_workdir="$project_abs"
fi

# -----------------------------------------------------------------------------
# Fail-loud guard: set-but-missing paths.
#
# The forwarding logic above is forgiving by design — a CA env var that
# points at a non-existent file is forwarded to the container anyway (the
# value may be meaningful even without a host bind-mount, e.g. inside a
# downstream image that bakes its own bundle at that path). But "forgiving"
# is also a silent-bypass failure mode: if the operator's host env points
# at a stale path, the container falls back to its baked system CA and
# corporate TLS endpoints quietly fail validation. That's the exact bug
# class motivating this warning.
#
# Policy: when one of the CA env vars OR CLAUDE_HOST_HOOKS_DIR is set but
# the referenced path doesn't exist (file for CA vars, directory for the
# hooks dir), emit a single explicit WARNING line per variable to stderr
# before invoking docker. Suppressed under --suppress-warnings (tests +
# explicit operator opt-out). Does NOT exit non-zero — silent fallback is
# still possible if the operator chooses to ignore the warning, but at
# least they've SEEN it.
# -----------------------------------------------------------------------------

warn() {
    if [ "$SUPPRESS_WARNINGS" = "0" ]; then
        printf 'claude-tmux: WARNING: %s\n' "$1" >&2
    fi
}

for v in NODE_EXTRA_CA_CERTS SSL_CERT_FILE REQUESTS_CA_BUNDLE CURL_CA_BUNDLE; do
    val="${!v-}"
    if [ -n "$val" ] && [ ! -f "$val" ]; then
        warn "\$$v is set to '$val' on the host but the file does not exist."
        warn "The container will silently use the system CA. To fix: either unset \$$v or correct the path."
    fi
done

if [ -n "${CLAUDE_HOST_HOOKS_DIR:-}" ] && [ ! -d "$CLAUDE_HOST_HOOKS_DIR" ]; then
    warn "\$CLAUDE_HOST_HOOKS_DIR is set to '$CLAUDE_HOST_HOOKS_DIR' on the host but no such directory exists."
    warn "settings.json hook references pointing at that path will fail inside the container. To fix: either unset \$CLAUDE_HOST_HOOKS_DIR or correct the path."
fi

if [ -n "${CLAUDE_HOST_PROJECT_DIR:-}" ] && [ ! -d "$CLAUDE_HOST_PROJECT_DIR" ]; then
    warn "\$CLAUDE_HOST_PROJECT_DIR is set to '$CLAUDE_HOST_PROJECT_DIR' on the host but no such directory exists."
    warn "The container will fall back to /workspace as its cwd. Project memory under ~/.claude/projects/-<host-path-key>/ will not load. To fix: either unset \$CLAUDE_HOST_PROJECT_DIR or correct the path."
fi

# -----------------------------------------------------------------------------
# Signal handling — forward SIGTERM/SIGINT to the container so it can exit
# cleanly. The trap fires the kill in the background; the main `docker run`
# call then returns naturally with the container's exit code.
# -----------------------------------------------------------------------------

forward_signal() {
    local sig="$1"
    # Best-effort. If the container is already gone, docker kill is a no-op.
    "${DOCKER_CMD[@]}" kill --signal="$sig" "$CONTAINER_NAME" >/dev/null 2>&1 || true
}

trap 'forward_signal TERM' TERM
trap 'forward_signal INT' INT

# -----------------------------------------------------------------------------
# Run.
#
# --rm so the container is disposed after exit (state lives on host bind mounts).
# -i always (need stdin for the tmux UI / debug shell).
# -t only if stdout is actually a TTY — non-tty callers (CI, agents running
#   `claude-tmux bash -c "..."` via a captured pipe) would otherwise fail with
#   "cannot attach stdin to a TTY-enabled container because stdin is not a terminal".
# --name <fixed> so the trap above can target the right container.
# Bridge networking (Docker's default) + --add-host=host.docker.internal:host-gateway
# so the in-container claude can dial the host's SSE listener via the env-var
# override (see header). Docker Desktop populates host.docker.internal natively
# on macOS/Windows; --add-host is harmless there and required on Linux.
# -w /workspace: matches Dockerfile WORKDIR; explicit here for safety.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# `claude-tmux verify` — post-up sanity check.
#
# Runs `docker compose exec` (or `docker exec`) against a running container
# matching the image tag and asserts each forwarded env var is visible AND,
# for the CA path / hooks-dir vars, that the referenced path resolves inside
# the container. Exits non-zero if any check fails.
#
# Detection: scans `docker ps` for a container running CLAUDE_CONTAINER_IMAGE.
# If multiple match, the operator can set CLAUDE_TMUX_CONTAINER to disambiguate.
# -----------------------------------------------------------------------------

if [ "$VERIFY_MODE" = "1" ]; then
    # Pick the target container. Operator override wins; otherwise first
    # match by image tag.
    target="${CLAUDE_TMUX_CONTAINER:-}"
    if [ -z "$target" ]; then
        target="$("${DOCKER_CMD[@]}" ps --filter "ancestor=$IMAGE" --format '{{.ID}}' | head -n1)"
    fi
    if [ -z "$target" ]; then
        cat >&2 <<EOF
claude-tmux verify: no running container found for image '$IMAGE'.

Start one with:
  docker compose up -d

Or specify a container id/name explicitly:
  CLAUDE_TMUX_CONTAINER=<id-or-name> claude-tmux verify
EOF
        exit 1
    fi

    verify_failures=0
    verify_checked=0

    # Check that a single env var is set inside the container (printenv).
    check_env_in_container() {
        local name="$1"
        local expected="$2"
        verify_checked=$((verify_checked + 1))
        local actual
        actual="$("${DOCKER_CMD[@]}" exec "$target" printenv "$name" 2>/dev/null || true)"
        if [ "$actual" != "$expected" ]; then
            printf 'claude-tmux verify: FAIL  $%s inside container = "%s" (expected "%s")\n' \
                "$name" "$actual" "$expected" >&2
            verify_failures=$((verify_failures + 1))
        else
            printf 'claude-tmux verify: PASS  $%s = "%s"\n' "$name" "$actual"
        fi
    }

    # Check that a path resolves inside the container.
    check_path_in_container() {
        local name="$1"
        local path="$2"
        local kind="$3"  # "file" or "dir"
        verify_checked=$((verify_checked + 1))
        local test_flag
        case "$kind" in
            file) test_flag="-f" ;;
            dir)  test_flag="-d" ;;
            *)    test_flag="-e" ;;
        esac
        if "${DOCKER_CMD[@]}" exec "$target" test "$test_flag" "$path" 2>/dev/null; then
            printf 'claude-tmux verify: PASS  $%s path resolves inside container (%s)\n' \
                "$name" "$path"
        else
            printf 'claude-tmux verify: FAIL  $%s path does NOT resolve inside container (%s)\n' \
                "$name" "$path" >&2
            verify_failures=$((verify_failures + 1))
        fi
    }

    # Forwarded CA / proxy env vars: every var SET on the host should be
    # visible inside the container with the same value. For path-valued
    # ones, the path should also resolve inside.
    for v in NODE_EXTRA_CA_CERTS SSL_CERT_FILE REQUESTS_CA_BUNDLE CURL_CA_BUNDLE; do
        val="${!v-}"
        if [ -n "$val" ]; then
            check_env_in_container "$v" "$val"
            if [ -f "$val" ]; then
                check_path_in_container "$v" "$val" file
            fi
        fi
    done

    for v in HTTPS_PROXY HTTP_PROXY NO_PROXY https_proxy http_proxy no_proxy; do
        val="${!v-}"
        if [ -n "$val" ]; then
            check_env_in_container "$v" "$val"
        fi
    done

    if [ -n "${CLAUDE_HOST_HOOKS_DIR:-}" ] && [ -d "$CLAUDE_HOST_HOOKS_DIR" ]; then
        hooks_abs="$(cd "$CLAUDE_HOST_HOOKS_DIR" && pwd)"
        check_path_in_container "CLAUDE_HOST_HOOKS_DIR" "$hooks_abs" dir
    fi

    if [ "$verify_checked" = "0" ]; then
        echo "claude-tmux verify: no forwarded env / mount vars set on host — nothing to check." >&2
        echo "  (Set NODE_EXTRA_CA_CERTS, HTTPS_PROXY, CLAUDE_HOST_HOOKS_DIR, etc. and re-run.)" >&2
        exit 0
    fi

    if [ "$verify_failures" = "0" ]; then
        printf '\nclaude-tmux verify: all %d check(s) passed.\n' "$verify_checked"
        exit 0
    fi
    printf '\nclaude-tmux verify: %d of %d check(s) FAILED.\n' "$verify_failures" "$verify_checked" >&2
    exit 1
fi

tty_flag=()
if [ -t 0 ] && [ -t 1 ]; then
    tty_flag=(-t)
fi

# Forward CLAUDE_HOST_PROJECT_DIR + CLAUDE_CONTAINER_REWRITE_HOOKS into the
# container env so the entrypoint can see them.  Both are read-only signals
# downstream of the mount + WORKDIR setup above; forwarding the value lets
# the entrypoint emit clearer diagnostics ("project dir not bind-mounted" /
# "rewrite hooks enabled") instead of guessing.
if [ -n "${CLAUDE_HOST_PROJECT_DIR:-}" ]; then
    env_args+=(-e "CLAUDE_HOST_PROJECT_DIR=$CLAUDE_HOST_PROJECT_DIR")
fi
if [ -n "${CLAUDE_CONTAINER_REWRITE_HOOKS:-}" ]; then
    env_args+=(-e "CLAUDE_CONTAINER_REWRITE_HOOKS=$CLAUDE_CONTAINER_REWRITE_HOOKS")
fi

# WORKDIR — default /workspace; override to the host-project path when
# CLAUDE_HOST_PROJECT_DIR is set (and resolved above to project_dir_workdir).
# Project-dir wins because it's the cwd the operator actually wants Claude
# Code to launch in (matches host project-memory key).
workdir="/workspace"
if [ -n "$project_dir_workdir" ]; then
    workdir="$project_dir_workdir"
fi

# Assemble the docker invocation as a single argv array so we can either
# print it (for tests) or exec it (for real invocations) without
# duplicating the argument list.
docker_argv=(
    "${DOCKER_CMD[@]}" run --rm -i "${tty_flag[@]}"
    --name "$CONTAINER_NAME"
    --add-host=host.docker.internal:host-gateway
    -v "${HOME}/.claude:/home/hndrewaall/.claude"
    -v "${HOME}/repos:/home/hndrewaall/repos"
    -v "${PWD}:/workspace"
    --mount type=volume,src=claude-container-versions,dst=/home/hndrewaall/.local/share/claude
    "${ssl_mount_args[@]}"
    "${hooks_mount_args[@]}"
    "${project_dir_mount_args[@]}"
    -w "$workdir"
    "${env_args[@]}"
    "$IMAGE"
    "$@"
)

if [ "$PRINT_DOCKER_ARGS" = "1" ]; then
    # One argv element per line; the test parses with `while read`.
    printf '%s\n' "${docker_argv[@]}"
    exit 0
fi

exec "${docker_argv[@]}"
