#!/usr/bin/env bash
# cw-tmux-bootstrap — creates the in-container tmux session in detached
# mode. Invoked by process-compose as the `setup-tmux-session` oneshot
# (see /opt/claude-container/process-compose.yml).
#
# This script extracts the tmux-session-creation logic from
# /usr/local/bin/claude-tmux-entrypoint so process-compose can run it
# as a discrete oneshot ahead of the foreground `tmux attach-session`
# process and the claude-watch daemon (both of which depend on the
# session existing).
#
# The CLAUDE_* env vars consumed below (CLAUDE_SHIM_SETTINGS_PATH,
# CLAUDE_SHIM_FILTER_USER, CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS,
# CLAUDE_AUTO_CONTINUE) are set by /usr/local/bin/claude-tmux-entrypoint
# during the pre-process-compose setup phase and propagated into this
# script via process-compose's environment-inheritance (every spawned
# process inherits the supervisor's env, which is the entrypoint's env).
#
# Re-runs are idempotent: if the session already exists (operator
# restarted process-compose without container teardown), we skip the
# creation step. `tmux has-session` is the canonical idempotency check.

set -euo pipefail

SESSION="claude-container"

# Remove stale tmux socket from a prior container incarnation. The socket
# lives on a named volume that survives force-recreate; without this, a
# stale socket would make has-session return 0 and we'd skip creation,
# leaving the operator with a dead pane. Safe here because this oneshot
# runs exactly once at container start (before anything else touches tmux).
rm -f /tmp/tmux-1000/default

if tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "[cw-tmux-bootstrap] session $SESSION already exists; skipping create" >&2
    exit 0
fi

# CLAUDE_CMD is built and exported by the entrypoint before process-compose
# starts. Use it directly.
if [ -z "${CLAUDE_CMD:-}" ]; then
    echo "[cw-tmux-bootstrap] CLAUDE_CMD not set — entrypoint did not export it" >&2
    exit 1
fi

tmux new-session -d -s "$SESSION" -x 200 -y 50 \
    "$CLAUDE_CMD"

# Allow terminal passthrough so VS Code image paste (OSC sequences)
# reaches Claude Code through tmux.
tmux set -g allow-passthrough on

# Advertise 24-bit truecolor.
tmux set -g terminal-overrides ',xterm-256color:RGB,tmux-256color:RGB'
tmux set-environment -g COLORTERM truecolor

# Optional sidebar pane.
if [ "${CLAUDE_CONTAINER_SIDEBAR:-0}" = "1" ]; then
    tmux split-window -h -t "$SESSION:0" -p 25 \
        "echo '[pane 1] starting claude-watch (config=${CLAUDE_WATCH_CONFIG:-/etc/claude-watch/config.toml})'; \
         claude-watch 2>&1 || { ec=\$?; \
            echo; echo '[pane 1] claude-watch exited with code '\$ec; \
            echo '[pane 1] dropping to shell so you can inspect; exit to close'; \
            exec bash; }"
fi

# Focus the main claude pane.
tmux select-pane -t "$SESSION:0.0"

echo "[cw-tmux-bootstrap] session $SESSION created" >&2
