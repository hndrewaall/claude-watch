#!/usr/bin/env python3
"""
eval-queue-ready-unspawned — obligation evaluator that blocks the main loop
when ready-but-unspawned queue items exist.

If `session-task queue ready --json` reports any pending item that has
been ready for longer than READY_AGE_THRESHOLD_SECS, this evaluator
DENIES (exit 1). The main loop must spawn the ready items before doing
other work.

`queue ready --json` returns exactly the ready-pending items (the
`_item_is_ready` predicate is applied server-side and the result is
pre-filtered), so we do NOT consult a `ready_now` field -- `list --json`
never emitted one, which was Bug A (the evaluator was always inert). We
keep a defensive `status == "pending"` check anyway. An age threshold
(~6 min, matching the stale-ready cron cadence) keeps freshly-registered
items from being flagged during the register->spawn window.

Exempt commands (never denied): same set as eval-event-must-act (session-task,
obligations, claude-watch-ack, etc.) plus Agent (spawning IS the fix).

Decision mode: exit_code (allow on 0, deny on 1).
"""
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone

_EXEMPT_PATTERNS = [
    r"session-task(\s|$)",
    r"obligations(\s|$)",
    r"claude-watch-ack(\s|$)",
    r"claude-watch-dispatch(\s|$)",
    r"agent-msg(\s|$)",
    r"agent-tail(\s|$)",
    r"agent-ack(\s|$)",
    r"event-ack(\s|$)",
    r"event-classify(\s|$)",
    r"signal-history(\s|$)",
    r"signal-ack(\s|$)",
    r"signal-mark-read(\s|$)",
    # botchat READ/ACK surface (operator DM channel). Andrew botchat #2049:
    # "botchat read/ack should be exempt from all gates" -- reading /
    # acking an operator botchat DM is loop bookkeeping (same role as
    # signal-* / event-ack above), never inline worker behaviour, so it must
    # not be blocked while ready-but-unspawned queue items exist. The
    # read/inspect verbs (unread-check/history/show/wait) can never worsen
    # queue state; the mark-read/ack CLEAR path is bookkeeping too. A BARE
    # compose-to-Andrew (`botchat-send --to ... --body ...`) stays GATED --
    # that is a SEND, so the send arm is arg-conditional (--mark-read/--ack
    # only), mirroring eval-event-must-act / eval-agent-ack-pending and the
    # botchat-mark-read manifest (#2047).
    r"botchat-unread-check(\s|$)",
    r"botchat-history(\s|$)",
    r"botchat-show(\s|$)",
    r"botchat-wait(\s|$)",
    r"botchat-send\b[^&;|]*\s--(?:mark-read|ack)\b",
    r"/opt/claude-container/watchers/",
    r"pingme(\s|$)",
]

_EXEMPT_RE = re.compile(
    r"^\s*(" + "|".join(_EXEMPT_PATTERNS) + r")",
)


# Only flag items that have been ready longer than this (seconds). Matches
# the stale-ready cron cadence (~6 min) so an item that was JUST registered
# and is about to be spawned in the same turn isn't falsely flagged during
# the register->spawn window. Override via env for tests.
READY_AGE_THRESHOLD_SECS = int(os.environ.get("READY_AGE_THRESHOLD_SECS", "360"))


def _is_exempt(cmd: str) -> bool:
    return bool(_EXEMPT_RE.match(cmd))


def _age_secs(item: dict) -> float | None:
    """Seconds since the item was created (its ready clock). None if unknown."""
    ts = item.get("registered_at") or item.get("created_at")
    if not ts:
        return None
    try:
        dt = datetime.fromisoformat(ts)
    except (ValueError, TypeError):
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return (datetime.now(timezone.utc) - dt).total_seconds()


def main() -> int:
    cmd = sys.stdin.read().strip()

    if _is_exempt(cmd):
        return 0

    try:
        result = subprocess.run(
            ["session-task", "queue", "ready", "--json"],
            capture_output=True, text=True, timeout=5,
        )
        if result.returncode != 0:
            return 0  # default-open on error

        items = json.loads(result.stdout)
    except (subprocess.TimeoutExpired, json.JSONDecodeError, OSError):
        return 0  # default-open

    # `queue ready --json` may return a bare list or {"items": [...]}.
    if isinstance(items, dict):
        items = items.get("items", [])
    if not isinstance(items, list):
        return 0  # default-open on unexpected shape

    # `queue ready` is already pre-filtered to ready-pending items. Keep a
    # defensive status check, and require the item to have been ready longer
    # than the threshold so we don't flag items mid register->spawn.
    ready_unspawned = []
    for i in items:
        if i.get("status") != "pending":
            continue
        age = _age_secs(i)
        if age is not None and age < READY_AGE_THRESHOLD_SECS:
            continue
        ready_unspawned.append(i)

    if not ready_unspawned:
        return 0

    summaries = "; ".join(i.get("summary", i.get("id", "?"))[:40] for i in ready_unspawned[:3])
    print(
        f"DENIED: {len(ready_unspawned)} ready queue item(s) unspawned: {summaries}. "
        f"Spawn them (session-task queue register + Agent) before doing other work.",
        file=sys.stderr,
    )
    return 1


if __name__ == "__main__":
    sys.exit(main())
