#!/usr/bin/env python3
"""Tests for container/hooks-shim/generate-hooks-shim-settings.

Coverage:
  - Empty / missing hooks key: passthrough, no rewrite.
  - Single hook command: wrapped with /usr/local/bin/exec-hook prefix.
  - Already-wrapped (exec-hook ... or /usr/local/bin/exec-hook ...):
    no double-wrap.
  - Mixed-shape settings.json: only hooks.<event>.[*].hooks[*].command
    is touched, every other top-level key passes through unchanged.
  - Multiple hooks across multiple events: every command wrapped.
  - Malformed hook tree (non-dict entries, non-list inner hooks):
    passed through unchanged, no exception.
  - Missing input file: exit 0, no output written.
  - Unparseable input: exit 0, no output written, stderr explains why.
  - Output path: created with 0600 perms, parent dir auto-created.
  - Atomic write: a temp file is used + rename (we don't catch a
    half-written file in a race, but we DO verify the temp suffix
    leaves no leftover after success).
  - mcpServers in input settings.json passes through verbatim
    (this helper no longer rewrites mcpServers — that's
    generate-project-mcp-json's job).

Run:  ./generate-hooks-shim-settings.test
"""

from __future__ import annotations

import json
import os
import stat
import subprocess
import sys
import tempfile
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "generate-hooks-shim-settings"

if not SCRIPT.exists():
    print(f"FAIL: cannot locate helper at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


EXEC_HOOK = "/usr/local/bin/exec-hook"


def run_helper(
    input_path: str,
    output_path: str,
    expect_rc: int = 0,
    patterns: str | None = None,
    env_patterns: str | None = None,
    inject_obligations: bool = False,
    mcp_autoapprove: bool = False,
) -> tuple[str, str]:
    cmd = [str(SCRIPT), "--input", input_path, "--output", output_path, "--quiet"]
    if patterns is not None:
        cmd += ["--shim-patterns", patterns]
    # Default to NOT injecting obligations hooks in tests so the
    # rewrite-only path stays inspectable. Production callers (entrypoint.sh)
    # pass --inject-obligations explicitly via $CLAUDE_CONTAINER_OBLIGATIONS.
    cmd += ["--inject-obligations", "1" if inject_obligations else "0"]
    # Default to NOT auto-approving project MCP servers in this shared
    # helper so the rewrite-only equality assertions (exact-dict compares)
    # stay clean. Production default is ON; the dedicated mcp-autoapprove
    # tests below exercise the default-on / opt-out behavior via
    # _run_helper_mcp().
    cmd += ["--mcp-autoapprove", "1" if mcp_autoapprove else "0"]
    env = dict(os.environ)
    # Always wipe CLAUDE_SHIM_PATTERNS so a host-set value doesn't leak
    # into tests that don't explicitly opt in.
    env.pop("CLAUDE_SHIM_PATTERNS", None)
    # Likewise wipe the obligations env var so a host-set value doesn't
    # override the explicit per-test default above.
    env.pop("CLAUDE_CONTAINER_OBLIGATIONS", None)
    env.pop("CLAUDE_SHIM_OBLIGATIONS_ONLY", None)
    # And the MCP auto-approve env var (explicit flag above already wins,
    # but wipe for hygiene / clarity).
    env.pop("CLAUDE_MCP_AUTOAPPROVE", None)
    if env_patterns is not None:
        env["CLAUDE_SHIM_PATTERNS"] = env_patterns
    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        timeout=10,
        env=env,
    )
    if result.returncode != expect_rc:
        raise AssertionError(
            f"helper exited {result.returncode} (expected {expect_rc})\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )
    return result.stdout, result.stderr


def write_json(path: Path, obj) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as f:
        json.dump(obj, f)


def load_output(path: Path):
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)


def test_no_hooks_key_passthrough() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"someOtherKey": {"x": 1}, "permissions": {"deny": []}})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result == {"someOtherKey": {"x": 1}, "permissions": {"deny": []}},
               f"no-hooks: expected passthrough, got {result}")


def test_empty_hooks_dict_passthrough() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {}})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result == {"hooks": {}},
               f"empty-hooks: expected unchanged, got {result}")


def test_single_command_wrapped() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": [
                    {
                        "matcher": "startup|resume",
                        "hooks": [
                            {"type": "command", "command": "/Users/me/.local/bin/telemetry-hook"},
                        ],
                    },
                ],
            },
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        cmd = result["hooks"]["SessionStart"][0]["hooks"][0]["command"]
        expect(cmd == f"{EXEC_HOOK} /Users/me/.local/bin/telemetry-hook",
               f"single-cmd: wrapper missing, got {cmd!r}")


def test_already_wrapped_not_double_wrapped() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        # Two forms of pre-wrap: bare `exec-hook ...` (PATH-resolved) and
        # the absolute path form. Both should pass through unchanged.
        write_json(inp, {
            "hooks": {
                "Stop": [
                    {
                        "hooks": [
                            {"type": "command", "command": "exec-hook /Users/me/hook"},
                            {"type": "command", "command": f"{EXEC_HOOK} /Users/me/hook2"},
                        ],
                    },
                ],
            },
        })
        run_helper(str(inp), str(out))
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        expect(cmds[0] == "exec-hook /Users/me/hook",
               f"already-wrapped: bare exec-hook should pass through, got {cmds[0]!r}")
        expect(cmds[1] == f"{EXEC_HOOK} /Users/me/hook2",
               f"already-wrapped: absolute exec-hook should pass through, got {cmds[1]!r}")


def test_multi_event_multi_hook_all_wrapped() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": [
                    {"hooks": [{"type": "command", "command": "/p/a"}]},
                    {"hooks": [{"type": "command", "command": "/p/b"}]},
                ],
                "PreToolUse": [
                    {
                        "matcher": "Bash",
                        "hooks": [
                            {"type": "command", "command": "/p/c"},
                            {"type": "command", "command": "/p/d"},
                        ],
                    },
                ],
                "Stop": [
                    {"hooks": [{"type": "command", "command": "/p/e"}]},
                ],
            },
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        cmds = []
        for entries in result["hooks"].values():
            for entry in entries:
                for h in entry["hooks"]:
                    cmds.append(h["command"])
        for cmd in cmds:
            expect(cmd.startswith(f"{EXEC_HOOK} "),
                   f"multi-hook: every command should be wrapped, got {cmd!r}")
        expect(len(cmds) == 5, f"multi-hook: expected 5 commands, got {len(cmds)}")


def test_other_top_level_keys_preserved() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "permissions": {"deny": ["Bash(rm -rf /)"]},
            "env": {"FOO": "bar"},
            "hooks": {
                "Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}],
            },
            "unknownTopLevelKey": [1, 2, 3],
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result["permissions"] == {"deny": ["Bash(rm -rf /)"]},
               "other-keys: permissions should pass through")
        expect(result["env"] == {"FOO": "bar"},
               "other-keys: env should pass through")
        expect(result["unknownTopLevelKey"] == [1, 2, 3],
               "other-keys: unknown keys should pass through")


def test_malformed_hooks_tree_no_exception() -> None:
    """Non-dict entries / non-list inner hooks pass through unchanged."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": "not-a-list",  # malformed event value
                "Stop": [
                    "not-a-dict-entry",  # malformed entry
                    {"hooks": "not-a-list"},  # malformed inner hooks
                    {"hooks": [
                        "not-a-dict-hook",  # malformed hook
                        {"type": "command", "command": "/p/valid"},  # valid one
                    ]},
                ],
            },
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        # Malformed paths pass through unchanged.
        expect(result["hooks"]["SessionStart"] == "not-a-list",
               "malformed: non-list event value should pass through")
        # The one valid command in the mess still gets wrapped.
        valid_cmd = result["hooks"]["Stop"][2]["hooks"][1]["command"]
        expect(valid_cmd == f"{EXEC_HOOK} /p/valid",
               f"malformed: valid command in messy tree should still be wrapped, got {valid_cmd!r}")


def test_missing_input_no_output() -> None:
    with tempfile.TemporaryDirectory() as td:
        out = Path(td) / "out.json"
        run_helper("/this/input/does/not/exist.json", str(out))
        expect(not out.exists(),
               "missing-input: helper should not write output for missing input")


def test_unparseable_input_no_output() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        inp.write_text("this is not json")
        _, stderr = run_helper(str(inp), str(out))
        expect(not out.exists(),
               "unparseable: helper should not write output for unparseable input")
        expect("failed to parse" in stderr,
               f"unparseable: stderr should explain the failure, got: {stderr!r}")


def test_output_perms_0600() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {"Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}]}})
        run_helper(str(inp), str(out))
        mode = stat.S_IMODE(out.stat().st_mode)
        expect(mode == 0o600,
               f"perms: output should be 0600, got {oct(mode)}")


def test_output_parent_dir_auto_created() -> None:
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        # Nested non-existent output dir — helper must mkdir -p.
        out = Path(td) / "nested" / "deep" / "out.json"
        write_json(inp, {"hooks": {}})
        run_helper(str(inp), str(out))
        expect(out.exists(),
               "parent-dir: helper should create missing output parent dirs")


def test_no_tmp_leftover() -> None:
    """The atomic-rename pattern should leave no .tmp leftover after success."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {"Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}]}})
        run_helper(str(inp), str(out))
        leftovers = list(Path(td).glob("*.tmp"))
        expect(not leftovers,
               f"atomic-rename: no .tmp leftover expected, got {leftovers}")


def test_realistic_corp_settings() -> None:
    """End-to-end with a realistic corp settings.json shape (multi-event, matchers, args)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": [
                    {
                        "matcher": "startup|resume",
                        "hooks": [
                            {"type": "command", "command": "/Users/me/.local/bin/telemetry-hook session-start"},
                        ],
                    },
                ],
                "UserPromptSubmit": [
                    {
                        "hooks": [
                            {"type": "command", "command": "/Users/me/.local/bin/telemetry-hook prompt-submit"},
                        ],
                    },
                ],
                "PreToolUse": [
                    {
                        "matcher": "Bash",
                        "hooks": [
                            {"type": "command", "command": "some-bare-path-hook"},
                            {"type": "command", "command": "/Users/me/.local/bin/telemetry-hook pre-tool"},
                        ],
                    },
                ],
            },
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        # Every command, regardless of whether it points at a Mach-O or a
        # bare name on PATH (some-bare-path-hook), gets wrapped. The
        # shim is transparent on ELF + shebang, so this is safe. (We use a
        # generic bare name here on purpose: backgrounded-watcher guarding
        # is now an AST-backed `no_backgrounded_watcher` obligation, not a
        # string-match exec-hook, so the fixture must not imply the image
        # ships/wires a `check-no-bg-ampersand` binary.)
        expect(
            result["hooks"]["SessionStart"][0]["hooks"][0]["command"]
            == f"{EXEC_HOOK} /Users/me/.local/bin/telemetry-hook session-start",
            "corp: SessionStart command should be wrapped with args preserved",
        )
        expect(
            result["hooks"]["PreToolUse"][0]["hooks"][0]["command"]
            == f"{EXEC_HOOK} some-bare-path-hook",
            "corp: bare PATH command should also be wrapped",
        )


def test_mcp_servers_pass_through_unchanged() -> None:
    """mcpServers is no longer rewritten by this helper (PR after #145).
    Any mcpServers block in the input is passed through verbatim — the
    project-tier `.mcp.json` writer handles MCP server wrapping."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "mcpServers": {
                "telemetry": {
                    "command": "/Users/me/.local/bin/host-mcp-server",
                    "args": ["--port", "9999"],
                },
            },
            "hooks": {
                "Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}],
            },
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        # mcpServers passes through verbatim — NOT wrapped.
        telem = result["mcpServers"]["telemetry"]
        expect(
            telem["command"] == "/Users/me/.local/bin/host-mcp-server",
            f"mcp-passthrough: command should NOT be wrapped here, got {telem['command']!r}",
        )
        expect(
            telem["args"] == ["--port", "9999"],
            f"mcp-passthrough: args should round-trip, got {telem['args']!r}",
        )
        # Hooks are still wrapped.
        hook_cmd = result["hooks"]["Stop"][0]["hooks"][0]["command"]
        expect(
            hook_cmd == f"{EXEC_HOOK} /p/x",
            f"mcp-passthrough: hooks still wrapped, got {hook_cmd!r}",
        )


# ---------------------------------------------------------------------------
# Pattern filtering (--shim-patterns / CLAUDE_SHIM_PATTERNS)
# ---------------------------------------------------------------------------


def _settings_with_three_paths() -> dict:
    """Common input: one command per "/Users/me/.local/bin/X",
    "/Users/me/.local/pkgs/y/bin/X", and "/opt/local/bin/X". Used by
    several pattern tests."""
    return {
        "hooks": {
            "Stop": [
                {"hooks": [
                    {"type": "command", "command": "/Users/me/.local/bin/telemetry"},
                    {"type": "command", "command": "/Users/me/.local/pkgs/foo/bin/telemetry"},
                    {"type": "command", "command": "/opt/local/bin/native-tool"},
                ]},
            ],
        },
    }


def test_empty_pattern_flag_wraps_everything() -> None:
    """--shim-patterns "" preserves default: wrap every command."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        run_helper(str(inp), str(out), patterns="")
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        for cmd in cmds:
            expect(
                cmd.startswith(f"{EXEC_HOOK} "),
                f"empty-pattern: every command should still be wrapped, got {cmd!r}",
            )


def test_no_pattern_flag_wraps_everything() -> None:
    """No --shim-patterns flag at all + no env var = wrap everything."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        # No `patterns` kwarg = no flag passed. env_patterns also unset.
        run_helper(str(inp), str(out))
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        for cmd in cmds:
            expect(
                cmd.startswith(f"{EXEC_HOOK} "),
                f"no-pattern: every command should still be wrapped, got {cmd!r}",
            )


def test_pattern_narrow_match_only_wraps_matches() -> None:
    """Pattern matches one path family; only matching commands are wrapped."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        run_helper(str(inp), str(out), patterns="/Users/*/.local/bin/*")
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        # Only the first command matches /Users/*/.local/bin/* (the
        # /pkgs/ path has more segments and doesn't match this glob;
        # /opt/local doesn't match either).
        expect(
            cmds[0] == f"{EXEC_HOOK} /Users/me/.local/bin/telemetry",
            f"narrow: /Users/me/.local/bin/telemetry should be wrapped, got {cmds[0]!r}",
        )
        expect(
            cmds[1] == "/Users/me/.local/pkgs/foo/bin/telemetry",
            f"narrow: /pkgs/ path should NOT match /Users/*/.local/bin/*, got {cmds[1]!r}",
        )
        expect(
            cmds[2] == "/opt/local/bin/native-tool",
            f"narrow: /opt/local path should NOT match, got {cmds[2]!r}",
        )


def test_multiple_patterns_union_match() -> None:
    """Colon-separated patterns form a union — any match wraps the command."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        run_helper(
            str(inp),
            str(out),
            patterns="/Users/*/.local/bin/*:/Users/*/.local/pkgs/*/bin/*",
        )
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        # Both /Users/ paths match (different globs); /opt/local doesn't.
        expect(
            cmds[0].startswith(f"{EXEC_HOOK} "),
            f"union: /Users/.../bin/telemetry should be wrapped, got {cmds[0]!r}",
        )
        expect(
            cmds[1].startswith(f"{EXEC_HOOK} "),
            f"union: /Users/.../pkgs/.../bin/telemetry should be wrapped, got {cmds[1]!r}",
        )
        expect(
            cmds[2] == "/opt/local/bin/native-tool",
            f"union: /opt/local should still pass through, got {cmds[2]!r}",
        )


def test_pattern_matches_zero_commands_passes_all_through() -> None:
    """Pattern matches nothing → nothing wrapped, output round-trips."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        run_helper(str(inp), str(out), patterns="/nonexistent/path/*")
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        for cmd in cmds:
            expect(
                not cmd.startswith(f"{EXEC_HOOK} "),
                f"no-match: nothing should be wrapped, got {cmd!r}",
            )


def test_env_var_supplies_patterns_when_flag_absent() -> None:
    """CLAUDE_SHIM_PATTERNS env var is honored when --shim-patterns flag isn't passed."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        run_helper(
            str(inp),
            str(out),
            env_patterns="/Users/*/.local/bin/*",
        )
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        expect(
            cmds[0].startswith(f"{EXEC_HOOK} "),
            f"env: /Users/.../bin path should be wrapped via env, got {cmds[0]!r}",
        )
        expect(
            cmds[1] == "/Users/me/.local/pkgs/foo/bin/telemetry",
            f"env: /pkgs/ should NOT match, got {cmds[1]!r}",
        )


def test_flag_overrides_env_var() -> None:
    """--shim-patterns CLI flag wins over CLAUDE_SHIM_PATTERNS env var."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, _settings_with_three_paths())
        # Env says "match everything"; flag says "match nothing".
        run_helper(
            str(inp),
            str(out),
            patterns="/nonexistent/*",
            env_patterns="/Users/*",
        )
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        for cmd in cmds:
            expect(
                not cmd.startswith(f"{EXEC_HOOK} "),
                f"flag-wins: flag pattern should override env, got {cmd!r}",
            )


def test_pattern_matches_command_with_args() -> None:
    """Pattern matches against the FIRST token only — args are not part of the match."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "Stop": [{"hooks": [
                    {"type": "command", "command": "/Users/me/.local/bin/hook --flag value | grep foo"},
                ]}],
            },
        })
        run_helper(str(inp), str(out), patterns="/Users/*/.local/bin/*")
        cmd = load_output(out)["hooks"]["Stop"][0]["hooks"][0]["command"]
        expect(
            cmd == f"{EXEC_HOOK} /Users/me/.local/bin/hook --flag value | grep foo",
            f"args-not-matched: shell args should NOT participate in matching, got {cmd!r}",
        )


def test_pattern_preserves_already_wrapped() -> None:
    """Already-wrapped commands are still passed through unchanged regardless of patterns."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "Stop": [{"hooks": [
                    {"type": "command", "command": f"{EXEC_HOOK} /opt/local/bin/native"},
                    {"type": "command", "command": "/opt/local/bin/native2"},
                ]}],
            },
        })
        # Pattern wouldn't match /opt/local; the already-wrapped one
        # must still pass through verbatim (no de-wrap), and the bare
        # one stays bare because pattern doesn't match.
        run_helper(str(inp), str(out), patterns="/Users/*")
        cmds = [h["command"] for h in load_output(out)["hooks"]["Stop"][0]["hooks"]]
        expect(
            cmds[0] == f"{EXEC_HOOK} /opt/local/bin/native",
            f"already-wrapped-with-pattern: pre-wrapped command should pass through, got {cmds[0]!r}",
        )
        expect(
            cmds[1] == "/opt/local/bin/native2",
            f"non-matching: bare command should stay bare, got {cmds[1]!r}",
        )


# ---------------------------------------------------------------------------
# Obligations injection tests
# ---------------------------------------------------------------------------

OBLIGATIONS_HOOKS_BY_EVENT_MATCHER = {
    ("PreToolUse", "Agent"): "/usr/local/bin/pre-agent-queue-gate-hook",
    ("PreToolUse", "*"): "/usr/local/bin/pre-tool-obligations-gate-hook",
    ("PostToolUse", "*"): "/usr/local/bin/post-tool-obligations-update-hook",
    ("PostToolUse", "Read"): "/usr/local/bin/post-tool-mark-attachment-read-hook",
}


def _collect_hook_commands(settings: dict, event: str, matcher: str) -> list[str]:
    """Collect every command string under settings.hooks[event] whose
    matcher block matches `matcher`."""
    out = []
    entries = (settings.get("hooks") or {}).get(event) or []
    for entry in entries:
        if str((entry or {}).get("matcher", "")) != matcher:
            continue
        for h in (entry or {}).get("hooks") or []:
            cmd = (h or {}).get("command")
            if isinstance(cmd, str):
                out.append(cmd)
    return out


def test_obligations_inject_into_empty_settings() -> None:
    """--inject-obligations 1 against an empty settings.json adds all four
    obligations gate hooks at the right (event, matcher) buckets."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {})
        run_helper(str(inp), str(out), inject_obligations=True)
        result = load_output(out)
        for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
            cmds = _collect_hook_commands(result, event, matcher)
            expect(
                command in cmds,
                f"obligations: {event}.{matcher!r} should include {command}, got {cmds}",
            )


def test_obligations_inject_foreground_gate() -> None:
    """The container-only foreground-agent gate is injected alongside the
    queue gate on the PreToolUse/Agent matcher (a second hook in the same
    bucket — the (event,matcher) dict above can't represent two, so it's
    asserted separately)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {})
        run_helper(str(inp), str(out), inject_obligations=True)
        cmds = _collect_hook_commands(load_output(out), "PreToolUse", "Agent")
        expect(
            "/usr/local/bin/pre-agent-background-required-hook" in cmds,
            f"obligations: PreToolUse.Agent should include the background-required "
            f"gate, got {cmds}",
        )


def test_obligations_idempotent_no_duplicates() -> None:
    """Running the helper twice does NOT duplicate the injected hooks
    (the same command in the same matcher bucket is detected and
    skipped)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        mid = Path(td) / "mid.json"
        out = Path(td) / "out.json"
        write_json(inp, {})
        # First pass: empty → mid (with obligations).
        run_helper(str(inp), str(mid), inject_obligations=True)
        # Second pass: mid → out (with obligations again).
        run_helper(str(mid), str(out), inject_obligations=True)
        result = load_output(out)
        for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
            cmds = _collect_hook_commands(result, event, matcher)
            expect(
                cmds.count(command) == 1,
                f"idempotent: {event}.{matcher!r} should have exactly ONE "
                f"copy of {command}, got {cmds}",
            )


def test_obligations_preserves_host_hooks() -> None:
    """When the input has host hooks AND --inject-obligations 1, both the
    wrapped host hooks AND the obligations hooks land in the output. The
    obligations hooks layer alongside, not replacing."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": [
                    {
                        "matcher": "startup|resume",
                        "hooks": [
                            {"type": "command",
                             "command": "/Users/me/.local/bin/telemetry"},
                        ],
                    },
                ],
            },
        })
        run_helper(str(inp), str(out), inject_obligations=True)
        result = load_output(out)
        # Host hook still present + wrapped.
        ss = _collect_hook_commands(result, "SessionStart", "startup|resume")
        expect(
            f"{EXEC_HOOK} /Users/me/.local/bin/telemetry" in ss,
            f"preserve: host SessionStart hook should be wrapped + present, got {ss}",
        )
        # Obligations hooks all present.
        for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
            cmds = _collect_hook_commands(result, event, matcher)
            expect(
                command in cmds,
                f"preserve: {event}.{matcher!r} should still have obligations "
                f"{command}, got {cmds}",
            )


def test_obligations_only_drops_host_hooks() -> None:
    """--obligations-only mode emits ONLY the obligations gate hooks; the
    host's hooks are NOT copied through. This is the right shape for
    additive layering on top of the live user-tier settings."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {
                "SessionStart": [
                    {
                        "matcher": "startup|resume",
                        "hooks": [
                            {"type": "command",
                             "command": "/Users/me/.local/bin/telemetry"},
                        ],
                    },
                ],
            },
        })
        cmd = [str(SCRIPT), "--input", str(inp), "--output", str(out),
               "--quiet", "--inject-obligations", "1", "--obligations-only"]
        env = dict(os.environ)
        env.pop("CLAUDE_SHIM_PATTERNS", None)
        env.pop("CLAUDE_CONTAINER_OBLIGATIONS", None)
        env.pop("CLAUDE_SHIM_OBLIGATIONS_ONLY", None)
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=10, env=env,
        )
        if result.returncode != 0:
            raise AssertionError(
                f"helper exited {result.returncode}\n"
                f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
            )
        out_settings = load_output(out)
        # Host SessionStart hook NOT carried forward.
        ss = _collect_hook_commands(out_settings, "SessionStart", "startup|resume")
        expect(
            ss == [],
            f"obligations-only: host SessionStart hook should be DROPPED, got {ss}",
        )
        # Obligations hooks all present.
        for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
            cmds = _collect_hook_commands(out_settings, event, matcher)
            expect(
                command in cmds,
                f"obligations-only: {event}.{matcher!r} should have obligations "
                f"{command}, got {cmds}",
            )


def test_obligations_disabled_via_flag() -> None:
    """--inject-obligations 0 → obligations hooks are NOT added even
    against an empty input. Default-off in the test helper is already the
    workhorse; this is the explicit guard."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "hooks": {"Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}]},
        })
        run_helper(str(inp), str(out), inject_obligations=False)
        result = load_output(out)
        for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
            cmds = _collect_hook_commands(result, event, matcher)
            expect(
                command not in cmds,
                f"disabled: {event}.{matcher!r} should NOT have {command}, got {cmds}",
            )


def test_obligations_only_writes_output_with_missing_input() -> None:
    """When the input file is missing AND obligations injection is on,
    the helper still writes an output containing just the obligations
    hooks (so the entrypoint's no-host-settings.json case still gets
    the gates wired)."""
    with tempfile.TemporaryDirectory() as td:
        out = Path(td) / "out.json"
        cmd = [str(SCRIPT), "--input", "/this/does/not/exist.json",
               "--output", str(out), "--quiet",
               "--inject-obligations", "1"]
        env = dict(os.environ)
        env.pop("CLAUDE_SHIM_PATTERNS", None)
        env.pop("CLAUDE_CONTAINER_OBLIGATIONS", None)
        env.pop("CLAUDE_SHIM_OBLIGATIONS_ONLY", None)
        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=10, env=env,
        )
        if result.returncode != 0:
            raise AssertionError(
                f"helper exited {result.returncode}\n"
                f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
            )
        expect(
            out.exists(),
            "missing-input + inject-obligations: output should be written so "
            "the in-container claude still gets the gates wired",
        )
        if out.exists():
            settings = load_output(out)
            for (event, matcher), command in OBLIGATIONS_HOOKS_BY_EVENT_MATCHER.items():
                cmds = _collect_hook_commands(settings, event, matcher)
                expect(
                    command in cmds,
                    f"missing-input: {event}.{matcher!r} should have {command}, "
                    f"got {cmds}",
                )


# ---------------------------------------------------------------------------
# Project MCP auto-approve (--mcp-autoapprove / CLAUDE_MCP_AUTOAPPROVE)
# ---------------------------------------------------------------------------


def _run_helper_mcp(
    input_path: str,
    output_path: str,
    mcp_autoapprove: str | None = None,
    env_autoapprove: str | None = None,
) -> None:
    """Run the helper exercising the --mcp-autoapprove flag / env var.

    `mcp_autoapprove` (when not None) is passed as the CLI flag value;
    `env_autoapprove` (when not None) is set in CLAUDE_MCP_AUTOAPPROVE.
    Both default to NOT setting them so the helper's own default applies.
    """
    cmd = [str(SCRIPT), "--input", input_path, "--output", output_path,
           "--quiet", "--inject-obligations", "0"]
    if mcp_autoapprove is not None:
        cmd += ["--mcp-autoapprove", mcp_autoapprove]
    env = dict(os.environ)
    env.pop("CLAUDE_SHIM_PATTERNS", None)
    env.pop("CLAUDE_CONTAINER_OBLIGATIONS", None)
    env.pop("CLAUDE_SHIM_OBLIGATIONS_ONLY", None)
    # Wipe any host-set CLAUDE_MCP_AUTOAPPROVE so it doesn't leak into the
    # default-behavior tests; re-set it only when env_autoapprove is given.
    env.pop("CLAUDE_MCP_AUTOAPPROVE", None)
    if env_autoapprove is not None:
        env["CLAUDE_MCP_AUTOAPPROVE"] = env_autoapprove
    result = subprocess.run(
        cmd, capture_output=True, text=True, timeout=10, env=env,
    )
    if result.returncode != 0:
        raise AssertionError(
            f"helper exited {result.returncode}\n"
            f"stdout:\n{result.stdout}\nstderr:\n{result.stderr}"
        )


def test_mcp_autoapprove_on_by_default() -> None:
    """No --mcp-autoapprove flag + no env var → key written as true."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {}})
        _run_helper_mcp(str(inp), str(out))
        result = load_output(out)
        expect(
            result.get("enableAllProjectMcpServers") is True,
            f"mcp-autoapprove: key should default to true, got "
            f"{result.get('enableAllProjectMcpServers')!r}",
        )


def test_mcp_autoapprove_disabled_via_flag() -> None:
    """--mcp-autoapprove 0 → key omitted entirely."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {}})
        _run_helper_mcp(str(inp), str(out), mcp_autoapprove="0")
        result = load_output(out)
        expect(
            "enableAllProjectMcpServers" not in result,
            f"mcp-autoapprove: --mcp-autoapprove 0 should omit the key, got "
            f"{result.get('enableAllProjectMcpServers')!r}",
        )


def test_mcp_autoapprove_disabled_via_env() -> None:
    """CLAUDE_MCP_AUTOAPPROVE=0 (no flag) → key omitted entirely."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"hooks": {}})
        _run_helper_mcp(str(inp), str(out), env_autoapprove="0")
        result = load_output(out)
        expect(
            "enableAllProjectMcpServers" not in result,
            f"mcp-autoapprove: CLAUDE_MCP_AUTOAPPROVE=0 should omit the key, "
            f"got {result.get('enableAllProjectMcpServers')!r}",
        )


def test_mcp_autoapprove_preserves_other_keys() -> None:
    """The auto-approve key is added alongside hook rewrites + other top-
    level keys, not in place of them."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "env": {"FOO": "bar"},
            "hooks": {"Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}]},
        })
        _run_helper_mcp(str(inp), str(out))
        result = load_output(out)
        expect(result.get("enableAllProjectMcpServers") is True,
               "mcp-autoapprove+keys: auto-approve key should be present")
        expect(result.get("env") == {"FOO": "bar"},
               "mcp-autoapprove+keys: unrelated env key must survive")
        expect(result["hooks"]["Stop"][0]["hooks"][0]["command"] == f"{EXEC_HOOK} /p/x",
               "mcp-autoapprove+keys: hooks still wrapped alongside the key")


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

def test_apikeyhelper_dropped_when_path_missing() -> None:
    """A host-only absolute apiKeyHelper path that doesn't exist in the
    container is dropped (the macOS host-helper leak case)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {
            "apiKeyHelper": "'/Users/me/.local/bin/get-api-key' auth claude",
            "env": {"FOO": "bar"},
            "hooks": {"Stop": [{"hooks": [{"type": "command", "command": "/p/x"}]}]},
        })
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect("apiKeyHelper" not in result,
               f"apikeyhelper: missing-path helper should be dropped, got {result.get('apiKeyHelper')!r}")
        # Other top-level keys + hook rewrite still happen.
        expect(result["env"] == {"FOO": "bar"},
               "apikeyhelper: unrelated keys must survive the drop")
        expect(result["hooks"]["Stop"][0]["hooks"][0]["command"] == f"{EXEC_HOOK} /p/x",
               "apikeyhelper: hooks still wrapped alongside the drop")


def test_apikeyhelper_dropped_when_macho() -> None:
    """A present-but-Mach-O apiKeyHelper target is dropped (can't exec on Linux)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        macho = Path(td) / "helper-macho"
        # Mach-O 64-bit magic 0xFEEDFACF (little-endian on disk: cf fa ed fe).
        macho.write_bytes(b"\xcf\xfa\xed\xfe" + b"\x00" * 32)
        macho.chmod(0o755)
        write_json(inp, {"apiKeyHelper": f"{macho} auth claude"})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect("apiKeyHelper" not in result,
               f"apikeyhelper: Mach-O helper should be dropped, got {result.get('apiKeyHelper')!r}")


def test_apikeyhelper_kept_when_elf() -> None:
    """A real ELF helper (Linux host) is preserved verbatim."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        elf = Path(td) / "helper-elf"
        elf.write_bytes(b"\x7fELF" + b"\x00" * 32)
        elf.chmod(0o755)
        cmd = f"{elf} auth claude"
        write_json(inp, {"apiKeyHelper": cmd})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result.get("apiKeyHelper") == cmd,
               f"apikeyhelper: ELF helper should be kept verbatim, got {result.get('apiKeyHelper')!r}")


def test_apikeyhelper_kept_when_shebang() -> None:
    """A shebang script helper is runnable and preserved."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        script = Path(td) / "helper.sh"
        script.write_text("#!/bin/sh\necho key\n")
        script.chmod(0o755)
        write_json(inp, {"apiKeyHelper": str(script)})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result.get("apiKeyHelper") == str(script),
               f"apikeyhelper: shebang helper should be kept, got {result.get('apiKeyHelper')!r}")


def test_apikeyhelper_kept_when_bare_command() -> None:
    """A bare command name (PATH lookup, no slash) is assumed runtime-
    resolvable and kept — we only strip absolute-path leaks."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / "in.json"
        out = Path(td) / "out.json"
        write_json(inp, {"apiKeyHelper": "get-my-key --json"})
        run_helper(str(inp), str(out))
        result = load_output(out)
        expect(result.get("apiKeyHelper") == "get-my-key --json",
               f"apikeyhelper: bare command should be kept, got {result.get('apiKeyHelper')!r}")


TESTS = [
    test_no_hooks_key_passthrough,
    test_empty_hooks_dict_passthrough,
    test_single_command_wrapped,
    test_already_wrapped_not_double_wrapped,
    test_multi_event_multi_hook_all_wrapped,
    test_other_top_level_keys_preserved,
    test_apikeyhelper_dropped_when_path_missing,
    test_apikeyhelper_dropped_when_macho,
    test_apikeyhelper_kept_when_elf,
    test_apikeyhelper_kept_when_shebang,
    test_apikeyhelper_kept_when_bare_command,
    test_malformed_hooks_tree_no_exception,
    test_missing_input_no_output,
    test_unparseable_input_no_output,
    test_output_perms_0600,
    test_output_parent_dir_auto_created,
    test_no_tmp_leftover,
    test_realistic_corp_settings,
    test_mcp_servers_pass_through_unchanged,
    test_empty_pattern_flag_wraps_everything,
    test_no_pattern_flag_wraps_everything,
    test_pattern_narrow_match_only_wraps_matches,
    test_multiple_patterns_union_match,
    test_pattern_matches_zero_commands_passes_all_through,
    test_env_var_supplies_patterns_when_flag_absent,
    test_flag_overrides_env_var,
    test_pattern_matches_command_with_args,
    test_pattern_preserves_already_wrapped,
    test_obligations_inject_into_empty_settings,
    test_obligations_inject_foreground_gate,
    test_obligations_idempotent_no_duplicates,
    test_obligations_preserves_host_hooks,
    test_obligations_only_drops_host_hooks,
    test_obligations_disabled_via_flag,
    test_obligations_only_writes_output_with_missing_input,
    test_mcp_autoapprove_on_by_default,
    test_mcp_autoapprove_disabled_via_flag,
    test_mcp_autoapprove_disabled_via_env,
    test_mcp_autoapprove_preserves_other_keys,
]

for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
