#!/usr/bin/env python3
"""Tests for container/hooks-shim/exec-hook-bridge.

Spins up a fake MCP server (HTTP socket on localhost) that mimics
mcp-host-bash + cli-mcp-server's streamable-HTTP transport. The bridge
points at the fake via CLAUDE_HOST_HOOK_BRIDGE_URL.

The fake recognizes the three POSTs the bridge sends per invocation:

  1. `initialize`           -> 200 + `mcp-session-id` response header
  2. `notifications/initialized` -> 202, empty body
  3. `tools/call`           -> 200 + cli-mcp-server text-body response

`tools/call` requests are required to carry the `mcp-session-id`
header captured from step 1 (the real mcp-proxy 0.11+ enforces this).
The fake records every request (method, body, session header) so tests
can assert the handshake fired in order.

Asserts:

  - Bridge OFF (CLAUDE_HOST_HOOK_BRIDGE != 1): exit 0, no HTTP call.
  - Bridge ON, full handshake: 3 sequential POSTs in the right order
    with the mcp-session-id propagated; exit / stdout / stderr from
    the tools/call response propagate to the bridge's exit / stdout /
    stderr.
  - Bridge ON, isError tools/call response: exit 0, stderr explains.
  - Bridge ON, server unreachable: exit 0, fall-back stderr line.
  - Bridge ON, initialize parse failure: exit 0, fall-back stderr line.
  - Bridge ON, server in stateless mode (no session-id issued): bridge
    still sends tools/call (without the header) and succeeds.
  - Bridge ON, initialize JSON-RPC error: fall-back.
  - Forwarded env vars: well-known Claude vars + custom ones from
    CLAUDE_HOST_HOOK_BRIDGE_FORWARD_ENV land in the tools/call request
    as `env KEY=VAL ...` prefix args.
  - SSE response shape (`text/event-stream` with `data: <json>`) parses.
  - Bad argv (no target): exit 2 + usage stderr.
  - JSON-RPC error envelope on tools/call: exit 0, stderr explains.

Each test runs the fake server in-process on an ephemeral port, sets
CLAUDE_HOST_HOOK_BRIDGE_URL to point at it, then runs the bridge as
a subprocess so we exercise the real shebang + import path.

Run:  ./exec-hook-bridge.test
"""

from __future__ import annotations

import contextlib
import http.server
import json
import os
import subprocess
import sys
import threading
import uuid
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "exec-hook-bridge"

if not SCRIPT.exists():
    print(f"FAIL: cannot locate exec-hook-bridge at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)
        print(f"  -> FAIL: {msg}")


# ---------------------------------------------------------------------------
# Fake MCP server
# ---------------------------------------------------------------------------


class FakeMCPHandler(http.server.BaseHTTPRequestHandler):
    """Streamable-HTTP MCP server stub.

    Class-level state, reset by each test:

      tools_call_response : dict   — what `result` payload to embed in
                                     the tools/call JSON-RPC envelope.
      response_mode       : str    — "json" or "sse" for tools/call.
      stateless_mode      : bool   — if True, initialize replies WITHOUT
                                     issuing an mcp-session-id header
                                     (server in stateless mode); bridge
                                     must still complete tools/call.
      init_failure_mode   : str    — "" / "garbage_body" /
                                     "jsonrpc_error". Triggers the
                                     respective initialize failure.
      requests            : list   — every POST observed, in order.
                                     Each entry: {"method": str,
                                     "body": dict|str, "session_id":
                                     str|None, "auth": str|None}
      issued_session_id   : str    — UUID handed out by initialize.
    """

    tools_call_response: dict = {}
    response_mode: str = "json"
    stateless_mode: bool = False
    init_failure_mode: str = ""
    requests: list = []
    issued_session_id: str = ""

    def do_POST(self) -> None:  # noqa: N802 (BaseHTTPRequestHandler API)
        length = int(self.headers.get("Content-Length", "0"))
        raw_body = self.rfile.read(length).decode("utf-8") if length else ""
        try:
            body = json.loads(raw_body) if raw_body else {}
        except json.JSONDecodeError:
            body = {"_raw": raw_body}

        method = body.get("method", "") if isinstance(body, dict) else ""
        session_hdr = self.headers.get("mcp-session-id")
        auth_hdr = self.headers.get("Authorization")
        FakeMCPHandler.requests.append(
            {
                "method": method,
                "body": body,
                "session_id": session_hdr,
                "auth": auth_hdr,
            }
        )

        if method == "initialize":
            self._handle_initialize(body)
        elif method == "notifications/initialized":
            self._handle_initialized_notification()
        elif method == "tools/call":
            self._handle_tools_call(body)
        else:
            # Unknown method — return a JSON-RPC method-not-found error.
            rpc_id = body.get("id", 0) if isinstance(body, dict) else 0
            err_env = {
                "jsonrpc": "2.0",
                "id": rpc_id,
                "error": {"code": -32601, "message": f"Method not found: {method!r}"},
            }
            self._send_json(200, err_env)

    def _handle_initialize(self, body: dict) -> None:
        rpc_id = body.get("id", 1)
        if FakeMCPHandler.init_failure_mode == "garbage_body":
            # Mimics a misbehaving streamable-HTTP server: 200 OK but
            # body is not JSON. The bridge should fall back.
            payload = "this is not JSON"
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload.encode("utf-8"))
            return
        if FakeMCPHandler.init_failure_mode == "jsonrpc_error":
            envelope = {
                "jsonrpc": "2.0",
                "id": rpc_id,
                "error": {"code": -32600, "message": "init refused"},
            }
            self._send_json(200, envelope)
            return

        envelope = {
            "jsonrpc": "2.0",
            "id": rpc_id,
            "result": {
                "protocolVersion": "2025-06-18",
                "capabilities": {},
                "serverInfo": {"name": "fake-mcp", "version": "0"},
            },
        }
        if not FakeMCPHandler.stateless_mode:
            FakeMCPHandler.issued_session_id = uuid.uuid4().hex
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("mcp-session-id", FakeMCPHandler.issued_session_id)
            body_bytes = json.dumps(envelope).encode("utf-8")
            self.send_header("Content-Length", str(len(body_bytes)))
            self.end_headers()
            self.wfile.write(body_bytes)
        else:
            self._send_json(200, envelope)

    def _handle_initialized_notification(self) -> None:
        # Notifications get HTTP 202 with no body, per MCP spec.
        self.send_response(202)
        self.send_header("Content-Length", "0")
        self.end_headers()

    def _handle_tools_call(self, body: dict) -> None:
        rpc_id = body.get("id", 2)
        envelope = {
            "jsonrpc": "2.0",
            "id": rpc_id,
        }
        envelope.update(FakeMCPHandler.tools_call_response)

        if FakeMCPHandler.response_mode == "sse":
            payload = f"data: {json.dumps(envelope)}\n\n"
            ct = "text/event-stream"
        else:
            payload = json.dumps(envelope)
            ct = "application/json"

        self.send_response(200)
        self.send_header("Content-Type", ct)
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload.encode("utf-8"))

    def _send_json(self, status: int, body: dict) -> None:
        payload = json.dumps(body).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def log_message(self, fmt: str, *args) -> None:  # silence noise
        return


@contextlib.contextmanager
def fake_server():
    """Spin up the fake MCP handler on localhost:<ephemeral>. Yields
    the bridge URL pointing at /mcp on that port."""
    server = http.server.HTTPServer(("127.0.0.1", 0), FakeMCPHandler)
    port = server.server_address[1]
    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    try:
        yield f"http://127.0.0.1:{port}/mcp"
    finally:
        server.shutdown()
        server.server_close()


def run_bridge(
    target: str | None,
    *args: str,
    bridge_env: dict | None = None,
    timeout: float = 10.0,
) -> subprocess.CompletedProcess:
    """Run the bridge as a subprocess. bridge_env overrides env vars.

    PATH + a sane HOME is preserved so urllib can resolve.
    """
    env = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "HOME": os.environ.get("HOME", "/tmp"),
    }
    if bridge_env:
        env.update(bridge_env)
    argv = [str(SCRIPT)]
    if target is not None:
        argv.append(target)
    argv.extend(args)
    return subprocess.run(
        argv,
        env=env,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def make_run_command_text(stdout: str = "", stderr: str = "", exit_code: int = 0) -> str:
    """Build cli-mcp-server's text body for a successful run."""
    parts = ["Command executed successfully."]
    if stdout:
        parts.append(f"Stdout: {stdout}")
    if stderr:
        parts.append(f"Stderr: {stderr}")
    parts.append(f"Exit Code: {exit_code}")
    return "\n".join(parts)


def reset_fake() -> None:
    """Clear all per-test handler state before a new test runs."""
    FakeMCPHandler.tools_call_response = {}
    FakeMCPHandler.response_mode = "json"
    FakeMCPHandler.stateless_mode = False
    FakeMCPHandler.init_failure_mode = ""
    FakeMCPHandler.requests = []
    FakeMCPHandler.issued_session_id = ""


def set_tools_call_response(stdout="", stderr="", exit_code=0, is_error=False, error_text="") -> None:
    if is_error:
        FakeMCPHandler.tools_call_response = {
            "result": {
                "isError": True,
                "content": [{"type": "text", "text": error_text}],
            }
        }
    else:
        FakeMCPHandler.tools_call_response = {
            "result": {
                "content": [
                    {
                        "type": "text",
                        "text": make_run_command_text(stdout, stderr, exit_code),
                    }
                ]
            }
        }


def find_request(method: str) -> dict | None:
    """Return the FIRST recorded request matching `method`, or None."""
    for r in FakeMCPHandler.requests:
        if r["method"] == method:
            return r
    return None


# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------


def test_bridge_off_short_circuits() -> None:
    """CLAUDE_HOST_HOOK_BRIDGE unset / != 1 => exit 0 immediately, NO HTTP call."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="should-not-see", exit_code=99)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={"CLAUDE_HOST_HOOK_BRIDGE_URL": url},
        )
        expect(r.returncode == 0, f"bridge OFF: expected exit 0, got {r.returncode}")
        expect(
            len(FakeMCPHandler.requests) == 0,
            f"bridge OFF: expected no HTTP call, got {len(FakeMCPHandler.requests)} requests: {FakeMCPHandler.requests!r}",
        )


def test_bridge_on_runs_full_handshake() -> None:
    """Bridge ON: initialize -> notifications/initialized -> tools/call,
    each carrying the right session header. Response stdout/stderr/exit
    propagate."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="hello from host", stderr="warn from host", exit_code=42)
        r = run_bridge(
            "/host/path/telemetry-hook",
            "--flag",
            "value",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 42, f"handshake: expected exit 42, got {r.returncode}; stderr: {r.stderr!r}")
        expect("hello from host" in r.stdout, f"handshake: stdout missing host body, got: {r.stdout!r}")
        expect("warn from host" in r.stderr, f"handshake: stderr missing host body, got: {r.stderr!r}")

        # Three POSTs in order: initialize, notifications/initialized, tools/call.
        methods = [req["method"] for req in FakeMCPHandler.requests]
        expect(
            methods == ["initialize", "notifications/initialized", "tools/call"],
            f"handshake: wrong request sequence: {methods!r}",
        )

        # initialize POST: no session header (we don't have one yet),
        # params carries protocolVersion + clientInfo.
        init_req = FakeMCPHandler.requests[0]
        expect(init_req["session_id"] is None, f"init: should not carry session_id, got {init_req['session_id']!r}")
        init_params = init_req["body"].get("params", {})
        expect(
            "protocolVersion" in init_params,
            f"init: missing protocolVersion, params={init_params!r}",
        )
        expect(
            init_params.get("clientInfo", {}).get("name", "").startswith("claude-watch"),
            f"init: clientInfo.name should identify the bridge, got {init_params.get('clientInfo')!r}",
        )

        # notifications/initialized: no `id`, carries the session header.
        init_notif = FakeMCPHandler.requests[1]
        expect(
            "id" not in init_notif["body"],
            f"initialized notification should have no `id`, got {init_notif['body']!r}",
        )
        expect(
            init_notif["session_id"] == FakeMCPHandler.issued_session_id,
            f"initialized notification missing session header: got {init_notif['session_id']!r}, expected {FakeMCPHandler.issued_session_id!r}",
        )

        # tools/call: carries the session header + the run_command shape.
        call_req = FakeMCPHandler.requests[2]
        expect(
            call_req["session_id"] == FakeMCPHandler.issued_session_id,
            f"tools/call missing session header: got {call_req['session_id']!r}, expected {FakeMCPHandler.issued_session_id!r}",
        )
        params = call_req["body"].get("params", {})
        expect(params.get("name") == "run_command", f"wrong tool name: {params.get('name')!r}")
        rpc_args = params.get("arguments", {})
        expect(rpc_args.get("command") == "/host/path/telemetry-hook",
               f"wrong command: {rpc_args.get('command')!r}")
        expect(rpc_args.get("args") == ["--flag", "value"],
               f"wrong args: {rpc_args.get('args')!r}")


def test_bridge_forwards_env_via_env_prefix() -> None:
    """Well-known Claude env vars + extras forward as `env KEY=VAL ... <bin>`
    in the tools/call request."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
                "CLAUDE_PROJECT_DIR": "/Users/me/repo",
                "CLAUDE_SESSION_ID": "sess-abc",
                "CLAUDE_HOOK_EVENT": "SessionEnd",
                "CLAUDE_HOST_HOOK_BRIDGE_FORWARD_ENV": "FOO_VAR:BAR_VAR",
                "FOO_VAR": "foo-val",
                "BAR_VAR": "bar-val",
            },
        )
        expect(r.returncode == 0, f"forward-env: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}")
        call_req = find_request("tools/call")
        expect(call_req is not None, "forward-env: no tools/call request recorded")
        if call_req is None:
            return
        rpc_args = call_req["body"]["params"]["arguments"]
        expect(rpc_args["command"] == "env",
               f"forward-env: command should be 'env', got {rpc_args.get('command')!r}")
        a = rpc_args["args"]
        expect("CLAUDE_PROJECT_DIR=/Users/me/repo" in a,
               f"forward-env: missing CLAUDE_PROJECT_DIR, args={a!r}")
        expect("CLAUDE_SESSION_ID=sess-abc" in a,
               f"forward-env: missing CLAUDE_SESSION_ID, args={a!r}")
        expect("CLAUDE_HOOK_EVENT=SessionEnd" in a,
               f"forward-env: missing CLAUDE_HOOK_EVENT, args={a!r}")
        expect("FOO_VAR=foo-val" in a,
               f"forward-env: missing FOO_VAR, args={a!r}")
        expect("BAR_VAR=bar-val" in a,
               f"forward-env: missing BAR_VAR, args={a!r}")
        expect("/host/path/telemetry-hook" in a,
               f"forward-env: missing target, args={a!r}")
        target_idx = a.index("/host/path/telemetry-hook")
        for env_pair in [
            "CLAUDE_PROJECT_DIR=/Users/me/repo",
            "CLAUDE_SESSION_ID=sess-abc",
            "FOO_VAR=foo-val",
        ]:
            expect(a.index(env_pair) < target_idx,
                   f"forward-env: {env_pair!r} should precede target, args={a!r}")


def test_bridge_on_is_error_falls_back_silently() -> None:
    """isError tools/call response (allow-list reject) => exit 0, stderr explains."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(is_error=True, error_text="Command not in ALLOWED_COMMANDS")
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"isError: expected exit 0, got {r.returncode}")
        expect("isError" in r.stderr or "ALLOWED_COMMANDS" in r.stderr,
               f"isError: stderr should explain, got: {r.stderr!r}")
        # Handshake still completed before the isError response.
        methods = [req["method"] for req in FakeMCPHandler.requests]
        expect(
            methods == ["initialize", "notifications/initialized", "tools/call"],
            f"isError: handshake should still fire fully, got: {methods!r}",
        )


def test_bridge_unreachable_falls_back() -> None:
    """Bridge ON but server unreachable => exit 0, fall-back stderr line."""
    reset_fake()
    # Use a port we know nothing's listening on.
    r = run_bridge(
        "/host/path/telemetry-hook",
        bridge_env={
            "CLAUDE_HOST_HOOK_BRIDGE": "1",
            "CLAUDE_HOST_HOOK_BRIDGE_URL": "http://127.0.0.1:1/mcp",
            "CLAUDE_HOST_HOOK_BRIDGE_TIMEOUT": "2",
        },
    )
    expect(r.returncode == 0, f"unreachable: expected exit 0, got {r.returncode}")
    expect("[hook-bridge]" in r.stderr,
           f"unreachable: expected fall-back heads-up, got: {r.stderr!r}")
    expect("falling back to no-op" in r.stderr,
           f"unreachable: expected fall-back message, got: {r.stderr!r}")


def test_bridge_unparseable_initialize_response_falls_back() -> None:
    """Server returns garbage on initialize => exit 0, fall-back stderr.

    Streamable-HTTP servers that return 200 OK + non-JSON body on
    initialize are misbehaving; the bridge must treat them as a transport
    failure and fall back rather than crash."""
    reset_fake()
    with fake_server() as url:
        FakeMCPHandler.init_failure_mode = "garbage_body"
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"garbage init: expected exit 0, got {r.returncode}")
        expect("falling back to no-op" in r.stderr,
               f"garbage init: expected fall-back message, got: {r.stderr!r}")


def test_bridge_initialize_jsonrpc_error_falls_back() -> None:
    """JSON-RPC error envelope on initialize => exit 0, fall-back stderr."""
    reset_fake()
    with fake_server() as url:
        FakeMCPHandler.init_failure_mode = "jsonrpc_error"
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"init-error: expected exit 0, got {r.returncode}")
        expect("falling back to no-op" in r.stderr,
               f"init-error: expected fall-back message, got: {r.stderr!r}")


def test_bridge_sse_response_shape() -> None:
    """text/event-stream tools/call response is parsed correctly."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="from-sse", exit_code=7)
        FakeMCPHandler.response_mode = "sse"
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 7, f"sse: expected exit 7, got {r.returncode}; stderr: {r.stderr!r}")
        expect("from-sse" in r.stdout, f"sse: stdout missing body, got: {r.stdout!r}")


def test_bridge_bad_argv() -> None:
    """No target on argv => exit 2 + usage stderr."""
    reset_fake()
    r = run_bridge(None, bridge_env={"CLAUDE_HOST_HOOK_BRIDGE": "1"})
    expect(r.returncode == 2, f"bad argv: expected exit 2, got {r.returncode}")
    expect("usage" in r.stderr.lower(),
           f"bad argv: expected usage line, got: {r.stderr!r}")


def test_bridge_tools_call_jsonrpc_error_falls_back() -> None:
    """JSON-RPC error envelope on tools/call => exit 0, stderr explains."""
    reset_fake()
    with fake_server() as url:
        FakeMCPHandler.tools_call_response = {
            "error": {"code": -32601, "message": "Method not found"}
        }
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"jsonrpc-error: expected exit 0, got {r.returncode}")
        expect("Method not found" in r.stderr or "host-bash error" in r.stderr,
               f"jsonrpc-error: stderr should explain, got: {r.stderr!r}")


def test_bearer_header_sent_on_every_request_when_env_set() -> None:
    """CLAUDE_HOST_HOOK_BRIDGE_BEARER set => every POST (initialize,
    notifications/initialized, tools/call) carries
    `Authorization: Bearer <token>`. The shim on the host side
    validates this header and 401's anything without it; the bridge
    must put the header on EVERY request, not just one."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="auth-ok", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
                "CLAUDE_HOST_HOOK_BRIDGE_BEARER": "test-secret-123",
            },
        )
        expect(
            r.returncode == 0,
            f"bearer-on: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}",
        )
        # All three requests must carry the bearer header.
        expect(
            len(FakeMCPHandler.requests) >= 1,
            f"bearer-on: at least initialize should fire, got {FakeMCPHandler.requests!r}",
        )
        for req in FakeMCPHandler.requests:
            expect(
                req["auth"] == "Bearer test-secret-123",
                f"bearer-on: request {req['method']!r} missing or wrong "
                f"Authorization header, got {req['auth']!r}",
            )


def test_no_bearer_header_when_env_unset() -> None:
    """No CLAUDE_HOST_HOOK_BRIDGE_BEARER => no Authorization header on
    any request. The bridge stays backward-compatible with deployments
    that don't run the shim (pre-PR-B and loopback-only stacks)."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="no-auth-ok", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(
            r.returncode == 0,
            f"no-bearer: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}",
        )
        for req in FakeMCPHandler.requests:
            expect(
                req["auth"] is None,
                f"no-bearer: request {req['method']!r} should have NO "
                f"Authorization header when CLAUDE_HOST_HOOK_BRIDGE_BEARER "
                f"is unset, got {req['auth']!r}",
            )


def test_empty_bearer_env_treated_as_unset() -> None:
    """CLAUDE_HOST_HOOK_BRIDGE_BEARER="" (empty string) => no header.
    Treats empty same as unset so an operator wiring an empty .env
    value doesn't end up sending `Authorization: Bearer ` (literal
    empty token, which would 401 against a real shim AND noise up
    the logs)."""
    reset_fake()
    with fake_server() as url:
        set_tools_call_response(stdout="empty-bearer-ok", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
                "CLAUDE_HOST_HOOK_BRIDGE_BEARER": "",
            },
        )
        expect(
            r.returncode == 0,
            f"empty-bearer: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}",
        )
        for req in FakeMCPHandler.requests:
            expect(
                req["auth"] is None,
                f"empty-bearer: request {req['method']!r} should have NO "
                f"Authorization header for empty env value, got {req['auth']!r}",
            )


def test_bridge_stateless_server_skips_session_header() -> None:
    """If initialize doesn't issue a session id (server in stateless
    mode), the bridge still completes tools/call — just without the
    header."""
    reset_fake()
    with fake_server() as url:
        FakeMCPHandler.stateless_mode = True
        set_tools_call_response(stdout="stateless-ok", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"stateless: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}")
        expect("stateless-ok" in r.stdout, f"stateless: stdout missing body, got: {r.stdout!r}")
        # tools/call request should NOT carry a session header in stateless mode.
        call_req = find_request("tools/call")
        expect(call_req is not None, "stateless: no tools/call request recorded")
        if call_req:
            expect(
                call_req["session_id"] is None,
                f"stateless: tools/call should not carry mcp-session-id, got {call_req['session_id']!r}",
            )


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

TESTS = [
    test_bridge_off_short_circuits,
    test_bridge_on_runs_full_handshake,
    test_bridge_forwards_env_via_env_prefix,
    test_bridge_on_is_error_falls_back_silently,
    test_bridge_unreachable_falls_back,
    test_bridge_unparseable_initialize_response_falls_back,
    test_bridge_initialize_jsonrpc_error_falls_back,
    test_bridge_sse_response_shape,
    test_bridge_bad_argv,
    test_bridge_tools_call_jsonrpc_error_falls_back,
    test_bearer_header_sent_on_every_request_when_env_set,
    test_no_bearer_header_when_env_unset,
    test_empty_bearer_env_treated_as_unset,
    test_bridge_stateless_server_skips_session_header,
]

for t in TESTS:
    print(f"--- {t.__name__}")
    pre_failures = len(failures)
    try:
        t()
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")
        continue
    if len(failures) == pre_failures:
        print(f"PASS  {t.__name__}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
