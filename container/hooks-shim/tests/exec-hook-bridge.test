#!/usr/bin/env python3
"""Tests for container/hooks-shim/exec-hook-bridge.

Spins up a fake MCP server (HTTP socket on localhost) that mimics
mcp-host-bash + cli-mcp-server's `tools/call` shape for the
`run_command` tool. The bridge points at the fake via
CLAUDE_HOST_HOOK_BRIDGE_URL, and we assert:

  - Bridge OFF (CLAUDE_HOST_HOOK_BRIDGE != 1): exit 0, no HTTP call.
  - Bridge ON, server reachable: exit propagates; stdout / stderr from
    the host binary surface to the bridge's stdout / stderr.
  - Bridge ON, isError response (allow-list reject etc.): exit 0,
    stderr explains.
  - Bridge ON, server unreachable: exit 0, fall-back stderr line.
  - Bridge ON, parse failure: exit 0, fall-back stderr line.
  - Forwarded env: well-known Claude vars + custom ones from
    CLAUDE_HOST_HOOK_BRIDGE_FORWARD_ENV land in the request as
    `env KEY=VAL ...` prefix args.
  - SSE response shape (`text/event-stream` with `data: <json>`) parses.
  - Bad argv (no target): exit 2 + usage stderr.

Each test runs the fake server in-process on an ephemeral port, sets
CLAUDE_HOST_HOOK_BRIDGE_URL to point at it, then runs the bridge as
a subprocess so we exercise the real shebang + import path.

Run:  ./exec-hook-bridge.test
"""

from __future__ import annotations

import contextlib
import http.server
import json
import os
import subprocess
import sys
import threading
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
SCRIPT = HERE.parent / "exec-hook-bridge"

if not SCRIPT.exists():
    print(f"FAIL: cannot locate exec-hook-bridge at {SCRIPT}", file=sys.stderr)
    sys.exit(2)


failures: list[str] = []


def expect(cond: bool, msg: str) -> None:
    if not cond:
        failures.append(msg)
        print(f"  -> FAIL: {msg}")


# ---------------------------------------------------------------------------
# Fake MCP server
# ---------------------------------------------------------------------------


class FakeMCPHandler(http.server.BaseHTTPRequestHandler):
    """One-shot JSON-RPC handler. The class-level `handler_response`
    dict is the canned response; tests set it before sending requests.

    Records the LAST request body in `last_request` for assertion.
    """

    handler_response: dict = {}
    last_request: dict | None = None
    response_mode: str = "json"  # "json" or "sse"
    response_status: int = 200

    def do_POST(self) -> None:  # noqa: N802 (BaseHTTPRequestHandler API)
        length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(length).decode("utf-8") if length else ""
        try:
            FakeMCPHandler.last_request = json.loads(body)
        except json.JSONDecodeError:
            FakeMCPHandler.last_request = {"_raw": body}

        rpc_id = FakeMCPHandler.last_request.get("id", 1) if isinstance(FakeMCPHandler.last_request, dict) else 1
        envelope = {"jsonrpc": "2.0", "id": rpc_id}
        envelope.update(FakeMCPHandler.handler_response)

        if FakeMCPHandler.response_mode == "sse":
            payload = f"data: {json.dumps(envelope)}\n\n"
            ct = "text/event-stream"
        else:
            payload = json.dumps(envelope)
            ct = "application/json"

        self.send_response(FakeMCPHandler.response_status)
        self.send_header("Content-Type", ct)
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload.encode("utf-8"))

    def log_message(self, fmt: str, *args) -> None:  # silence noise
        return


@contextlib.contextmanager
def fake_server():
    """Spin up the fake MCP handler on localhost:<ephemeral>. Yields
    the bridge URL pointing at /mcp on that port."""
    server = http.server.HTTPServer(("127.0.0.1", 0), FakeMCPHandler)
    port = server.server_address[1]
    t = threading.Thread(target=server.serve_forever, daemon=True)
    t.start()
    try:
        yield f"http://127.0.0.1:{port}/mcp"
    finally:
        server.shutdown()
        server.server_close()


def run_bridge(
    target: str | None,
    *args: str,
    bridge_env: dict | None = None,
    timeout: float = 10.0,
) -> subprocess.CompletedProcess:
    """Run the bridge as a subprocess. bridge_env overrides env vars.

    PATH + a sane HOME is preserved so urllib can resolve.
    """
    env = {
        "PATH": os.environ.get("PATH", "/usr/bin:/bin"),
        "HOME": os.environ.get("HOME", "/tmp"),
    }
    if bridge_env:
        env.update(bridge_env)
    argv = [str(SCRIPT)]
    if target is not None:
        argv.append(target)
    argv.extend(args)
    return subprocess.run(
        argv,
        env=env,
        capture_output=True,
        text=True,
        timeout=timeout,
    )


def make_run_command_text(stdout: str = "", stderr: str = "", exit_code: int = 0) -> str:
    """Build cli-mcp-server's text body for a successful run."""
    parts = ["Command executed successfully."]
    if stdout:
        parts.append(f"Stdout: {stdout}")
    if stderr:
        parts.append(f"Stderr: {stderr}")
    parts.append(f"Exit Code: {exit_code}")
    return "\n".join(parts)


def set_canned_response(stdout="", stderr="", exit_code=0, is_error=False, error_text="") -> None:
    if is_error:
        FakeMCPHandler.handler_response = {
            "result": {
                "isError": True,
                "content": [{"type": "text", "text": error_text}],
            }
        }
    else:
        FakeMCPHandler.handler_response = {
            "result": {
                "content": [
                    {
                        "type": "text",
                        "text": make_run_command_text(stdout, stderr, exit_code),
                    }
                ]
            }
        }
    FakeMCPHandler.last_request = None
    FakeMCPHandler.response_mode = "json"
    FakeMCPHandler.response_status = 200


# ---------------------------------------------------------------------------
# Tests
# ---------------------------------------------------------------------------


def test_bridge_off_short_circuits() -> None:
    """CLAUDE_HOST_HOOK_BRIDGE unset / != 1 => exit 0 immediately, NO HTTP call."""
    with fake_server() as url:
        set_canned_response(stdout="should-not-see", exit_code=99)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={"CLAUDE_HOST_HOOK_BRIDGE_URL": url},
        )
        expect(r.returncode == 0, f"bridge OFF: expected exit 0, got {r.returncode}")
        expect(FakeMCPHandler.last_request is None,
               f"bridge OFF: expected no HTTP call, got {FakeMCPHandler.last_request!r}")


def test_bridge_on_propagates_exit_and_streams() -> None:
    """Bridge ON + server replies with stdout/stderr/exit -> all three propagate."""
    with fake_server() as url:
        set_canned_response(stdout="hello from host", stderr="warn from host", exit_code=42)
        r = run_bridge(
            "/host/path/telemetry-hook",
            "--flag",
            "value",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 42, f"bridge ON: expected exit 42, got {r.returncode}; stderr: {r.stderr!r}")
        expect("hello from host" in r.stdout, f"bridge ON: stdout missing host body, got: {r.stdout!r}")
        expect("warn from host" in r.stderr, f"bridge ON: stderr missing host body, got: {r.stderr!r}")
        # Verify request shape.
        req = FakeMCPHandler.last_request
        expect(isinstance(req, dict), f"request not parsed as dict: {req!r}")
        expect(req["method"] == "tools/call", f"wrong method: {req.get('method')!r}")
        params = req.get("params", {})
        expect(params.get("name") == "run_command", f"wrong tool name: {params.get('name')!r}")
        rpc_args = params.get("arguments", {})
        # No forwarded env vars => command is the binary itself.
        expect(rpc_args.get("command") == "/host/path/telemetry-hook",
               f"wrong command: {rpc_args.get('command')!r}")
        expect(rpc_args.get("args") == ["--flag", "value"],
               f"wrong args: {rpc_args.get('args')!r}")


def test_bridge_forwards_env_via_env_prefix() -> None:
    """Well-known Claude env vars + extras forward as `env KEY=VAL ... <bin>`."""
    with fake_server() as url:
        set_canned_response(stdout="", exit_code=0)
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
                "CLAUDE_PROJECT_DIR": "/Users/me/repo",
                "CLAUDE_SESSION_ID": "sess-abc",
                "CLAUDE_HOOK_EVENT": "SessionEnd",
                "CLAUDE_HOST_HOOK_BRIDGE_FORWARD_ENV": "FOO_VAR:BAR_VAR",
                "FOO_VAR": "foo-val",
                "BAR_VAR": "bar-val",
            },
        )
        expect(r.returncode == 0, f"forward-env: expected exit 0, got {r.returncode}; stderr: {r.stderr!r}")
        req = FakeMCPHandler.last_request
        rpc_args = req["params"]["arguments"]
        expect(rpc_args["command"] == "env",
               f"forward-env: command should be 'env', got {rpc_args.get('command')!r}")
        # The args are env vars + target + original args. Order is
        # well_known + extras + target.
        a = rpc_args["args"]
        expect("CLAUDE_PROJECT_DIR=/Users/me/repo" in a,
               f"forward-env: missing CLAUDE_PROJECT_DIR, args={a!r}")
        expect("CLAUDE_SESSION_ID=sess-abc" in a,
               f"forward-env: missing CLAUDE_SESSION_ID, args={a!r}")
        expect("CLAUDE_HOOK_EVENT=SessionEnd" in a,
               f"forward-env: missing CLAUDE_HOOK_EVENT, args={a!r}")
        expect("FOO_VAR=foo-val" in a,
               f"forward-env: missing FOO_VAR, args={a!r}")
        expect("BAR_VAR=bar-val" in a,
               f"forward-env: missing BAR_VAR, args={a!r}")
        expect("/host/path/telemetry-hook" in a,
               f"forward-env: missing target, args={a!r}")
        # Target binary appears after the env vars.
        target_idx = a.index("/host/path/telemetry-hook")
        for env_pair in [
            "CLAUDE_PROJECT_DIR=/Users/me/repo",
            "CLAUDE_SESSION_ID=sess-abc",
            "FOO_VAR=foo-val",
        ]:
            expect(a.index(env_pair) < target_idx,
                   f"forward-env: {env_pair!r} should precede target, args={a!r}")


def test_bridge_on_is_error_falls_back_silently() -> None:
    """isError response (allow-list reject) => exit 0, stderr explains."""
    with fake_server() as url:
        set_canned_response(is_error=True, error_text="Command not in ALLOWED_COMMANDS")
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"isError: expected exit 0, got {r.returncode}")
        expect("isError" in r.stderr or "ALLOWED_COMMANDS" in r.stderr,
               f"isError: stderr should explain, got: {r.stderr!r}")


def test_bridge_unreachable_falls_back() -> None:
    """Bridge ON but server unreachable => exit 0, fall-back stderr line."""
    # Use a port we know nothing's listening on.
    r = run_bridge(
        "/host/path/telemetry-hook",
        bridge_env={
            "CLAUDE_HOST_HOOK_BRIDGE": "1",
            "CLAUDE_HOST_HOOK_BRIDGE_URL": "http://127.0.0.1:1/mcp",
            "CLAUDE_HOST_HOOK_BRIDGE_TIMEOUT": "2",
        },
    )
    expect(r.returncode == 0, f"unreachable: expected exit 0, got {r.returncode}")
    expect("[hook-bridge]" in r.stderr,
           f"unreachable: expected fall-back heads-up, got: {r.stderr!r}")
    expect("falling back to no-op" in r.stderr,
           f"unreachable: expected fall-back message, got: {r.stderr!r}")


def test_bridge_unparseable_response_falls_back() -> None:
    """Server returns garbage => exit 0, fall-back stderr."""
    with fake_server() as url:
        # Override the response to invalid JSON via a custom handler attr.
        FakeMCPHandler.handler_response = {}
        FakeMCPHandler.last_request = None

        # Patch the handler to return raw garbage. We do that by
        # monkey-patching the do_POST path: easier just to set
        # response_status to something that triggers urllib error,
        # but simpler: make the response shape invalid by setting a
        # non-dict result and returning empty content. The bridge
        # parses gracefully; let's instead force the body to non-JSON
        # by using SSE mode WITH no `data:` line.
        original_do_POST = FakeMCPHandler.do_POST

        def garbage_post(self):
            length = int(self.headers.get("Content-Length", "0"))
            body = self.rfile.read(length).decode("utf-8") if length else ""
            try:
                FakeMCPHandler.last_request = json.loads(body)
            except json.JSONDecodeError:
                FakeMCPHandler.last_request = {"_raw": body}
            payload = "this is not JSON"
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload.encode("utf-8"))

        FakeMCPHandler.do_POST = garbage_post
        try:
            r = run_bridge(
                "/host/path/telemetry-hook",
                bridge_env={
                    "CLAUDE_HOST_HOOK_BRIDGE": "1",
                    "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
                },
            )
            expect(r.returncode == 0, f"garbage: expected exit 0, got {r.returncode}")
            expect("falling back to no-op" in r.stderr,
                   f"garbage: expected fall-back message, got: {r.stderr!r}")
        finally:
            FakeMCPHandler.do_POST = original_do_POST


def test_bridge_sse_response_shape() -> None:
    """text/event-stream with `data: <json>` line is parsed correctly."""
    with fake_server() as url:
        set_canned_response(stdout="from-sse", exit_code=7)
        FakeMCPHandler.response_mode = "sse"
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 7, f"sse: expected exit 7, got {r.returncode}; stderr: {r.stderr!r}")
        expect("from-sse" in r.stdout, f"sse: stdout missing body, got: {r.stdout!r}")


def test_bridge_bad_argv() -> None:
    """No target on argv => exit 2 + usage stderr."""
    r = run_bridge(None, bridge_env={"CLAUDE_HOST_HOOK_BRIDGE": "1"})
    expect(r.returncode == 2, f"bad argv: expected exit 2, got {r.returncode}")
    expect("usage" in r.stderr.lower(),
           f"bad argv: expected usage line, got: {r.stderr!r}")


def test_bridge_jsonrpc_error_falls_back() -> None:
    """JSON-RPC error envelope => exit 0, stderr explains."""
    with fake_server() as url:
        FakeMCPHandler.handler_response = {
            "error": {"code": -32601, "message": "Method not found"}
        }
        FakeMCPHandler.last_request = None
        FakeMCPHandler.response_mode = "json"
        FakeMCPHandler.response_status = 200
        r = run_bridge(
            "/host/path/telemetry-hook",
            bridge_env={
                "CLAUDE_HOST_HOOK_BRIDGE": "1",
                "CLAUDE_HOST_HOOK_BRIDGE_URL": url,
            },
        )
        expect(r.returncode == 0, f"jsonrpc-error: expected exit 0, got {r.returncode}")
        expect("Method not found" in r.stderr or "host-bash error" in r.stderr,
               f"jsonrpc-error: stderr should explain, got: {r.stderr!r}")


# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

TESTS = [
    test_bridge_off_short_circuits,
    test_bridge_on_propagates_exit_and_streams,
    test_bridge_forwards_env_via_env_prefix,
    test_bridge_on_is_error_falls_back_silently,
    test_bridge_unreachable_falls_back,
    test_bridge_unparseable_response_falls_back,
    test_bridge_sse_response_shape,
    test_bridge_bad_argv,
    test_bridge_jsonrpc_error_falls_back,
]

for t in TESTS:
    print(f"--- {t.__name__}")
    pre_failures = len(failures)
    try:
        t()
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")
        continue
    if len(failures) == pre_failures:
        print(f"PASS  {t.__name__}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
