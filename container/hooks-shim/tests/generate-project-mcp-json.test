            f"preserve-http-keys: alwaysLoad should survive rewrite, "
            f"got {adaptor.get('alwaysLoad')!r}",
        )


def test_http_bridge_combines_with_pattern_filter() -> None:
    """HTTP-bridged servers are not eligible for pattern wrapping
    (they don't have a `command` anymore); non-bridged servers
    still respect the shim-patterns filter."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, _mcp_input_for_bridge())
        project = Path(td) / "project"
        project.mkdir()
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            # A pattern that only matches `npx` — chrome-devtools should
            # still be wrapped; mcp-adaptor is now http and unaffected.
            patterns="npx",
        )
        out = load_output(project)
        expect(
            out["mcpServers"]["mcp-adaptor"].get("type") == "http",
            f"bridge+pattern: mcp-adaptor rewrite should win over pattern, "
            f"got {out['mcpServers']['mcp-adaptor']!r}",
        )
        expect(
            out["mcpServers"]["chrome-devtools"].get("command")
            == f"{EXEC_HOOK} npx",
            f"bridge+pattern: chrome-devtools should still get wrapping, "
            f"got {out['mcpServers']['chrome-devtools']!r}",
        )


