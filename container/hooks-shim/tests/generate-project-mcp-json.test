            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            bearer_env="",
            bearer_value="dont-care",
        )
        out = load_output(project)
        adaptor = out["mcpServers"]["mcp-adaptor"]
        expect(
            "headers" not in adaptor,
            f"bearer-disabled: --bearer-env '' should suppress auto-inject "
            f"even with env var set, got {adaptor!r}",
        )


def test_bearer_env_custom_var_name() -> None:
    """Operator can point --bearer-env at a custom env var name (not
    the CLAUDE_HOST_HOOK_BRIDGE_BEARER default) and the auto-inject
    reads from that variable, references that name in the header."""
