# ---------------------------------------------------------------------------
# Bearer-auth header auto-inject (--bearer-env / CLAUDE_HOST_HOOK_BRIDGE_BEARER)
# ---------------------------------------------------------------------------


def test_bearer_env_set_injects_authorization_header() -> None:
    """When the bearer env var is set non-empty, http-bridged entries
    pick up `Authorization: Bearer ${<var>}` (note the `${...}` form —
    Claude Code's MCP loader expands env vars at runtime; the literal
    secret never lives in the file)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, _mcp_input_for_bridge())
        project = Path(td) / "project"
        project.mkdir()
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            # Set the default env var that --bearer-env points at.
            bearer_value="dont-care-the-secret-value",
        )
        out = load_output(project)
        adaptor = out["mcpServers"]["mcp-adaptor"]
        expect(
            isinstance(adaptor.get("headers"), dict),
            f"bearer-set: headers should be a dict, got {adaptor.get('headers')!r}",
        )
        expect(
            adaptor.get("headers", {}).get("Authorization")
            == "Bearer ${CLAUDE_HOST_HOOK_BRIDGE_BEARER}",
            f"bearer-set: Authorization header should reference env var, "
            f"got {adaptor.get('headers', {}).get('Authorization')!r}",
        )
        # The literal secret must NOT appear in the serialized file.
        raw = (project / ".mcp.json").read_text(encoding="utf-8")
        expect(
            "dont-care-the-secret-value" not in raw,
            "bearer-set: literal secret should NEVER appear in .mcp.json — "
            "only the ${VAR} reference",
        )


def test_bearer_env_unset_no_headers_field() -> None:
    """When the bearer env var is UNSET, no headers field is added
    (exact match to pre-PR behavior). Other http-bridge behavior
    unchanged."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, _mcp_input_for_bridge())
        project = Path(td) / "project"
        project.mkdir()
        # bearer_value=None means run_helper does NOT set the env var.
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
        )
        out = load_output(project)
        adaptor = out["mcpServers"]["mcp-adaptor"]
        expect(
            adaptor.get("type") == "http",
            f"bearer-unset: rewrite still happens, "
            f"got type={adaptor.get('type')!r}",
        )
        expect(
            "headers" not in adaptor,
            f"bearer-unset: no headers field should be added when env "
            f"var unset, got {adaptor!r}",
        )


def test_bearer_env_empty_no_headers_field() -> None:
    """An env var set to the empty string is equivalent to unset —
    no headers field added. Guards against accidentally injecting
    `Authorization: Bearer ${VAR}` when VAR=""."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
