    test_already_wrapped_not_double,
    test_project_scoped_servers_merged,
    test_only_project_scoped_servers_picked_up,
    test_neither_top_level_nor_project_scoped_no_output,
    test_output_format,
    test_idempotent_same_input_unchanged,
    test_changed_input_rewrites,
    test_weird_definition_passes_through,
    test_empty_pattern_wraps_every_server,
    test_no_pattern_wraps_every_server,
    test_pattern_narrow_match_only_wraps_matches,
    test_multiple_patterns_union,
    test_pattern_matches_zero_servers_all_pass_through,
    test_env_var_supplies_patterns_when_flag_absent,
    test_flag_overrides_env_var,
    test_pattern_with_npx_style_command,
    test_pattern_idempotent,
    test_http_bridge_rewrites_matching_server,
    test_http_bridge_leaves_other_servers_alone,
    test_http_bridge_multiple_servers_colon_separated,
    test_http_bridge_empty_no_rewrite,
    test_http_bridge_unknown_name_no_rewrite,
    test_http_bridge_env_var_supplies_value,
    test_http_bridge_flag_overrides_env_var,
    test_http_bridge_preserves_http_specific_keys,
    test_http_bridge_combines_with_pattern_filter,
    test_http_bridge_malformed_pair_ignored,
    test_bearer_env_set_injects_authorization_header,
    test_bearer_env_unset_no_headers_field,
    test_bearer_env_empty_no_headers_field,
    test_bearer_env_disabled_via_empty_flag,
    test_bearer_env_custom_var_name,
    test_bearer_env_preserves_existing_headers,
    test_bearer_env_operator_authorization_wins,
    test_bearer_env_non_bridged_server_unaffected,
    test_bearer_env_unset_default_var_no_inject,
]

for t in TESTS:
    try:
        t()
        print(f"PASS  {t.__name__}")
    except AssertionError as e:
        failures.append(f"{t.__name__}: {e}")
        print(f"FAIL  {t.__name__}: {e}")
    except Exception as e:
        failures.append(f"{t.__name__}: unexpected exception: {e}")
        print(f"FAIL  {t.__name__}: unexpected exception: {e}")

if failures:
    print(f"\n{len(failures)} failure(s):", file=sys.stderr)
    for f in failures:
        print(f"  - {f}", file=sys.stderr)
    sys.exit(1)

print(f"\nAll {len(TESTS)} tests passed.")
