def test_bearer_env_preserves_existing_headers() -> None:
    """When the operator already declared `headers` on the HTTP entry
    (e.g. X-Trace), the bearer auto-inject MERGES with those headers
    instead of clobbering them."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, {
            "mcpServers": {
                "mcp-adaptor": {
                    "command": "/Users/me/.mcp-adaptor/bin/x",
                    "headers": {"X-Trace": "1", "X-Operator": "andrew"},
                },
            },
        })
        project = Path(td) / "project"
        project.mkdir()
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            bearer_value="zz",
        )
        out = load_output(project)
        headers = out["mcpServers"]["mcp-adaptor"].get("headers", {})
        expect(
            headers.get("X-Trace") == "1",
            f"bearer-merge: X-Trace should survive, got {headers!r}",
        )
        expect(
            headers.get("X-Operator") == "andrew",
            f"bearer-merge: X-Operator should survive, got {headers!r}",
        )
        expect(
            headers.get("Authorization")
            == "Bearer ${CLAUDE_HOST_HOOK_BRIDGE_BEARER}",
            f"bearer-merge: Authorization should be added, got {headers!r}",
        )


def test_bearer_env_operator_authorization_wins() -> None:
    """If the operator explicitly pinned an `Authorization` header,
    the auto-inject does NOT clobber it. Escape hatch for operators
    who want to use a different header value (e.g. a static token,
    OAuth bearer, etc.)."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, {
            "mcpServers": {
                "mcp-adaptor": {
                    "command": "/Users/me/.mcp-adaptor/bin/x",
                    "headers": {"Authorization": "Bearer hardcoded-by-operator"},
                },
            },
        })
        project = Path(td) / "project"
        project.mkdir()
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            bearer_value="zz",
        )
        out = load_output(project)
        auth = out["mcpServers"]["mcp-adaptor"]["headers"]["Authorization"]
        expect(
            auth == "Bearer hardcoded-by-operator",
            f"bearer-operator-wins: operator's explicit Authorization "
            f"should survive, got {auth!r}",
        )


