def test_bearer_env_unset_default_var_no_inject() -> None:
    """Defense-in-depth: the default --bearer-env points at
    CLAUDE_HOST_HOOK_BRIDGE_BEARER. When that var isn't set in the
    process env, no headers field is added — exact match to pre-PR
    behavior. Mirrors test_bearer_env_unset_no_headers_field but
    explicit about the default var name."""
    with tempfile.TemporaryDirectory() as td:
        inp = Path(td) / ".claude.json"
        write_json(inp, _mcp_input_for_bridge())
        project = Path(td) / "project"
        project.mkdir()
        # run_helper pops CLAUDE_HOST_HOOK_BRIDGE_BEARER from env when
        # bearer_value is None; this asserts the helper observes
        # "unset" via os.environ.get("VAR", "") == "".
        run_helper(
            str(inp),
            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
        )
        out = load_output(project)
        # No headers added => exact pre-PR shape.
        for name, entry in out["mcpServers"].items():
            expect(
                "headers" not in entry or "Authorization" not in entry.get("headers", {}),
                f"bearer-default-unset: {name} should NOT have Authorization, "
                f"got {entry!r}",
            )


