            str(project),
            http_bridge="mcp-adaptor=http://host.docker.internal:8765/mcp",
            bearer_value="",  # explicit empty
        )
        out = load_output(project)
        adaptor = out["mcpServers"]["mcp-adaptor"]
        expect(
            "headers" not in adaptor,
            f"bearer-empty: empty env var should NOT inject Authorization, "
            f"got {adaptor!r}",
        )


def test_bearer_env_disabled_via_empty_flag() -> None:
    """`--bearer-env ''` explicitly disables the auto-inject even when
    the default env var (CLAUDE_HOST_HOOK_BRIDGE_BEARER) is set —
    operator escape hatch for "I want to manage headers myself"."""
