#!/usr/bin/env bash
# exec-hook — safe-exec wrapper for settings.json hook commands whose target
# binary may not be Linux-native.
#
# WHY THIS EXISTS
#
# Claude Code's hook system (settings.json `hooks.<event>.command`) fires a
# shell command on session events. When a user runs Claude Code inside this
# container but their host settings.json (bind-mounted into the container at
# ~/.claude/settings.json) points at a hook binary built for a DIFFERENT
# platform — e.g. a corporate telemetry hook compiled as Mach-O / arm64 on a
# Mac, mounted into a Linux container — Linux's exec() bounces it with
# "Exec format error" and Claude Code logs the failure on EVERY event
# (SessionStart, UserPromptSubmit, Stop, ...). The result is a continuous
# stream of error noise in the log, no telemetry actually fires, and the
# session works around it anyway.
#
# This shim:
#   1. Inspects the target binary's magic bytes via `head -c 4 | xxd` (no
#      external `file` dependency — works on debian:slim out of the box).
#   2. If it's ELF (Linux-native), exec's it transparently and the hook
#      behaves identically to having no shim at all. Arguments are
#      forwarded verbatim.
#   3. If it's Mach-O, an unknown format, or absent, silently no-ops + writes
#      a ONE-TIME line to stderr to the dedupe flag file (one entry per
#      target path, per container lifetime) so the operator gets a single
#      heads-up at session start instead of one per hook firing. Exits 0.
#
# Exit 0 on the no-op path is deliberate: Claude Code's hook semantics treat
# a non-zero hook exit as a soft failure (sometimes surfaced in the UI,
# sometimes blocking). For the cross-arch case we want the session to
# behave as if the hook simply ran successfully and did nothing — which is
# exactly the user's intent when the only available binary is cross-arch.
#
# USAGE
#
#   exec-hook /path/to/host-hook [args...]
#
# Typical settings.json hook entry on a host whose hook binary may be
# non-Linux:
#
#   {
#     "hooks": {
#       "SessionStart": [
#         {
#           "matcher": "startup|resume",
#           "hooks": [
#             { "type": "command", "command": "exec-hook /Users/me/.devbar/bin/telemetry-hook" }
#           ]
#         }
#       ]
#     }
#   }
#
# With the entrypoint wiring (see container/entrypoint.sh + Dockerfile,
# which prepend /usr/local/lib/claude-hooks-shim to PATH and install this
# script there as `exec-hook`), bare `exec-hook ...` resolves to this
# script.
#
# DEDUP FLAG FILE
#
# The first time the shim no-ops a given target path within a container's
# lifetime, it writes one line to stderr. Subsequent invocations against
# the SAME target path are silent. State lives under
# ${TMPDIR:-/tmp}/exec-hook-skipped (touched once per target). The flag
# file is created with 0600 perms; multi-user containers should set
# TMPDIR to a per-user directory.
#
# TODO: future IPC-forwarder option. Rather than no-op'ing the hook
# entirely, a host-side daemon (e.g. a launchd LaunchAgent on macOS)
# could listen on a Unix socket bind-mounted into the container; this
# shim would marshal the hook event over the socket to be run by the
# host's native binary. That's strictly future scope — the current
# silent-no-op behaviour matches what users want today (containers
# shouldn't try to run host-side telemetry).

set -u

# Where we record "skipped this target already this session" — flag-file
# dedup, one stderr line per unique target path per container lifetime.
# Falls back to /tmp if $TMPDIR is unset.
SKIP_FLAG_FILE="${TMPDIR:-/tmp}/exec-hook-skipped"

# Path to the upstream hook binary the operator wanted to run.
TARGET="${1:-}"

if [ -z "$TARGET" ]; then
    cat >&2 <<'EOF'
exec-hook: missing required first argument (path to the hook binary).

Usage:
  exec-hook /path/to/hook [args...]

This wrapper is meant to be referenced from ~/.claude/settings.json hook
"command" entries when the underlying hook binary may not be Linux-native
(e.g. a Mac telemetry hook bind-mounted into a Linux container). It
exec's the target on ELF binaries and silently no-ops on Mach-O / unknown
formats so cross-arch hooks don't spam the log.
EOF
    exit 2
fi

shift  # consume $1; "$@" is now the args to pass through

emit_skip_warning_once() {
    # Print one stderr line per (container lifetime, target path). Use a
    # plain flag file with one line per target; `grep -Fxq` checks
    # presence, then we append if missing.
    local target="$1"
    # Best-effort: if we can't write the flag file (read-only /tmp?),
    # emit the warning every time rather than fail silently — better
    # noisy than invisible when something is wrong with /tmp.
    if [ ! -e "$SKIP_FLAG_FILE" ]; then
        : > "$SKIP_FLAG_FILE" 2>/dev/null || true
        chmod 0600 "$SKIP_FLAG_FILE" 2>/dev/null || true
    fi
    if [ -r "$SKIP_FLAG_FILE" ] && grep -Fxq "$target" "$SKIP_FLAG_FILE" 2>/dev/null; then
        return 0
    fi
    printf '[hook-shim] skipped non-ELF hook (Linux container): %s\n' "$target" >&2
    printf '%s\n' "$target" >> "$SKIP_FLAG_FILE" 2>/dev/null || true
}

# Magic-byte sniff. ELF = 0x7F 'E' 'L' 'F'. Mach-O 32/64 + fat variants
# have a small set of magic values (0xFEEDFACE / 0xFEEDFACF, plus reverse
# byte orders and the FAT 0xCAFEBABE / 0xBEBAFECA). Anything else (script,
# missing file, etc.) is handled by the "exists and executable" check
# below so we can still exec a #!shebang script transparently.
if [ ! -e "$TARGET" ]; then
    # Treat a missing path as a non-ELF target — quiet no-op + one-line
    # heads-up. The settings.json reference is broken but that's not a
    # reason to bring the session down.
    emit_skip_warning_once "$TARGET (missing)"
    exit 0
fi

# Use od (POSIX, always present) to read the first 4 bytes as
# two-character hex tokens. xxd is NOT installed by default on
# debian:bookworm-slim; od is.
read_magic() {
    od -An -tx1 -N4 "$1" 2>/dev/null | tr -d ' \n'
}

magic="$(read_magic "$TARGET")"

case "$magic" in
    7f454c46)
        # ELF — Linux-native. exec it transparently.
        exec "$TARGET" "$@"
        ;;
    feedface|feedfacf|cefaedfe|cffaedfe|cafebabe|bebafeca)
        # Mach-O (32, 64, reverse byte-order pairs, fat).
        emit_skip_warning_once "$TARGET (Mach-O)"
        exit 0
        ;;
    *)
        # Could be a shebang script (`#!/usr/bin/env bash` -> magic
        # `2321...`), a Windows PE (`4d5a...`), a wasm module, or
        # garbage. For shebang scripts the OS's exec() handles them
        # natively, so try to exec — but only if the file is marked
        # executable. Anything else falls into the silent-no-op path.
        if [ -x "$TARGET" ] && [ "${magic#2321}" != "$magic" ]; then
            # Looks like a shebang script (#! = 0x23 0x21). exec it.
            exec "$TARGET" "$@"
        fi
        emit_skip_warning_once "$TARGET (unknown format: magic=${magic:-empty})"
        exit 0
        ;;
esac
