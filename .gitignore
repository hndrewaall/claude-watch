# Operator-specific bind-mount overrides for the example compose stack.
# The committed `docker-compose.override.yml.example` is the canonical
# template; each operator copies it to `docker-compose.override.yml` and
# uncomments the mounts that apply to their host. The actual override
# file leaks personal paths (gh token dir, gitconfig, ssh-agent socket,
# work-private bare-repo paths) and must NOT be committed.
examples/compose/docker-compose.override.yml

# Operator-specific env for the example compose stack. Holds personal host
# paths and live secrets (mcp-host-bash bearer, etc.). The committed
# `.env.example` is the canonical template; the real `.env` must NOT be
# committed.
examples/compose/.env
