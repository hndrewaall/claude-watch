#!/usr/bin/env python3
"""Tests for the `make install-hooks` target and its worktree behaviour.

Background: linked git worktrees have their own private gitdir and do NOT
consult the main repo's `.git/hooks/`. The old `install-hooks` recipe
symlinked `scripts/git-hooks/pre-commit` into `.git/hooks/`, so a fresh
`git worktree add` checkout (what isolation:worktree agents run in) had no
pre-commit and silently skipped the lint/test gate. The fix sets a
RELATIVE, per-repo `core.hooksPath` instead: git config lives in the shared
common dir so it auto-applies to every worktree, and a relative path
resolves against each worktree's own top-level so each runs its own
checked-out hooks.

This test asserts:

  1. The Makefile `install-hooks` recipe runs `git config core.hooksPath
     scripts/git-hooks` — a RELATIVE path.
  2. It does NOT pass `--global` (must stay scoped to this repo's local
     config; other repos untouched).
  3. It no longer symlinks into `.git/hooks/` (the broken approach).
  4. Functionally: replaying the recipe in a throwaway repo sets
     core.hooksPath in the LOCAL config only, and a `git worktree add`
     checkout of that repo resolves the hook from its OWN top-level
     `scripts/git-hooks/` (i.e. the pre-commit would run there).

Run:  ./scripts/git-hooks/tests/install-hooks.test
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[3]
MAKEFILE = REPO_ROOT / "Makefile"

failures: list[str] = []


def check(cond: bool, msg: str) -> None:
    if cond:
        print(f"  ok: {msg}")
    else:
        print(f"  FAIL: {msg}")
        failures.append(msg)


def extract_recipe(makefile_text: str, target: str) -> str:
    """Return the recipe body (tab-indented lines) for a Makefile target."""
    lines = makefile_text.splitlines()
    out: list[str] = []
    in_target = False
    for line in lines:
        if re.match(rf"^{re.escape(target)}:", line):
            in_target = True
            continue
        if in_target:
            if line.startswith("\t"):
                out.append(line[1:])
            elif line.strip() == "":
                out.append("")
            else:
                break
    return "\n".join(out).strip()


def git(args: list[str], cwd: Path, **kw) -> subprocess.CompletedProcess:
    env = dict(os.environ)
    # Hermetic: never read the developer's ~/.gitconfig (could carry a
    # global core.hooksPath that would mask the local-only assertion).
    env["HOME"] = str(cwd)
    env["GIT_CONFIG_GLOBAL"] = str(cwd / "nonexistent-global-gitconfig")
    env["GIT_CONFIG_SYSTEM"] = "/dev/null"
    env.setdefault("GIT_AUTHOR_NAME", "t")
    env.setdefault("GIT_AUTHOR_EMAIL", "t@t")
    env.setdefault("GIT_COMMITTER_NAME", "t")
    env.setdefault("GIT_COMMITTER_EMAIL", "t@t")
    return subprocess.run(
        ["git", *args], cwd=cwd, env=env, text=True,
        capture_output=True, check=False, **kw,
    )


def main() -> int:
    print("== install-hooks recipe (static) ==")
    recipe = extract_recipe(MAKEFILE.read_text(), "install-hooks")
    check(
        "git config core.hooksPath scripts/git-hooks" in recipe,
        "recipe runs `git config core.hooksPath scripts/git-hooks`",
    )
    check(
        "scripts/git-hooks" in recipe and not re.search(
            r"core\.hooksPath\s+/", recipe
        ),
        "core.hooksPath value is RELATIVE (not absolute)",
    )
    check("--global" not in recipe, "recipe does NOT pass --global")
    check(
        ".git/hooks" not in recipe,
        "recipe no longer touches .git/hooks/ (no symlink-into-gitdir)",
    )

    print("== install-hooks behaviour (functional, throwaway repo) ==")
    with tempfile.TemporaryDirectory() as td:
        root = Path(td)
        repo = root / "repo"
        repo.mkdir()

        git(["init", "-q"], repo)
        # Mirror the tracked hook layout.
        hooks_dir = repo / "scripts" / "git-hooks"
        hooks_dir.mkdir(parents=True)
        marker = repo / "hook-ran"
        hook = hooks_dir / "pre-commit"
        hook.write_text(
            "#!/bin/sh\n"
            'echo ran > "$(git rev-parse --show-toplevel)/hook-ran"\n'
            "exit 1\n"  # block the commit so we can detect it fired
        )
        hook.chmod(0o755)
        (repo / "f").write_text("x")
        git(["add", "-A"], repo)
        git(["commit", "-q", "--no-verify", "-m", "init"], repo)

        # Replay the recipe's effective command.
        git(["config", "core.hooksPath", "scripts/git-hooks"], repo)

        # (1) value landed in the LOCAL config, not global.
        local = git(["config", "--local", "--get", "core.hooksPath"], repo)
        check(
            local.stdout.strip() == "scripts/git-hooks",
            "local core.hooksPath == scripts/git-hooks",
        )
        glob = git(["config", "--global", "--get", "core.hooksPath"], repo)
        check(
            glob.returncode != 0 and glob.stdout.strip() == "",
            "global core.hooksPath is unset (scoped to this repo only)",
        )

        # (2) a linked worktree inherits the setting (shared common dir)
        #     and resolves the hook from ITS OWN top-level.
        wt = root / "wt"
        add = git(["worktree", "add", "-q", str(wt), "HEAD"], repo)
        check(add.returncode == 0, f"git worktree add succeeded ({add.stderr.strip()})")

        wt_cfg = git(["config", "--get", "core.hooksPath"], wt)
        check(
            wt_cfg.stdout.strip() == "scripts/git-hooks",
            "worktree sees core.hooksPath == scripts/git-hooks",
        )

        # `git rev-parse --git-path hooks` reflects the configured path
        # (relative -> resolved against the worktree top-level).
        gp = git(["rev-parse", "--git-path", "hooks"], wt)
        resolved = (wt / gp.stdout.strip()).resolve()
        check(
            resolved == (wt / "scripts" / "git-hooks").resolve(),
            "worktree's hooks dir resolves to its own scripts/git-hooks/",
        )

        # End-to-end: a commit in the worktree must FIRE the pre-commit.
        # The hook writes a marker and exits 1, so the commit is rejected
        # AND the marker proves it ran — exactly the gate that was being
        # silently skipped before this fix.
        (wt / "g").write_text("y")
        git(["add", "-A"], wt)
        commit = git(["commit", "-m", "should-be-blocked"], wt)
        wt_marker = wt / "hook-ran"
        check(
            commit.returncode != 0 and wt_marker.exists(),
            "pre-commit hook FIRES in a fresh worktree (gate enforced)",
        )

    print()
    if failures:
        print(f"FAILED: {len(failures)} check(s)")
        return 1
    print("PASSED")
    return 0


if __name__ == "__main__":
    sys.exit(main())
