#!/usr/bin/env python3
"""
claude-event-tail: Inspect the ring-buffer log of consumed Claude events.

The `claude-event-watch` watcher appends every event it consumes (one
compact JSON object per line) to ~/.config/claude-events/consumed.jsonl
before deleting the queue file. This CLI reads that log out-of-band so
the main loop can review recent events without the noise of the watcher's
firehose.

By default prints the last 20 entries as a clean table sorted newest-first.
Filters: --tag, --source, --since DUR (e.g. 5m, 1h, 1d, 7d).
Use --json for machine-readable raw JSONL output (still one object per line,
in display order).

Read-only — never deletes, never modifies the log file.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import sys
import time
from pathlib import Path
from typing import Any, Iterator

LOG_DIR = Path(os.environ.get("CLAUDE_EVENT_LOG_DIR", str(Path.home() / ".config" / "claude-events")))
LOG_FILE = LOG_DIR / "consumed.jsonl"
ROTATIONS = 3  # consumed.jsonl.1 .. .3 (matches watcher script)

DURATION_RE = re.compile(r"^\s*(\d+)\s*([smhdw])\s*$")
DURATION_UNITS = {"s": 1, "m": 60, "h": 3600, "d": 86400, "w": 604800}


def parse_duration(s: str) -> int:
    """Parse '5m' / '1h' / '7d' / '2w' into seconds. Raises ValueError on bad input."""
    m = DURATION_RE.match(s)
    if not m:
        raise ValueError(f"bad duration: {s!r} (expected like 5m, 1h, 1d, 7d)")
    n, unit = int(m.group(1)), m.group(2)
    return n * DURATION_UNITS[unit]


def iter_log_files() -> list[Path]:
    """Return the consumed.jsonl files in newest-first order: current then .1 .. .N.
    The current file holds the freshest entries; rotations hold older ones.
    We read in this order and let the caller sort by timestamp at the end.
    """
    files: list[Path] = []
    if LOG_FILE.exists():
        files.append(LOG_FILE)
    for i in range(1, ROTATIONS + 1 + 1):  # +1 for the in-flight rotation slot
        rot = LOG_FILE.with_suffix(LOG_FILE.suffix + f".{i}")
        if rot.exists():
            files.append(rot)
    return files


def iter_events(files: list[Path]) -> Iterator[dict[str, Any]]:
    """Yield parsed JSON objects from the given files. Skips malformed lines."""
    for path in files:
        try:
            with path.open("r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        yield json.loads(line)
                    except json.JSONDecodeError:
                        # Tolerate the occasional torn line — log is best-effort
                        continue
        except FileNotFoundError:
            continue


def event_ts(ev: dict[str, Any]) -> float:
    """Best-effort numeric timestamp for sorting/filtering. Falls back to 0."""
    ts = ev.get("timestamp")
    if isinstance(ts, (int, float)):
        return float(ts)
    iso = ev.get("timestamp_iso")
    if isinstance(iso, str):
        try:
            # Python 3.11+ accepts trailing tz offset; older accepts strict ISO
            return time.mktime(time.strptime(iso[:19], "%Y-%m-%dT%H:%M:%S"))
        except (ValueError, OverflowError):
            pass
    return 0.0


def fmt_ts(ts: float) -> str:
    if ts <= 0:
        return "----"
    return time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(ts))


def truncate(s: str, width: int) -> str:
    """Truncate s to width chars, replacing newlines with spaces, adding ellipsis."""
    s = s.replace("\n", " ").replace("\r", " ")
    if len(s) <= width:
        return s
    if width <= 1:
        return s[:width]
    return s[: width - 1] + "…"


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Inspect the consumed-Claude-event ring buffer log.",
    )
    ap.add_argument("-n", type=int, default=20, help="number of entries to show (default 20)")
    ap.add_argument("--tag", default=None, help="filter: tag substring match (case-insensitive)")
    ap.add_argument("--source", default=None, help="filter: source exact match")
    ap.add_argument("--since", default=None, help="filter: only entries newer than DUR (e.g. 5m, 1h, 1d, 7d)")
    ap.add_argument("--json", action="store_true", help="output raw JSONL instead of a table")
    args = ap.parse_args()

    since_cutoff = 0.0
    if args.since:
        try:
            since_cutoff = time.time() - parse_duration(args.since)
        except ValueError as e:
            print(f"claude-event-tail: {e}", file=sys.stderr)
            return 2

    tag_filter = args.tag.lower() if args.tag else None
    source_filter = args.source

    # Collect, filter, sort newest-first, truncate to N.
    rows: list[dict[str, Any]] = []
    for ev in iter_events(iter_log_files()):
        ts = event_ts(ev)
        if since_cutoff and ts < since_cutoff:
            continue
        if tag_filter is not None:
            tag = str(ev.get("tag", "")).lower()
            if tag_filter not in tag:
                continue
        if source_filter is not None and ev.get("source") != source_filter:
            continue
        rows.append(ev)

    rows.sort(key=event_ts, reverse=True)
    if args.n > 0:
        rows = rows[: args.n]

    if not rows:
        if args.json:
            return 0
        print("(no consumed events match)", file=sys.stderr)
        return 0

    if args.json:
        for ev in rows:
            sys.stdout.write(json.dumps(ev, separators=(",", ":")) + "\n")
        return 0

    # Table layout
    term_w = shutil.get_terminal_size((100, 24)).columns
    ts_w = 19   # "YYYY-MM-DD HH:MM:SS"
    src_w = 14
    tag_w = 22
    sep = 2  # spaces between columns
    fixed = ts_w + sep + src_w + sep + tag_w + sep
    msg_w = max(20, term_w - fixed)

    header = f"{'TIMESTAMP':<{ts_w}}  {'SOURCE':<{src_w}}  {'TAG':<{tag_w}}  {'MESSAGE':<{msg_w}}"
    print(header)
    for ev in rows:
        ts = fmt_ts(event_ts(ev))
        source = truncate(str(ev.get("source", "")), src_w)
        tag = truncate(str(ev.get("tag", "")), tag_w)
        message = truncate(str(ev.get("message", "")), msg_w)
        print(f"{ts:<{ts_w}}  {source:<{src_w}}  {tag:<{tag_w}}  {message}")

    return 0


if __name__ == "__main__":
    sys.exit(main())
