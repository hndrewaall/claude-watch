#!/usr/bin/env python3
"""
claude-event: Emit an arbitrary event to the Claude event queue for the main loop to handle.

Intended for use from cron jobs, alertmanager webhooks, the session-task queue,
or anything else that needs fuzzy handling by Claude. Events are written
atomically (tmp + rename) as JSON into the queue directory, where
`claude-event-watch` will pick them up.

Usage:
    claude-event "message text" [--tag TAG] [--source SOURCE] [--priority P] [--data KEY=VAL ...]

The `--source` field categorizes where the event originated. Valid values:
    cron          -- recurring cron job (default)
    alertmanager  -- Prometheus alertmanager webhook
    queue         -- session-task queue event
    torrent       -- torrent-related pipeline event
    security      -- security-scan / patcher pipeline
    claude-watch  -- emitted by the claude-watch daemon (e.g. watcher-down)
    manual        -- hand-emitted by Andrew or me for testing

Examples (from crontab):
    */30 * * * * lpotl-stream sync || claude-event "lpotl sync failed" --tag lpotl-failure --priority high --source cron
    0 4 * * *    check-disk-space || claude-event "disk space low" --tag disk --priority urgent --source cron

Backward-compat:
    The old name `cron-event` is preserved as a symlink shim. When invoked by
    that name, a deprecation warning is printed to stderr but the event is
    still emitted. Please migrate callers to `claude-event`.
"""
from __future__ import annotations

import argparse
import json
import os
import socket
import sys
import tempfile
import time
from pathlib import Path

# Honor legacy env var for backward compat; prefer new var.
QUEUE_DIR = Path(
    os.environ.get(
        "CLAUDE_EVENT_QUEUE",
        os.environ.get("CRON_EVENT_QUEUE", str(Path.home() / "claude-events")),
    )
)

VALID_SOURCES = {
    "cron",
    "alertmanager",
    "queue",
    "torrent",
    "security",
    "manual",
    "claude-watch",
}


def cmd_emit(args: argparse.Namespace) -> int:
    """Emit an event into the queue."""
    # Source defaults + validation
    source = args.source or "cron"
    if source not in VALID_SOURCES:
        print(
            f"claude-event: --source must be one of {sorted(VALID_SOURCES)}, got: {source}",
            file=sys.stderr,
        )
        return 2

    extra: dict[str, str] = {}
    for kv in args.data:
        if "=" not in kv:
            print(f"claude-event: --data must be KEY=VAL, got: {kv}", file=sys.stderr)
            return 2
        k, v = kv.split("=", 1)
        extra[k] = v

    QUEUE_DIR.mkdir(parents=True, exist_ok=True)

    now = time.time()
    event = {
        "timestamp": now,
        "timestamp_iso": time.strftime("%Y-%m-%dT%H:%M:%S%z", time.localtime(now)),
        "hostname": socket.gethostname(),
        "source": source,
        "source_name": args.source_name or os.environ.get("CRON_COMMAND", ""),
        "tag": args.tag,
        "priority": args.priority,
        "message": args.message,
        "data": extra,
        "pid": os.getpid(),
        "user": os.environ.get("USER", ""),
    }

    # Atomic write: tmp in same dir, then rename into place
    ts_ns = time.time_ns()
    safe_tag = "".join(c if c.isalnum() or c in "-_" else "_" for c in args.tag)[:40]
    final_name = f"{ts_ns}_{safe_tag}.json"
    final_path = QUEUE_DIR / final_name

    fd, tmp_path = tempfile.mkstemp(
        prefix=f".{final_name}.", suffix=".tmp", dir=str(QUEUE_DIR)
    )
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(event, f, indent=2)
            f.write("\n")
        os.replace(tmp_path, final_path)
    except Exception:
        try:
            os.unlink(tmp_path)
        except FileNotFoundError:
            pass
        raise

    print(str(final_path))
    return 0


def cmd_ls(_args: argparse.Namespace) -> int:
    """List pending events in the queue."""
    if not QUEUE_DIR.is_dir():
        print("0 pending events.")
        return 0

    events: list[tuple[float, str, str, str]] = []  # (timestamp, source, tag, message)
    for p in QUEUE_DIR.iterdir():
        if not p.name.endswith(".json") or p.name.startswith("."):
            continue
        try:
            with open(p) as f:
                ev = json.load(f)
            events.append((
                ev.get("timestamp", 0.0),
                ev.get("source", "unknown"),
                ev.get("tag", "unknown"),
                ev.get("message", ""),
            ))
        except (json.JSONDecodeError, OSError):
            continue

    if not events:
        print("0 pending events.")
        return 0

    events.sort(key=lambda e: e[0])
    now = time.time()
    for ts, source, tag, message in events:
        age = int(now - ts)
        print(f"EVENT[{source}/{tag}] {message} (age: {age}s)")
    print(f"\n{len(events)} pending event(s).")
    return 0


def cmd_count(_args: argparse.Namespace) -> int:
    """Print the number of pending events in the queue."""
    if not QUEUE_DIR.is_dir():
        print("0")
        return 0

    count = sum(
        1
        for p in QUEUE_DIR.iterdir()
        if p.name.endswith(".json") and not p.name.startswith(".")
    )
    print(str(count))
    return 0


def main() -> int:
    # Detect legacy invocation (via cron-event shim/symlink) and warn.
    invoked_as = os.path.basename(sys.argv[0])
    if invoked_as == "cron-event":
        print(
            "cron-event: DEPRECATED — please use `claude-event` instead. "
            "The old name is kept as a shim for backward compat.",
            file=sys.stderr,
        )

    ap = argparse.ArgumentParser(
        description="Emit events to (or inspect) the Claude event queue.",
    )
    sub = ap.add_subparsers(dest="subcommand")

    # --- emit (also the default when no subcommand given) ---
    emit_p = sub.add_parser("emit", help="Emit an event into the queue")
    emit_p.add_argument("message", help="Event message (arbitrary text)")
    emit_p.add_argument("--tag", default="generic", help="Short tag/category (default: generic)")
    emit_p.add_argument(
        "--priority",
        default="normal",
        choices=["low", "normal", "high", "urgent"],
        help="Priority hint for Claude (default: normal)",
    )
    emit_p.add_argument(
        "--data",
        action="append",
        default=[],
        metavar="KEY=VAL",
        help="Extra structured data (repeatable)",
    )
    emit_p.add_argument(
        "--source",
        default=None,
        help=(
            "Originating source type "
            "(cron|alertmanager|queue|torrent|security|claude-watch|manual). "
            "Defaults to 'cron' for backward compat."
        ),
    )
    emit_p.add_argument(
        "--source-name",
        default=os.environ.get("CLAUDE_EVENT_SOURCE_NAME", os.environ.get("CRON_EVENT_SOURCE", "")),
        help="Originating job/script name (defaults to $CLAUDE_EVENT_SOURCE_NAME)",
    )

    # --- ls ---
    sub.add_parser("ls", help="List pending events in the queue")

    # --- count ---
    sub.add_parser("count", help="Print number of pending events (for scripts)")

    # Backward compat: if the first positional arg is not a known subcommand,
    # treat the entire argv as an implicit "emit" invocation.
    known_subcommands = {"emit", "ls", "count"}
    if len(sys.argv) > 1 and sys.argv[1] not in known_subcommands and not sys.argv[1].startswith("-"):
        sys.argv.insert(1, "emit")

    args = ap.parse_args()

    if args.subcommand == "ls":
        return cmd_ls(args)
    elif args.subcommand == "count":
        return cmd_count(args)
    elif args.subcommand == "emit":
        return cmd_emit(args)
    else:
        ap.print_help()
        return 0


if __name__ == "__main__":
    sys.exit(main())
