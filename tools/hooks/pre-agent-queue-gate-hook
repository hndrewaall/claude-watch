#!/usr/bin/env python3
"""PreToolUse hook for the Agent/Task tool.

Enforces "STRONG" queue discipline (Andrew, 2026-04-24): every Agent tool
invocation MUST include a ``Queue item: q-XXXX`` marker in its prompt, AND
that queue id must exist with status == running. If not, we DENY the spawn
via the Claude Code hook permissionDecision protocol and present a banner
explaining the workflow.

Wiring (in ``~/.claude/settings.json``): point ``command`` at the installed
hook script (``$BIN_DIR/pre-agent-queue-gate-hook``, default
``~/bin/pre-agent-queue-gate-hook``)::

    {
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Agent",
            "hooks": [
              {
                "type": "command",
                "command": "/path/to/pre-agent-queue-gate-hook",
                "timeout": 5
              }
            ]
          }
        ]
      }
    }

Input: JSON on stdin with the standard Claude Code PreToolUse payload, e.g.::

    {
      "tool_name": "Agent",
      "tool_input": {
        "subagent_type": "general-purpose",
        "prompt": "...Queue item: q-2026-04-24-abcd...",
        ...
      },
      ...
    }

Decision protocol:

- Exit 0 with JSON ``{}`` to allow (silently). Any other tool than Agent/Task
  is a trivial allow.
- Exit 0 with ``hookSpecificOutput.permissionDecision == "deny"`` plus a
  ``systemMessage`` banner to block. Exit code stays 0; the *decision* field
  is what stops the tool.
- On any unexpected internal error, default-open (exit 0, empty output).
  Fail-closed would turn a hook bug into a full-agent outage.

Emergency bypass: set ``QUEUE_GATE_BYPASS=1`` in the environment. Bypass
events are logged to ``~/.config/claude/queue-gate-bypass.log`` for later
auditing.
"""

from __future__ import annotations

import datetime as _dt
import errno
import fcntl
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

# Match both 'Agent' (modern) and 'Task' (legacy) internal tool names. Andrew
# wrote "Agent" in the spec -- the matcher in settings.json is "Agent", but we
# also accept Task here so that if Claude Code ever reverts/renames we still
# enforce.
AGENT_TOOL_NAMES = {"Agent", "Task"}

# Queue id format from session-task: ``q-YYYY-MM-DD-xxxx`` (lowercase hex-ish
# suffix). We stay permissive: 'q-' + one or more allowed chars.
QUEUE_MARKER_RE = re.compile(r"Queue\s+item\s*:\s*(q-[0-9a-zA-Z][0-9a-zA-Z-]*)")

BYPASS_LOG_DIR = Path(os.path.expanduser("~/.config/claude"))
BYPASS_LOG_PATH = BYPASS_LOG_DIR / "queue-gate-bypass.log"

# Pending-spawns sidecar: written here at PreToolUse:Agent time so the
# `force_started_unspawned` obligations predicate can flip to satisfied
# immediately, without waiting for the once-a-minute claude-watch
# active-agents poller to refresh ``active-agents.json``. Path can be
# overridden via ``CLAUDE_PENDING_SPAWNS_PATH`` (used by the test suite
# to keep its writes out of /var/lib).
DEFAULT_PENDING_SPAWNS_PATH = Path("/var/lib/claude-watch/pending-spawns.json")
# Records older than this are pruned on every write. Matches the default
# `pending_spawn_max_age_secs` in the obligations predicate so a stale
# entry can never out-live what the predicate considers "fresh".
PENDING_SPAWN_PRUNE_AGE_SECS = 600


def _allow() -> dict:
    """Empty dict means 'no decision override' -> tool proceeds."""
    return {}


def _deny(reason: str, banner: str) -> dict:
    """Build a PreToolUse deny response.

    ``permissionDecision: deny`` blocks the tool. ``permissionDecisionReason``
    surfaces on the user side (and often in Claude's context). We also include
    ``systemMessage`` so the full banner lands verbatim in the transcript.
    """
    return {
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": "deny",
            "permissionDecisionReason": reason,
        },
        "systemMessage": banner,
    }


def _banner(specific_reason: str) -> str:
    return (
        "!! BLOCKED: Agent tool spawn without valid queue discipline\n"
        "!!\n"
        "!! Every Agent invocation MUST include a 'Queue item: q-XXXX' marker\n"
        "!! in its prompt, and that queue item must be status=running.\n"
        "!!\n"
        "!! Workflow:\n"
        "!!   1. session-task queue add \"desc\" --scope <scope> --summary \"...\"  ->  get id\n"
        "!!   2. session-task queue register <id>  ->  marks it running\n"
        "!!   3. Spawn agent with 'Queue item: q-XXXX' in the prompt\n"
        "!!   4. On completion: session-task queue done <id>\n"
        "!!\n"
        f"!! What was wrong: {specific_reason}\n"
        "!!\n"
        "!! Hook source: pre-agent-queue-gate-hook (claude-watch tools/hooks/)\n"
        "!! Emergency bypass: set QUEUE_GATE_BYPASS=1 env var (logs)"
    )


def _log_bypass(tool_name: str, prompt_preview: str) -> None:
    """Audit log for emergency bypass. Best-effort; swallow errors."""
    try:
        BYPASS_LOG_DIR.mkdir(parents=True, exist_ok=True)
        ts = _dt.datetime.now(_dt.timezone.utc).isoformat()
        with BYPASS_LOG_PATH.open("a", encoding="utf-8") as fh:
            fh.write(
                json.dumps(
                    {
                        "ts": ts,
                        "tool_name": tool_name,
                        "prompt_preview": prompt_preview[:200],
                        "pid": os.getpid(),
                    }
                )
                + "\n"
            )
        try:
            BYPASS_LOG_PATH.chmod(0o600)
        except OSError:
            pass
    except (OSError, ValueError):
        pass


def _pending_spawns_path() -> Path:
    """Resolve the pending-spawns sidecar path.

    Honours ``CLAUDE_PENDING_SPAWNS_PATH`` so tests (and any operator
    debugging) can redirect writes off ``/var/lib`` without root.
    """
    override = os.environ.get("CLAUDE_PENDING_SPAWNS_PATH", "").strip()
    if override:
        return Path(os.path.expanduser(override))
    return DEFAULT_PENDING_SPAWNS_PATH


def _record_pending_spawn(queue_id: str) -> None:
    """Upsert a pending-spawn record for ``queue_id``.

    Called from the hook AFTER all queue-discipline checks pass and the
    Agent spawn is about to be allowed through. Atomically writes the
    JSON via tmp-file + rename, with an fcntl lock against the parent
    dir to serialise concurrent writers (same hook running for two
    spawns in flight). Prunes any entries older than
    ``PENDING_SPAWN_PRUNE_AGE_SECS`` so the file size stays bounded.

    Best-effort: any failure (no permission to write the dir, lock
    contention beyond the timeout, etc.) is swallowed. The fallback is
    that the predicate will simply wait for claude-watch's active-agents
    poller to notice the spawned agent (up to ~60s). The hook MUST never
    block the spawn it has already approved.
    """
    path = _pending_spawns_path()
    try:
        path.parent.mkdir(parents=True, exist_ok=True)
    except OSError:
        # Can't even create the dir (e.g. /var/lib not writable); give up.
        return

    now_ts = int(time.time())
    new_entry = {
        "queue_id": queue_id,
        "registered_at": now_ts,
        "registered_at_iso": _dt.datetime.fromtimestamp(
            now_ts, tz=_dt.timezone.utc
        ).isoformat(),
        "pid": os.getpid(),
    }

    # Lock file in the same dir; lock-then-read-then-write keeps two
    # concurrent hook invocations from clobbering each other's records.
    lock_path = path.with_suffix(path.suffix + ".lock")
    lock_fh = None
    try:
        try:
            lock_fh = open(lock_path, "a+")
        except OSError:
            return
        try:
            fcntl.flock(lock_fh.fileno(), fcntl.LOCK_EX)
        except OSError:
            return

        # Read current state (default: empty list).
        existing: list[dict] = []
        if path.exists():
            try:
                raw = path.read_text(encoding="utf-8")
                if raw.strip():
                    data = json.loads(raw)
                    if isinstance(data, dict):
                        existing = list(data.get("pending", []))
                    elif isinstance(data, list):
                        existing = list(data)
            except (OSError, json.JSONDecodeError, ValueError):
                # Corrupt file: start fresh. We do not propagate the
                # error -- the spawn must proceed regardless.
                existing = []

        # Prune stale entries + any prior record for this same queue_id
        # (we replace, not append, so a re-spawn refreshes the timestamp).
        cutoff = now_ts - PENDING_SPAWN_PRUNE_AGE_SECS
        kept: list[dict] = []
        for e in existing:
            if not isinstance(e, dict):
                continue
            if e.get("queue_id") == queue_id:
                continue
            try:
                reg_at = int(e.get("registered_at", 0))
            except (TypeError, ValueError):
                continue
            if reg_at >= cutoff:
                kept.append(e)
        kept.append(new_entry)

        out_obj = {"pending": kept}
        tmp_path = path.with_suffix(path.suffix + ".tmp")
        try:
            tmp_path.write_text(
                json.dumps(out_obj, indent=2, sort_keys=True) + "\n",
                encoding="utf-8",
            )
            os.replace(str(tmp_path), str(path))
        except OSError:
            # Atomic write failed: drop the tmp file if it's there.
            try:
                tmp_path.unlink()
            except OSError as unlink_exc:
                if unlink_exc.errno != errno.ENOENT:
                    pass
            return
    finally:
        if lock_fh is not None:
            try:
                fcntl.flock(lock_fh.fileno(), fcntl.LOCK_UN)
            except OSError:
                pass
            try:
                lock_fh.close()
            except OSError:
                pass


def _queue_status(queue_id: str) -> tuple[str | None, bool]:
    """Return (status, found) for a queue item id.

    ``found=False`` means session-task queue show could not locate it.
    ``status`` is None when not found or when the JSON lacked a 'status' field.
    """
    try:
        proc = subprocess.run(
            ["session-task", "queue", "show", queue_id],
            capture_output=True,
            text=True,
            timeout=4,
            check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        # Tool missing or hung. Default-open: don't let a broken environment
        # block every Agent spawn.
        return (None, False)

    if proc.returncode != 0:
        return (None, False)

    try:
        data = json.loads(proc.stdout)
    except (json.JSONDecodeError, ValueError):
        return (None, False)

    if not isinstance(data, dict):
        return (None, False)

    status = data.get("status")
    if isinstance(status, str):
        return (status, True)
    return (None, True)


def main() -> int:
    # Read stdin payload.
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        # Malformed / empty stdin: default-open.
        print(json.dumps(_allow()))
        return 0

    if not isinstance(payload, dict):
        print(json.dumps(_allow()))
        return 0

    tool_name = payload.get("tool_name", "")
    if tool_name not in AGENT_TOOL_NAMES:
        # Some other tool -- not our concern. Should not happen if settings.json
        # matcher is "Agent", but defend in depth.
        print(json.dumps(_allow()))
        return 0

    tool_input = payload.get("tool_input", {})
    if not isinstance(tool_input, dict):
        tool_input = {}

    prompt = tool_input.get("prompt", "")
    if not isinstance(prompt, str):
        prompt = ""

    # Emergency bypass. Documented in CLAUDE.md.
    if os.environ.get("QUEUE_GATE_BYPASS", "").strip() not in ("", "0"):
        _log_bypass(tool_name, prompt)
        print(json.dumps(_allow()))
        return 0

    # --- Enforcement starts here ---

    match = QUEUE_MARKER_RE.search(prompt)
    if not match:
        reason = "no 'Queue item: q-XXXX' marker found in the Agent prompt"
        print(json.dumps(_deny(reason, _banner(reason))))
        return 0

    queue_id = match.group(1)
    status, found = _queue_status(queue_id)

    if not found:
        reason = (
            f"queue id {queue_id!r} not found via "
            "`session-task queue show` (did you forget `queue add`?)"
        )
        print(json.dumps(_deny(reason, _banner(reason))))
        return 0

    if status != "running":
        reason = (
            f"queue id {queue_id!r} status is {status!r}, expected 'running' "
            "(run `session-task queue register <id>` before spawning)"
        )
        print(json.dumps(_deny(reason, _banner(reason))))
        return 0

    # Valid marker + running status -> allow. Record a pending-spawn
    # entry so the `force_started_unspawned` obligations predicate sees
    # this dispatch immediately, without waiting for claude-watch's
    # once-a-minute active-agents poller. Best-effort: failures here
    # are swallowed inside the helper.
    _record_pending_spawn(queue_id)
    print(json.dumps(_allow()))
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:  # noqa: BLE001  -- last-ditch default-open
        try:
            sys.stderr.write(f"pre-agent-queue-gate-hook: unexpected error: {exc}\n")
        except OSError:
            pass
        # Default-open on any crash so a hook bug never silences the whole
        # Agent tool.
        print("{}")
        sys.exit(0)
