#!/usr/bin/env python3
"""Tests for pre-tool-obligations-gate-hook + post-tool-obligations-update-hook
+ the underlying obligations CLI.

Test cases (PreToolUse):
  1. No obligations             -> all tools allowed
  2. file_mtime_within fresh    -> allowed
  3. file_mtime_within stale    -> denied with banner
  4. Expired obligation (TTL)   -> not enforced (should allow + auto-prune)
  5. OBLIGATIONS_BYPASS=1       -> allowed even when predicate fails
  6. no_pipe_pattern matching   -> denied
  7. no_pipe_pattern non-match  -> allowed
  8. PostToolUse satisfies      -> next PreToolUse passes
  9. Malformed stdin            -> default-open
 10. Non-Bash tool with no_pipe -> allowed (predicate is N/A for non-Bash)
 11. Banner content sanity      -> contains expected workflow hints
 12. process_alive PID 1 alive  -> allowed
 13. process_alive dead PID     -> denied
 14. process_alive missing file -> denied
 15. process_alive garbage      -> denied (non-integer)
 16. process_in_pgrep matches   -> allowed
 17. process_in_pgrep no match  -> denied
 18. inform-mode never gates    -> allow even when predicate would fail
 19. inform-mode + post-hook    -> failing predicate surfaces on stderr
 20. inform-mode + healthy pred -> post-hook stays silent
 21. watchers_healthy w/no CLI  -> default-open (silent, no banner)
 22. no_pending_watcher_outputs no sidecars -> allow
 23. no_pending_watcher_outputs sidecar w/ written output -> deny w/ path in why
 24. no_pending_watcher_outputs sidecar w/ empty output -> allow
 25. no_pending_watcher_outputs stale sidecar (output gone) -> auto-clean + allow
 26. Read of sidecar output path clears sidecar -> next non-exempt tool allowed
 27. Exempt: Bash:^watcher-ctl bypasses gate even with unread sidecar
 28. Exempt: Bash:^pgrep bypasses gate even with unread sidecar
 29. Exempt: Read tool bypasses gate even with unread sidecar
 30. Sidecar-write on Bash + run_in_background + watcher-ctl run -> sidecar appears
 30a. exempt_command_patterns absent -> watcher-ctl sidecar still gates (baseline)
 30b. exempt_command_patterns matches watcher-ctl -> sidecar skipped, predicate allows
 30c. exempt_command_patterns doesn't skip non-matching sidecars (regression guard)
 30d. exempt_command_patterns empty list -> no filtering (deny)
 31. is_main_loop predicate alone: main-loop (no agent_id) -> allow
 32. is_main_loop predicate alone: subagent (agent_id present) -> deny
 32b. is_main_loop predicate: empty-string agent_id -> allow (treated as main loop)
 33. is_main_loop {negate: true} alone: subagent -> allow, main-loop -> deny
 34. all_of [is_main_loop, file_exists(missing)]: subagent -> ALLOW (scope-guard skip)
 35. all_of [is_main_loop, file_exists(missing)]: main-loop -> deny (file_exists fails, no skip)
 36. all_of [is_main_loop, file_exists(present)]: main-loop -> allow (both pass)
 37. all_of []: trivially satisfied -> allow
 38. all_of [is_main_loop, X(failing)] inform: subagent post-hook -> silent (scope-guard skip)
 39. all_of [is_main_loop, X(failing)] inform: main-loop post-hook -> banner present
 40. all_of with one non-is_main_loop failing child + main-loop -> deny
 41. all_of unknown child kind -> default-open allow
 45. exempt_patterns: matching exempt_pattern bypasses gate even when predicate fails
 46. exempt_patterns: non-matching call still gated
 47. exempt_patterns: multiple patterns, second one matches
 48. exempt_patterns: inform-mode also honors exempt_patterns
 49. override: active override bypasses ALL gate-mode obligations
 50. override: expired override does NOT bypass (TTL respected)
 51. override: cancelled-via-satisfy does NOT bypass
 52. override: invalid duration / empty reason rejected with exit 2
 53. override: 24h cap enforced
 54. override: bypass is audited to obligations-bypass.log
 55. override: shows in `obligations list` output
 56. override: does NOT silence inform-mode advisories
 57. state-aware recovery: DUPLICATE in why -> watcher-restart suggested
 58. state-aware recovery: DOWN-only in why -> watcher-ctl run <name> suggested
 59. state-aware recovery: mixed DOWN + DUPLICATE -> DUPLICATE wins
 60. state-aware recovery: non-watcher why text -> no recovery line (None)
 61. end-to-end: DUPLICATE deny banner contains watcher-restart line
 62. watcher-ctl gate: bare `watcher-ctl run X` -> allow
 63. watcher-ctl gate: bare `watcher-ctl run X 2>&1` -> allow
 64. watcher-ctl gate: trailing `2>&1 &` -> deny + cardinal banner
 65. watcher-ctl gate: trailing `&` -> deny
 66. watcher-ctl gate: `;` separator -> deny
 67. watcher-ctl gate: two bg watcher-ctls in one command -> deny
 68. watcher-ctl gate: `watcher-restart` -> allow (gate inert)
 69. watcher-ctl gate: unrelated `ls` -> allow (gate inert)
 70. watcher-ctl gate: pipe `|` -> deny
 71. watcher-ctl gate: `&&` compound -> deny
 72. watcher-ctl gate: subshell `$()` -> deny
 73. watcher-ctl gate: OBLIGATIONS_BYPASS=1 forces allow
 74. watcher-ctl gate: Bash-only (Read tool with watcher-text path -> allow)
 74a. Monitor gate: subagent + Monitor -> deny with educational banner
 74b. Monitor gate: main-loop + Monitor (no agent_id) -> allow
 74c. Monitor gate: main-loop + Monitor (empty agent_id) -> allow
 74d. Monitor gate: whitespace-only agent_id -> allow (treated as main-loop)
 74e. Monitor gate: subagent + Bash -> allow (only Monitor gated)
 74f. Monitor gate: subagent + Read -> allow
 74g. Monitor gate: OBLIGATIONS_BYPASS=1 forces allow
 74h. Monitor gate: null agent_id -> allow (defensive coerce)
 75. stale_ready_queue_present: empty queue -> allow
 76. stale_ready_queue_present: queue file missing -> allow (default-open)
 77. stale_ready_queue_present: malformed queue.json -> allow (default-open)
 78. stale_ready_queue_present: ready+pending fresh (1 min) -> allow
 79. stale_ready_queue_present: ready+pending stale (10 min) -> deny + ids in why
 80. stale_ready_queue_present: status=running not counted -> allow
 81. stale_ready_queue_present: blocked-pending (running peer in group) -> allow
 82. stale_ready_queue_present: non-head pending in group -> allow
 83. stale_ready_queue_present: custom threshold honored
 84. stale_ready_queue_present: multiple stale items -> all named, oldest first
 85. stale_ready_queue_present: exempt Agent allows even when stale present
 86. stale_ready_queue_present: exempt session-task queue register allows
 87. stale_ready_queue_present: scope-guard subagent bypasses (all_of with is_main_loop)
 88. stale_ready_queue_present: auto-mandatory refuses override (exit 4)
 89. override: pingme called when override created
 90. override: pingme suppressed by OBLIGATIONS_DISABLE_PINGME=1
 91. universal recovery: `obligations override` allowed even with row-level deny
 92. universal recovery: `session-task queue register` allowed past arbitrary deny
 93. universal recovery: Read of tasks/<id>.output allowed past arbitrary deny
 94. universal recovery: Agent allowed past arbitrary deny
 95. universal recovery: watcher-restart allowed past arbitrary deny
 96. universal recovery: deadlock scenario (c834 + bedb shape) -- recovery passes
 97. universal recovery property: every concurrently-fired obligation pair must
     leave the universal recovery surface allowed (smoke test against the
     three currently-deployed long-lived obligations + stale_ready)
 98. inform-mode: universal recovery suppresses inform advisories too
110. obligations add --mandatory persists the flag in state
111. override against an explicitly --mandatory row -> exit 4 + MANDATORY
112. override against a non-mandatory row still works (regression)
113. stale_ready_queue_present is AUTO-MANDATORY (no --mandatory flag);
     persisted as mandatory + override refused
114. nested all_of[is_main_loop, stale_ready_queue_present] inherits
     auto-mandatory + override refused (production cron shape)
115. cron-queue-check parity: production add invocation
     yields a mandatory row; override refused
116. subagent_queue_item_running: q-id running -> allow
117. subagent_queue_item_running: q-id done -> deny + named
118. subagent_queue_item_running: q-id abandoned -> deny
119. subagent_queue_item_running: q-id missing from queue -> deny
120. subagent_queue_item_running: binding file missing -> allow (default-open)
121. subagent_queue_item_running: corrupt bindings -> allow (default-open)
122. subagent_queue_item_running: main-loop call -> allow (scope-guard skip)
123. subagent_queue_item_running: no entry for this agent -> allow
124. end-to-end: arm-hook -> bind -> queue=running allow -> queue=done deny
125. evaluator (exit_code): cmd returns 0 -> allow
126. evaluator (exit_code): cmd returns 1 -> deny + stderr in reason
127. evaluator (exit_code): allow_on_zero_exit=false flips polarity
128. evaluator (stdout_pattern): stdout matches allow_pattern -> allow
129. evaluator (stdout_pattern): stdout matches deny_pattern -> deny
130. evaluator (stdout_pattern): neither pattern matches -> default-open allow
131. evaluator: subprocess timeout -> allow + audit log
132. evaluator: cmd not found -> allow + audit log
133. evaluator: missing cmd config -> allow + audit log
134. evaluator: invalid allow_pattern regex -> allow + audit log
135. evaluator: unknown decision_mode -> allow + audit log
136. evaluator: stdin_field=tool_input.command pipes command to evaluator
137. evaluator: deny banner / reason carries evaluator stderr verbatim
138. evaluator end-to-end: PreToolUse gate denies when evaluator says deny
139. evaluator: OBLIGATIONS_BYPASS=1 forces allow past evaluator deny
140. evaluator: argv list cmd form works (no shell)
141. evaluator: env param merged into subprocess environment

Each test uses a SEPARATE OBLIGATIONS_FILE path (not the live ~/.config/claude/
one) by overriding via environment + an isolated state dir, so we never touch
the user's real obligations.
"""

from __future__ import annotations

import json
import os
import secrets
import subprocess
import sys
import tempfile
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
HOOKS_DIR = HERE.parent
TOOLS_DIR = HOOKS_DIR.parent
PRE_HOOK = HOOKS_DIR / "pre-tool-obligations-gate-hook"
POST_HOOK = HOOKS_DIR / "post-tool-obligations-update-hook"
CLI = TOOLS_DIR / "obligations" / "obligations"


# We isolate the obligations file by setting HOME to a tmpdir for test runs,
# so the script's hardcoded ~/.config/claude/obligations.json points into the
# scratch dir. (The hooks resolve the CLI via PATH or fallback to a known
# absolute path; we'll prepend the scratch HOME-aware bin dir to PATH.)


def _make_isolated_env(tmpdir: Path):
    """Return env dict + obligations_path for a sandboxed run."""
    env = os.environ.copy()
    env["HOME"] = str(tmpdir)
    # Ensure both the obligations CLI and any sibling tools (e.g.
    # session-task) are findable on PATH. The hook's CLI-resolution path
    # falls back to the in-repo sibling, but the test exercises the
    # PATH-resolved happy path.
    obligations_dir = TOOLS_DIR / "obligations"
    session_task_dir = TOOLS_DIR / "session-task"
    env["PATH"] = (f"{obligations_dir}:{session_task_dir}:"
                   f"{env.get('PATH','')}")
    obligations_path = tmpdir / ".config" / "claude" / "obligations.json"
    return env, obligations_path


def _run(cmd, env, *, stdin=None, timeout=10):
    return subprocess.run(
        cmd, capture_output=True, text=True,
        timeout=timeout, env=env, check=False, input=stdin,
    )


def _add_ob(env, *, tool_pattern, predicate, params, ttl, deny_msg,
            satisfied_by_tool=None, satisfied_by_cmd_regex=None,
            enforcement=None, exempt_tool_patterns=None):
    args = [
        str(CLI), "add",
        "--tool-pattern", tool_pattern,
        "--predicate", predicate,
        "--params", json.dumps(params),
        "--ttl", str(ttl),
        "--deny-msg", deny_msg,
        "--created-by", "test",
        "--json",
    ]
    if enforcement:
        args += ["--enforcement", enforcement]
    if satisfied_by_tool:
        args += ["--satisfied-by-tool", satisfied_by_tool]
    if satisfied_by_cmd_regex:
        args += ["--satisfied-by-cmd-regex", satisfied_by_cmd_regex]
    for pat in (exempt_tool_patterns or []):
        args += ["--exempt-tool-pattern", pat]
    proc = _run(args, env)
    if proc.returncode != 0:
        raise RuntimeError(f"add failed rc={proc.returncode} stderr={proc.stderr}")
    return json.loads(proc.stdout)["id"]


def _add_override(env, reason, duration, created_by="test"):
    proc = _run([
        str(CLI), "override", reason,
        "--duration", str(duration),
        "--created-by", created_by,
        "--json",
    ], env)
    if proc.returncode != 0:
        raise RuntimeError(f"override add failed rc={proc.returncode} "
                           f"stderr={proc.stderr}")
    return json.loads(proc.stdout)["id"]


def _hook_pre(payload: dict, env: dict, extra_env=None):
    e = env.copy()
    if extra_env:
        e.update(extra_env)
    proc = _run([str(PRE_HOOK)], e, stdin=json.dumps(payload))
    try:
        out = json.loads(proc.stdout) if proc.stdout.strip() else {}
    except json.JSONDecodeError:
        out = {"__raw__": proc.stdout}
    return proc.returncode, out, proc.stderr


def _hook_post(payload: dict, env: dict):
    proc = _run([str(POST_HOOK)], env, stdin=json.dumps(payload))
    return proc.returncode, proc.stdout, proc.stderr


def _is_deny(out: dict) -> bool:
    hso = out.get("hookSpecificOutput") or {}
    return hso.get("permissionDecision") == "deny"


def _is_allow(out: dict) -> bool:
    return not _is_deny(out)


def _check(name: str, cond: bool, detail: str = "") -> bool:
    if cond:
        print(f"  PASS  {name}")
        return True
    print(f"  FAIL  {name}  {detail}")
    return False


def main() -> int:
    if not PRE_HOOK.exists():
        print(f"ERROR: pre-hook not found at {PRE_HOOK}")
        return 1
    if not POST_HOOK.exists():
        print(f"ERROR: post-hook not found at {POST_HOOK}")
        return 1
    if not CLI.exists():
        print(f"ERROR: CLI not found at {CLI}")
        return 1

    results: list[bool] = []

    with tempfile.TemporaryDirectory(prefix="obligations-test-") as td:
        tmpdir = Path(td)
        env, obligations_path = _make_isolated_env(tmpdir)

        print(f"=== Sandbox: {tmpdir} ===")
        print(f"=== Obligations file: {obligations_path} ===")

        # --- Test 1: no obligations -> allow ---
        payload = {"tool_name": "Bash", "tool_input": {"command": "ls"}}
        rc, out, _err = _hook_pre(payload, env)
        results.append(_check(
            "1. no obligations -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 2: fresh file_mtime_within -> allow ---
        marker = tmpdir / "fresh-marker"
        marker.write_text("hi")  # mtime=now
        ob_fresh = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_mtime_within",
            params={"path": str(marker), "max_age_secs": 60},
            ttl=120,
            deny_msg="marker stale",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "2. fresh file_mtime_within -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 3: stale file_mtime_within -> deny ---
        # Backdate the marker so the predicate fails.
        old = time.time() - 7200
        os.utime(marker, (old, old))
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "3. stale file_mtime_within -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))

        # Clean up #2/#3
        _run([str(CLI), "satisfy", ob_fresh], env)

        # --- Test 4: TTL-expired obligation should be ignored ---
        # ttl=1: obligation expires almost immediately. Sleep 2s, then
        # confirm a Bash call is allowed (predicate never even checked).
        marker2 = tmpdir / "marker-2"  # nonexistent path, would fail file_exists
        ob_ttl = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(marker2)},
            ttl=1,
            deny_msg="marker missing",
        )
        time.sleep(2)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "4. expired-by-TTL obligation is not enforced",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        # Best-effort cleanup (may already be auto-pruned)
        _run([str(CLI), "satisfy", ob_ttl], env)

        # --- Test 5: bypass env var ---
        marker3 = tmpdir / "marker-3"  # also nonexistent
        ob_bypass = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(marker3)},
            ttl=120,
            deny_msg="bypass test marker missing",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
            extra_env={"OBLIGATIONS_BYPASS": "1"},
        )
        results.append(_check(
            "5. OBLIGATIONS_BYPASS=1 forces allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_bypass], env)

        # --- Test 6: no_pipe_pattern matching | tail -10 -> deny ---
        ob_pipe = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="no_pipe_pattern",
            params={"regex": r"\|\s*(tail|head)\s+-"},
            ttl=0,  # non-expiring
            deny_msg="don't pipe to tail/head",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "cat foo.json | tail -10"}}, env,
        )
        results.append(_check(
            "6. no_pipe_pattern matches tail -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 7: no_pipe_pattern non-match -> allow ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "ls -la /tmp"}}, env,
        )
        results.append(_check(
            "7. no_pipe_pattern non-match -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 10: non-Bash tool with no_pipe_pattern -> allow ---
        # (we'll do this BEFORE deleting ob_pipe to keep the regex installed)
        rc, out, _err = _hook_pre(
            {"tool_name": "Read",
             "tool_input": {"file_path": "/some/path | tail -10"}}, env,
        )
        results.append(_check(
            "10. no_pipe_pattern N/A for non-Bash tool -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 11: banner sanity ---
        # Re-trigger #6 and inspect banner
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "cat foo | tail -3"}}, env,
        )
        banner = (out or {}).get("systemMessage", "")
        wanted = ("BLOCKED", "obligations", "OBLIGATIONS_BYPASS",
                  "obligations list", "obligations satisfy")
        results.append(_check(
            "11. denial banner contains workflow hints",
            all(s in banner for s in wanted),
            f"banner={banner!r}",
        ))
        _run([str(CLI), "satisfy", ob_pipe], env)

        # --- Test 8: PostToolUse auto-satisfies ---
        # Set up a marker_file_present obligation that requires the SIGNAL
        # marker file (some path in the sandbox), with satisfied_by matching
        # a Bash command "watcher-restart". Pre-hook denies, post-hook
        # satisfies, pre-hook now allows.
        marker_path = tmpdir / "wch-restart-marker"
        ob_sat = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="marker_file_present",
            params={"path": str(marker_path)},  # does not exist
            ttl=600,
            deny_msg="must restart watcher first",
            satisfied_by_tool="Bash",
            satisfied_by_cmd_regex=r"^watcher-restart\b",
        )
        # Pre-hook should deny because marker missing
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "signal-send hi"}},
            env,
        )
        denied_first = (rc == 0 and _is_deny(out))
        # Now run the post-hook for a Bash command matching the satisfied_by
        rc, _stdout, _err = _hook_post(
            {"tool_name": "Bash",
             "tool_input": {"command": "watcher-restart signal"}}, env,
        )
        # Re-run pre-hook -- should now allow because the obligation was removed
        rc2, out2, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "signal-send hi"}},
            env,
        )
        allowed_after = (rc2 == 0 and _is_allow(out2))
        results.append(_check(
            "8. PostToolUse auto-satisfies obligation",
            denied_first and allowed_after,
            f"denied_first={denied_first} allowed_after={allowed_after} "
            f"first_out={out} after_out={out2}",
        ))
        # Cleanup -- ob_sat is gone already; defensive
        _run([str(CLI), "satisfy", ob_sat], env)

        # --- Test 12: process_alive with PID 1 (init -- always alive) -> allow ---
        pid_file_alive = tmpdir / "alive.pid"
        pid_file_alive.write_text("1\n")
        ob_alive = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_alive",
            params={"pid_file": str(pid_file_alive)},
            ttl=120,
            deny_msg="watcher must be running",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "12. process_alive with live PID -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_alive], env)

        # --- Test 13: process_alive with a dead PID -> deny ---
        pid_file_dead = tmpdir / "dead.pid"
        # Find a PID that's almost certainly not running. Try a high number.
        # Sanity-check: if /proc/999999 exists, fall back to a different one.
        dead_pid = 999999
        while os.path.isdir(f"/proc/{dead_pid}"):
            dead_pid += 1
        pid_file_dead.write_text(f"{dead_pid}\n")
        ob_dead = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_alive",
            params={"pid_file": str(pid_file_dead)},
            ttl=120,
            deny_msg="watcher dead -- restart it",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "13. process_alive with dead PID -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_dead], env)

        # --- Test 14: process_alive with missing pid_file -> deny ---
        pid_file_missing = tmpdir / "nonexistent.pid"
        ob_missing = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_alive",
            params={"pid_file": str(pid_file_missing)},
            ttl=120,
            deny_msg="watcher pid_file missing",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "14. process_alive with missing pid_file -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_missing], env)

        # --- Test 15: process_alive with garbage pid_file -> deny ---
        pid_file_garbage = tmpdir / "garbage.pid"
        pid_file_garbage.write_text("not-a-pid\n")
        ob_garbage = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_alive",
            params={"pid_file": str(pid_file_garbage)},
            ttl=120,
            deny_msg="watcher pid_file is garbage",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "15. process_alive with garbage pid_file -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_garbage], env)

        # --- Test 16: process_in_pgrep that matches the running test -> allow ---
        # The test process itself is python3 running this file.
        # Use 'python3' or an even more specific marker -- our own basename
        # is in the pgrep -f surface area for the test process.
        ob_pgrep_ok = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_in_pgrep",
            # match the basename of this test script (definitely running)
            params={"pattern": Path(__file__).name},
            ttl=120,
            deny_msg="(should not fire)",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "16. process_in_pgrep matching pattern -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_pgrep_ok], env)

        # --- Test 17: process_in_pgrep with a no-match pattern -> deny ---
        ob_pgrep_miss = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_in_pgrep",
            params={"pattern": "definitely-not-a-real-process-zzzzzz-xyzzy-12345"},
            ttl=120,
            deny_msg="watcher process not running",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "17. process_in_pgrep with no-match pattern -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_pgrep_miss], env)

        # --- Test 18: inform-mode never gates a tool call ---
        # Use a predicate guaranteed to fail (file_exists on a missing path).
        # In gate mode this would deny; in inform mode the PreToolUse hook
        # MUST allow.
        absent = tmpdir / "definitely-not-here"
        ob_inform_fail = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(absent)},
            ttl=120,
            enforcement="inform",
            deny_msg="(inform-only -- should never block)",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "18. inform-mode never gates -> allow even when predicate fails",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 19: inform-mode + post-hook surfaces failure on stderr ---
        # The same failing inform obligation should produce a stderr banner
        # when the PostToolUse hook runs.
        rc, _stdout, err = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "19. inform-mode + failing predicate -> post-hook prints stderr",
            rc == 0 and "[obligations:inform]" in err and ob_inform_fail in err,
            f"rc={rc} err={err!r}",
        ))
        _run([str(CLI), "satisfy", ob_inform_fail], env)

        # --- Test 20: inform-mode + healthy predicate -> post-hook silent ---
        present = tmpdir / "i-exist"
        present.write_text("yes")
        ob_inform_ok = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(present)},
            ttl=120,
            enforcement="inform",
            deny_msg="(should not surface)",
        )
        rc, _stdout, err = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "20. inform-mode + healthy predicate -> post-hook silent",
            rc == 0 and "[obligations:inform]" not in err,
            f"rc={rc} err={err!r}",
        ))
        _run([str(CLI), "satisfy", ob_inform_ok], env)

        # --- Test 21: watchers_healthy default-open when CLI missing ---
        # We strip every directory containing watcher-status from PATH so the
        # predicate can't resolve it via shutil.which. We also need /usr/bin
        # / /bin etc. on PATH because the obligations CLI runs through
        # `/usr/bin/env python3`. Our HOME override (tmpdir) means
        # ~/bin/watcher-status (a fallback path the predicate probes) also
        # resolves into the sandbox and doesn't exist.
        env_no_watcher = env.copy()
        sanitized = []
        for p in env.get("PATH", "").split(os.pathsep):
            if not p:
                continue
            if os.path.exists(os.path.join(p, "watcher-status")):
                continue
            sanitized.append(p)
        env_no_watcher["PATH"] = os.pathsep.join(sanitized)
        ob_wh_gate = _add_ob(
            env_no_watcher,
            tool_pattern="Bash",
            predicate="watchers_healthy",
            params={},
            ttl=120,
            deny_msg="watcher gate (should not fire when CLI missing)",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env_no_watcher,
        )
        gate_open = (rc == 0 and _is_allow(out))
        _run([str(CLI), "satisfy", ob_wh_gate], env_no_watcher)

        ob_wh_inform = _add_ob(
            env_no_watcher,
            tool_pattern="Bash",
            predicate="watchers_healthy",
            params={},
            ttl=120,
            enforcement="inform",
            deny_msg="watcher inform (should not surface when CLI missing)",
        )
        rc, _stdout, err = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env_no_watcher,
        )
        inform_silent = (rc == 0 and "[obligations:inform]" not in err)
        _run([str(CLI), "satisfy", ob_wh_inform], env_no_watcher)
        results.append(_check(
            "21. watchers_healthy without CLI -> default-open silent",
            gate_open and inform_silent,
            f"gate_open={gate_open} inform_silent={inform_silent} err={err!r}",
        ))

        # ===== no_pending_watcher_outputs predicate tests =====
        # We isolate the sidecar dir per-test by setting WATCHER_PENDING_DIR
        # to a tmpdir-relative path, picked up by both the obligations CLI
        # and the post-tool hook (both have a _watcher_pending_dir() that
        # consults this env var first).
        sidecar_dir = tmpdir / "watcher-output-pending"
        env_npwo = env.copy()
        env_npwo["WATCHER_PENDING_DIR"] = str(sidecar_dir)

        # Register the gate. tool_pattern '*' so it tries to fire for every
        # tool; the predicate's exemption logic guards the recovery paths.
        ob_npwo = _add_ob(
            env_npwo,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={},
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )

        def _write_sidecar(task_id: str, output_path: Path,
                           registered_at: float | None = None) -> Path:
            sidecar_dir.mkdir(parents=True, exist_ok=True)
            sc = {
                "task_id": task_id,
                "command": f"watcher-ctl run sample-{task_id}",
                "watcher_name": f"sample-{task_id}",
                "output_file_path": str(output_path),
                "registered_at": registered_at if registered_at is not None else time.time(),
            }
            sp = sidecar_dir / f"{task_id}.json"
            sp.write_text(json.dumps(sc))
            return sp

        # --- Test 22: no sidecars -> allow ---
        # Make sure the sidecar dir is empty.
        if sidecar_dir.exists():
            for f in sidecar_dir.iterdir():
                f.unlink()
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        results.append(_check(
            "22. no_pending_watcher_outputs no sidecars -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 23: sidecar with written output -> deny ---
        out_file = tmpdir / "captured-1.output"
        registered = time.time() - 10  # 10 seconds ago
        out_file.write_text("watcher fired with content\n")
        # Bump mtime to NOW (definitely after registered_at).
        os.utime(out_file, (time.time(), time.time()))
        sc1 = _write_sidecar("bsidecar1", out_file, registered_at=registered)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        why_in_banner = (
            "unread watcher output" in (out.get("systemMessage", "") or "")
            and str(out_file) in (out.get("systemMessage", "") or "")
        )
        results.append(_check(
            "23. no_pending_watcher_outputs unread output -> deny w/ path",
            rc == 0 and _is_deny(out) and why_in_banner,
            f"rc={rc} out={out}",
        ))

        # --- Test 24: sidecar with empty output -> allow ---
        # Replace with an empty file (size 0).
        sc1.unlink()
        empty_out = tmpdir / "empty-out.output"
        empty_out.write_text("")
        sc2 = _write_sidecar("bsidecar2", empty_out, registered_at=time.time() - 10)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        results.append(_check(
            "24. no_pending_watcher_outputs empty output -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 25: stale sidecar (output file deleted) -> auto-clean + allow ---
        sc2.unlink()
        gone_out = tmpdir / "gone.output"
        # write the sidecar pointing at a path that does NOT exist
        sc3 = _write_sidecar("bsidecar3", gone_out, registered_at=time.time() - 10)
        # confirm the output file truly does not exist
        if gone_out.exists():
            gone_out.unlink()
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        # The predicate should auto-clean the stale sidecar AND allow.
        sidecar_gone = not sc3.exists()
        results.append(_check(
            "25. no_pending_watcher_outputs stale sidecar -> auto-clean + allow",
            rc == 0 and _is_allow(out) and sidecar_gone,
            f"rc={rc} out={out} sidecar_gone={sidecar_gone}",
        ))

        # --- Test 26: Read of sidecar output path clears sidecar ---
        # Re-create an unread sidecar, then PostToolUse hook for a Read of
        # the output path -> sidecar should be deleted -> next non-exempt
        # tool should be allowed.
        out_file2 = tmpdir / "captured-26.output"
        out_file2.write_text("more output\n")
        os.utime(out_file2, (time.time(), time.time()))
        sc4 = _write_sidecar("bsidecar4", out_file2, registered_at=time.time() - 10)
        # First confirm the gate fires (deny).
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        denied_before_read = (rc == 0 and _is_deny(out))
        # Now simulate Reading the output via PostToolUse hook.
        rc, _stdout, _err = _hook_post(
            {"tool_name": "Read",
             "tool_input": {"file_path": str(out_file2)}}, env_npwo,
        )
        sidecar_cleared = not sc4.exists()
        # And the next non-exempt tool should now be allowed.
        rc2, out2, _err2 = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_npwo,
        )
        allowed_after_read = (rc2 == 0 and _is_allow(out2))
        results.append(_check(
            "26. Read of sidecar output path -> sidecar cleared, next tool allowed",
            denied_before_read and sidecar_cleared and allowed_after_read,
            f"denied_before={denied_before_read} sidecar_cleared={sidecar_cleared} "
            f"allowed_after={allowed_after_read} out_before={out} out_after={out2}",
        ))

        # --- Test 27: Bash:^watcher-ctl exempt even with unread sidecar ---
        # Re-create an unread sidecar and confirm watcher-ctl is allowed.
        out_file3 = tmpdir / "captured-27.output"
        out_file3.write_text("yet more\n")
        os.utime(out_file3, (time.time(), time.time()))
        sc5 = _write_sidecar("bsidecar5", out_file3, registered_at=time.time() - 10)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "watcher-ctl run signal-wait-dm"}}, env_npwo,
        )
        results.append(_check(
            "27. Bash:^watcher-ctl exempt -> allow even with unread sidecar",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 28: Bash:^pgrep exempt even with unread sidecar ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "pgrep -f signal-wait-dm"}}, env_npwo,
        )
        results.append(_check(
            "28. Bash:^pgrep exempt -> allow even with unread sidecar",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 29: Read tool exempt even with unread sidecar ---
        # (Read tool needs to be the satisfier path; gating it would deadlock.)
        rc, out, _err = _hook_pre(
            {"tool_name": "Read",
             "tool_input": {"file_path": "/tmp/anything"}}, env_npwo,
        )
        results.append(_check(
            "29. Read tool exempt -> allow even with unread sidecar",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        # Cleanup the test 27/28/29 sidecar so it doesn't leak.
        if sc5.exists():
            sc5.unlink()
        # Done with the npwo gate.
        _run([str(CLI), "satisfy", ob_npwo], env_npwo)

        # --- Test 30: PostToolUse on Bash + run_in_background + watcher-ctl
        # writes a sidecar. We supply a deterministic backgroundTaskId and
        # pre-create the corresponding session-task output file so the
        # session UUID resolver finds it.
        # Layout: /tmp/claude-<uid>/<HOME-slug>/<uuid>/tasks/<id>.output
        # where <HOME-slug> is HOME with `/` -> `-` and a leading `-`. We
        # mirror the resolver in the hook (which derives the slug from $HOME
        # at call time, so this hook is portable across users).
        fake_uuid = "deadbeef-cafe-1234-5678-abcdef012345"
        uid = os.geteuid()
        home_slug = env["HOME"].replace("/", "-")
        # Use a unique task id so we don't collide with a real Claude
        # session. The file we create here is what makes the resolver
        # succeed (it globs for an existing output file with this task id).
        fake_task_id = f"btestxx30{secrets.token_hex(2)}"
        fake_session_dir = Path(
            f"/tmp/claude-{uid}/{home_slug}/{fake_uuid}/tasks")
        fake_session_dir.mkdir(parents=True, exist_ok=True)
        fake_output = fake_session_dir / f"{fake_task_id}.output"
        fake_output.write_text("")  # exists, empty (so the predicate would allow)
        # Re-isolate sidecar dir for this test.
        sidecar_dir2 = tmpdir / "watcher-output-pending-2"
        env_npwo2 = env.copy()
        env_npwo2["WATCHER_PENDING_DIR"] = str(sidecar_dir2)
        rc, _stdout, _err = _hook_post(
            {
                "tool_name": "Bash",
                "tool_input": {
                    "command": "watcher-ctl run signal-wait-dm",
                    "run_in_background": True,
                },
                "tool_response": {
                    "backgroundTaskId": fake_task_id,
                },
            },
            env_npwo2,
        )
        sidecar_path = sidecar_dir2 / f"{fake_task_id}.json"
        sidecar_appeared = sidecar_path.exists()
        sidecar_ok = False
        if sidecar_appeared:
            try:
                sc_data = json.loads(sidecar_path.read_text())
                sidecar_ok = (
                    sc_data.get("task_id") == fake_task_id
                    and sc_data.get("watcher_name") == "signal-wait-dm"
                    and sc_data.get("output_file_path") == str(fake_output)
                    and sc_data.get("command", "").startswith("watcher-ctl run")
                    and isinstance(sc_data.get("registered_at"), (int, float))
                )
            except (OSError, json.JSONDecodeError):
                pass
        results.append(_check(
            "30. PostToolUse on watcher-ctl run + bg writes sidecar",
            rc == 0 and sidecar_appeared and sidecar_ok,
            f"rc={rc} appeared={sidecar_appeared} ok={sidecar_ok} "
            f"sidecar={sidecar_path}",
        ))
        # Cleanup -- best-effort.
        try:
            if sidecar_path.exists():
                sidecar_path.unlink()
            if fake_output.exists():
                fake_output.unlink()
            if fake_session_dir.exists():
                fake_session_dir.rmdir()
            fake_session_dir.parent.rmdir()
        except OSError:
            pass

        # ===== exempt_command_patterns predicate-param tests =====
        # The no_pending_watcher_outputs predicate accepts an optional
        # `exempt_command_patterns` list. Each sidecar's recorded `command`
        # field is matched (tool_name="Bash") against the patterns; any
        # match skips the sidecar in the unread count. Use case: silence
        # the `watcher-ctl run X` "Started watcher X" blurbs that accumulate
        # hundreds-per-session and gate everything until each is Read.
        #
        # We isolate the sidecar dir to a fresh subdir of tmpdir so the
        # tests don't see stragglers from earlier scenarios.
        sidecar_dir3 = tmpdir / "watcher-output-pending-ecp"
        env_ecp = env.copy()
        env_ecp["WATCHER_PENDING_DIR"] = str(sidecar_dir3)

        def _write_sidecar_cmd(task_id: str, output_path: Path,
                               command: str,
                               registered_at: float | None = None) -> Path:
            sidecar_dir3.mkdir(parents=True, exist_ok=True)
            sc = {
                "task_id": task_id,
                "command": command,
                "watcher_name": "explicit-test",
                "output_file_path": str(output_path),
                "registered_at": (registered_at if registered_at is not None
                                  else time.time()),
            }
            sp = sidecar_dir3 / f"{task_id}.json"
            sp.write_text(json.dumps(sc))
            return sp

        # --- Test 30a: baseline -- exempt_command_patterns absent ->
        # watcher-ctl sidecar still gates (regression guard for the
        # default-no-filter behavior). ---
        out_file_ecp1 = tmpdir / "captured-ecp1.output"
        out_file_ecp1.write_text("watcher fired\n")
        os.utime(out_file_ecp1, (time.time(), time.time()))
        sc_ecp1 = _write_sidecar_cmd(
            "ecp1", out_file_ecp1,
            command="watcher-ctl run sample-ecp1",
            registered_at=time.time() - 10,
        )
        ob_ecp_baseline = _add_ob(
            env_ecp,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={},  # exempt_command_patterns absent
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_ecp,
        )
        results.append(_check(
            "30a. exempt_command_patterns absent -> watcher-ctl sidecar gates",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_ecp_baseline], env_ecp)

        # --- Test 30b: exempt_command_patterns matches the watcher-ctl
        # sidecar's command -> sidecar is skipped -> predicate allows. ---
        ob_ecp_match = _add_ob(
            env_ecp,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={
                "exempt_command_patterns": ["Bash:^watcher-ctl\\b"],
            },
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_ecp,
        )
        results.append(_check(
            "30b. exempt_command_patterns matches watcher-ctl -> sidecar skipped",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_ecp_match], env_ecp)

        # --- Test 30c: non-watcher-ctl sidecar with the same exempt list
        # is NOT skipped (regression guard against over-broad filtering). ---
        out_file_ecp2 = tmpdir / "captured-ecp2.output"
        out_file_ecp2.write_text("arbitrary bg output\n")
        os.utime(out_file_ecp2, (time.time(), time.time()))
        sc_ecp2 = _write_sidecar_cmd(
            "ecp2", out_file_ecp2,
            command="sleep 30 && echo done",
            registered_at=time.time() - 10,
        )
        ob_ecp_non = _add_ob(
            env_ecp,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={
                "exempt_command_patterns": ["Bash:^watcher-ctl\\b"],
            },
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_ecp,
        )
        # Banner should mention the non-exempt sidecar path (not the
        # watcher-ctl one). Both unread sidecars exist, but only the
        # sleep-30 one should be counted in `unread`.
        banner = (out.get("systemMessage", "") or "")
        names_ok = (
            str(out_file_ecp2) in banner
            and str(out_file_ecp1) not in banner
        )
        results.append(_check(
            "30c. exempt_command_patterns doesn't skip non-matching sidecars",
            rc == 0 and _is_deny(out) and names_ok,
            f"rc={rc} out={out} names_ok={names_ok}",
        ))
        _run([str(CLI), "satisfy", ob_ecp_non], env_ecp)

        # --- Test 30d: empty exempt_command_patterns list -> no filtering
        # (same effect as absent). ---
        ob_ecp_empty = _add_ob(
            env_ecp,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={"exempt_command_patterns": []},
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_ecp,
        )
        results.append(_check(
            "30d. exempt_command_patterns empty list -> no filtering (deny)",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_ecp_empty], env_ecp)

        # Cleanup ECP sidecars.
        for sc_path in (sc_ecp1, sc_ecp2):
            try:
                if sc_path.exists():
                    sc_path.unlink()
            except OSError:
                pass

        # ===== is_main_loop + all_of (predicate composition) tests =====
        # Replaces the old row-level `main_loop_only` flag tests. The
        # canonical way to scope an obligation to the main loop is now
        # `predicate: all_of [is_main_loop, <other>]` -- the new
        # `is_main_loop` predicate is itself a boolean that returns true
        # iff agent_id is empty/missing in the hook payload, and `all_of`
        # is a meta-predicate that ANDs an arbitrary list of children.
        #
        # SEMANTICS: standard Boolean AND. all_of is satisfied iff every
        # child is satisfied. Empty list is trivially true. is_main_loop
        # FAILS in subagent context (predicate returns False), so an
        # `all_of [is_main_loop, X]` obligation will FAIL (and DENY) in
        # subagent context unless X also happens to fail. To express
        # "main-loop only enforce X" semantics (where subagents bypass),
        # the natural shape is `is_main_loop {negate: true}` ORed with X
        # -- but we don't have OR. Today's pilot use-case is the
        # watcher-output gate, which intentionally USES the AND
        # semantics: in the main loop the obligation actively gates;
        # subagents would deny too, BUT subagents don't read the main
        # loop's sidecar dir, so in practice no_pending_watcher_outputs
        # passes vacuously for them. The is_main_loop child is included
        # as documentation of intent + future-proofing if the predicate
        # ever becomes ambient.
        #
        # The tests below verify the pure AND semantics; the live
        # obligation refit lives in the deployment step.

        # Wipe the obligations file to start clean for the composition tests.
        proc = _run([str(CLI), "list", "--json"], env)
        try:
            existing = json.loads(proc.stdout).get("obligations", [])
        except (json.JSONDecodeError, ValueError):
            existing = []
        for ob in existing:
            _run([str(CLI), "satisfy", ob["id"]], env)

        # --- Test 31: is_main_loop alone + main-loop (no agent_id) -> allow ---
        ob_iml = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="is_main_loop",
            params={},
            ttl=120,
            deny_msg="must be in main loop",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "31. is_main_loop alone + main-loop -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 32: is_main_loop alone + subagent context -> deny ---
        rc, out, _err = _hook_pre(
            {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "subagent-abc-123",
            },
            env,
        )
        results.append(_check(
            "32. is_main_loop alone + subagent context -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))

        # Belt-and-suspenders: empty-string agent_id treated as main loop.
        rc, out, _err = _hook_pre(
            {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "",
            },
            env,
        )
        results.append(_check(
            "32b. is_main_loop + agent_id='' -> allow (treated as main loop)",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_iml], env)

        # --- Test 33: is_main_loop {negate: true} = "is subagent" ---
        # Only enforce when inside a subagent. Used as a building block
        # for "subagent-only" obligations.
        ob_iml_neg = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="is_main_loop",
            params={"negate": True},
            ttl=120,
            deny_msg="must be in subagent",
        )
        # subagent context -> allow (predicate satisfied: we ARE in subagent)
        rc, out, _err = _hook_pre(
            {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "subagent-xyz",
            },
            env,
        )
        sub_allowed = (rc == 0 and _is_allow(out))
        # main-loop context -> deny (predicate fails)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        main_denied = (rc == 0 and _is_deny(out))
        results.append(_check(
            "33. is_main_loop {negate:true}: subagent allow / main-loop deny",
            sub_allowed and main_denied,
            f"sub_allowed={sub_allowed} main_denied={main_denied}",
        ))
        _run([str(CLI), "satisfy", ob_iml_neg], env)

        # --- Test 34: all_of [is_main_loop, file_exists(missing)] subagent
        #     -> ALLOW. Scope-guard short-circuit: is_main_loop FAILS in
        #     subagent context, which (inside all_of) marks the all_of as
        #     INACTIVE -> satisfied=True -> obligation does NOT block.
        #     This is the canonical "main-loop only enforce X" pattern.
        absent_x = tmpdir / "absent-composition"
        ob_aof_iml = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={
                "predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {"kind": "file_exists", "params": {"path": str(absent_x)}},
                ]
            },
            ttl=120,
            deny_msg="all_of [is_main_loop, file_exists(missing)]",
        )
        rc, out, _err = _hook_pre(
            {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "subagent-abc-123",
            },
            env,
        )
        results.append(_check(
            "34. all_of [is_main_loop, file_exists(missing)] subagent -> allow "
            "(scope-guard short-circuit)",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 35: same all_of in main-loop + missing file -> deny
        #     (is_main_loop=T, file_exists=F -> all_of=F -> deny)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "35. all_of [is_main_loop, file_exists(missing)] main-loop -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aof_iml], env)

        # --- Test 36: all_of [is_main_loop, file_exists(present)] main-loop
        #     -> allow (both children satisfied)
        present_x = tmpdir / "present-composition"
        present_x.write_text("hi")
        ob_aof_ok = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={
                "predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {"kind": "file_exists", "params": {"path": str(present_x)}},
                ]
            },
            ttl=120,
            deny_msg="all_of [is_main_loop, file_exists(present)]",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "36. all_of [is_main_loop, file_exists(present)] main-loop -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aof_ok], env)

        # --- Test 37: all_of [] is trivially satisfied (empty AND => true) ---
        ob_aof_empty = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={"predicates": []},
            ttl=120,
            deny_msg="all_of [] should never block",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "37. all_of [] empty list -> trivially satisfied -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aof_empty], env)

        # --- Test 38: inform-mode all_of [is_main_loop, file_exists(missing)],
        #     subagent post-hook -> SILENT (scope-guard skip).
        absent_inform = tmpdir / "absent-inform-composition"
        ob_aof_inform = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={
                "predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {"kind": "file_exists", "params": {"path": str(absent_inform)}},
                ]
            },
            ttl=120,
            enforcement="inform",
            deny_msg="composed inform (main-loop sees banner; subagent silent)",
        )
        proc = subprocess.run(
            [str(POST_HOOK)],
            capture_output=True, text=True, timeout=5, check=False, env=env,
            input=json.dumps({
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "subagent-aaa-111",
            }),
        )
        results.append(_check(
            "38. inform all_of [is_main_loop, file_exists(miss)] "
            "subagent -> silent (scope-guard skip)",
            proc.returncode == 0 and "[obligations:inform]" not in proc.stderr,
            f"rc={proc.returncode} stderr={proc.stderr!r}",
        ))

        # --- Test 39: same inform obligation, main-loop post-hook -> banner
        # (is_main_loop=T, file_exists=F -> all_of=F -> banner fires)
        proc = subprocess.run(
            [str(POST_HOOK)],
            capture_output=True, text=True, timeout=5, check=False, env=env,
            input=json.dumps({
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                # no agent_id => main loop
            }),
        )
        results.append(_check(
            "39. inform all_of [is_main_loop, file_exists(miss)] "
            "main-loop -> banner present",
            proc.returncode == 0 and "[obligations:inform]" in proc.stderr
                and ob_aof_inform in proc.stderr,
            f"rc={proc.returncode} stderr={proc.stderr!r}",
        ))
        _run([str(CLI), "satisfy", ob_aof_inform], env)

        # --- Test 40: all_of [file_exists(missing), env_present(unset)]
        #     main-loop -> deny. No is_main_loop => standard AND: any
        #     failing child propagates to the all_of result.
        absent_y = tmpdir / "absent-no-iml"
        ob_aof_no_iml = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={
                "predicates": [
                    {"kind": "file_exists", "params": {"path": str(absent_y)}},
                ]
            },
            ttl=120,
            deny_msg="all_of [file_exists(missing)] should deny",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "40. all_of [file_exists(missing)] (no is_main_loop) -> deny",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aof_no_iml], env)

        # --- Test 41: all_of with unknown child kind -> default-open (allow)
        ob_aof_unknown = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="all_of",
            params={
                "predicates": [
                    {"kind": "totally_made_up_predicate", "params": {}},
                ]
            },
            ttl=120,
            deny_msg="all_of with unknown child should default-open",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        results.append(_check(
            "41. all_of [unknown-kind] -> default-open allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aof_unknown], env)

        # ===== why-in-deny-output tests (multi-path embedding) =====
        # These regression-guard the fix that embeds the predicate's `why`
        # field directly in BOTH the systemMessage banner AND the
        # permissionDecisionReason. Pre-fix, only the first unread path made
        # it into `why`, and `why` was buried in a one-line "why: ..." in
        # the banner only -- the visible reason just showed
        # "<id>: <deny_message>", forcing the caller to round-trip through
        # `obligations check --json` to enumerate all unread paths.
        env_why = env.copy()
        sidecar_dir_why = tmpdir / "why-watcher-output-pending"
        env_why["WATCHER_PENDING_DIR"] = str(sidecar_dir_why)
        sidecar_dir_why.mkdir(parents=True, exist_ok=True)

        ob_why = _add_ob(
            env_why,
            tool_pattern="*",
            predicate="no_pending_watcher_outputs",
            params={},
            ttl=0,
            deny_msg="Read the captured watcher output before proceeding",
        )

        def _write_sidecar_why(task_id: str, output_path: Path,
                                registered_at: float | None = None) -> Path:
            sc = {
                "task_id": task_id,
                "command": f"watcher-ctl run sample-{task_id}",
                "watcher_name": f"sample-{task_id}",
                "output_file_path": str(output_path),
                "registered_at": registered_at if registered_at is not None else time.time(),
            }
            sp = sidecar_dir_why / f"{task_id}.json"
            sp.write_text(json.dumps(sc))
            return sp

        # --- Test 42: deny with single unread path -> path appears in BOTH
        # systemMessage banner AND permissionDecisionReason
        out_a = tmpdir / "why-single.output"
        out_a.write_text("watcher fired\n")
        os.utime(out_a, (time.time(), time.time()))
        sc_a = _write_sidecar_why("whysingle", out_a, registered_at=time.time() - 10)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_why,
        )
        msg = (out.get("systemMessage") or "")
        reason = ((out.get("hookSpecificOutput") or {})
                  .get("permissionDecisionReason") or "")
        results.append(_check(
            "42. single unread path appears in both systemMessage and reason",
            rc == 0 and _is_deny(out)
            and str(out_a) in msg and str(out_a) in reason,
            f"rc={rc} msg={msg!r} reason={reason!r}",
        ))
        sc_a.unlink()

        # --- Test 43: deny with TWO unread paths -> BOTH paths appear in
        # banner (one per line) AND in reason
        out_b = tmpdir / "why-multi-1.output"
        out_c = tmpdir / "why-multi-2.output"
        out_b.write_text("first\n")
        out_c.write_text("second\n")
        os.utime(out_b, (time.time(), time.time()))
        os.utime(out_c, (time.time(), time.time()))
        sc_b = _write_sidecar_why("whymulti1", out_b, registered_at=time.time() - 10)
        sc_c = _write_sidecar_why("whymulti2", out_c, registered_at=time.time() - 10)
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_why,
        )
        msg = (out.get("systemMessage") or "")
        reason = ((out.get("hookSpecificOutput") or {})
                  .get("permissionDecisionReason") or "")
        # Both paths appear in BOTH fields, no "+1 more" hand-waving.
        both_in_msg = str(out_b) in msg and str(out_c) in msg
        both_in_reason = str(out_b) in reason and str(out_c) in reason
        no_more_handwave = "+1 more" not in msg and "+1 more" not in reason
        # Each path renders on its own indented line in the banner.
        bullet_b = f"!!       {out_b}" in msg
        bullet_c = f"!!       {out_c}" in msg
        results.append(_check(
            "43. TWO unread paths -> all paths in banner + reason, bulleted",
            rc == 0 and _is_deny(out) and both_in_msg and both_in_reason
            and no_more_handwave and bullet_b and bullet_c,
            f"both_in_msg={both_in_msg} both_in_reason={both_in_reason} "
            f"no_more_handwave={no_more_handwave} "
            f"bullet_b={bullet_b} bullet_c={bullet_c} "
            f"msg={msg!r} reason={reason!r}",
        ))
        sc_b.unlink()
        sc_c.unlink()

        # --- Test 44: non-path-list `why` (e.g. process_alive) -> reason
        # includes the why text inline (parenthetical fallback)
        sidecar_dir_why_clean = sidecar_dir_why
        # Drain any remaining sidecars to keep no_pending_watcher_outputs quiet
        for f in sidecar_dir_why_clean.glob("*.json"):
            f.unlink()
        _run([str(CLI), "satisfy", ob_why], env_why)
        # Use a process_alive obligation with a dead PID. Its `why` is
        # narrative ("pid_file ... refers to non-existent process X"), not a
        # comma-separated path list -> the hook should fall back to inline
        # parenthetical embedding.
        pid_file_why = tmpdir / "why-dead.pid"
        # Find a dead pid
        dead_pid_w = 999999
        while os.path.isdir(f"/proc/{dead_pid_w}"):
            dead_pid_w += 1
        pid_file_why.write_text(f"{dead_pid_w}\n")
        ob_why_pa = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="process_alive",
            params={"pid_file": str(pid_file_why)},
            ttl=120,
            deny_msg="watcher dead -- restart it",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        reason = ((out.get("hookSpecificOutput") or {})
                  .get("permissionDecisionReason") or "")
        # The reason should include "watcher dead" AND a "(why: ...)" inline,
        # carrying the predicate's narrative explanation.
        results.append(_check(
            "44. non-path `why` -> reason embeds inline as (why: ...)",
            rc == 0 and _is_deny(out)
            and "watcher dead" in reason
            and "(why:" in reason,
            f"rc={rc} reason={reason!r}",
        ))
        _run([str(CLI), "satisfy", ob_why_pa], env)

        # --- Test 45: agent_inbox_empty with missing inbox -> allow ---
        bogus_inbox = tmpdir / "absent-inbox.json"
        ob_aim = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="agent_inbox_empty",
            params={"path": str(bogus_inbox)},
            ttl=120,
            deny_msg="agent inbox not empty",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "45. agent_inbox_empty missing -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aim], env)

        # --- Test 46: agent_inbox_empty with [] -> allow ---
        empty_inbox = tmpdir / "empty-inbox.json"
        empty_inbox.write_text("[]")
        ob_aie = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="agent_inbox_empty",
            params={"path": str(empty_inbox)},
            ttl=120,
            deny_msg="empty inbox test",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "46. agent_inbox_empty [] -> allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))
        _run([str(CLI), "satisfy", ob_aie], env)

        # --- Test 47: agent_inbox_empty with messages -> deny + why has body ---
        full_inbox = tmpdir / "full-inbox.json"
        full_inbox.write_text(json.dumps([{
            "from": "andrew@signal", "ts": "2026-04-28",
            "queue_item": "q-test", "text": "hello agent please switch tasks"
        }]))
        ob_ain = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="agent_inbox_empty",
            params={"path": str(full_inbox)},
            ttl=120,
            deny_msg="messages waiting",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        reason_full = ((out.get("hookSpecificOutput") or {})
                       .get("permissionDecisionReason") or "")
        results.append(_check(
            "47. agent_inbox_empty with messages -> deny + body in why",
            rc == 0 and _is_deny(out)
            and "hello agent" in (out.get("systemMessage") or "")
            and "messages waiting" in reason_full,
            f"rc={rc} systemMessage_preview={(out.get('systemMessage') or '')[:200]!r}",
        ))
        _run([str(CLI), "satisfy", ob_ain], env)

        # --- Test 48: agent_inbox_empty inform-mode subagent scope -> banner on stderr ---
        # Compose with all_of [is_main_loop {negate: true}, agent_inbox_empty]
        # This is the production wiring shape. In a subagent context with
        # messages in the inbox, the post-hook must surface the inbox.
        inform_inbox = tmpdir / "subagent-inbox.json"
        inform_inbox.write_text(json.dumps([{
            "from": "main-loop", "ts": "2026-04-28",
            "queue_item": None,
            "text": "abandon current task; new instructions queued"
        }]))
        # Use the obligations CLI directly to register the all_of obligation
        # (the _add_ob helper doesn't compose easily). Inform mode + ttl 0.
        params_compose = {
            "predicates": [
                {"kind": "is_main_loop", "params": {"negate": True}},
                {"kind": "agent_inbox_empty", "params": {"path": str(inform_inbox)}},
            ]
        }
        proc = _run([
            str(CLI), "add",
            "--tool-pattern", "*",
            "--predicate", "all_of",
            "--params", json.dumps(params_compose),
            "--ttl", "120",
            "--enforcement", "inform",
            "--deny-msg", "agent-msg/inbox:test",
            "--created-by", "test",
            "--json",
        ], env)
        ob_inf = json.loads(proc.stdout)["id"] if proc.returncode == 0 else None
        # Subagent post-hook with messages -> banner present.
        rc, _stdout, stderr = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"},
             "agent_id": "test-subagent-uuid"}, env,
        )
        sub_has_banner = ("agent-msg/inbox:test" in stderr
                          and "abandon current task" in stderr)
        # Main-loop post-hook (no agent_id) with same inbox -> NO banner
        # because the is_main_loop {negate:true} scope-guard fails.
        rc2, _stdout2, stderr2 = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        main_silent = "agent-msg/inbox:test" not in stderr2
        results.append(_check(
            "48. inform all_of [is_main_loop neg, agent_inbox] subagent banner / main silent",
            sub_has_banner and main_silent,
            f"sub_has_banner={sub_has_banner} main_silent={main_silent} "
            f"sub_stderr_preview={stderr[:300]!r} main_stderr_preview={stderr2[:200]!r}",
        ))
        if ob_inf:
            _run([str(CLI), "satisfy", ob_inf], env)

        # --- Tests 57-60: agent_inbox_empty GATE-mode (production wiring) ---
        # The `agent-msg arm` subcommand registers a gate-mode obligation
        # with these exempt_patterns:
        #   Bash:^agent-msg\s+ack\b
        #   Bash:^agent-msg\s+inbox\b
        #   Bash:^agent-msg\s+disarm\b
        # These tests assert the harness behavior: subagent + non-empty inbox
        # blocks non-exempt calls with the message body in the deny banner;
        # ack/inbox/disarm always pass; main-loop is scope-guarded out.
        gate_inbox = tmpdir / "gate-mode-inbox.json"
        gate_inbox.write_text(json.dumps([{
            "from": "main-loop", "ts": "2026-04-30",
            "queue_item": "q-test-gate",
            "text": "switch tasks immediately - this is a gate-mode test",
        }]))
        params_gate = {
            "predicates": [
                {"kind": "is_main_loop", "params": {"negate": True}},
                {"kind": "agent_inbox_empty", "params": {"path": str(gate_inbox)}},
            ]
        }
        gate_args = [
            str(CLI), "add",
            "--tool-pattern", "*",
            "--predicate", "all_of",
            "--params", json.dumps(params_gate),
            "--ttl", "120",
            "--enforcement", "gate",
            "--deny-msg", "agent-msg/inbox:gate-test",
            "--created-by", "test",
            "--exempt-tool-pattern", r"Bash:^agent-msg\s+ack\b",
            "--exempt-tool-pattern", r"Bash:^agent-msg\s+inbox\b",
            "--exempt-tool-pattern", r"Bash:^agent-msg\s+disarm\b",
            "--json",
        ]
        proc_gate = _run(gate_args, env)
        ob_gate = (json.loads(proc_gate.stdout)["id"]
                   if proc_gate.returncode == 0 else None)

        # --- Test 57: subagent + non-exempt tool -> deny + body in banner ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"},
             "agent_id": "test-subagent"},
            env,
        )
        sysmsg = out.get("systemMessage") or ""
        results.append(_check(
            "57. gate agent_inbox: subagent + non-exempt -> deny + body",
            rc == 0 and _is_deny(out)
            and "switch tasks immediately" in sysmsg,
            f"rc={rc} deny={_is_deny(out)} sysmsg={sysmsg[:200]!r}",
        ))

        # --- Test 58: subagent + `agent-msg ack` -> ALLOW (exempt) ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "agent-msg ack test-subagent"},
             "agent_id": "test-subagent"},
            env,
        )
        results.append(_check(
            "58. gate agent_inbox: `agent-msg ack` exempt even with full inbox",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 59: subagent + `agent-msg inbox` and `disarm` exempt ---
        rc1, out1, _ = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "agent-msg inbox test-subagent"},
             "agent_id": "test-subagent"},
            env,
        )
        rc2, out2, _ = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "agent-msg disarm test-subagent"},
             "agent_id": "test-subagent"},
            env,
        )
        results.append(_check(
            "59. gate agent_inbox: `inbox` and `disarm` also exempt",
            rc1 == 0 and _is_allow(out1) and rc2 == 0 and _is_allow(out2),
            f"rc1={rc1} out1={out1} rc2={rc2} out2={out2}",
        ))

        # --- Test 60: main-loop scope-guard fires -> ALLOW ---
        # No agent_id in payload -> main loop. is_main_loop {negate:true}
        # fails, all_of returns satisfied=True (scope-guard), no deny.
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "60. gate agent_inbox: main-loop scope-guard short-circuits to allow",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        if ob_gate:
            _run([str(CLI), "satisfy", ob_gate], env)

        # --- Test 9: malformed stdin -> default-open ---
        proc = subprocess.run(
            [str(PRE_HOOK)], input="not json {{",
            capture_output=True, text=True, timeout=5, check=False, env=env,
        )
        try:
            out = json.loads(proc.stdout) if proc.stdout.strip() else {}
        except json.JSONDecodeError:
            out = {"__raw__": proc.stdout}
        results.append(_check(
            "9. malformed stdin -> default-open",
            proc.returncode == 0 and _is_allow(out),
            f"rc={proc.returncode} stdout={proc.stdout!r}",
        ))

        # ===================================================================
        # Tests 45-48: per-obligation `exempt_patterns`
        # ===================================================================
        # Set up an obligation that gates ALL Bash on a missing marker file.
        # The gate fires when predicate fails. We expect the gate to fire on
        # `ls`, but NOT on commands matching the exempt patterns.
        marker_missing = tmpdir / "exempt-test-marker"
        if marker_missing.exists():
            marker_missing.unlink()
        ob_exempt = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(marker_missing)},
            ttl=120,
            deny_msg="marker missing -- gate fires unless command is exempt",
            exempt_tool_patterns=[
                "Bash:^watcher-ctl run\\b",
                "Bash:^obligations\\b",
            ],
        )

        # --- Test 45: matching exempt_pattern bypasses gate ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "watcher-ctl run claude-event-watch"}},
            env,
        )
        results.append(_check(
            "45. exempt: Bash:^watcher-ctl run bypasses gate even when "
            "predicate fails",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 46: non-matching call still gated ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "46. exempt: non-matching call ('ls') still denied by gate",
            rc == 0 and _is_deny(out),
            f"rc={rc} out={out}",
        ))

        # --- Test 47: second exempt pattern also matches ---
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash",
             "tool_input": {"command": "obligations list"}},
            env,
        )
        results.append(_check(
            "47. exempt: second pattern (Bash:^obligations) also bypasses",
            rc == 0 and _is_allow(out),
            f"rc={rc} out={out}",
        ))

        _run([str(CLI), "satisfy", ob_exempt], env)

        # --- Test 48: inform-mode honors exempt_patterns too ---
        ob_exempt_inform = _add_ob(
            env,
            tool_pattern="Bash",
            predicate="file_exists",
            params={"path": str(marker_missing)},
            ttl=120,
            deny_msg="inform: marker missing",
            enforcement="inform",
            exempt_tool_patterns=["Bash:^watcher-ctl run\\b"],
        )
        # Inform-mode never gates the PreToolUse path, so we check the
        # PostToolUse hook output directly: an exempt call must NOT print
        # the inform banner; a non-exempt failing call MUST print it.
        rc_post1, _stdout1, stderr1 = _hook_post(
            {"tool_name": "Bash",
             "tool_input": {"command": "watcher-ctl run x"}},
            env,
        )
        rc_post2, _stdout2, stderr2 = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}},
            env,
        )
        # The post-tool hook prints the inform banner on stdout (per the CLI
        # spec) -- check both stdout and stderr to be safe.
        all_post1 = (_stdout1 or "") + (stderr1 or "")
        all_post2 = (_stdout2 or "") + (stderr2 or "")
        results.append(_check(
            "48. exempt: inform-mode also honors exempt_patterns (silent on "
            "exempt call, banner on non-exempt call)",
            (rc_post1 == 0 and "inform: marker missing" not in all_post1
             and rc_post2 == 0
             and "inform: marker missing" in all_post2),
            f"rc1={rc_post1} all1={all_post1!r} rc2={rc_post2} "
            f"all2={all_post2!r}",
        ))
        _run([str(CLI), "satisfy", ob_exempt_inform], env)

        # ===================================================================
        # Tests 49-56: per-call audited overrides
        # ===================================================================

        # --- Test 49: active override bypasses ALL gate-mode obligations ---
        # Register a permanent gate-mode obligation that should always block
        # on plain Bash. Then create an override and confirm the call passes.
        marker_missing2 = tmpdir / "override-test-marker"
        if marker_missing2.exists():
            marker_missing2.unlink()
        ob_for_ov = _add_ob(
            env,
            tool_pattern="*",
            predicate="file_exists",
            params={"path": str(marker_missing2)},
            ttl=0,
            deny_msg="marker missing -- always gated",
        )
        # Without override -> deny
        rc, out_before, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        denied_before = (rc == 0 and _is_deny(out_before))
        # Create override
        ov_id = _add_override(env, "running watcher recovery", "30s")
        rc, out_after, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "49. override: active override bypasses gate-mode obligations",
            denied_before
            and rc == 0
            and _is_allow(out_after)
            and ov_id.startswith("ov-"),
            f"denied_before={denied_before} rc={rc} out_after={out_after} "
            f"ov_id={ov_id}",
        ))

        # --- Test 51: cancelled-via-satisfy does NOT bypass ---
        # (we test 51 before 50 because we still hold a live override)
        _run([str(CLI), "satisfy", ov_id], env)
        rc, out_post_cancel, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "51. override: cancelled-via-satisfy does NOT bypass",
            rc == 0 and _is_deny(out_post_cancel),
            f"rc={rc} out={out_post_cancel}",
        ))

        # --- Test 50: expired override does NOT bypass ---
        # Manually inject an already-expired override into the JSON state.
        ov_state = json.loads(obligations_path.read_text())
        ov_state.setdefault("overrides", []).append({
            "id": "ov-test-expired",
            "reason": "already expired",
            "duration_secs": 30,
            "expires_at": time.time() - 10,  # 10s in the past
            "created_at": time.time() - 40,
            "created_by": "test",
        })
        obligations_path.write_text(json.dumps(ov_state, indent=2))
        rc, out_expired, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        results.append(_check(
            "50. override: expired override does NOT bypass (TTL respected)",
            rc == 0 and _is_deny(out_expired),
            f"rc={rc} out={out_expired}",
        ))

        # --- Test 52: invalid duration / empty reason rejected exit 2 ---
        proc_bad_dur = _run([str(CLI), "override", "valid reason",
                             "--duration", "0"], env)
        proc_bad_neg = _run([str(CLI), "override", "valid reason",
                             "--duration", "-5"], env)
        proc_empty = _run([str(CLI), "override", "",
                           "--duration", "30s"], env)
        results.append(_check(
            "52. override: invalid duration / empty reason -> exit 2",
            (proc_bad_dur.returncode == 2
             and proc_bad_neg.returncode == 2
             and proc_empty.returncode == 2),
            f"dur0={proc_bad_dur.returncode} "
            f"durneg={proc_bad_neg.returncode} "
            f"empty={proc_empty.returncode}",
        ))

        # --- Test 53: 24h cap enforced ---
        proc_cap = _run([str(CLI), "override", "valid reason",
                         "--duration", "25h"], env)
        proc_cap_secs = _run([str(CLI), "override", "valid reason",
                              "--duration", "86401"], env)
        results.append(_check(
            "53. override: 24h cap enforced",
            (proc_cap.returncode == 2
             and proc_cap_secs.returncode == 2
             and "86400" in (proc_cap.stderr or proc_cap_secs.stderr)),
            f"cap_h={proc_cap.returncode} "
            f"cap_s={proc_cap_secs.returncode} "
            f"stderr={(proc_cap.stderr + proc_cap_secs.stderr)!r}",
        ))

        # --- Test 54: bypass is audited to obligations-bypass.log ---
        bypass_log = tmpdir / ".config" / "claude" / "obligations-bypass.log"
        # Wipe the log so we measure ONLY this test's writes.
        if bypass_log.exists():
            bypass_log.unlink()
        ov_audit = _add_override(env, "audit test", "30s",
                                 created_by="test-audit")
        # Trigger a bypass via the hook -- the obligation from earlier still
        # gates the call.
        _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        log_text = bypass_log.read_text() if bypass_log.exists() else ""
        # Expect at least 2 lines: one for override-created, one for
        # override-applied (when the hook bypassed).
        results.append(_check(
            "54. override: audited to obligations-bypass.log",
            (bypass_log.exists()
             and "override-created" in log_text
             and "override-applied" in log_text
             and "audit test" in log_text
             and "test-audit" in log_text),
            f"exists={bypass_log.exists()} text={log_text!r}",
        ))

        # --- Test 55: shows in `obligations list` ---
        proc_list = _run([str(CLI), "list"], env)
        proc_list_json = _run([str(CLI), "list", "--json"], env)
        try:
            data_list = json.loads(proc_list_json.stdout)
        except json.JSONDecodeError:
            data_list = {}
        results.append(_check(
            "55. override: shows in `obligations list`",
            (proc_list.returncode == 0
             and "ACTIVE OVERRIDES" in proc_list.stdout
             and "audit test" in proc_list.stdout
             and ov_audit in proc_list.stdout
             and isinstance(data_list.get("overrides"), list)
             and any(ov.get("id") == ov_audit
                     for ov in data_list["overrides"])),
            f"text={proc_list.stdout!r} json_data={data_list!r}",
        ))

        # --- Test 56: does NOT silence inform-mode advisories ---
        # An inform-mode obligation whose predicate fails should still
        # surface in PostToolUse output even when an override is active.
        ob_inf = _add_ob(
            env,
            tool_pattern="*",
            predicate="file_exists",
            params={"path": str(marker_missing2)},  # still missing
            ttl=120,
            deny_msg="advisory: marker missing -- inform-mode",
            enforcement="inform",
        )
        rc_post, stdout_post, stderr_post = _hook_post(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env,
        )
        all_post = (stdout_post or "") + (stderr_post or "")
        results.append(_check(
            "56. override: does NOT silence inform-mode advisories",
            (rc_post == 0
             and "advisory: marker missing -- inform-mode" in all_post),
            f"rc={rc_post} all_post={all_post!r}",
        ))
        _run([str(CLI), "satisfy", ob_inf], env)
        _run([str(CLI), "satisfy", ov_audit], env)
        _run([str(CLI), "satisfy", ob_for_ov], env)

        # ===================================================================
        # Tests 57-60: state-aware recovery hint in the deny banner
        # (q-2026-05-01-d487)
        #
        # The watcher-health gate now appends a Recovery line whose command
        # depends on whether the failing watcher is DOWN or DUPLICATE. Test
        # the helper directly (no need to spin up a fake watcher-status CLI
        # to drive the predicate end-to-end) by importing it from the
        # in-tree hook script.
        # ===================================================================
        import importlib.util
        from importlib.machinery import SourceFileLoader
        # The hook script has no .py extension; use SourceFileLoader to
        # load it as a module so we can call _watcher_state_recovery
        # directly.
        loader = SourceFileLoader("_gate_hook_mod", str(PRE_HOOK))
        spec = importlib.util.spec_from_loader(loader.name, loader)
        gate_mod = importlib.util.module_from_spec(spec)
        loader.exec_module(gate_mod)
        watcher_state_recovery = gate_mod._watcher_state_recovery

        # --- Test 57: DUPLICATE in why -> recommends watcher-restart ---
        why_dup = (
            "signal-wait-dm       DUPLICATE (3/1)  111 222 333\n"
            "                     duplicate pollers: 111 222 333\n"
            "\n"
            "WARNING: Some watchers are down or duplicated!"
        )
        rec_dup = watcher_state_recovery(why_dup) or ""
        results.append(_check(
            "57. state-aware recovery: DUPLICATE -> watcher-restart",
            ("Recovery for DUPLICATE state:" in rec_dup
             and "`watcher-restart`" in rec_dup),
            f"rec={rec_dup!r}",
        ))

        # --- Test 58: DOWN-only in why -> recommends watcher-ctl run ---
        why_down = (
            "claude-event-watch   DOWN      (0/1)  \n"
            "\n"
            "WARNING: Some watchers are down or duplicated!"
        )
        rec_down = watcher_state_recovery(why_down) or ""
        results.append(_check(
            "58. state-aware recovery: DOWN-only -> watcher-ctl run <name>",
            ("Recovery for DOWN state:" in rec_down
             and "`watcher-ctl run <name>`" in rec_down
             and "claude-event-watch" in rec_down
             and "`watcher-restart`" in rec_down),
            f"rec={rec_down!r}",
        ))

        # --- Test 59: mixed DOWN + DUPLICATE -> DUPLICATE takes precedence ---
        why_mixed = (
            "claude-event-watch   DOWN      (0/1)\n"
            "signal-wait-dm       DUPLICATE (3/1)  111 222 333\n"
            "\n"
            "WARNING: Some watchers are down or duplicated!"
        )
        rec_mixed = watcher_state_recovery(why_mixed) or ""
        results.append(_check(
            "59. state-aware recovery: mixed -> DUPLICATE wins",
            ("Recovery for DUPLICATE state:" in rec_mixed
             and "`watcher-restart`" in rec_mixed),
            f"rec={rec_mixed!r}",
        ))

        # --- Test 60: non-watcher why (sidecar narrative) -> None ---
        # The helper must NOT inject a Recovery line into unrelated
        # obligations (e.g. the no_pending_watcher_outputs sidecar gate
        # surfaces "unread watcher output: ..." paths).
        why_unrelated = "unread watcher output: /home/x/tasks/foo.output"
        rec_unrelated = watcher_state_recovery(why_unrelated)
        why_garbage = "the file is missing and the marker is stale"
        rec_garbage = watcher_state_recovery(why_garbage)
        results.append(_check(
            "60. state-aware recovery: non-watcher-state why -> None",
            rec_unrelated is None and rec_garbage is None,
            f"rec_unrelated={rec_unrelated!r} rec_garbage={rec_garbage!r}",
        ))

        # --- Test 61: end-to-end: deny banner contains the recovery line ---
        # Use the existing test 21 pattern: register a watchers_healthy
        # obligation, but place a fake watcher-status on PATH that prints
        # a DUPLICATE row and exits 0. The pre-hook should DENY (predicate
        # fails because output is non-empty) and the systemMessage banner
        # must include the DUPLICATE recovery line.
        fake_bin = tmpdir / "fake-bin"
        fake_bin.mkdir(parents=True, exist_ok=True)
        fake_status = fake_bin / "watcher-status"
        fake_status.write_text(
            "#!/bin/sh\n"
            "cat <<'EOF'\n"
            "signal-wait-dm       DUPLICATE (3/1)  111 222 333\n"
            "                     duplicate pollers: 111 222 333\n"
            "\n"
            "WARNING: Some watchers are down or duplicated!\n"
            "EOF\n"
        )
        fake_status.chmod(0o755)
        env_fake = env.copy()
        env_fake["PATH"] = f"{fake_bin}{os.pathsep}{env['PATH']}"
        ob_wh = _add_ob(
            env_fake,
            tool_pattern="Bash",
            predicate="watchers_healthy",
            params={},
            ttl=120,
            deny_msg="watcher health gate (test 61)",
        )
        rc, out, _err = _hook_pre(
            {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fake,
        )
        banner = (out or {}).get("systemMessage", "")
        results.append(_check(
            "61. end-to-end: DUPLICATE deny banner shows watcher-restart "
            "recovery line",
            (rc == 0 and _is_deny(out)
             and "Recovery for DUPLICATE state:" in banner
             and "`watcher-restart`" in banner),
            f"rc={rc} banner={banner!r}",
        ))
        _run([str(CLI), "satisfy", ob_wh], env_fake)

        # ===================================================================
        # Tests 62-69: hardcoded watcher-ctl run gate (cardinal-rule
        # enforcement). The gate refuses any `watcher-ctl run` invocation
        # that isn't a bare `watcher-ctl run <name>` (optionally with
        # `2>&1`). Shell `&`, pipes, subshells, and compound operators all
        # reparent the watcher to init -- it becomes orphaned from Claude
        # Code's process tree.
        #
        # The gate is hardcoded in pre-tool-obligations-gate-hook itself
        # (NOT a stored obligation row) so it can't be disabled by state
        # corruption. We use a FRESH sandbox env (no obligations registered)
        # so we're testing ONLY the hardcoded gate, not the obligations
        # CLI.
        # ===================================================================
        with tempfile.TemporaryDirectory(
            prefix="obligations-test-watcher-",
        ) as td_w:
            tmpdir_w = Path(td_w)
            env_w, _ = _make_isolated_env(tmpdir_w)

            # 62: bare watcher-ctl run -> ALLOW
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "watcher-ctl run signal-wait-dm"}},
                env_w,
            )
            results.append(_check(
                "62. watcher-ctl gate: bare invocation -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 63: bare watcher-ctl run X 2>&1 -> ALLOW
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run signal-wait-dm 2>&1",
                 }},
                env_w,
            )
            results.append(_check(
                "63. watcher-ctl gate: bare with 2>&1 -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 64: trailing `2>&1 &` -> DENY (shell background reparents to init)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run signal-wait-dm 2>&1 &",
                 }},
                env_w,
            )
            banner = (out or {}).get("systemMessage", "")
            results.append(_check(
                "64. watcher-ctl gate: `2>&1 &` -> deny + cardinal banner",
                (rc == 0 and _is_deny(out)
                 and "watcher architecture cardinal rule" in banner
                 and "run_in_background: true" in banner),
                f"rc={rc} banner={banner!r}",
            ))

            # 65: trailing `&` (no 2>&1) -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run signal-wait-dm &",
                 }},
                env_w,
            )
            results.append(_check(
                "65. watcher-ctl gate: trailing `&` -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 66: command separator `;` -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run signal-wait-dm; sleep 1",
                 }},
                env_w,
            )
            results.append(_check(
                "66. watcher-ctl gate: `;` separator -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 67: two bg watcher-ctls in one command -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run X & watcher-ctl run Y &",
                 }},
                env_w,
            )
            results.append(_check(
                "67. watcher-ctl gate: two bg watcher-ctls -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 68: bare `watcher-restart` -> ALLOW (gate doesn't apply --
            # `watcher-restart` is a different command, not `watcher-ctl run`)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "watcher-restart"}},
                env_w,
            )
            results.append(_check(
                "68. watcher-ctl gate: `watcher-restart` -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 69: unrelated `ls` -> ALLOW (gate doesn't fire for non-watcher
            # commands)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "ls"}},
                env_w,
            )
            results.append(_check(
                "69. watcher-ctl gate: `ls` -> allow (gate inert)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 70: pipe `|` -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run X | tee /tmp/log",
                 }},
                env_w,
            )
            results.append(_check(
                "70. watcher-ctl gate: pipe `|` -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 71: compound `&&` -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "cd /tmp && watcher-ctl run X",
                 }},
                env_w,
            )
            results.append(_check(
                "71. watcher-ctl gate: `&&` compound -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 72: subshell `$(...)` in name token -> DENY
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run $(echo X)",
                 }},
                env_w,
            )
            results.append(_check(
                "72. watcher-ctl gate: subshell $() -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 73: OBLIGATIONS_BYPASS=1 should still bypass the hardcoded gate
            # (audited bypass is the documented escape hatch).
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {
                     "command": "watcher-ctl run signal-wait-dm &",
                 }},
                env_w,
                extra_env={"OBLIGATIONS_BYPASS": "1"},
            )
            results.append(_check(
                "73. watcher-ctl gate: OBLIGATIONS_BYPASS=1 forces allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74: gate is Bash-only -- a Read tool with a path that happens
            # to contain `watcher-ctl run X &` text MUST NOT trip the gate.
            rc, out, _err = _hook_pre(
                {"tool_name": "Read",
                 "tool_input": {
                     "file_path": "/tmp/watcher-ctl run signal &",
                 }},
                env_w,
            )
            results.append(_check(
                "74. watcher-ctl gate: Bash-only (Read tool not gated)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # ---------------------------------------------------------
            # Tests 74a-74h: Monitor-tool subagent gate (hardcoded).
            #
            # Re-uses the same isolated env (no obligations registered)
            # so we exercise the hardcoded path independent of stored
            # obligations state. Same policy as the watcher-ctl gate
            # above: the gate must fire even with an empty obligations
            # store.
            # ---------------------------------------------------------

            # 74a: subagent + Monitor -> DENY with educational banner
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "some-task-id"},
                 "agent_id": "agent-uuid-abc123"},
                env_w,
            )
            banner = (out or {}).get("systemMessage", "")
            reason = (
                ((out or {}).get("hookSpecificOutput") or {})
                .get("permissionDecisionReason", "")
            )
            results.append(_check(
                "74a. Monitor gate: subagent + Monitor -> deny + banner",
                (rc == 0 and _is_deny(out)
                 and "Monitor tool is disabled for subagents" in banner
                 and "gh pr view" in banner
                 and "run_in_background" in banner
                 and "gh pr view" in reason),
                f"rc={rc} banner={banner!r} reason={reason!r}",
            ))

            # 74b: main-loop + Monitor (no agent_id) -> ALLOW
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "some-task-id"}},
                env_w,
            )
            results.append(_check(
                "74b. Monitor gate: main-loop + Monitor -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74c: main-loop + Monitor (explicit empty agent_id) -> ALLOW
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "some-task-id"},
                 "agent_id": ""},
                env_w,
            )
            results.append(_check(
                "74c. Monitor gate: empty agent_id -> allow (main-loop)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74d: main-loop + Monitor (whitespace-only agent_id) -> ALLOW
            # The hook strips before truthiness check, matching the
            # obligations CLI's is_main_loop predicate.
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "t"},
                 "agent_id": "   \t  "},
                env_w,
            )
            results.append(_check(
                "74d. Monitor gate: whitespace agent_id -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74e: subagent + non-Monitor tool -> ALLOW (only Monitor is
            # gated; Bash/Read/etc inside a subagent are fine)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "ls"},
                 "agent_id": "agent-uuid-abc123"},
                env_w,
            )
            results.append(_check(
                "74e. Monitor gate: subagent + Bash -> allow (gate inert)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74f: subagent + Read tool -> ALLOW
            rc, out, _err = _hook_pre(
                {"tool_name": "Read",
                 "tool_input": {"file_path": "/tmp/foo"},
                 "agent_id": "agent-uuid-abc123"},
                env_w,
            )
            results.append(_check(
                "74f. Monitor gate: subagent + Read -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74g: OBLIGATIONS_BYPASS=1 forces allow even for subagent
            # Monitor calls -- the audited bypass is the documented
            # escape hatch, same as for the watcher-ctl gate.
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "t"},
                 "agent_id": "agent-uuid-abc123"},
                env_w,
                extra_env={"OBLIGATIONS_BYPASS": "1"},
            )
            results.append(_check(
                "74g. Monitor gate: OBLIGATIONS_BYPASS=1 forces allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 74h: subagent + null agent_id (JSON null) -> ALLOW
            # Defensive: a non-string agent_id should be coerced to "".
            # `_hook_pre` JSON-encodes the dict, so a Python None becomes
            # JSON null on the wire.
            rc, out, _err = _hook_pre(
                {"tool_name": "Monitor",
                 "tool_input": {"task_id": "t"},
                 "agent_id": None},
                env_w,
            )
            results.append(_check(
                "74h. Monitor gate: null agent_id -> allow (defensive)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

        # ---------------------------------------------------------------
        # Tests 75-88: stale_ready_queue_present predicate.
        #
        # Each test starts with a clean obligations sandbox and a custom
        # queue.json fixture under tmpdir. The predicate is registered
        # with `queue_path` overridden to point at the fixture so the
        # tests don't touch the live queue.
        # ---------------------------------------------------------------
        with tempfile.TemporaryDirectory(prefix="obligations-stale-") as td_s:
            tmpdir_s = Path(td_s)
            env_s, _ob_s = _make_isolated_env(tmpdir_s)
            queue_path = tmpdir_s / "queue.json"

            def _write_queue(items):
                queue_path.write_text(json.dumps({"items": items}))

            def _add_stale_ob(threshold=300, exempt=None):
                return _add_ob(
                    env_s,
                    tool_pattern="*",
                    predicate="stale_ready_queue_present",
                    params={
                        "queue_path": str(queue_path),
                        "threshold_secs": threshold,
                    },
                    ttl=600,
                    deny_msg="dispatch the stale queue item before unrelated work",
                    exempt_tool_patterns=exempt,
                )

            now_ts = time.time()

            def _iso(offset_secs):
                from datetime import datetime as _dt, timezone as _tz
                return _dt.fromtimestamp(now_ts + offset_secs,
                                         tz=_tz.utc).isoformat()

            # --- 75: empty queue -> allow ---
            _write_queue([])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "75. stale_ready_queue_present: empty queue -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 76: queue file missing -> allow (default-open) ---
            queue_path.unlink(missing_ok=True)
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "76. stale_ready_queue_present: queue missing -> allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 77: malformed queue.json -> allow (default-open) ---
            queue_path.write_text("{not json")
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "77. stale_ready_queue_present: malformed -> allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 78: ready+pending fresh (1 min old) -> allow ---
            _write_queue([{
                "id": "q-fresh",
                "status": "pending",
                "group_id": "g-1",
                "priority": 5,
                "created_at": _iso(-60),
                "summary": "fresh item",
            }])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "78. stale_ready_queue_present: fresh ready -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 79: ready+pending stale (10 min) -> deny + id in why ---
            _write_queue([{
                "id": "q-stale-79",
                "status": "pending",
                "group_id": "g-1",
                "priority": 5,
                "created_at": _iso(-600),
                "summary": "stale item",
            }])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            denied = _is_deny(out)
            reason = (out.get("hookSpecificOutput") or {}).get(
                "permissionDecisionReason", ""
            )
            banner = out.get("systemMessage", "")
            results.append(_check(
                "79. stale_ready_queue_present: stale ready -> deny + id in why",
                rc == 0 and denied
                and ("q-stale-79" in reason or "q-stale-79" in banner),
                f"rc={rc} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 80: status=running NOT counted (only pending) ---
            _write_queue([{
                "id": "q-run",
                "status": "running",
                "group_id": "g-1",
                "priority": 5,
                "created_at": _iso(-600),
                "summary": "running item",
            }])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "80. stale_ready_queue_present: running item not counted -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 81: pending blocked by running peer in same group -> allow ---
            _write_queue([
                {"id": "q-running-head", "status": "running", "group_id": "g-1",
                 "priority": 5, "created_at": _iso(-1200), "summary": "head"},
                {"id": "q-blocked", "status": "pending", "group_id": "g-1",
                 "priority": 5, "created_at": _iso(-600), "summary": "blocked"},
            ])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            results.append(_check(
                "81. stale_ready_queue_present: blocked-by-running-peer -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 82: non-head pending in group (lower priority) -> allow ---
            _write_queue([
                # Higher priority pending item is the head; lower-priority
                # entry is not ready_now even though both are stale.
                {"id": "q-head-pending", "status": "pending", "group_id": "g-1",
                 "priority": 7, "created_at": _iso(-1200), "summary": "head"},
                {"id": "q-tail-pending", "status": "pending", "group_id": "g-1",
                 "priority": 5, "created_at": _iso(-1200), "summary": "tail"},
            ])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            denied = _is_deny(out)
            reason = (out.get("hookSpecificOutput") or {}).get(
                "permissionDecisionReason", ""
            ) + " " + out.get("systemMessage", "")
            # Head should be flagged; tail should NOT.
            results.append(_check(
                "82. stale_ready_queue_present: non-head pending NOT counted",
                rc == 0 and denied
                and "q-head-pending" in reason
                and "q-tail-pending" not in reason,
                f"rc={rc} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 83: custom threshold honored (60s; 90s old item triggers) ---
            _write_queue([{
                "id": "q-90s", "status": "pending", "group_id": "g-1",
                "priority": 5, "created_at": _iso(-90), "summary": "90s old",
            }])
            # threshold=60 => 90s item DOES qualify; threshold=120 => doesn't.
            ob_low = _add_stale_ob(threshold=60)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            denied_low = _is_deny(out)
            _run([str(CLI), "satisfy", ob_low], env_s)
            ob_high = _add_stale_ob(threshold=120)
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            allowed_high = _is_allow(out)
            _run([str(CLI), "satisfy", ob_high], env_s)
            results.append(_check(
                "83. stale_ready_queue_present: custom threshold honored",
                denied_low and allowed_high,
                f"denied_low={denied_low} allowed_high={allowed_high}",
            ))

            # --- 84: multiple stale items, oldest first ---
            _write_queue([
                {"id": "q-old-30m", "status": "pending", "group_id": "g-1",
                 "priority": 5, "created_at": _iso(-1800), "summary": "30m old"},
                {"id": "q-mid-10m", "status": "pending", "group_id": "g-2",
                 "priority": 5, "created_at": _iso(-600), "summary": "10m old"},
            ])
            ob = _add_stale_ob()
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            banner = out.get("systemMessage", "")
            reason = (out.get("hookSpecificOutput") or {}).get(
                "permissionDecisionReason", ""
            )
            combined = banner + " " + reason
            # Both ids should appear; oldest first ordering: q-old-30m before q-mid-10m
            i_old = combined.find("q-old-30m")
            i_mid = combined.find("q-mid-10m")
            results.append(_check(
                "84. stale_ready_queue_present: multiple stale, oldest first",
                rc == 0 and _is_deny(out)
                and i_old != -1 and i_mid != -1 and i_old < i_mid,
                f"i_old={i_old} i_mid={i_mid} combined={combined[:300]!r}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 85: exempt Agent tool allowed even when stale items present ---
            _write_queue([{
                "id": "q-stale-85", "status": "pending", "group_id": "g-1",
                "priority": 5, "created_at": _iso(-600), "summary": "stale",
            }])
            ob = _add_stale_ob(exempt=["Agent"])
            rc, out, _err = _hook_pre(
                {"tool_name": "Agent",
                 "tool_input": {"prompt": "Queue item: q-stale-85\nDo X"}},
                env_s,
            )
            results.append(_check(
                "85. stale_ready_queue_present: Agent exempt -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            # Sanity: a non-exempt Bash call IS denied with the same obligation.
            rc2, out2, _e2 = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_s,
            )
            results.append(_check(
                "85b. stale_ready_queue_present: non-exempt Bash still denied",
                rc2 == 0 and _is_deny(out2),
                f"rc={rc2} out={out2}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 86: exempt session-task queue register/spawn-check allowed ---
            ob = _add_stale_ob(exempt=[
                "Bash:^session-task queue (register|spawn-check|add|abandon|done)\\b",
            ])
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command":
                                "session-task queue register q-stale-85"}},
                env_s,
            )
            results.append(_check(
                "86. stale_ready_queue_present: session-task queue register exempt",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 87: scope-guard subagent bypass via all_of[is_main_loop, X] ---
            # Register an obligation that's main-loop-only via all_of.
            proc_add = _run([
                str(CLI), "add",
                "--tool-pattern", "*",
                "--predicate", "all_of",
                "--params", json.dumps({"predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {"kind": "stale_ready_queue_present",
                     "params": {"queue_path": str(queue_path)}},
                ]}),
                "--ttl", "600",
                "--deny-msg", "dispatch stale queue item",
                "--created-by", "test",
                "--json",
            ], env_s)
            ob_id = json.loads(proc_add.stdout)["id"]
            # Subagent call (agent_id present) -> scope-guard inactive -> allow
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"},
                 "agent_id": "subagent-xyz"},
                env_s,
            )
            sub_allow = _is_allow(out)
            # Main-loop call (no agent_id) -> predicate fires -> deny
            rc2, out2, _e2 = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_s,
            )
            main_deny = _is_deny(out2)
            results.append(_check(
                "87. stale_ready_queue_present: scope-guard "
                "(subagent allow / main-loop deny)",
                sub_allow and main_deny,
                f"sub_allow={sub_allow} main_deny={main_deny}",
            ))
            _run([str(CLI), "satisfy", ob_id], env_s)

            # --- 88: stale_ready_queue_present is auto-mandatory ---
            # Per Andrew DM 2026-05-03 05:16 ET, event-queueing
            # obligations (stale-ready, ...) are AUTO-MANDATORY:
            # `obligations override` MUST refuse (exit 4) while a
            # mandatory row is active. The operator must dispatch /
            # abandon the underlying work (or `obligations satisfy
            # <id>`) instead. The hook should still DENY (override
            # never landed).
            ob = _add_stale_ob()
            ov_proc = subprocess.run(
                [str(CLI), "override", "test bypass for stale",
                 "--duration", "60", "--created-by", "test"],
                env=env_s, capture_output=True, text=True,
            )
            override_refused = (
                ov_proc.returncode == 4
                and "MANDATORY" in ov_proc.stderr
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_s,
            )
            still_denied = _is_deny(out)
            results.append(_check(
                "88. stale_ready_queue_present: auto-mandatory refuses override",
                override_refused and still_denied,
                f"override_rc={ov_proc.returncode} "
                f"override_stderr={ov_proc.stderr!r} "
                f"hook_out={out!r}",
            ))
            _run([str(CLI), "satisfy", ob], env_s)

            # --- 89: override calls pingme (when not suppressed) ---
            # Install a fake pingme on PATH that records its argv to a file.
            pingme_log = tmpdir_s / "pingme.log"
            fake_bin = tmpdir_s / "fake-bin"
            fake_bin.mkdir(parents=True, exist_ok=True)
            fake_pingme = fake_bin / "pingme"
            fake_pingme.write_text(
                "#!/usr/bin/env bash\n"
                f"echo \"$@\" >> {pingme_log}\n"
                "exit 0\n"
            )
            fake_pingme.chmod(0o755)
            env_pm = env_s.copy()
            env_pm["PATH"] = f"{fake_bin}:{env_s.get('PATH','')}"
            # Make sure the suppression is OFF for this test (it's set in
            # the outer test invocation env, but we want to actively
            # exercise the call path here).
            env_pm.pop("OBLIGATIONS_DISABLE_PINGME", None)
            # Create the override.
            proc = _run([
                str(CLI), "override", "test pingme override",
                "--duration", "120",
                "--created-by", "test",
                "--json",
            ], env_pm)
            ov_pm_id = (json.loads(proc.stdout)["id"]
                        if proc.returncode == 0 else "")
            pingme_called = (
                pingme_log.exists()
                and ov_pm_id in pingme_log.read_text()
                and "test pingme override" in pingme_log.read_text()
            )
            results.append(_check(
                "89. override: pingme called with override id + reason + duration",
                proc.returncode == 0 and pingme_called,
                f"rc={proc.returncode} pingme_log_exists={pingme_log.exists()} "
                f"contents={pingme_log.read_text() if pingme_log.exists() else None!r}",
            ))
            if ov_pm_id:
                _run([str(CLI), "satisfy", ov_pm_id], env_pm)

            # --- 90: override pingme suppressed by env flag ---
            pingme_log.unlink(missing_ok=True)
            env_pm_off = env_pm.copy()
            env_pm_off["OBLIGATIONS_DISABLE_PINGME"] = "1"
            proc = _run([
                str(CLI), "override", "suppressed override",
                "--duration", "120",
                "--created-by", "test",
                "--json",
            ], env_pm_off)
            ov_off_id = (json.loads(proc.stdout)["id"]
                         if proc.returncode == 0 else "")
            results.append(_check(
                "90. override: pingme suppressed by OBLIGATIONS_DISABLE_PINGME",
                proc.returncode == 0 and not pingme_log.exists(),
                f"rc={proc.returncode} pingme_log_exists={pingme_log.exists()}",
            ))
            if ov_off_id:
                _run([str(CLI), "satisfy", ov_off_id], env_pm_off)

        # ---------------------------------------------------------------
        # Tests 91-98: UNIVERSAL RECOVERY EXEMPT (deadlock prevention)
        #
        # An obligation row may forget to list `Bash:^obligations`,
        # `Bash:^session-task queue`, Read, Agent, or watcher-* in its
        # exempt_patterns. Without a framework-level floor, two such
        # obligations whose exempt sets do not overlap form a deadlock:
        # whichever recovery action you try is blocked by the OTHER
        # obligation. The universal recovery exempts solve this by
        # ALWAYS allowing the recovery surface, regardless of per-row
        # configuration.
        #
        # We register obligations with BARE * tool_pattern and NO
        # exempt_patterns so the gate would deny everything but the
        # framework-level floor. Then we confirm every recovery surface
        # call still passes.
        # ---------------------------------------------------------------
        with tempfile.TemporaryDirectory(prefix="obligations-univ-") as td_u:
            tmpdir_u = Path(td_u)
            env_u, _ob_u = _make_isolated_env(tmpdir_u)
            # Predicate that always FAILS: file_exists for a nonexistent
            # path. The * tool_pattern + no exempt_patterns would block
            # every tool absent the universal recovery floor.
            missing = tmpdir_u / "this-does-not-exist"
            ob_universal = _add_ob(
                env_u,
                tool_pattern="*",
                predicate="file_exists",
                params={"path": str(missing)},
                ttl=600,
                deny_msg="universal-deadlock-test gate",
            )

            # 91: `obligations override <reason> --duration <s>` allowed.
            # We exercise via the hook (not the CLI) -- the hook is what
            # the harness wires; the CLI itself is separately exempt.
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "obligations override stuck "
                                            "--duration 5m"}},
                env_u,
            )
            results.append(_check(
                "91. universal recovery: obligations override allowed",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 92: session-task queue register
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "session-task queue register "
                                            "q-test-0001"}},
                env_u,
            )
            results.append(_check(
                "92. universal recovery: session-task queue register allowed",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 93: Read of /tmp/.../tasks/<id>.output
            rc, out, _err = _hook_pre(
                {"tool_name": "Read",
                 "tool_input": {"file_path":
                                "/tmp/claude-1000/abc/tasks/9-bg.output"}},
                env_u,
            )
            results.append(_check(
                "93. universal recovery: Read of tasks/<id>.output allowed",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 94: Agent tool always allowed (dispatcher recovery path).
            rc, out, _err = _hook_pre(
                {"tool_name": "Agent",
                 "tool_input": {"prompt": "subagent prompt body"}},
                env_u,
            )
            results.append(_check(
                "94. universal recovery: Agent allowed past arbitrary deny",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # 95: watcher-restart
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "watcher-restart"}},
                env_u,
            )
            results.append(_check(
                "95. universal recovery: watcher-restart allowed past arbitrary deny",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))

            # Sanity: an UNRELATED Bash call should STILL be denied (the
            # gate is firing -- only the recovery surface is exempt).
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "ls /nonexistent"}},
                env_u,
            )
            results.append(_check(
                "95b. universal recovery: non-recovery Bash still denied "
                "(gate is firing, only recovery surface bypasses)",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))

            # 96: DEADLOCK SCENARIO -- replay the prompt's exact case.
            # Two obligations active simultaneously, neither one's exempt
            # set covers the other's recovery action. Without the
            # universal recovery floor, the loop would be stuck.
            # We use file_exists for both to keep the test hermetic; the
            # SHAPE (two * obligations with disjoint exempts) is what
            # matters.
            ob_a = _add_ob(
                env_u,
                tool_pattern="*",
                predicate="file_exists",
                params={"path": str(tmpdir_u / "missing-a")},
                ttl=600,
                deny_msg="gate A",
                exempt_tool_patterns=["Read", "Bash:^watcher-ctl\\b"],
            )
            ob_b = _add_ob(
                env_u,
                tool_pattern="*",
                predicate="file_exists",
                params={"path": str(tmpdir_u / "missing-b")},
                ttl=600,
                deny_msg="gate B",
                exempt_tool_patterns=[
                    "Bash:^session-task queue (register|done)\\b",
                ],
            )
            # In the OLD design, every recovery call hits at least one
            # gate. Now the universal floor passes them all.
            for cmd, label in [
                ("obligations override deadlock --duration 5m",
                 "obligations override"),
                ("session-task queue register q-x", "session-task register"),
                ("watcher-restart", "watcher-restart"),
            ]:
                rc, out, _err = _hook_pre(
                    {"tool_name": "Bash", "tool_input": {"command": cmd}},
                    env_u,
                )
                results.append(_check(
                    f"96. deadlock scenario: {label} passes both gates",
                    rc == 0 and _is_allow(out),
                    f"rc={rc} out={out}",
                ))
            # Read also passes (universal floor + ob_a's per-row exempt).
            rc, out, _err = _hook_pre(
                {"tool_name": "Read",
                 "tool_input": {"file_path":
                                "/tmp/claude-1000/x/tasks/0-bg.output"}},
                env_u,
            )
            results.append(_check(
                "96. deadlock scenario: Read of captured-output passes both gates",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_a], env_u)
            _run([str(CLI), "satisfy", ob_b], env_u)
            _run([str(CLI), "satisfy", ob_universal], env_u)

            # 97: PROPERTY TEST -- iterate every pair of currently-active
            # obligation rows in the live obligations.json (not the
            # sandbox; we read the file directly read-only). For each
            # pair, the universal recovery surface MUST be allowed.
            #
            # Hermetic version: we replay the SHAPES we have deployed
            # (no_pending_watcher_outputs, watchers_healthy,
            # stale_ready_queue_present, signal-wait-dm process_alive,
            # the no-pipe_pattern signal-history rule, and an
            # inbox-empty agent-msg shape). Each is registered in turn
            # alongside the others; the universal recovery surface
            # must pass every time.
            #
            # We add ALL of them simultaneously and check the recovery
            # surface clears with EVERY combination.
            shapes = [
                # signal-history no-pipe pattern (Bash-narrow, doesn't
                # universally apply). Skipped because tool_pattern is
                # narrow.
                # process_alive on a missing pid_file -- always fails.
                ("Bash:^signal-send", "process_alive",
                 {"pid_file": str(tmpdir_u / "missing-pid")}),
                # watchers_healthy -- the predicate shells out; we mock
                # it to return DOWN by faking the binary. Use
                # file_exists as a stand-in so the shape matches.
                ("*", "file_exists",
                 {"path": str(tmpdir_u / "missing-watchers")}),
                # no_pending_watcher_outputs shape -- emulate by
                # file_exists on a missing path with * tool_pattern.
                ("*", "file_exists",
                 {"path": str(tmpdir_u / "missing-watcher-output")}),
                # stale_ready_queue_present shape -- file_exists fail
                # on * tool_pattern (the predicate's exempt list is
                # already in cron-queue-check; here we test the floor).
                ("*", "file_exists",
                 {"path": str(tmpdir_u / "missing-queue")}),
            ]
            shape_ids = []
            for tp, pred, par in shapes:
                shape_ids.append(_add_ob(
                    env_u,
                    tool_pattern=tp, predicate=pred, params=par,
                    ttl=600, deny_msg=f"shape {pred} on {tp}",
                ))
            # Now check every recovery-surface command passes.
            recovery_calls = [
                ("Bash", "obligations override deadlock --duration 5m"),
                ("Bash", "obligations satisfy ob-x"),
                ("Bash", "obligations prune"),
                ("Bash", "session-task queue register q-y"),
                ("Bash", "session-task queue done q-y"),
                ("Bash", "session-task queue spawn-check q-y"),
                ("Bash", "session-task queue add 'foo'"),
                ("Bash", "session-task set 'state'"),
                ("Bash", "session-task clear"),
                ("Bash", "watcher-ctl run signal-wait-dm"),
                ("Bash", "watcher-status --unhealthy-only"),
                ("Bash", "watcher-restart"),
                ("Bash", "pgrep -f signal-wait-dm"),
                ("Bash", "self-clear"),
                ("Agent", None),
                ("Read", "/tmp/claude-1000/abc/tasks/9-bg.output"),
            ]
            all_passed = True
            failure_details: list[str] = []
            for tn, body in recovery_calls:
                if tn == "Bash":
                    payload = {"tool_name": "Bash",
                               "tool_input": {"command": body}}
                elif tn == "Read":
                    payload = {"tool_name": "Read",
                               "tool_input": {"file_path": body}}
                else:
                    payload = {"tool_name": tn,
                               "tool_input": {"prompt": "x"}}
                rc, out, _err = _hook_pre(payload, env_u)
                if not (rc == 0 and _is_allow(out)):
                    all_passed = False
                    failure_details.append(f"{tn}:{body!r} -> {out}")
            results.append(_check(
                "97. property: every recovery-surface call passes "
                f"with {len(shapes)} concurrent gate-mode obligations",
                all_passed,
                "; ".join(failure_details)[:600],
            ))
            for sid in shape_ids:
                _run([str(CLI), "satisfy", sid], env_u)

            # 98: inform-mode also honors universal recovery.
            ob_inform = _add_ob(
                env_u,
                tool_pattern="*",
                predicate="file_exists",
                params={"path": str(tmpdir_u / "missing-inform")},
                ttl=600,
                deny_msg="inform should suppress on recovery",
                enforcement="inform",
            )
            # PostToolUse hook: surfacing happens in stderr. We invoke
            # it with a recovery-surface command and confirm the inform
            # banner is suppressed.
            payload_post = {
                "tool_name": "Bash",
                "tool_input": {"command": "obligations list"},
                "tool_response": {"output": ""},
            }
            rc_post, out_post, err_post = _hook_post(payload_post, env_u)
            inform_silent = "inform should suppress on recovery" not in err_post
            results.append(_check(
                "98. inform-mode also suppressed by universal recovery exempts",
                rc_post == 0 and inform_silent,
                f"rc={rc_post} stderr={err_post[:300]!r}",
            ))
            _run([str(CLI), "satisfy", ob_inform], env_u)

        # ===================================================================
        # Tests 99-105: force_started_unspawned predicate.
        #
        # Used by `session-task queue force-start` to gate the main loop
        # after a force-start until an Agent has been dispatched for the
        # promoted queue id. Predicate fails iff the queue item is
        # `running` AND no live agent record exists for it in the
        # active-agents JSON. Default-open on any IO / parse error.
        # ===================================================================
        with tempfile.TemporaryDirectory(prefix="obligations-fs-") as td_fs:
            tmpdir_fs = Path(td_fs)
            env_fs, _ob_fs = _make_isolated_env(tmpdir_fs)

            # Helper: write a queue.json with one item.
            def _write_queue_one(path, qid, status, summary="test summary"):
                path.parent.mkdir(parents=True, exist_ok=True)
                path.write_text(json.dumps({
                    "items": [{
                        "id": qid,
                        "status": status,
                        "group_id": "g-x",
                        "summary": summary,
                        "scope": ["test"],
                        "created_at": "2026-05-02T00:00:00+00:00",
                    }],
                }) + "\n")

            # Helper: write an active-agents.json with given agent records.
            def _write_agents(path, records):
                path.parent.mkdir(parents=True, exist_ok=True)
                path.write_text(json.dumps({
                    "subagents": [],
                    "workloads": [],
                    "agents": records,
                }) + "\n")

            # 99: queue running + no agent record at all -> DENY
            qfile_99 = tmpdir_fs / "fs99-queue.json"
            afile_99 = tmpdir_fs / "fs99-agents.json"
            _write_queue_one(qfile_99, "q-fs-99-test", "running")
            _write_agents(afile_99, [])
            ob_99 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-99-test",
                    "queue_path": str(qfile_99),
                    "agents_state_path": str(afile_99),
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-99-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            banner = (out or {}).get("systemMessage", "")
            results.append(_check(
                "99. force_started_unspawned: running + no agent -> deny",
                (rc == 0 and _is_deny(out)
                 and "q-fs-99-test" in banner
                 and "spawn an Agent" in banner),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_99], env_fs)

            # 100: queue running + live agent record -> ALLOW
            qfile_100 = tmpdir_fs / "fs100-queue.json"
            afile_100 = tmpdir_fs / "fs100-agents.json"
            _write_queue_one(qfile_100, "q-fs-100-test", "running")
            _write_agents(afile_100, [
                {
                    "agent_id": "a-fs-100",
                    "queue_id": "q-fs-100-test",
                    "alive": True,
                    "jsonl_age_seconds": 4,
                },
            ])
            ob_100 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-100-test",
                    "queue_path": str(qfile_100),
                    "agents_state_path": str(afile_100),
                },
                ttl=120,
                deny_msg="(should not fire)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "100. force_started_unspawned: running + live agent -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_100], env_fs)

            # 101: queue running + dead agent record -> DENY
            # alive=false means the prior dispatch is gone -- we still owe a
            # fresh spawn while the queue item remains `running`.
            qfile_101 = tmpdir_fs / "fs101-queue.json"
            afile_101 = tmpdir_fs / "fs101-agents.json"
            _write_queue_one(qfile_101, "q-fs-101-test", "running")
            _write_agents(afile_101, [
                {
                    "agent_id": "a-fs-101",
                    "queue_id": "q-fs-101-test",
                    "alive": False,
                    "jsonl_age_seconds": 9999,
                },
            ])
            ob_101 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-101-test",
                    "queue_path": str(qfile_101),
                    "agents_state_path": str(afile_101),
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-101-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "101. force_started_unspawned: running + dead agent -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_101], env_fs)

            # 102: queue done -> ALLOW (obligation moot once item completes)
            qfile_102 = tmpdir_fs / "fs102-queue.json"
            afile_102 = tmpdir_fs / "fs102-agents.json"
            _write_queue_one(qfile_102, "q-fs-102-test", "done")
            _write_agents(afile_102, [])
            ob_102 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-102-test",
                    "queue_path": str(qfile_102),
                    "agents_state_path": str(afile_102),
                },
                ttl=120,
                deny_msg="(should not fire)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "102. force_started_unspawned: queue done -> allow (moot)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_102], env_fs)

            # 103: missing active-agents file -> DENY
            qfile_103 = tmpdir_fs / "fs103-queue.json"
            afile_103 = tmpdir_fs / "fs103-NONEXISTENT.json"
            _write_queue_one(qfile_103, "q-fs-103-test", "running")
            ob_103 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-103-test",
                    "queue_path": str(qfile_103),
                    "agents_state_path": str(afile_103),
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-103-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "103. force_started_unspawned: missing agents file -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_103], env_fs)

            # 104: missing queue.json -> ALLOW (default-open: a broken queue
            # state must not blackhole the loop).
            qfile_104 = tmpdir_fs / "fs104-NONEXISTENT.json"
            afile_104 = tmpdir_fs / "fs104-agents.json"
            _write_agents(afile_104, [])
            ob_104 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-104-test",
                    "queue_path": str(qfile_104),
                    "agents_state_path": str(afile_104),
                },
                ttl=120,
                deny_msg="(should not fire)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "104. force_started_unspawned: missing queue.json -> "
                "allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_104], env_fs)

            # 105: Agent tool itself is universally exempt, so a force-
            # started-unspawned obligation must still allow the spawning
            # Agent call through. Otherwise the gate self-deadlocks (you
            # can't spawn the agent that satisfies you).
            qfile_105 = tmpdir_fs / "fs105-queue.json"
            afile_105 = tmpdir_fs / "fs105-agents.json"
            _write_queue_one(qfile_105, "q-fs-105-test", "running")
            _write_agents(afile_105, [])  # no agent yet -> would deny Bash
            ob_105 = _add_ob(
                env_fs,
                tool_pattern="*",  # universal pattern -- worst case
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-105-test",
                    "queue_path": str(qfile_105),
                    "agents_state_path": str(afile_105),
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-105-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Agent",
                 "tool_input": {"prompt": "Queue item: q-fs-105-test\nGo"}},
                env_fs,
            )
            results.append(_check(
                "105. force_started_unspawned: Agent tool exempt -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_105], env_fs)

            # ===================================================================
            # Tests 106-109: force_started_unspawned + pending-spawns sidecar.
            #
            # Closes the cron-cadence race in the original predicate: the
            # active-agents poller refreshes every 60s, but the
            # pre-agent-queue-gate-hook writes a synthetic pending-spawn
            # record at PreToolUse:Agent time. The predicate must accept a
            # FRESH pending-spawn entry as proof of dispatch, ignore stale
            # ones, ignore mismatched queue ids, and default-open on a
            # corrupt file.
            # ===================================================================

            # Helper: write a pending-spawns.json with given entries.
            def _write_pending(path, entries):
                path.parent.mkdir(parents=True, exist_ok=True)
                path.write_text(json.dumps({"pending": entries}) + "\n")

            # 106: queue running + no agent + FRESH pending-spawn -> ALLOW
            qfile_106 = tmpdir_fs / "fs106-queue.json"
            afile_106 = tmpdir_fs / "fs106-agents.json"
            pfile_106 = tmpdir_fs / "fs106-pending.json"
            _write_queue_one(qfile_106, "q-fs-106-test", "running")
            _write_agents(afile_106, [])
            _write_pending(pfile_106, [{
                "queue_id": "q-fs-106-test",
                "registered_at": int(time.time()),
                "pid": 12345,
            }])
            ob_106 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-106-test",
                    "queue_path": str(qfile_106),
                    "agents_state_path": str(afile_106),
                    "pending_spawns_path": str(pfile_106),
                },
                ttl=120,
                deny_msg="(should not fire)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "106. force_started_unspawned: fresh pending-spawn -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_106], env_fs)

            # 107: queue running + no agent + STALE pending-spawn -> DENY
            # `pending_spawn_max_age_secs=0` makes any non-zero-age entry
            # stale, so an entry registered 5s ago is rejected.
            qfile_107 = tmpdir_fs / "fs107-queue.json"
            afile_107 = tmpdir_fs / "fs107-agents.json"
            pfile_107 = tmpdir_fs / "fs107-pending.json"
            _write_queue_one(qfile_107, "q-fs-107-test", "running")
            _write_agents(afile_107, [])
            _write_pending(pfile_107, [{
                "queue_id": "q-fs-107-test",
                "registered_at": int(time.time()) - 5,
                "pid": 12345,
            }])
            ob_107 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-107-test",
                    "queue_path": str(qfile_107),
                    "agents_state_path": str(afile_107),
                    "pending_spawns_path": str(pfile_107),
                    "pending_spawn_max_age_secs": 0,
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-107-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "107. force_started_unspawned: stale pending-spawn -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_107], env_fs)

            # 108: queue running + no agent + WRONG-QID pending-spawn -> DENY
            # A pending-spawn for a DIFFERENT queue id must not satisfy us.
            qfile_108 = tmpdir_fs / "fs108-queue.json"
            afile_108 = tmpdir_fs / "fs108-agents.json"
            pfile_108 = tmpdir_fs / "fs108-pending.json"
            _write_queue_one(qfile_108, "q-fs-108-test", "running")
            _write_agents(afile_108, [])
            _write_pending(pfile_108, [{
                "queue_id": "q-fs-108-OTHER",
                "registered_at": int(time.time()),
                "pid": 12345,
            }])
            ob_108 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-108-test",
                    "queue_path": str(qfile_108),
                    "agents_state_path": str(afile_108),
                    "pending_spawns_path": str(pfile_108),
                },
                ttl=120,
                deny_msg="must spawn agent for q-fs-108-test",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "108. force_started_unspawned: wrong-qid pending-spawn -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_108], env_fs)

            # 109: corrupt pending-spawns.json -> default-open ALLOW (we do
            # NOT blackhole on a parse error -- same posture as the
            # active-agents and queue.json default-open clauses).
            qfile_109 = tmpdir_fs / "fs109-queue.json"
            afile_109 = tmpdir_fs / "fs109-agents.json"
            pfile_109 = tmpdir_fs / "fs109-pending.json"
            _write_queue_one(qfile_109, "q-fs-109-test", "running")
            _write_agents(afile_109, [])
            pfile_109.parent.mkdir(parents=True, exist_ok=True)
            pfile_109.write_text("not json {{{")
            ob_109 = _add_ob(
                env_fs,
                tool_pattern="Bash",
                predicate="force_started_unspawned",
                params={
                    "queue_id": "q-fs-109-test",
                    "queue_path": str(qfile_109),
                    "agents_state_path": str(afile_109),
                    "pending_spawns_path": str(pfile_109),
                },
                ttl=120,
                deny_msg="(should not fire)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}}, env_fs,
            )
            results.append(_check(
                "109. force_started_unspawned: corrupt pending file -> "
                "allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_109], env_fs)

        # ===========================================================
        # Tests 110-115: --mandatory flag + AUTO_MANDATORY_PREDICATE_KINDS
        # (Andrew DM 2026-05-03 05:16 ET: event-queueing obligations
        # must be non-bypassable. `obligations override` must refuse
        # exit-4 when any active mandatory row exists.)
        # ===========================================================
        with tempfile.TemporaryDirectory(prefix="obligations-mand-") as td_m:
            tmpdir_m = Path(td_m)
            env_m, ob_path_m = _make_isolated_env(tmpdir_m)

            # --- 110: `obligations add --mandatory` persists the flag ---
            proc_add = _run([
                str(CLI), "add",
                "--tool-pattern", "Bash",
                "--predicate", "file_exists",
                "--params", json.dumps({"path": "/nonexistent/path-110"}),
                "--ttl", "60",
                "--deny-msg", "explicit mandatory test",
                "--mandatory",
                "--created-by", "test",
                "--json",
            ], env_m)
            ob_110 = (json.loads(proc_add.stdout)["id"]
                      if proc_add.returncode == 0 else None)
            persisted_mandatory = False
            if ob_110:
                state = json.loads(ob_path_m.read_text())
                for ob in state.get("obligations", []):
                    if ob.get("id") == ob_110:
                        persisted_mandatory = bool(ob.get("mandatory"))
                        break
            results.append(_check(
                "110. obligations add --mandatory persists mandatory=true",
                proc_add.returncode == 0 and persisted_mandatory,
                f"rc={proc_add.returncode} persisted={persisted_mandatory} "
                f"stdout={proc_add.stdout[:200]!r} "
                f"stderr={proc_add.stderr[:200]!r}",
            ))

            # --- 111: override against mandatory row -> exit 4 ---
            ov_proc_111 = _run([
                str(CLI), "override",
                "explicit mandatory bypass attempt",
                "--duration", "60", "--created-by", "test",
            ], env_m)
            results.append(_check(
                "111. override against --mandatory row -> exit 4 + MANDATORY",
                (ov_proc_111.returncode == 4
                 and "MANDATORY" in ov_proc_111.stderr),
                f"rc={ov_proc_111.returncode} "
                f"stderr={ov_proc_111.stderr!r}",
            ))
            if ob_110:
                _run([str(CLI), "satisfy", ob_110], env_m)

            # --- 112: override against non-mandatory row -> still works ---
            # (regression: legacy gate-mode rows continue to be bypassable.)
            ob_112 = _add_ob(
                env_m,
                tool_pattern="Bash",
                predicate="file_exists",
                params={"path": "/nonexistent/path-112"},
                ttl=60,
                deny_msg="non-mandatory test",
            )
            ov_proc_112 = _run([
                str(CLI), "override", "non-mandatory bypass test",
                "--duration", "60", "--created-by", "test",
                "--json",
            ], env_m)
            ov_112_id = ""
            if ov_proc_112.returncode == 0:
                try:
                    ov_112_id = json.loads(ov_proc_112.stdout).get("id", "")
                except json.JSONDecodeError:
                    pass
            results.append(_check(
                "112. override against non-mandatory row still works",
                (ov_proc_112.returncode == 0
                 and ov_112_id.startswith("ov-")),
                f"rc={ov_proc_112.returncode} "
                f"stdout={ov_proc_112.stdout[:200]!r} "
                f"stderr={ov_proc_112.stderr[:200]!r}",
            ))
            if ov_112_id:
                _run([str(CLI), "satisfy", ov_112_id], env_m)
            _run([str(CLI), "satisfy", ob_112], env_m)

            # --- 113: stale_ready_queue_present is AUTO-MANDATORY even
            # without --mandatory at registration. Provide a queue file
            # with one stale ready+pending item so the predicate is
            # active. Override must refuse exit-4. ---
            qfile_113 = tmpdir_m / "mand-113-queue.json"
            stale_ts = time.time() - 600  # 10 min ago
            iso_stale = (
                __import__("datetime").datetime
                .fromtimestamp(stale_ts,
                               tz=__import__("datetime").timezone.utc)
                .isoformat()
            )
            qfile_113.write_text(json.dumps({
                "items": [{
                    "id": "q-mand-113",
                    "scope": "test",
                    "summary": "test stale ready",
                    "status": "pending",
                    "created_at": iso_stale,
                    "updated_at": iso_stale,
                    "group_id": "g-113",
                }],
            }))
            ob_113 = _add_ob(
                env_m,
                tool_pattern="*",
                predicate="stale_ready_queue_present",
                params={
                    "queue_path": str(qfile_113),
                    "threshold_secs": 300,
                },
                ttl=600,
                deny_msg="dispatch stale item",
            )
            # Verify the row was AUTO-marked mandatory in state.
            state_113 = json.loads(ob_path_m.read_text())
            row_113 = next((ob for ob in state_113.get("obligations", [])
                            if ob.get("id") == ob_113), None)
            auto_mand_persisted = bool(
                row_113 and row_113.get("mandatory") is True
            )
            ov_proc_113 = _run([
                str(CLI), "override", "stale-ready bypass attempt",
                "--duration", "60", "--created-by", "test",
            ], env_m)
            results.append(_check(
                "113. stale_ready_queue_present auto-mandatory: "
                "persisted + override refused",
                (auto_mand_persisted
                 and ov_proc_113.returncode == 4
                 and "MANDATORY" in ov_proc_113.stderr),
                f"auto_persisted={auto_mand_persisted} "
                f"rc={ov_proc_113.returncode} "
                f"stderr={ov_proc_113.stderr!r}",
            ))
            _run([str(CLI), "satisfy", ob_113], env_m)

            # --- 114: nested all_of [is_main_loop,
            # stale_ready_queue_present] still inherits auto-mandatory.
            # This mirrors the predicate cron-queue-check actually
            # registers in production. ---
            qfile_114 = tmpdir_m / "mand-114-queue.json"
            qfile_114.write_text(json.dumps({
                "items": [{
                    "id": "q-mand-114",
                    "scope": "test",
                    "summary": "test stale ready nested",
                    "status": "pending",
                    "created_at": iso_stale,
                    "updated_at": iso_stale,
                    "group_id": "g-114",
                }],
            }))
            ob_114 = _add_ob(
                env_m,
                tool_pattern="*",
                predicate="all_of",
                params={"predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {"kind": "stale_ready_queue_present", "params": {
                        "queue_path": str(qfile_114),
                        "threshold_secs": 300,
                    }},
                ]},
                ttl=600,
                deny_msg="dispatch stale item (nested)",
            )
            state_114 = json.loads(ob_path_m.read_text())
            row_114 = next((ob for ob in state_114.get("obligations", [])
                            if ob.get("id") == ob_114), None)
            nested_auto_persisted = bool(
                row_114 and row_114.get("mandatory") is True
            )
            ov_proc_114 = _run([
                str(CLI), "override", "nested all_of bypass attempt",
                "--duration", "60", "--created-by", "test",
            ], env_m)
            results.append(_check(
                "114. nested all_of[..,stale_ready_queue_present] "
                "inherits auto-mandatory + override refused",
                (nested_auto_persisted
                 and ov_proc_114.returncode == 4
                 and "MANDATORY" in ov_proc_114.stderr),
                f"nested_persisted={nested_auto_persisted} "
                f"rc={ov_proc_114.returncode} "
                f"stderr={ov_proc_114.stderr!r}",
            ))
            _run([str(CLI), "satisfy", ob_114], env_m)

            # --- 115: cron-queue-check parity: the exact obligation
            # shape that bin/cron-queue-check registers in production
            # (all_of[is_main_loop, stale_ready_queue_present] with
            # production exempt patterns) MUST be auto-mandatory and
            # MUST refuse override. Pure shape-check test. ---
            qfile_115 = tmpdir_m / "mand-115-queue.json"
            qfile_115.write_text(json.dumps({
                "items": [{
                    "id": "q-mand-115",
                    "scope": "test",
                    "summary": "cron-queue-check parity",
                    "status": "pending",
                    "created_at": iso_stale,
                    "updated_at": iso_stale,
                    "group_id": "g-115",
                }],
            }))
            # Replicate cron-queue-check's add invocation as faithfully
            # as possible (modulo the queue_path override for test
            # isolation). The shape mirrors register_stale_ready_obligation.
            cron_params = json.dumps({
                "predicates": [
                    {"kind": "is_main_loop", "params": {}},
                    {
                        "kind": "stale_ready_queue_present",
                        "params": {
                            "threshold_secs": 300,
                            "queue_path": str(qfile_115),
                        },
                    },
                ]
            })
            proc_cron = _run([
                str(CLI), "add",
                "--tool-pattern", "*",
                "--predicate", "all_of",
                "--params", cron_params,
                "--ttl", "360",
                "--deny-msg",
                "dispatch the stale ready+pending queue item before "
                "unrelated work",
                "--created-by", "cron-queue-check",
                "--mandatory",  # cron-queue-check passes this explicitly
                "--json",
            ], env_m)
            cron_ob_id = (json.loads(proc_cron.stdout)["id"]
                          if proc_cron.returncode == 0 else None)
            state_115 = json.loads(ob_path_m.read_text())
            row_115 = next((ob for ob in state_115.get("obligations", [])
                            if ob.get("id") == cron_ob_id), None)
            cron_persisted = bool(
                row_115 and row_115.get("mandatory") is True
            )
            ov_proc_115 = _run([
                str(CLI), "override", "cron-queue-check parity bypass",
                "--duration", "60", "--created-by", "test",
            ], env_m)
            results.append(_check(
                "115. cron-queue-check parity: production obligation "
                "shape is mandatory + override refused",
                (proc_cron.returncode == 0
                 and cron_persisted
                 and ov_proc_115.returncode == 4
                 and "MANDATORY" in ov_proc_115.stderr),
                f"add_rc={proc_cron.returncode} "
                f"persisted={cron_persisted} "
                f"ov_rc={ov_proc_115.returncode} "
                f"stderr={ov_proc_115.stderr!r}",
            ))
            if cron_ob_id:
                _run([str(CLI), "satisfy", cron_ob_id], env_m)

        # ===========================================================
        # Tests 116-123: subagent_queue_item_running predicate
        # (Andrew DM 2026-05-15: continuous queue-discipline
        # enforcement for subagents. Pairs with post-tool-agent-arm-
        # hook which writes agent_id -> q-id bindings.)
        # ===========================================================
        with tempfile.TemporaryDirectory(prefix="obligations-sqr-") as td_sqr:
            tmpdir_sqr = Path(td_sqr)
            env_sqr, ob_path_sqr = _make_isolated_env(tmpdir_sqr)

            qfile_sqr = tmpdir_sqr / "queue.json"
            bindings_sqr = tmpdir_sqr / "agent-queue-bindings.json"
            test_agent_id = "agent-sqr-test-001"

            def _write_queue_sqr(items):
                qfile_sqr.write_text(json.dumps({"items": items}))

            def _write_bindings_sqr(agent_id, qid):
                now_ts = int(time.time())
                bindings_sqr.write_text(json.dumps({
                    "bindings": {
                        agent_id: {
                            "queue_id": qid,
                            "registered_at": now_ts,
                            "registered_at_iso": "ignored",
                            "pid": 1,
                        }
                    }
                }))

            # Add an `all_of [is_main_loop {negate: true},
            # subagent_queue_item_running]` row so the predicate only
            # fires for subagents (matches the production seed shape).
            def _add_sqr_ob(extra_params=None):
                params = {"predicates": [
                    {"kind": "is_main_loop", "params": {"negate": True}},
                    {"kind": "subagent_queue_item_running",
                     "params": {
                         "bindings_path": str(bindings_sqr),
                         "queue_path": str(qfile_sqr),
                         **(extra_params or {}),
                     }},
                ]}
                return _add_ob(
                    env_sqr,
                    tool_pattern="*",
                    predicate="all_of",
                    params=params,
                    ttl=600,
                    deny_msg="subagent q-id not running",
                )

            # --- 116: q-id status=running + subagent -> ALLOW ---
            _write_queue_sqr([{
                "id": "q-sqr-001",
                "scope": "test",
                "summary": "running item",
                "status": "running",
                "created_at": "2026-05-15T00:00:00+00:00",
                "updated_at": "2026-05-15T00:00:00+00:00",
            }])
            _write_bindings_sqr(test_agent_id, "q-sqr-001")
            ob_116 = _add_sqr_ob()
            payload_subagent = {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": test_agent_id,
            }
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            results.append(_check(
                "116. subagent_queue_item_running: q-id running -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_116], env_sqr)

            # --- 117: q-id status=done + subagent -> DENY ---
            _write_queue_sqr([{
                "id": "q-sqr-001",
                "scope": "test",
                "summary": "done item",
                "status": "done",
                "created_at": "2026-05-15T00:00:00+00:00",
                "updated_at": "2026-05-15T00:00:00+00:00",
            }])
            ob_117 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", "")) if isinstance(out, dict) else ""
            results.append(_check(
                "117. subagent_queue_item_running: q-id done -> deny "
                "+ q-id named in reason",
                (rc == 0 and _is_deny(out)
                 and "q-sqr-001" in reason
                 and "done" in reason),
                f"rc={rc} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob_117], env_sqr)

            # --- 118: q-id status=abandoned + subagent -> DENY ---
            _write_queue_sqr([{
                "id": "q-sqr-001",
                "scope": "test",
                "summary": "abandoned item",
                "status": "abandoned",
                "created_at": "2026-05-15T00:00:00+00:00",
                "updated_at": "2026-05-15T00:00:00+00:00",
            }])
            ob_118 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", "")) if isinstance(out, dict) else ""
            results.append(_check(
                "118. subagent_queue_item_running: q-id abandoned -> deny",
                (rc == 0 and _is_deny(out)
                 and "q-sqr-001" in reason
                 and "abandoned" in reason),
                f"rc={rc} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob_118], env_sqr)

            # --- 119: q-id missing from queue + subagent -> DENY ---
            _write_queue_sqr([])  # empty queue
            ob_119 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", "")) if isinstance(out, dict) else ""
            results.append(_check(
                "119. subagent_queue_item_running: q-id missing from queue "
                "-> deny (Andrew's explicit case)",
                (rc == 0 and _is_deny(out)
                 and "q-sqr-001" in reason
                 and "missing" in reason),
                f"rc={rc} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob_119], env_sqr)

            # --- 120: binding file missing + subagent -> ALLOW
            #         (default-open: subagent pre-binding rollout) ---
            bindings_sqr.unlink()
            _write_queue_sqr([{
                "id": "q-sqr-001",
                "scope": "test",
                "summary": "still done",
                "status": "done",
                "created_at": "2026-05-15T00:00:00+00:00",
                "updated_at": "2026-05-15T00:00:00+00:00",
            }])
            ob_120 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            results.append(_check(
                "120. subagent_queue_item_running: binding file missing "
                "-> allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_120], env_sqr)

            # --- 121: corrupt bindings file -> ALLOW + audit ---
            bindings_sqr.write_text("{{ totally corrupt JSON")
            ob_121 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            results.append(_check(
                "121. subagent_queue_item_running: corrupt bindings "
                "-> allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_121], env_sqr)

            # --- 122: main-loop (no agent_id) -> ALLOW
            #         (predicate does not apply via scope guard) ---
            _write_bindings_sqr(test_agent_id, "q-sqr-001")
            _write_queue_sqr([{
                "id": "q-sqr-001",
                "scope": "test",
                "summary": "would-be-deny if subagent",
                "status": "done",
                "created_at": "2026-05-15T00:00:00+00:00",
                "updated_at": "2026-05-15T00:00:00+00:00",
            }])
            ob_122 = _add_sqr_ob()
            payload_main = {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                # No agent_id field -> main loop.
            }
            rc, out, _err = _hook_pre(payload_main, env_sqr)
            results.append(_check(
                "122. subagent_queue_item_running: main-loop call "
                "(no agent_id) -> allow (scope-guard skip)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_122], env_sqr)

            # --- 123: subagent w/o a binding entry -> ALLOW
            #         (default-open: subagent pre-binding rollout OR
            #         no q-id marker in original prompt) ---
            # Bindings file exists but only carries OTHER agents.
            bindings_sqr.write_text(json.dumps({
                "bindings": {
                    "agent-someone-else": {
                        "queue_id": "q-other-thing",
                        "registered_at": int(time.time()),
                        "registered_at_iso": "ignored",
                        "pid": 1,
                    }
                }
            }))
            ob_123 = _add_sqr_ob()
            rc, out, _err = _hook_pre(payload_subagent, env_sqr)
            results.append(_check(
                "123. subagent_queue_item_running: no entry for THIS "
                "agent -> allow (default-open)",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_123], env_sqr)

        # ===========================================================
        # Test 124: end-to-end -- arm via post-hook + mutate queue
        # status + observe deny on next pre-hook call. This is the
        # important wiring proof (Step 3 in v62b workbot prompt).
        # ===========================================================
        with tempfile.TemporaryDirectory(prefix="obligations-e2e-") as td_e2e:
            tmpdir_e2e = Path(td_e2e)
            env_e2e, ob_path_e2e = _make_isolated_env(tmpdir_e2e)

            qfile_e2e = tmpdir_e2e / "queue.json"
            bindings_e2e = tmpdir_e2e / "agent-queue-bindings.json"
            env_e2e["CLAUDE_AGENT_QUEUE_BINDINGS_PATH"] = str(bindings_e2e)

            # Register the seed-shape obligation (mirrors what
            # obligations-init seeds in production).
            _add_ob(
                env_e2e,
                tool_pattern="*",
                predicate="all_of",
                params={"predicates": [
                    {"kind": "is_main_loop", "params": {"negate": True}},
                    {"kind": "subagent_queue_item_running", "params": {
                        "bindings_path": str(bindings_e2e),
                        "queue_path": str(qfile_e2e),
                    }},
                ]},
                ttl=0,
                deny_msg="subagent q-id not running",
            )

            # Arm a subagent via post-tool-agent-arm-hook.
            arm_payload = {
                "tool_name": "Agent",
                "tool_input": {
                    "prompt": "Do the task.\nQueue item: q-e2e-001\n",
                },
                "tool_response": {
                    "async_launched": True,
                    "agentId": "agent-e2e-001",
                },
            }
            arm_hook = HOOKS_DIR / "post-tool-agent-arm-hook"
            arm_proc = subprocess.run(
                [str(arm_hook)], input=json.dumps(arm_payload),
                capture_output=True, text=True, env=env_e2e, timeout=5,
                check=False,
            )
            armed = bindings_e2e.exists()

            # Queue item is running -> subagent allowed.
            qfile_e2e.write_text(json.dumps({"items": [{
                "id": "q-e2e-001",
                "status": "running",
                "created_at": "2026-05-15T00:00:00+00:00",
            }]}))
            payload_e2e = {
                "tool_name": "Bash",
                "tool_input": {"command": "ls"},
                "agent_id": "agent-e2e-001",
            }
            rc_running, out_running, _err = _hook_pre(payload_e2e, env_e2e)

            # Flip to done; subagent denied.
            qfile_e2e.write_text(json.dumps({"items": [{
                "id": "q-e2e-001",
                "status": "done",
                "created_at": "2026-05-15T00:00:00+00:00",
            }]}))
            rc_done, out_done, _err = _hook_pre(payload_e2e, env_e2e)

            results.append(_check(
                "124. end-to-end: post-arm-hook writes binding, "
                "queue=running -> allow, queue=done -> deny",
                (arm_proc.returncode == 0
                 and armed
                 and rc_running == 0 and _is_allow(out_running)
                 and rc_done == 0 and _is_deny(out_done)),
                f"arm_rc={arm_proc.returncode} armed={armed} "
                f"running_allow={_is_allow(out_running)} "
                f"done_deny={_is_deny(out_done)}",
            ))

        # ===========================================================
        # Tests 125-141: evaluator predicate (generic delegation
        # primitive). Per Andrew DM 2026-05-15 17:00 ET: cw should
        # provide basic primitives; this one is NOT LLM-specific --
        # any user-supplied subprocess (script, LLM-call, HTTP probe,
        # regex audit) can be wired in.
        # ===========================================================
        with tempfile.TemporaryDirectory(prefix="obligations-eval-") as td_eval:
            tmpdir_eval = Path(td_eval)
            env_eval, ob_path_eval = _make_isolated_env(tmpdir_eval)
            scripts_dir = tmpdir_eval / "scripts"
            scripts_dir.mkdir(parents=True, exist_ok=True)

            def _write_script(name: str, body: str) -> str:
                p = scripts_dir / name
                p.write_text(body)
                p.chmod(0o755)
                return str(p)

            def _audit_log_lines() -> list[str]:
                """Read the obligations-hook-errors.log under the sandboxed
                HOME. Each line should be a JSON record; we just return raw
                lines so callers can grep."""
                log = (tmpdir_eval / ".config" / "claude"
                       / "obligations-hook-errors.log")
                if not log.exists():
                    return []
                try:
                    return [ln for ln in log.read_text(
                        encoding="utf-8").splitlines() if ln.strip()]
                except OSError:
                    return []

            def _audit_log_clear():
                log = (tmpdir_eval / ".config" / "claude"
                       / "obligations-hook-errors.log")
                if log.exists():
                    log.unlink()

            # --- 125: exit_code mode, cmd exits 0 -> ALLOW ---
            allow_script = _write_script("allow.sh", "#!/bin/sh\nexit 0\n")
            ob_125 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": allow_script,
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            results.append(_check(
                "125. evaluator exit_code=0 -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_125], env_eval)

            # --- 126: exit_code mode, cmd exits 1 -> DENY ---
            deny_script = _write_script(
                "deny.sh",
                "#!/bin/sh\necho 'POLICY VIOLATION: nope' 1>&2\nexit 1\n",
            )
            ob_126 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": deny_script,
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied call",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", ""))
            results.append(_check(
                "126. evaluator exit_code=1 -> deny + stderr in reason",
                (rc == 0 and _is_deny(out)
                 and "POLICY VIOLATION" in reason),
                f"rc={rc} deny={_is_deny(out)} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob_126], env_eval)

            # --- 127: allow_on_zero_exit=false inverts polarity ---
            ob_127 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": allow_script,  # exits 0
                        "decision_mode": "exit_code",
                        "allow_on_zero_exit": False,
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (inverted)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            results.append(_check(
                "127. evaluator allow_on_zero_exit=false flips polarity: "
                "exit 0 -> deny",
                rc == 0 and _is_deny(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_127], env_eval)

            # --- 128: stdout_pattern mode, matches allow_pattern -> ALLOW ---
            ok_stdout = _write_script(
                "ok-stdout.sh", "#!/bin/sh\necho 'ALLOW: looks fine'\nexit 0\n",
            )
            ob_128 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": ok_stdout,
                        "decision_mode": "stdout_pattern",
                        "allow_pattern": r"^ALLOW\b",
                        "deny_pattern": r"^DENY\b",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied stdout",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            results.append(_check(
                "128. evaluator stdout_pattern allow_pattern match -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_128], env_eval)

            # --- 129: stdout_pattern mode, matches deny_pattern -> DENY ---
            bad_stdout = _write_script(
                "bad-stdout.sh",
                "#!/bin/sh\necho 'DENY: blocked by policy'\nexit 0\n",
            )
            ob_129 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": bad_stdout,
                        "decision_mode": "stdout_pattern",
                        "allow_pattern": r"^ALLOW\b",
                        "deny_pattern": r"^DENY\b",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied stdout",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", ""))
            results.append(_check(
                "129. evaluator stdout_pattern deny_pattern match -> deny",
                (rc == 0 and _is_deny(out)
                 and "DENY: blocked by policy" in reason),
                f"rc={rc} deny={_is_deny(out)} reason={reason!r}",
            ))
            _run([str(CLI), "satisfy", ob_129], env_eval)

            # --- 130: stdout_pattern, neither matches -> default-open ALLOW ---
            _audit_log_clear()
            undecided_stdout = _write_script(
                "undecided.sh",
                "#!/bin/sh\necho 'MAYBE: not sure'\nexit 0\n",
            )
            ob_130 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": undecided_stdout,
                        "decision_mode": "stdout_pattern",
                        "allow_pattern": r"^ALLOW\b",
                        "deny_pattern": r"^DENY\b",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied stdout",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            undecided_logged = any('"undecided"' in ln for ln in audit_lines)
            results.append(_check(
                "130. evaluator stdout_pattern undecided -> default-open "
                "allow + audit log",
                rc == 0 and _is_allow(out) and undecided_logged,
                f"rc={rc} undecided_logged={undecided_logged}",
            ))
            _run([str(CLI), "satisfy", ob_130], env_eval)

            # --- 131: subprocess timeout -> ALLOW + audit log ---
            _audit_log_clear()
            slow_script = _write_script(
                "slow.sh", "#!/bin/sh\nsleep 2\nexit 1\n",
            )
            ob_131 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": slow_script,
                        "decision_mode": "exit_code",
                        "timeout_ms": 200},  # 0.2s, script sleeps 2s
                ttl=300,
                deny_msg="evaluator denied (slow)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            timeout_logged = any('"timeout"' in ln for ln in audit_lines)
            results.append(_check(
                "131. evaluator timeout -> default-open allow + audit log",
                rc == 0 and _is_allow(out) and timeout_logged,
                f"rc={rc} timeout_logged={timeout_logged}",
            ))
            _run([str(CLI), "satisfy", ob_131], env_eval)

            # --- 132: cmd not found -> ALLOW + audit log ---
            _audit_log_clear()
            ob_132 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": ["/no/such/binary/anywhere-here-12345"],
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (missing)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            spawn_logged = any('"spawn-error"' in ln for ln in audit_lines)
            results.append(_check(
                "132. evaluator cmd not found -> default-open allow + audit "
                "log",
                rc == 0 and _is_allow(out) and spawn_logged,
                f"rc={rc} spawn_logged={spawn_logged}",
            ))
            _run([str(CLI), "satisfy", ob_132], env_eval)

            # --- 133: missing cmd config -> ALLOW + audit log ---
            _audit_log_clear()
            ob_133 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"decision_mode": "exit_code"},  # no cmd
                ttl=300,
                deny_msg="evaluator denied (no cmd)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            invalid_logged = any('"invalid-config"' in ln
                                 and "missing cmd" in ln
                                 for ln in audit_lines)
            results.append(_check(
                "133. evaluator missing cmd -> default-open allow + audit log",
                rc == 0 and _is_allow(out) and invalid_logged,
                f"rc={rc} invalid_logged={invalid_logged}",
            ))
            _run([str(CLI), "satisfy", ob_133], env_eval)

            # --- 134: invalid allow_pattern regex -> ALLOW + audit log ---
            _audit_log_clear()
            ob_134 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": ok_stdout,
                        "decision_mode": "stdout_pattern",
                        "allow_pattern": "[invalid(regex",  # broken regex
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (bad regex)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            bad_regex_logged = any('"invalid-config"' in ln
                                   and "allow_pattern" in ln
                                   for ln in audit_lines)
            results.append(_check(
                "134. evaluator invalid allow_pattern regex -> default-open "
                "allow + audit log",
                rc == 0 and _is_allow(out) and bad_regex_logged,
                f"rc={rc} bad_regex_logged={bad_regex_logged}",
            ))
            _run([str(CLI), "satisfy", ob_134], env_eval)

            # --- 135: unknown decision_mode -> ALLOW + audit log ---
            _audit_log_clear()
            ob_135 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": allow_script,
                        "decision_mode": "weird-mode"},
                ttl=300,
                deny_msg="evaluator denied (unknown mode)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            audit_lines = _audit_log_lines()
            unknown_mode_logged = any('"invalid-config"' in ln
                                      and "decision_mode" in ln
                                      for ln in audit_lines)
            results.append(_check(
                "135. evaluator unknown decision_mode -> default-open allow "
                "+ audit log",
                rc == 0 and _is_allow(out) and unknown_mode_logged,
                f"rc={rc} unknown_mode_logged={unknown_mode_logged}",
            ))
            _run([str(CLI), "satisfy", ob_135], env_eval)

            # --- 136: stdin_field pipes command to evaluator ---
            # The evaluator inspects stdin and denies iff stdin contains
            # the string "FORBIDDEN-TOKEN". This proves the gate is wiring
            # tool_input.command -> evaluator stdin.
            stdin_probe = _write_script(
                "stdin-probe.sh",
                "#!/bin/sh\nbody=$(cat)\n"
                "case \"$body\" in\n"
                "  *FORBIDDEN-TOKEN*) echo \"matched\" 1>&2; exit 1;;\n"
                "esac\nexit 0\n",
            )
            ob_136 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": stdin_probe,
                        "decision_mode": "exit_code",
                        "stdin_field": "tool_input.command",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (forbidden token)",
            )
            # Benign command should pass (no forbidden token in stdin).
            rc_ok, out_ok, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls -la"}},
                env_eval,
            )
            # Forbidden command should be denied.
            rc_bad, out_bad, _err = _hook_pre(
                {"tool_name": "Bash",
                 "tool_input": {"command": "rm FORBIDDEN-TOKEN"}},
                env_eval,
            )
            results.append(_check(
                "136. evaluator stdin_field pipes tool_input.command -> "
                "evaluator sees the literal command",
                (rc_ok == 0 and _is_allow(out_ok)
                 and rc_bad == 0 and _is_deny(out_bad)),
                f"rc_ok={rc_ok} ok_allow={_is_allow(out_ok)} "
                f"rc_bad={rc_bad} bad_deny={_is_deny(out_bad)}",
            ))
            _run([str(CLI), "satisfy", ob_136], env_eval)

            # --- 137: deny banner / reason carries evaluator stderr ---
            verbose_deny = _write_script(
                "verbose-deny.sh",
                "#!/bin/sh\n"
                "echo 'EVAL-STDERR-PROBE-MARKER: explained reason here' "
                "1>&2\nexit 1\n",
            )
            ob_137 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": verbose_deny,
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (verbose)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", ""))
            # Get the structured `why` field too via the CLI (operator-
            # facing inspection path).
            check_proc = _run([
                str(CLI), "check", "--tool", "Bash",
                "--command-string", "ls", "--json",
            ], env_eval)
            why_carries_marker = False
            try:
                check_data = json.loads(check_proc.stdout)
                for b in check_data.get("blocking", []):
                    if "EVAL-STDERR-PROBE-MARKER" in (b.get("why") or ""):
                        why_carries_marker = True
                        break
            except (json.JSONDecodeError, ValueError):
                pass
            results.append(_check(
                "137. evaluator stderr surfaces in deny reason AND in "
                "structured `why` field",
                (rc == 0 and _is_deny(out)
                 and "EVAL-STDERR-PROBE-MARKER" in reason
                 and why_carries_marker),
                f"rc={rc} reason_has_marker="
                f"{'EVAL-STDERR-PROBE-MARKER' in reason} "
                f"why_has_marker={why_carries_marker}",
            ))
            _run([str(CLI), "satisfy", ob_137], env_eval)

            # --- 138: end-to-end -- evaluator deny propagates to the
            # pre-tool hook's deny payload (banner systemMessage +
            # permissionDecisionReason both surface the deny_msg) ---
            ob_138 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": deny_script,
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator e2e gate denied",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            banner = out.get("systemMessage", "") if isinstance(out, dict) else ""
            reason = (out.get("hookSpecificOutput", {})
                      .get("permissionDecisionReason", "")
                      if isinstance(out, dict) else "")
            results.append(_check(
                "138. evaluator end-to-end: PreToolUse gate denies + "
                "banner + reason both carry deny_msg",
                (rc == 0 and _is_deny(out)
                 and "evaluator e2e gate denied" in banner
                 and "evaluator e2e gate denied" in reason),
                f"rc={rc} deny={_is_deny(out)} "
                f"banner_has_msg={'evaluator e2e gate denied' in banner} "
                f"reason_has_msg={'evaluator e2e gate denied' in reason}",
            ))
            _run([str(CLI), "satisfy", ob_138], env_eval)

            # --- 139: OBLIGATIONS_BYPASS=1 forces allow past evaluator deny ---
            ob_139 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": deny_script,
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator denied (should be bypassed)",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
                extra_env={"OBLIGATIONS_BYPASS": "1"},
            )
            results.append(_check(
                "139. evaluator: OBLIGATIONS_BYPASS=1 forces allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_139], env_eval)

            # --- 140: argv list cmd form works (no shell interp needed) ---
            argv_marker = _write_script(
                "argv-marker.sh",
                "#!/bin/sh\nif [ \"$1\" = \"sentinel\" ]; then exit 0; "
                "else echo \"missing sentinel\" 1>&2; exit 1; fi\n",
            )
            ob_140 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": [argv_marker, "sentinel"],
                        "decision_mode": "exit_code",
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator argv form denied",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            results.append(_check(
                "140. evaluator argv list cmd form -> exit 0 -> allow",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_140], env_eval)

            # --- 141: env param merges into subprocess environment ---
            env_check = _write_script(
                "env-check.sh",
                "#!/bin/sh\nif [ \"$EVAL_CUSTOM_KEY\" = \"present\" ]; then "
                "exit 0; else echo missing 1>&2; exit 1; fi\n",
            )
            ob_141 = _add_ob(
                env_eval,
                tool_pattern="Bash",
                predicate="evaluator",
                params={"cmd": env_check,
                        "decision_mode": "exit_code",
                        "env": {"EVAL_CUSTOM_KEY": "present"},
                        "timeout_ms": 2000},
                ttl=300,
                deny_msg="evaluator env merge denied",
            )
            rc, out, _err = _hook_pre(
                {"tool_name": "Bash", "tool_input": {"command": "ls"}},
                env_eval,
            )
            results.append(_check(
                "141. evaluator env param is merged into subprocess "
                "environment",
                rc == 0 and _is_allow(out),
                f"rc={rc} out={out}",
            ))
            _run([str(CLI), "satisfy", ob_141], env_eval)

    total = len(results)
    passed = sum(1 for r in results if r)
    print()
    print(f"RESULT: {passed}/{total} passed")
    return 0 if passed == total else 1


if __name__ == "__main__":
    sys.exit(main())
