#!/usr/bin/env python3
"""PostToolUse hook -- four passes:

1. **Sidecar register** -- when the just-completed Bash tool kicked off
   ``watcher-ctl run <name>`` in the background (run_in_background=True),
   write a JSON sidecar to /tmp/claude-watcher-output-pending/<task_id>.json
   describing the captured output file path. The
   ``no_pending_watcher_outputs`` predicate (in the obligations CLI) reads
   these sidecars to gate any tool that fires before Claude has Read the
   captured watcher output. Sidecar contents:
       {
         "task_id": "...",
         "command": "watcher-ctl run signal-wait-dm",
         "watcher_name": "signal-wait-dm",
         "output_file_path": "/tmp/claude-1000/.../tasks/<id>.output",
         "registered_at": <unix epoch seconds>
       }
2. **Sidecar clear-on-Read** -- when Claude Reads a path that matches a
   sidecar's output_file_path, delete that sidecar.
3. ``obligations post-satisfy`` -- auto-removes obligations whose
   ``satisfied_by`` pattern matches the just-completed tool (e.g.
   ``watcher-restart`` clears a watcher-restart obligation).
4. ``obligations inform-check`` -- evaluates every ACTIVE inform-mode
   obligation whose ``tool_pattern`` matches the just-completed tool and
   prints a single-line stderr advisory for each failing predicate. Inform-
   mode obligations are non-blocking by definition; they exist so we can
   surface health signals (e.g. "watcher X is DOWN") without gating the
   tool call. The harness forwards stderr to the main loop alongside the
   tool result, so failing inform predicates show up exactly where the
   loop is already looking.

(Passes 3 and 4 are merged into a single subprocess via the CLI's
``obligations post-tool`` subcommand for hot-path latency.)

Reads the standard Claude Code PostToolUse JSON payload on stdin and exits 0
regardless of result. The original tool call already succeeded; this hook
must not block.

Note: the sidecar passes (1, 2) are best-effort and self-contained -- they
default-open on any error via ``_log`` so a broken sidecar dir cannot
blackhole the loop.

Wiring (in ``~/.claude/settings.json``): point ``command`` at the installed
hook script (``$BIN_DIR/post-tool-obligations-update-hook``, default
``~/bin/post-tool-obligations-update-hook``)::

    {
      "hooks": {
        "PostToolUse": [
          {
            "matcher": "*",
            "hooks": [
              {
                "type": "command",
                "command": "/path/to/post-tool-obligations-update-hook",
                "timeout": 5
              }
            ]
          }
        ]
      }
    }
"""

from __future__ import annotations

import datetime as _dt
import glob
import json
import os
import re
import shutil
import subprocess
import sys
import time
from pathlib import Path

ERR_LOG_DIR = Path(os.path.expanduser("~/.config/claude"))
ERR_LOG_PATH = ERR_LOG_DIR / "obligations-hook-errors.log"

# Sidecar dir for the no_pending_watcher_outputs predicate. Default location
# is /tmp/claude-watcher-output-pending/, overridable via the
# WATCHER_PENDING_DIR env var (used by the test suite for isolation).
# Mirrored in the obligations CLI -- we duplicate the resolver here instead
# of importing so this hook stays self-contained.
def _watcher_pending_dir() -> Path:
    override = os.environ.get("WATCHER_PENDING_DIR", "").strip()
    if override:
        return Path(override)
    return Path("/tmp/claude-watcher-output-pending")


WATCHER_CTL_RE = re.compile(r"^\s*watcher-ctl\s+run\s+(\S+)")


def _log(payload: dict) -> None:
    try:
        ERR_LOG_DIR.mkdir(parents=True, exist_ok=True)
        ts = _dt.datetime.now(_dt.timezone.utc).isoformat()
        rec = {"ts": ts, "pid": os.getpid(), "phase": "post", **payload}
        with ERR_LOG_PATH.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps(rec) + "\n")
        try:
            ERR_LOG_PATH.chmod(0o600)
        except OSError:
            pass
    except (OSError, ValueError):
        pass


def _ensure_sidecar_dir() -> None:
    """Create the sidecar dir 0700 if missing. Default-open on any error."""
    try:
        sidecar_dir = _watcher_pending_dir()
        sidecar_dir.mkdir(parents=True, exist_ok=True)
        try:
            sidecar_dir.chmod(0o700)
        except OSError:
            pass
    except OSError as e:
        _log({"kind": "sidecar-mkdir-fail", "exc": str(e)})


def _claude_project_slug() -> str:
    """Derive the Claude Code project-slug component of the task-output path.

    Claude Code stores task outputs at::

        /tmp/claude-<uid>/<HOME-as-slug>/<session-uuid>/tasks/<task-id>.output

    where ``<HOME-as-slug>`` is ``HOME`` with ``/`` swapped for ``-`` and a
    leading ``-`` (e.g. ``/home/alice`` -> ``-home-alice``). We derive the
    slug from ``$HOME`` at call time so this hook is portable across users
    rather than hard-coding any specific account.
    """
    home = os.environ.get("HOME", "") or os.path.expanduser("~")
    return home.replace("/", "-")


def _resolve_session_uuid_for_task_path(task_id: str) -> str | None:
    """Recover the session UUID for a Claude Code task output path.

    Strategy:
      1. CLAUDE_SESSION_UUID env var (preferred when Claude Code sets it).
      2. CLAUDE_SESSION_ID env var (alternate name).
      3. Glob /tmp/claude-<uid>/<HOME-slug>/*/tasks/<task_id>.output and
         return the first existing match. The bg task's output file is
         normally already created by the time the PostToolUse hook fires.
    """
    for var in ("CLAUDE_SESSION_UUID", "CLAUDE_SESSION_ID"):
        val = os.environ.get(var, "").strip()
        if val:
            return val

    # Glob fallback: find an existing output file with this task id.
    uid = os.geteuid()
    slug = _claude_project_slug()
    project_dir_glob = f"/tmp/claude-{uid}/{slug}/*/tasks/{task_id}.output"
    matches = glob.glob(project_dir_glob)
    if matches:
        # Layout: /tmp/claude-{uid}/<slug>/<uuid>/tasks/<id>.output
        # so the parent of the parent of the matched path is the session uuid.
        parts = Path(matches[0]).parts
        try:
            tasks_idx = parts.index("tasks")
            return parts[tasks_idx - 1]
        except (ValueError, IndexError):
            pass
    return None


def _output_file_path_for_task(task_id: str) -> str | None:
    """Return the deterministic output_file_path for a bg task, or None if
    we can't resolve the session uuid."""
    if not task_id or not isinstance(task_id, str):
        return None
    uuid = _resolve_session_uuid_for_task_path(task_id)
    if not uuid:
        return None
    uid = os.geteuid()
    slug = _claude_project_slug()
    return f"/tmp/claude-{uid}/{slug}/{uuid}/tasks/{task_id}.output"


def _maybe_register_watcher_sidecar(payload: dict) -> None:
    """If this PostToolUse payload describes a Bash tool that just kicked off
    `watcher-ctl run <name>` in the background, write a sidecar."""
    try:
        tool_name = payload.get("tool_name", "")
        if tool_name != "Bash":
            return
        tool_input = payload.get("tool_input", {}) or {}
        # Only handle background tasks. tool_input has the original kwargs.
        run_in_background = bool(tool_input.get("run_in_background", False))
        if not run_in_background:
            return
        cmd = tool_input.get("command", "")
        if not isinstance(cmd, str):
            return
        m = WATCHER_CTL_RE.match(cmd)
        if not m:
            return
        watcher_name = m.group(1)

        # Pull the task id from tool_response.backgroundTaskId.
        tool_response = payload.get("tool_response", {}) or {}
        task_id = None
        if isinstance(tool_response, dict):
            task_id = tool_response.get("backgroundTaskId")
        if not task_id or not isinstance(task_id, str):
            _log({
                "kind": "sidecar-no-task-id",
                "watcher": watcher_name,
                "tool_response_keys": (
                    list(tool_response.keys()) if isinstance(tool_response, dict) else None
                ),
            })
            return

        output_path = _output_file_path_for_task(task_id)
        if not output_path:
            _log({"kind": "sidecar-no-session-uuid", "task_id": task_id})
            return

        _ensure_sidecar_dir()
        sidecar_path = _watcher_pending_dir() / f"{task_id}.json"
        sc = {
            "task_id": task_id,
            "command": cmd,
            "watcher_name": watcher_name,
            "output_file_path": output_path,
            "registered_at": time.time(),
        }
        try:
            sidecar_path.write_text(json.dumps(sc, indent=2) + "\n")
            try:
                sidecar_path.chmod(0o600)
            except OSError:
                pass
        except OSError as e:
            _log({"kind": "sidecar-write-fail", "exc": str(e),
                  "sidecar_path": str(sidecar_path)})
    except Exception as e:  # noqa: BLE001 -- never propagate
        _log({"kind": "sidecar-register-uncaught", "exc": str(e)})


def _maybe_clear_watcher_sidecar_on_read(payload: dict) -> None:
    """If this is a Read of a path that matches a sidecar's output_file_path,
    delete that sidecar."""
    try:
        tool_name = payload.get("tool_name", "")
        if tool_name != "Read":
            return
        tool_input = payload.get("tool_input", {}) or {}
        file_path = tool_input.get("file_path", "")
        if not isinstance(file_path, str) or not file_path:
            return
        abs_read = os.path.abspath(os.path.expanduser(file_path))
        sidecar_dir = _watcher_pending_dir()
        if not sidecar_dir.exists():
            return
        for sidecar_path in sidecar_dir.glob("*.json"):
            try:
                sc = json.loads(sidecar_path.read_text())
            except (OSError, json.JSONDecodeError):
                continue
            output_path = sc.get("output_file_path")
            if not output_path:
                continue
            if os.path.abspath(output_path) == abs_read:
                try:
                    sidecar_path.unlink()
                except OSError as e:
                    _log({"kind": "sidecar-unlink-fail", "exc": str(e),
                          "sidecar_path": str(sidecar_path)})
    except Exception as e:  # noqa: BLE001
        _log({"kind": "sidecar-clear-uncaught", "exc": str(e)})


def _short_command_string(tool_input: dict, tool_name: str) -> str:
    if not isinstance(tool_input, dict):
        return ""
    if tool_name == "Bash":
        cmd = tool_input.get("command", "")
        return cmd if isinstance(cmd, str) else ""
    try:
        return json.dumps(tool_input, default=str)
    except (TypeError, ValueError):
        return str(tool_input)


def main() -> int:
    try:
        payload = json.load(sys.stdin)
    except (json.JSONDecodeError, ValueError):
        return 0

    if not isinstance(payload, dict):
        return 0

    tool_name = payload.get("tool_name", "")
    if not isinstance(tool_name, str) or not tool_name:
        return 0

    tool_input = payload.get("tool_input", {})
    cmd_str = _short_command_string(tool_input, tool_name)

    # Subagent context detection (mirrors the PreToolUse hook). Forwarded to
    # the obligations CLI so the `is_main_loop` predicate (in `all_of`
    # compositions or standalone) can branch on context, e.g. inform-mode
    # `all_of [is_main_loop, X]` obligations stay silent inside subagents.
    # `agent_type` is the AUTHORITATIVE main-loop-vs-subagent signal (the
    # main loop now also carries a non-empty `agent_id`); `agent_id` is a
    # legacy fallback for older Claude Code. See the PreToolUse hook + the
    # CLI's `_is_subagent_context` for the full rationale.
    raw_agent_id = payload.get("agent_id", "")
    agent_id = raw_agent_id.strip() if isinstance(raw_agent_id, str) else ""
    raw_agent_type = payload.get("agent_type", "")
    agent_type = (raw_agent_type.strip()
                  if isinstance(raw_agent_type, str) else "")

    # Manage the watcher-output-pending sidecars BEFORE running the
    # obligations CLI. These two helpers are best-effort no-ops when the
    # tool isn't relevant; they swallow all errors via _log().
    _maybe_register_watcher_sidecar(payload)
    _maybe_clear_watcher_sidecar_on_read(payload)

    # Locate the obligations CLI. Prefer PATH; fall back to the in-repo
    # sibling (when running uninstalled).
    cli = shutil.which("obligations")
    if not cli:
        here = Path(__file__).resolve().parent
        sibling = here.parent / "obligations" / "obligations"
        if sibling.exists():
            cli = str(sibling)
    if not cli or not os.path.exists(cli):
        # Best-effort no-op.
        return 0

    # Single combined pass: satisfy-by-completion + inform-check in ONE
    # python startup. The CLI's `post-tool` subcommand always exits 0 and
    # prints the inform banner (one line per failing inform predicate) on
    # stdout. We forward that to stderr so the harness shows it alongside
    # the tool result.
    try:
        proc = subprocess.run(
            [cli, "post-tool", "--tool", tool_name,
             "--command-string", cmd_str,
             "--agent-id", agent_id,
             "--agent-type", agent_type],
            capture_output=True, text=True, timeout=5, check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as e:
        _log({"kind": "post-tool-exc", "exc": str(e), "tool_name": tool_name})
        return 0

    if proc.stdout.strip():
        sys.stderr.write(proc.stdout)
        if not proc.stdout.endswith("\n"):
            sys.stderr.write("\n")

    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception as exc:  # noqa: BLE001
        try:
            _log({"kind": "uncaught", "exc": str(exc)})
        except Exception:
            pass
        sys.exit(0)
