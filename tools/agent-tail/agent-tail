#!/usr/bin/env python3
"""agent-tail: stream a Claude Code subagent's JSONL transcript.

Each spawned subagent writes a JSONL transcript at:

    ~/.claude/projects/<project-slug>/<session-uuid>/subagents/agent-<id>.jsonl

This CLI resolves an agent id (or short prefix) to the right path under
that tree, then either dumps it once or follows it like `tail -f`.

Records are pretty-printed by default:
  - user message            -> "USER: <text>" (or "USER: [tool_result toolu_...] <preview>")
  - assistant text          -> "ASSISTANT: <text>"
  - assistant tool_use      -> "TOOL_CALL <Name>(<one-line-args>)  [toolu_...]"
  - tool_result             -> "TOOL_RESULT [toolu_...]  <preview>" (truncated)
  - system / unknown        -> "SYSTEM: <repr>"

`--json` emits the original JSONL lines verbatim (one per line) for
downstream consumers like queue-minisite SSE.

Resolution order for the agent id argument:
  1. Exact match on `agent-<arg>.jsonl` somewhere under ~/.claude/projects/.
  2. Glob match on `agent-<arg>*.jsonl` (lets you type a short prefix).
  3. If still ambiguous after the projects scan, prefer the most recently
     modified candidate (working assumption: that's the one you mean).

Resolution can also use `claude-watch active-agents --json` to enumerate
the active session's agent ids first; we still fall back to the full
projects walk if that command isn't available or returned nothing.

Usage:
    agent-tail <agent_id>                         # one-shot dump
    agent-tail <agent_id> --follow                # stream new appends
    agent-tail <agent_id> --since 5m              # only events newer than 5m
    agent-tail <agent_id> --json                  # raw JSONL passthrough
    agent-tail <agent_id> --truncate-tool-result 10  # cap tool-result preview
    agent-tail <agent_id> --path                  # print the resolved path
    agent-tail --list                             # list active agents w/ paths
    agent-tail --test                             # run embedded test suite
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
import time
from pathlib import Path
from typing import Any, Iterator, Optional

# ---------------------------------------------------------------------------
# Paths / constants
# ---------------------------------------------------------------------------

PROJECTS_DIR_DEFAULT = Path.home() / ".claude" / "projects"

DURATION_RE = re.compile(r"^\s*(\d+)\s*([smhdw])\s*$")
DURATION_UNITS = {"s": 1, "m": 60, "h": 3600, "d": 86400, "w": 604800}

DEFAULT_TOOL_RESULT_MAX_LINES = 20
DEFAULT_TOOL_RESULT_MAX_CHARS = 2000


# ---------------------------------------------------------------------------
# Pure helpers
# ---------------------------------------------------------------------------


def parse_duration(s: str) -> int:
    """Parse '5m' / '1h' / '1d' / '2w' into seconds. Raises ValueError on bad input."""
    m = DURATION_RE.match(s)
    if not m:
        raise ValueError(f"bad duration: {s!r} (expected like 5m, 1h, 1d, 7d)")
    return int(m.group(1)) * DURATION_UNITS[m.group(2)]


def parse_iso_ts(s: str) -> Optional[float]:
    """Parse an ISO8601 timestamp into a UNIX epoch float. Returns None on failure."""
    if not s:
        return None
    try:
        # Python <3.11 doesn't accept trailing Z; normalise.
        if s.endswith("Z"):
            s = s[:-1] + "+00:00"
        from datetime import datetime
        return datetime.fromisoformat(s).timestamp()
    except (ValueError, TypeError):
        return None


def truncate_lines(text: str, max_lines: int, max_chars: int) -> str:
    """Truncate ``text`` to at most ``max_lines`` lines and ``max_chars`` chars.

    Pure: no I/O. If truncation occurs, append a marker line summarising what
    was cut. Newline at end is preserved iff it was in the original.
    """
    if max_lines <= 0 and max_chars <= 0:
        return text
    truncated = False
    if max_chars > 0 and len(text) > max_chars:
        text = text[:max_chars]
        truncated = True
    lines = text.split("\n")
    if max_lines > 0 and len(lines) > max_lines:
        kept = lines[:max_lines]
        cut = len(lines) - max_lines
        lines = kept + [f"... [{cut} more line(s) truncated]"]
        truncated = True
    elif truncated:
        lines.append("... [truncated]")
    return "\n".join(lines)


def one_line_args(args: Any, max_chars: int = 200) -> str:
    """Render a tool-call ``input`` dict as a compact single-line string."""
    if args is None:
        return ""
    try:
        s = json.dumps(args, separators=(",", ":"), ensure_ascii=False, sort_keys=True)
    except (TypeError, ValueError):
        s = repr(args)
    s = s.replace("\n", "\\n")
    if max_chars > 0 and len(s) > max_chars:
        s = s[:max_chars] + "...(+{})".format(len(s) - max_chars)
    return s


# ---------------------------------------------------------------------------
# Resolution
# ---------------------------------------------------------------------------


def projects_dir() -> Path:
    """Return the projects dir, honoring CLAUDE_PROJECTS_DIR for tests."""
    override = os.environ.get("CLAUDE_PROJECTS_DIR")
    if override:
        return Path(override)
    return PROJECTS_DIR_DEFAULT


def list_agent_jsonls(root: Optional[Path] = None) -> list[Path]:
    """Walk ``root``/<project>/<session>/subagents/ and return every agent-*.jsonl.

    Sorted by mtime descending so callers can break ties on "most recent".
    """
    base = root if root is not None else projects_dir()
    out: list[tuple[float, Path]] = []
    if not base.is_dir():
        return []
    for project_entry in base.iterdir():
        if not project_entry.is_dir():
            continue
        for session_entry in project_entry.iterdir():
            if not session_entry.is_dir():
                continue
            subagents = session_entry / "subagents"
            if not subagents.is_dir():
                continue
            try:
                children = list(subagents.iterdir())
            except OSError:
                continue
            for child in children:
                if not child.is_file():
                    continue
                name = child.name
                if not name.startswith("agent-") or not name.endswith(".jsonl"):
                    continue
                try:
                    mt = child.stat().st_mtime
                except OSError:
                    mt = 0.0
                out.append((mt, child))
    out.sort(key=lambda x: x[0], reverse=True)
    return [p for (_, p) in out]


def resolve_agent_id(
    agent_id: str, root: Optional[Path] = None
) -> tuple[Optional[Path], list[Path]]:
    """Resolve ``agent_id`` (full id or short prefix) to a JSONL path.

    Returns (chosen_path, all_candidates). ``chosen_path`` is None when there
    are no candidates. When several candidates match a prefix, the most
    recently modified one wins (sorted that way already by ``list_agent_jsonls``).

    Accepts either ``a194312241cc25f9c`` or ``agent-a194312241cc25f9c``.
    """
    needle = agent_id.strip()
    if needle.startswith("agent-"):
        needle = needle[len("agent-"):]
    all_jsonls = list_agent_jsonls(root)

    # Phase 1: exact match
    exact: list[Path] = []
    target_name = f"agent-{needle}.jsonl"
    for p in all_jsonls:
        if p.name == target_name:
            exact.append(p)
    if exact:
        return exact[0], exact

    # Phase 2: prefix match
    prefix = f"agent-{needle}"
    pref: list[Path] = [p for p in all_jsonls if p.name.startswith(prefix)]
    if pref:
        return pref[0], pref

    return None, []


# ---------------------------------------------------------------------------
# Pretty printing
# ---------------------------------------------------------------------------


class FormatOpts:
    __slots__ = ("max_lines", "max_chars", "show_ts", "verbose")

    def __init__(
        self,
        max_lines: int = DEFAULT_TOOL_RESULT_MAX_LINES,
        max_chars: int = DEFAULT_TOOL_RESULT_MAX_CHARS,
        show_ts: bool = True,
        verbose: bool = False,
    ) -> None:
        self.max_lines = max_lines
        self.max_chars = max_chars
        self.show_ts = show_ts
        # When set, each record renders an extra indented metadata
        # block exposing model / usage / requestId / stop_reason /
        # uuid / parentUuid / attributionAgent / agentId / slug / etc.
        # Default off — the headline stays terminal-friendly.
        self.verbose = verbose


def _format_ts(obj: dict[str, Any]) -> str:
    ts = obj.get("timestamp")
    if not isinstance(ts, str):
        return ""
    # Compact: drop the date if it's today; else keep ISO date+time. We
    # print whatever the JSONL says; downstream tools can reformat.
    return ts


def _content_to_text(content: Any) -> str:
    """Flatten an assistant `content` array of {type: text, text: ...} into one string."""
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    parts: list[str] = []
    for c in content:
        if not isinstance(c, dict):
            continue
        if c.get("type") == "text":
            parts.append(str(c.get("text", "")))
    return "\n".join(parts)


def _meta_lines(obj: dict[str, Any]) -> list[str]:
    """Build verbose-mode metadata footer lines for a record.

    Lists every per-record field that's useful for debugging but noisy
    by default: model / usage / stop_reason / requestId /
    attributionAgent / agentId / slug / uuid / parentUuid / caller /
    sourceToolAssistantUUID / cwd / gitBranch / etc. Returns each
    field as ``  <key>: <value>`` (two-space indent so it visually
    nests under the headline line).
    """
    if not isinstance(obj, dict):
        return []
    out: list[str] = []
    msg = obj.get("message")
    msg = msg if isinstance(msg, dict) else {}
    if msg.get("model"):
        out.append(f"  model: {msg.get('model')}")
    if msg.get("stop_reason"):
        out.append(f"  stop_reason: {msg.get('stop_reason')}")
    if msg.get("stop_sequence"):
        out.append(f"  stop_sequence: {msg.get('stop_sequence')}")
    if msg.get("stop_details"):
        out.append(f"  stop_details: {one_line_args(msg.get('stop_details'))}")
    usage = msg.get("usage")
    if isinstance(usage, dict):
        parts: list[str] = []
        if usage.get("input_tokens") is not None:
            parts.append(f"in={usage.get('input_tokens')}")
        if usage.get("output_tokens") is not None:
            parts.append(f"out={usage.get('output_tokens')}")
        if usage.get("cache_creation_input_tokens"):
            parts.append(f"cache_create={usage.get('cache_creation_input_tokens')}")
        if usage.get("cache_read_input_tokens"):
            parts.append(f"cache_read={usage.get('cache_read_input_tokens')}")
        if usage.get("service_tier"):
            parts.append(f"tier={usage.get('service_tier')}")
        if parts:
            out.append("  usage: " + " ".join(parts))
        cc = usage.get("cache_creation")
        if isinstance(cc, dict):
            cc_parts: list[str] = []
            if cc.get("ephemeral_5m_input_tokens") is not None:
                cc_parts.append(f"5m={cc['ephemeral_5m_input_tokens']}")
            if cc.get("ephemeral_1h_input_tokens") is not None:
                cc_parts.append(f"1h={cc['ephemeral_1h_input_tokens']}")
            if cc_parts:
                out.append("  cache_creation: " + " ".join(cc_parts))
    for key in (
        "requestId",
        "attributionAgent",
        "agentId",
        "slug",
        "uuid",
        "parentUuid",
        "sourceToolAssistantUUID",
        "logicalParentUuid",
        "promptId",
        "sessionId",
        "gitBranch",
        "cwd",
        "version",
        "userType",
        "entrypoint",
    ):
        val = obj.get(key)
        if val:
            out.append(f"  {key}: {val}")
    # isSidechain / isMeta default to False — only show when non-default
    for key in ("isSidechain", "isMeta"):
        val = obj.get(key)
        if val:
            out.append(f"  {key}: {val}")
    return out


def format_record(obj: dict[str, Any], opts: FormatOpts) -> Iterator[str]:
    """Yield zero or more pretty-printed lines for one JSONL record.

    Pure: no I/O.
    """
    rtype = obj.get("type")
    msg = obj.get("message")
    msg = msg if isinstance(msg, dict) else {}
    ts_prefix = ""
    if opts.show_ts:
        ts = _format_ts(obj)
        if ts:
            ts_prefix = f"[{ts}] "

    if rtype == "user":
        # User content is either a bare string (the spawn prompt), a list
        # of {type: tool_result, ...} blocks (model handing back tool output),
        # or a list of {type: image, source: {...}} blocks.
        content = msg.get("content")
        if isinstance(content, str):
            text = truncate_lines(content, opts.max_lines, opts.max_chars)
            yield f"{ts_prefix}USER: {text}"
            if opts.verbose:
                yield from _meta_lines(obj)
            return
        if isinstance(content, list):
            for c in content:
                if not isinstance(c, dict):
                    continue
                ct = c.get("type")
                if ct == "tool_result":
                    tu_id = c.get("tool_use_id", "?")
                    inner = c.get("content")
                    is_error = bool(c.get("is_error"))
                    body = _tool_result_body(inner)
                    body = truncate_lines(body, opts.max_lines, opts.max_chars)
                    tag = "TOOL_RESULT" + (" [error]" if is_error else "")
                    yield f"{ts_prefix}{tag} [{tu_id}]"
                    for ln in body.split("\n"):
                        yield f"  {ln}"
                    # Side-channel summary stashed at the top level. When
                    # it diverges from `content`, surface it — the
                    # obligation-gate denial path uses this to ship a
                    # clean `Error: ...` separate from the wrapped
                    # `<tool_use_error>` blob inside `content`.
                    side = obj.get("toolUseResult")
                    if side and isinstance(side, str) and side != body:
                        yield "  toolUseResult:"
                        for ln in truncate_lines(side, opts.max_lines, opts.max_chars).split("\n"):
                            yield f"    {ln}"
                    elif isinstance(side, dict):
                        yield f"  toolUseResult: {one_line_args(side)}"
                elif ct == "image":
                    src = c.get("source") or {}
                    mt = src.get("media_type", "image/?")
                    stype = src.get("type", "unknown")
                    data = src.get("data") or ""
                    yield f"{ts_prefix}USER_IMAGE [{mt} / {stype}] ({len(data)} base64 chars)"
                elif ct == "text":
                    text = truncate_lines(str(c.get("text", "")), opts.max_lines, opts.max_chars)
                    yield f"{ts_prefix}USER: {text}"
                else:
                    yield f"{ts_prefix}USER[{ct or '?'}]: {one_line_args(c)}"
            if opts.verbose:
                yield from _meta_lines(obj)
            return
        # Fallback: dump repr.
        yield f"{ts_prefix}USER: {one_line_args(msg)}"
        if opts.verbose:
            yield from _meta_lines(obj)
        return

    if rtype == "assistant":
        content = msg.get("content")
        if not isinstance(content, list):
            yield f"{ts_prefix}ASSISTANT: {one_line_args(msg)}"
            if opts.verbose:
                yield from _meta_lines(obj)
            return
        for c in content:
            if not isinstance(c, dict):
                continue
            ct = c.get("type")
            if ct == "text":
                text = str(c.get("text", ""))
                text = truncate_lines(text, opts.max_lines, opts.max_chars)
                yield f"{ts_prefix}ASSISTANT: {text}"
            elif ct == "tool_use":
                name = c.get("name", "?")
                tu_id = c.get("id", "?")
                args = one_line_args(c.get("input"))
                caller = c.get("caller")
                caller_tag = ""
                if isinstance(caller, dict) and caller.get("type"):
                    caller_tag = f"  via={caller['type']}"
                yield f"{ts_prefix}TOOL_CALL {name}({args})  [{tu_id}]{caller_tag}"
            elif ct == "thinking":
                text = str(c.get("thinking", ""))
                text = truncate_lines(text, opts.max_lines, opts.max_chars)
                yield f"{ts_prefix}THINKING: {text}"
                # `signature` is an opaque hash — only worth printing
                # in verbose mode for full traceability.
                if opts.verbose and c.get("signature"):
                    yield f"  signature: {c['signature']}"
            else:
                yield f"{ts_prefix}ASSISTANT[{ct or '?'}]: {one_line_args(c)}"
        if opts.verbose:
            yield from _meta_lines(obj)
        return

    if rtype == "progress":
        data = obj.get("data") if isinstance(obj.get("data"), dict) else {}
        dtype = data.get("type", "?")
        parts = [f"type={dtype}"]
        for key in ("hookEvent", "hookName", "command"):
            if data.get(key):
                parts.append(f"{key}={data[key]}")
        if obj.get("toolUseID"):
            parts.append(f"toolUseID={obj['toolUseID']}")
        yield f"{ts_prefix}PROGRESS: " + " ".join(parts)
        if opts.verbose:
            yield from _meta_lines(obj)
        return

    if rtype == "system":
        subtype = obj.get("subtype", "")
        parts: list[str] = []
        if subtype:
            parts.append(f"subtype={subtype}")
        if obj.get("durationMs") is not None:
            parts.append(f"duration={obj['durationMs'] / 1000:.2f}s")
        if obj.get("level"):
            parts.append(f"level={obj['level']}")
        if obj.get("toolUseID"):
            parts.append(f"toolUseID={obj['toolUseID']}")
        if obj.get("hookCount") is not None:
            parts.append(f"hookCount={obj['hookCount']}")
        if obj.get("preventedContinuation") is not None:
            parts.append(f"preventedContinuation={obj['preventedContinuation']}")
        headline = " ".join(parts) if parts else "(no subtype)"
        content = obj.get("content")
        yield f"{ts_prefix}SYSTEM: {headline}"
        if isinstance(content, str) and content:
            body = truncate_lines(content, opts.max_lines, opts.max_chars)
            for ln in body.split("\n"):
                yield f"  {ln}"
        elif isinstance(content, (list, dict)) and content:
            yield f"  content: {one_line_args(content)}"
        if opts.verbose:
            yield from _meta_lines(obj)
        return

    if rtype == "attachment":
        att = obj.get("attachment") if isinstance(obj.get("attachment"), dict) else {}
        atype = att.get("type", "?")
        # Compact headline + selected highlights for the common attachment
        # shapes (deferred_tools_delta, skill_listing, hook_additional_context).
        yield f"{ts_prefix}ATTACHMENT [{atype}]"
        if atype == "deferred_tools_delta":
            added = att.get("addedNames") or []
            removed = att.get("removedNames") or []
            if added:
                yield f"  added ({len(added)}): {', '.join(added[:8])}" + (
                    f"...+{len(added) - 8}" if len(added) > 8 else ""
                )
            if removed:
                yield f"  removed ({len(removed)}): {', '.join(removed[:8])}" + (
                    f"...+{len(removed) - 8}" if len(removed) > 8 else ""
                )
        elif atype in ("skill_listing", "hook_additional_context"):
            cnt = att.get("content")
            if isinstance(cnt, str):
                body = truncate_lines(cnt, opts.max_lines, opts.max_chars)
                for ln in body.split("\n"):
                    yield f"  {ln}"
            elif isinstance(cnt, list):
                for line in cnt[: opts.max_lines if opts.max_lines > 0 else len(cnt)]:
                    body = truncate_lines(str(line), opts.max_lines, opts.max_chars)
                    for ln in body.split("\n"):
                        yield f"  {ln}"
        else:
            # Unknown attachment shape — dump a one-liner.
            yield f"  {one_line_args(att)}"
        if att.get("hookName"):
            yield f"  hookName: {att['hookName']}"
        if att.get("toolUseID"):
            yield f"  toolUseID: {att['toolUseID']}"
        if opts.verbose:
            yield from _meta_lines(obj)
        return

    # System events / unknown shapes — dump a one-line repr.
    yield f"{ts_prefix}{(rtype or 'EVENT').upper()}: {one_line_args(obj)}"
    if opts.verbose:
        yield from _meta_lines(obj)


def _tool_result_body(inner: Any) -> str:
    """Tool results can be a bare string or a list of {type: text, text: ...} blocks."""
    if isinstance(inner, str):
        return inner
    if isinstance(inner, list):
        parts: list[str] = []
        for sub in inner:
            if isinstance(sub, dict):
                if sub.get("type") == "text":
                    parts.append(str(sub.get("text", "")))
                else:
                    parts.append(one_line_args(sub))
            else:
                parts.append(str(sub))
        return "\n".join(parts)
    return one_line_args(inner)


# ---------------------------------------------------------------------------
# Reading + filtering
# ---------------------------------------------------------------------------


def iter_lines_with_ts(
    path: Path, since_epoch: Optional[float] = None
) -> Iterator[tuple[dict[str, Any], str]]:
    """Stream parsed records from ``path``; tolerate torn lines.

    Yields (parsed_obj, raw_line). When ``since_epoch`` is not None, drops
    records whose ``timestamp`` parses to an earlier epoch. Records with no
    parseable timestamp are kept (we'd rather over-include than silently
    swallow them).
    """
    with path.open("r", encoding="utf-8", errors="replace") as f:
        for raw in f:
            stripped = raw.strip()
            if not stripped:
                continue
            try:
                obj = json.loads(stripped)
            except json.JSONDecodeError:
                continue
            if since_epoch is not None:
                ts_epoch = parse_iso_ts(obj.get("timestamp", "")) if isinstance(obj, dict) else None
                if ts_epoch is not None and ts_epoch < since_epoch:
                    continue
            if not isinstance(obj, dict):
                continue
            yield obj, raw.rstrip("\n")


def follow_file(
    path: Path,
    poll_interval: float = 0.5,
    stop_after: Optional[float] = None,
) -> Iterator[tuple[dict[str, Any], str]]:
    """Generator: yield records as the file grows, like ``tail -f``.

    Handles file truncation/rotation via three signals:
      - inode change           -> file replaced (atomic write, mv, etc.)
      - size shrinks           -> in-place truncation we caught on the dip
      - byte at pos-1 != '\\n'  -> we lost the line boundary (catches the
                                   "open(w) + immediate rewrite past pos"
                                   case where size never dipped low enough
                                   for us to notice)

    Stops after ``stop_after`` seconds of wall-clock time when given (test hook).
    """
    start = time.time()
    pos = 0
    inode: Optional[int] = None
    last_seen_size = 0
    pending = ""
    while True:
        try:
            st = path.stat()
        except FileNotFoundError:
            if stop_after is not None and (time.time() - start) >= stop_after:
                return
            time.sleep(poll_interval)
            continue
        rotated = False
        if inode is None:
            inode = st.st_ino
        elif st.st_ino != inode:
            rotated = True
            inode = st.st_ino
        truncated = st.st_size < pos or st.st_size < last_seen_size
        if rotated or truncated:
            pos = 0
            pending = ""
        if st.st_size > pos:
            with path.open("rb") as f:
                # Sanity-check the line boundary at our resume offset. If
                # pos > 0 but the previous byte is not '\n', the file was
                # truncated-and-rewritten beneath us — start over.
                if pos > 0:
                    f.seek(pos - 1)
                    prev = f.read(1)
                    if prev != b"\n":
                        pos = 0
                        pending = ""
                        f.seek(0)
                else:
                    f.seek(0)
                chunk_b = f.read()
                pos = f.tell()
            try:
                chunk = chunk_b.decode("utf-8")
            except UnicodeDecodeError:
                chunk = chunk_b.decode("utf-8", errors="replace")
            pending += chunk
            while "\n" in pending:
                line, pending = pending.split("\n", 1)
                stripped = line.strip()
                if not stripped:
                    continue
                try:
                    obj = json.loads(stripped)
                except json.JSONDecodeError:
                    continue
                if isinstance(obj, dict):
                    yield obj, line.rstrip("\r")
        last_seen_size = st.st_size
        if stop_after is not None and (time.time() - start) >= stop_after:
            return
        time.sleep(poll_interval)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def cmd_list(args: argparse.Namespace) -> int:
    paths = list_agent_jsonls()
    if not paths:
        print("(no agent transcripts under {})".format(projects_dir()), file=sys.stderr)
        return 0
    for p in paths:
        # mtime as ISO without microseconds for readability
        try:
            mt = p.stat().st_mtime
            from datetime import datetime, timezone
            mt_iso = datetime.fromtimestamp(mt, tz=timezone.utc).isoformat(timespec="seconds")
        except OSError:
            mt_iso = "?"
        agent_id = p.name[len("agent-"):-len(".jsonl")]
        print(f"{agent_id}\t{mt_iso}\t{p}")
    return 0


def cmd_tail(args: argparse.Namespace) -> int:
    chosen, candidates = resolve_agent_id(args.agent_id)
    if chosen is None:
        print(
            f"agent-tail: no transcript found for {args.agent_id!r} under {projects_dir()}",
            file=sys.stderr,
        )
        return 2
    if len(candidates) > 1 and not args.quiet:
        print(
            f"agent-tail: {len(candidates)} candidates matched {args.agent_id!r}; "
            f"using most recent: {chosen}",
            file=sys.stderr,
        )

    if args.path:
        print(chosen)
        return 0

    since_epoch: Optional[float] = None
    if args.since:
        try:
            since_epoch = time.time() - parse_duration(args.since)
        except ValueError as e:
            print(f"agent-tail: {e}", file=sys.stderr)
            return 2

    opts = FormatOpts(
        max_lines=args.truncate_tool_result if args.truncate_tool_result is not None else DEFAULT_TOOL_RESULT_MAX_LINES,
        max_chars=args.truncate_chars if args.truncate_chars is not None else DEFAULT_TOOL_RESULT_MAX_CHARS,
        show_ts=not args.no_ts,
        verbose=bool(args.verbose),
    )

    # Phase 1: dump existing content (filtered by --since).
    last_size = 0
    for obj, raw in iter_lines_with_ts(chosen, since_epoch=since_epoch):
        if args.json:
            print(raw)
        else:
            for ln in format_record(obj, opts):
                print(ln)
    try:
        last_size = chosen.stat().st_size
    except OSError:
        last_size = 0

    if not args.follow:
        return 0

    # Phase 2: follow. Re-implement inline so we can seed pos at the
    # current EOF (Phase 1 already drained existing content) and route
    # through the same pretty/JSON formatting.
    pos = last_size
    inode: Optional[int] = None
    last_seen_size = last_size
    pending = ""
    poll = args.poll_interval
    try:
        while True:
            try:
                st = chosen.stat()
            except FileNotFoundError:
                time.sleep(poll)
                continue
            rotated = False
            if inode is None:
                inode = st.st_ino
            elif st.st_ino != inode:
                rotated = True
                inode = st.st_ino
            truncated = st.st_size < pos or st.st_size < last_seen_size
            if rotated or truncated:
                pos = 0
                pending = ""
            if st.st_size > pos:
                with chosen.open("rb") as f:
                    if pos > 0:
                        f.seek(pos - 1)
                        prev = f.read(1)
                        if prev != b"\n":
                            pos = 0
                            pending = ""
                            f.seek(0)
                    else:
                        f.seek(0)
                    chunk_b = f.read()
                    pos = f.tell()
                try:
                    chunk = chunk_b.decode("utf-8")
                except UnicodeDecodeError:
                    chunk = chunk_b.decode("utf-8", errors="replace")
                pending += chunk
                while "\n" in pending:
                    line, pending = pending.split("\n", 1)
                    stripped = line.strip()
                    if not stripped:
                        continue
                    try:
                        obj = json.loads(stripped)
                    except json.JSONDecodeError:
                        continue
                    if not isinstance(obj, dict):
                        continue
                    if args.json:
                        print(line.rstrip("\r"), flush=True)
                    else:
                        for ln in format_record(obj, opts):
                            print(ln, flush=True)
            last_seen_size = st.st_size
            time.sleep(poll)
    except KeyboardInterrupt:
        return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="agent-tail",
        description=(
            "Stream a Claude Code subagent's JSONL transcript. Resolves the "
            "agent id (full or short prefix) to a path under "
            "~/.claude/projects/<slug>/<session>/subagents/, then dumps or "
            "follows the file. Default output is pretty-printed; use --json "
            "for the raw JSONL."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument(
        "agent_id",
        nargs="?",
        help="agent id (or short prefix). Optional when using --list / --test.",
    )
    p.add_argument(
        "-f",
        "--follow",
        action="store_true",
        help="stream new lines as they are appended (tail -f).",
    )
    p.add_argument(
        "--since",
        metavar="DURATION",
        help="only show records newer than this (e.g. 5m, 1h, 1d).",
    )
    p.add_argument(
        "--json",
        action="store_true",
        help="emit raw JSONL passthrough (one line per record).",
    )
    p.add_argument(
        "--truncate-tool-result",
        type=int,
        metavar="LINES",
        default=None,
        help=f"cap tool-result preview at LINES lines (default {DEFAULT_TOOL_RESULT_MAX_LINES}; 0 = no cap).",
    )
    p.add_argument(
        "--truncate-chars",
        type=int,
        metavar="CHARS",
        default=None,
        help=f"cap each rendered text block at CHARS chars (default {DEFAULT_TOOL_RESULT_MAX_CHARS}; 0 = no cap).",
    )
    p.add_argument(
        "--no-ts",
        action="store_true",
        help="omit the leading [timestamp] prefix.",
    )
    p.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help=(
            "emit per-record metadata after each headline (model, "
            "usage tokens, stop_reason, requestId, attributionAgent, "
            "agentId, slug, uuid, parentUuid, sourceToolAssistantUUID, "
            "cwd, gitBranch, etc.). Defaults off to keep terminal "
            "output readable."
        ),
    )
    p.add_argument(
        "--path",
        action="store_true",
        help="print the resolved JSONL path and exit.",
    )
    p.add_argument(
        "--poll-interval",
        type=float,
        default=0.5,
        metavar="SECS",
        help="follow-mode poll interval (default 0.5s).",
    )
    p.add_argument(
        "-q",
        "--quiet",
        action="store_true",
        help="suppress informational stderr (e.g. multi-candidate notices).",
    )
    p.add_argument(
        "--list",
        action="store_true",
        help="list every agent transcript under ~/.claude/projects/, newest first.",
    )
    p.add_argument(
        "--test",
        action="store_true",
        help="run the embedded test suite and exit.",
    )
    return p


def main(argv: Optional[list[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.test:
        return _run_embedded_tests()
    if args.list:
        return cmd_list(args)
    if not args.agent_id:
        parser.error("agent_id is required (or use --list / --test)")
    return cmd_tail(args)


