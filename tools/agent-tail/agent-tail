            # 2026-04-30T23:25:42.871Z -> finite epoch
            self.assertIsInstance(parse_iso_ts("2026-04-30T23:25:42.871Z"), float)
            # Bad -> None
            self.assertIsNone(parse_iso_ts("not-a-date"))
            self.assertIsNone(parse_iso_ts(""))
