    class TestFollow(unittest.TestCase):
        def setUp(self) -> None:
            import tempfile
            self.tmp = tempfile.mkdtemp(prefix="agent-tail-follow-")
            self.path = Path(self.tmp) / "agent-x.jsonl"
            self.path.write_text("", encoding="utf-8")

        def tearDown(self) -> None:
            import shutil
            shutil.rmtree(self.tmp, ignore_errors=True)

        def test_follow_picks_up_new_lines(self):
            import threading
            collected: list[dict] = []

            def writer():
                time.sleep(0.05)
                with self.path.open("a") as f:
                    f.write(json.dumps({"type": "user", "message": {"content": "x"}}) + "\n")
                    f.flush()
                time.sleep(0.05)
                with self.path.open("a") as f:
                    f.write(json.dumps({"type": "assistant", "message": {"content": [{"type": "text", "text": "ok"}]}}) + "\n")
                    f.flush()

            t = threading.Thread(target=writer)
            t.start()
            try:
                for obj, _raw in follow_file(self.path, poll_interval=0.05, stop_after=0.5):
                    collected.append(obj)
                    if len(collected) >= 2:
                        break
            finally:
                t.join()
            self.assertGreaterEqual(len(collected), 2)
            self.assertEqual(collected[0]["message"]["content"], "x")

        def test_follow_handles_truncation(self):
            # Pre-fill, then truncate while follow is reading.
            with self.path.open("w") as f:
                f.write(json.dumps({"type": "user", "message": {"content": "first"}}) + "\n")
            import threading
            collected: list[dict] = []

            def truncator():
                time.sleep(0.1)
                # Truncate to empty, then write a new line.
                with self.path.open("w") as f:
                    f.write(json.dumps({"type": "user", "message": {"content": "after-trunc"}}) + "\n")

            t = threading.Thread(target=truncator)
            t.start()
            try:
                for obj, _raw in follow_file(self.path, poll_interval=0.05, stop_after=0.6):
                    collected.append(obj)
                    if any(c.get("message", {}).get("content") == "after-trunc" for c in collected):
                        break
            finally:
                t.join()
            self.assertTrue(any(c.get("message", {}).get("content") == "after-trunc" for c in collected))

    # Build & run.
    loader = unittest.TestLoader()
    suite = unittest.TestSuite()
    for cls in (TestPureHelpers, TestFormatRecord, TestResolution, TestFollow):
        suite.addTests(loader.loadTestsFromTestCase(cls))
    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(suite)
    return 0 if result.wasSuccessful() else 1


if __name__ == "__main__":
    sys.exit(main())
