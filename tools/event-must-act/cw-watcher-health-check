#!/usr/bin/env bash
# cw-watcher-health-check — detect dead event watcher via stale queue and
# inject a recovery alert into the Claude Code pane.
#
# The event watcher (claude-event-watch) runs as a `run_in_background` task
# inside the Claude Code session. When the container is recreated, the
# session clears, or the watcher otherwise dies, nobody restarts it and
# claude-events pile up unconsumed in the spool directory. This script
# detects that condition by checking for `*.json` event files that have sat
# past a staleness threshold.
#
# If stale events exist, the watcher is dead (or stuck). We inject a
# [CLAUDE-WATCH] alert directly into the tmux pane via `claude-watch inject`,
# bypassing the event system entirely (which is the whole point — if events
# are accumulating, the event consumption path is broken).
#
# This is the CRON-DRIVEN RECOVERY injector. It is distinct from, and
# complementary to, the claude-watch DAEMON's own heartbeat-stale inject:
#   - The daemon fires when the *host heartbeat file* mtime goes stale (the
#     main loop stopped touching it). PREVENTION/liveness path.
#   - This script fires when *event files* go unconsumed (the event WATCHER
#     is dead, even if the loop is otherwise alive). RECOVERY path for the
#     watcher itself.
# They watch different signals, so they don't double-fire on the same
# condition. The per-condition cooldown below keeps THIS script from
# re-injecting every cron tick while a stale window persists.
#
# Runs via cron. In the container that's the baked cron.d/cw-default entry;
# on a non-container (systemd) host it's wired into the host crontab. Both
# default to once per minute.
#
# Environment:
#   CLAUDE_EVENT_QUEUE  — event spool directory (default ~/claude-events)
#   CW_WATCHER_HEALTH_STALE_MIN — age threshold in minutes (default 2)
#   CW_WATCHER_HEALTH_PANE — tmux pane target. When UNSET/empty (the
#       default), `--pane` is omitted entirely and `claude-watch inject`
#       resolves the pane itself ($CW_WATCHER_HEALTH_PANE -> $CLAUDE_WATCH_PANE
#       -> `[tmux] dashboard_pane` config -> claude-pane auto-detect). Set it
#       explicitly to pin a pane (e.g. the container sets claude-container:0.0).
#   CW_WATCHER_HEALTH_RESTART_HINT — operator-specific instruction appended
#       to the alert telling the loop how to restart the watcher (default:
#       "Restart the event watcher (watcher-restart) immediately.").
#   CW_WATCHER_HEALTH_COOLDOWN_SECS — minimum seconds between injects while a
#       stale window persists (default 600 = 10 min). 0 disables the
#       cooldown (inject every tick that finds stale events).
#   CW_WATCHER_HEALTH_STATE — cooldown ledger path
#       (default $CLAUDE_EVENT_STATE_DIR/watcher-health-last-inject, falling
#       back to ~/.config/claude-events/watcher-health-last-inject).
#
# --- Last-resort auto-restart fallback (opt-in, 2026-06-25) ----------------
#   CW_WATCHER_HEALTH_AUTORESTART — when set to "1", enable the bounded
#       last-resort auto-restart of the event-consumer watcher described
#       below. DEFAULT OFF (empty): the script behaves exactly as before
#       (inject-only). This is an OPT-IN escape from the cardinal "watchers
#       are spawned only by the main loop" rule, scoped to the ONE watcher
#       whose death blinds the entire event bus.
#   CW_WATCHER_HEALTH_AUTORESTART_AFTER — how many consecutive successful
#       injects must fire (i.e. how many times the main-loop restart path
#       must demonstrably FAIL to drain the queue) before the fallback
#       relaunches the watcher itself. Default 3. Each inject is gated by the
#       cooldown above, so the default ~= 3 * COOLDOWN_SECS (≈30 min at 600s)
#       of a sustained-blind bus before the cron takes over.
#   CW_WATCHER_HEALTH_WATCHER_CMD — the command the fallback runs to relaunch
#       the consumer. Default "claude-event-watch". It is launched DETACHED
#       (setsid, fully backgrounded, output discarded) so the per-minute cron
#       tick returns immediately. The watcher's own fd-based flock singleton
#       guard (see tools/watchers/claude-event-watch) makes this a guaranteed
#       NO-OP if a live watcher already holds the lock — so the fallback can
#       only ever win when the bus is genuinely unconsumed.
#   CW_WATCHER_HEALTH_ESCALATION_STATE — escalation-counter ledger path
#       (default alongside the cooldown ledger as
#       <state-dir>/watcher-health-escalations).
#
# WHY THIS IS SAFE / HOW IT RESPECTS THE CARDINAL RULE.
#   The cardinal rule (watchers spawned ONLY by the Claude Code main loop, in
#   the main loop's process tree) exists because a daemon-spawned watcher in a
#   detached systemd/user slice is orphaned, invisible to the obligation gate,
#   and a surprise to the next session (see src/watcher.rs "REMOVED 2026-05-01"
#   + feedback_watcher-architecture-cardinal.md). This fallback is a deliberate,
#   NARROW, opt-in exception that respects the rule's intent four ways:
#     1. The inject (main-loop) path fires FIRST and remains primary. The
#        auto-restart only triggers after that path has PROVABLY failed
#        AUTORESTART_AFTER times in a row (the queue stayed stale across that
#        many inject windows).
#     2. It is scoped to the event-CONSUMER watcher ONLY — the single watcher
#        whose death blinds the WHOLE event bus (all other watchers' deaths are
#        merely a missed signal; this one's death means nothing is consumed and
#        events pile up unbounded, as happened for >1.5h this session).
#     3. The watcher's own flock singleton guard means a cron-spawned instance
#        is a no-op whenever a real watcher is alive — there is no double-spawn
#        and no race; the fallback only succeeds when the bus is truly blind.
#     4. It self-corrects: once the watcher is alive again, events drain, the
#        next cron tick finds nothing stale, and the next main-loop exit/restart
#        cycle naturally re-parents a fresh watcher into the main-loop tree. A
#        cron-parented-but-ALIVE consumer for a few minutes is strictly better
#        than a blind bus.
#   It is OFF by default so the exception is an explicit operator opt-in, never
#   silent.

set -euo pipefail

QUEUE="${CLAUDE_EVENT_QUEUE:-$HOME/claude-events}"
STALE_MIN="${CW_WATCHER_HEALTH_STALE_MIN:-2}"
PANE="${CW_WATCHER_HEALTH_PANE:-}"
RESTART_HINT="${CW_WATCHER_HEALTH_RESTART_HINT:-Restart the event watcher (watcher-restart) immediately.}"
COOLDOWN_SECS="${CW_WATCHER_HEALTH_COOLDOWN_SECS:-600}"

STATE_DIR_DEFAULT="${CLAUDE_EVENT_STATE_DIR:-$HOME/.config/claude-events}"
STATE_FILE="${CW_WATCHER_HEALTH_STATE:-$STATE_DIR_DEFAULT/watcher-health-last-inject}"

# Last-resort auto-restart fallback config (opt-in; see header).
AUTORESTART="${CW_WATCHER_HEALTH_AUTORESTART:-}"
AUTORESTART_AFTER="${CW_WATCHER_HEALTH_AUTORESTART_AFTER:-3}"
WATCHER_CMD="${CW_WATCHER_HEALTH_WATCHER_CMD:-claude-event-watch}"
ESCALATION_FILE="${CW_WATCHER_HEALTH_ESCALATION_STATE:-$STATE_DIR_DEFAULT/watcher-health-escalations}"

# If the queue directory doesn't exist, nothing to check.
if [ ! -d "$QUEUE" ]; then
    exit 0
fi

# Count .json files older than the threshold.
STALE=$(find "$QUEUE" -name '*.json' -mmin +"$STALE_MIN" 2>/dev/null | wc -l)

if [ "$STALE" -le 0 ]; then
    # Bus is healthy (nothing stale) — clear the escalation counter so a
    # FRESH outage starts counting from zero. (Removing the ledger is the
    # reset; absence reads as 0 below.)
    rm -f "$ESCALATION_FILE" 2>/dev/null || true
    exit 0
fi

# Cooldown: avoid re-injecting on every cron tick while the stale window
# persists (a single recovery nudge per cooldown window is enough; the loop
# either restarts the watcher and the events drain, or it's genuinely wedged
# and the daemon's own escalation takes over). Disabled when COOLDOWN_SECS=0.
NOW=$(date +%s)
if [ "$COOLDOWN_SECS" -gt 0 ] && [ -f "$STATE_FILE" ]; then
    LAST=$(cat "$STATE_FILE" 2>/dev/null || echo 0)
    case "$LAST" in
        ''|*[!0-9]*) LAST=0 ;;
    esac
    if [ $((NOW - LAST)) -lt "$COOLDOWN_SECS" ]; then
        # Still within cooldown — stay silent.
        exit 0
    fi
fi

# Inject directly into the tmux pane. This bypasses the event system (which
# is broken if we got here) and uses the same [CLAUDE-WATCH] prefix that the
# daemon uses for its alerts, triggering the "STOP EVERYTHING" protocol.
#
# The type-and-submit choreography is CENTRALIZED in `claude-watch inject`
# (src/tmux.rs) — the ONE verified copy of the Escape->NORMAL / dd / `i`
# INSERT verify-and-retry / type / Tab->Escape->Enter sequence. Shelling out
# to it (instead of hand-rolling send-keys) carries the proven keystroke
# order AND verifies the submission landed (payload cleared from the prompt
# line), exiting non-zero if it didn't.
ALERT="[CLAUDE-WATCH] WATCHER DOWN: $STALE event(s) unconsumed >${STALE_MIN}min — the event watcher is dead or stuck. $RESTART_HINT"

inject_rc=0
if [ -n "$PANE" ]; then
    claude-watch inject --pane "$PANE" --submit "$ALERT" || inject_rc=$?
else
    claude-watch inject --submit "$ALERT" || inject_rc=$?
fi

if [ "$inject_rc" -ne 0 ]; then
    printf 'cw-watcher-health-check: claude-watch inject reported submit not verified (rc=%s, pane=%q)\n' \
        "$inject_rc" "${PANE:-<auto>}" >&2
    # Do NOT record the cooldown stamp on a failed inject — let the next tick
    # retry rather than going silent for the whole cooldown window after a
    # submit that never landed.
    exit "$inject_rc"
fi

# Record the successful-inject timestamp for the cooldown gate.
mkdir -p "$(dirname "$STATE_FILE")" 2>/dev/null || true
printf '%s\n' "$NOW" > "$STATE_FILE" 2>/dev/null || true

# --- Last-resort auto-restart fallback ------------------------------------
# A successful inject just fired but the queue is STILL stale (we only reach
# here while $STALE > 0), so the main-loop restart path has not yet drained
# the bus. Count these consecutive escalations; once they reach the
# AUTORESTART_AFTER threshold (and the operator opted in via
# CW_WATCHER_HEALTH_AUTORESTART=1), relaunch the event-consumer watcher
# ourselves as a detached last resort. See the header for the full
# cardinal-rule safety argument. When the fallback is OFF, this whole block
# is inert except for keeping the counter (harmless) so flipping it on
# mid-outage takes effect promptly.
ESC=0
if [ -f "$ESCALATION_FILE" ]; then
    ESC=$(cat "$ESCALATION_FILE" 2>/dev/null || echo 0)
    case "$ESC" in
        ''|*[!0-9]*) ESC=0 ;;
    esac
fi
ESC=$((ESC + 1))
mkdir -p "$(dirname "$ESCALATION_FILE")" 2>/dev/null || true
printf '%s\n' "$ESC" > "$ESCALATION_FILE" 2>/dev/null || true

if [ "$AUTORESTART" = "1" ] && [ "$ESC" -ge "$AUTORESTART_AFTER" ]; then
    # The main-loop restart path has demonstrably failed $ESC times in a row
    # (>= threshold). Relaunch the consumer ourselves, fully DETACHED so this
    # per-minute cron tick returns immediately and the watcher outlives it.
    # The watcher's own fd-based flock singleton guard makes this a NO-OP if a
    # live watcher already holds the lock (it exits 3) — so we only ever win
    # when the bus is genuinely blind. We discard the watcher's stdout/stderr
    # here: when cron-launched there is no main loop reading its block-print
    # output, and that is fine — its job in this fallback is purely to DRAIN
    # the spool and keep the bus alive until the main loop re-parents a fresh
    # in-tree watcher on its next restart cycle.
    if command -v setsid >/dev/null 2>&1; then
        setsid sh -c "$WATCHER_CMD >/dev/null 2>&1 &" >/dev/null 2>&1 || true
    else
        # No setsid (rare): nohup + background as a best-effort detach.
        nohup sh -c "$WATCHER_CMD >/dev/null 2>&1 &" >/dev/null 2>&1 || true
    fi
    printf 'cw-watcher-health-check: LAST-RESORT auto-restart of event consumer (%s) after %s consecutive failed injects\n' \
        "$WATCHER_CMD" "$ESC" >&2
    # Reset the counter: we just took the corrective action, so the next
    # window starts fresh. If the relaunch was a flock no-op (watcher already
    # alive) the next healthy tick clears it anyway; if it genuinely revived
    # the bus, events drain and the healthy-tick reset fires.
    rm -f "$ESCALATION_FILE" 2>/dev/null || true
fi
