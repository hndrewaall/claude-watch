def _transcript_tree(td: Path):
    """Build an empty projects tree + return a context to point
    CLAUDE_PROJECTS_DIR at it; caller adds transcripts via _mk_transcript."""
    proj = Path(td) / "projects"
    proj.mkdir(parents=True, exist_ok=True)
    return proj


def _mk_transcript(proj: Path, agent_id: str,
                   project="-p", session="s") -> Path:
    """Create a transcript JSONL for ``agent_id`` under a fake projects tree,
    so _agent_is_live(agent_id) sees it as LIVE."""
    needle = agent_id[len("agent-"):] if agent_id.startswith("agent-") else agent_id
    d = proj / project / session / "subagents"
    d.mkdir(parents=True, exist_ok=True)
    f = d / f"agent-{needle}.jsonl"
    f.write_text('{"type":"user"}\n', encoding="utf-8")
    return f


