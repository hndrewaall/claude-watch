def test_gc_drops_aged_read_messages():
    """GC drops messages whose read_at is older than the TTL; keeps others.

    Manually backdate a read_at, then run cmd_gc with a 1h TTL -- only the
    aged entry should drop."""
    import tempfile
    from datetime import timedelta
    with tempfile.TemporaryDirectory() as td:
        inbox_dir = str(Path(td) / "inbox")
        cmd_send(_make_args(agent_id="gc-test", text="old", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="gc-test", text="recent", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="gc-test", text="unread", inbox_dir=inbox_dir))
        # ack the first two: they pick up read_at=now.
        path = Path(inbox_dir) / "gc-test.json"
        cmd_ack(_make_args(agent_id="gc-test", inbox_dir=inbox_dir))
        # cmd_ack flips ALL unread, so all three are now read. Manually
        # un-ack the third one to make it unread again.
        envelope = json.loads(path.read_text())
        envelope["messages"][2]["read"] = False
        envelope["messages"][2]["read_at"] = None
        # Backdate the first message's read_at by 25 hours.
        old_ts = (datetime.now(timezone.utc) - timedelta(hours=25)).isoformat()
        envelope["messages"][0]["read_at"] = old_ts
        path.write_text(json.dumps(envelope))
        # Run GC with a 24h TTL (default) via cmd_gc.
        rc = cmd_gc(_make_args(agent_id="gc-test", inbox_dir=inbox_dir,
                               ttl_hours=24.0, json=True))
        assert rc == 0
        after = _load_inbox_messages(path)
        # "old" was read 25h ago -> dropped. "recent" + "unread" remain.
        texts = [m["text"] for m in after]
        assert "old" not in texts, f"expected old to be gc'd: got {texts}"
        assert "recent" in texts and "unread" in texts, texts
    return True


