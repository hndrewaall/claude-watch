def test_gc_dead_satisfies_dead_agent_obligations():
    """Regression test (a): leaked obligation for dead agent gets GC'd."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        inbox_dir = tmpdir / "inbox"
        # Two agents: alive and dead. Both armed.
        alive_id = "aALIVE0000"
        dead_id = "aDEAD00000"
        env = _isolated_test_env(tmpdir)
        # Use a real obligations CLI for end-to-end -- need it to be the
        # tools/obligations/obligations sibling of this script.
        cli = _obligations_cli()
        if not cli:
            return True  # default-open
        # Arm both via the real path so the obligation is registered.
        proc_env = {**os.environ,
                    "HOME": str(tmpdir),
                    "AGENT_MSG_INBOX_DIR": str(inbox_dir),
                    # Make claude-watch report only `alive_id` as alive.
                    "AGENT_MSG_CLAUDE_WATCH_CLI": str(_make_fake_claude_watch(
                        tmpdir, alive_ids=[alive_id])),
                    # Disable the implicit gc-dead so we can exercise it
                    # explicitly without races on the debounce stamp.
                    "AGENT_MSG_GC_DEAD_INTERVAL_SECS": "0"}
        # Use the script binary directly so cmd_arm hits the real obligations CLI.
        script = str(Path(__file__).resolve())
        for aid in (alive_id, dead_id):
            r = subprocess.run(
                [sys.executable, script, "arm", aid,
                 "--inbox-dir", str(inbox_dir), "--ttl", "300", "--json"],
                capture_output=True, text=True, timeout=15, env=proc_env, check=False,
            )
            assert r.returncode == 0, f"arm {aid}: rc={r.returncode} stderr={r.stderr}"
        # Pre-conditions: two of our obligations exist.
        obs_before = json.loads(subprocess.run(
            [cli, "list", "--json"], capture_output=True, text=True,
            timeout=10, env=proc_env, check=False).stdout)
        ours_before = [o for o in obs_before.get("obligations", [])
                       if (o.get("deny_message") or "").startswith(OBLIGATION_TAG_PREFIX)
                       and _agent_id_from_obligation(o) in (alive_id, dead_id)]
        assert len(ours_before) == 2, ours_before
        # Run gc-dead.
        r = subprocess.run(
            [sys.executable, script, "gc-dead",
             "--inbox-dir", str(inbox_dir), "--json"],
            capture_output=True, text=True, timeout=15, env=proc_env, check=False,
        )
        assert r.returncode == 0, f"gc-dead failed: {r.stderr}"
        out = json.loads(r.stdout)
        assert out["ok"] is True, out
        assert out["alive_count"] == 1
        # Exactly one dead obligation reaped.
        dead_records = out["dead"]
        assert len(dead_records) == 1, dead_records
        assert dead_records[0]["agent_id"] == dead_id
        assert dead_records[0]["satisfied"] is True
        # Post-condition (a): dead agent's obligation gone.
        # Post-condition (b): alive agent's obligation untouched.
        obs_after = json.loads(subprocess.run(
            [cli, "list", "--json"], capture_output=True, text=True,
            timeout=10, env=proc_env, check=False).stdout)
        remaining_ids = [_agent_id_from_obligation(o)
                         for o in obs_after.get("obligations", [])
                         if (o.get("deny_message") or "").startswith(OBLIGATION_TAG_PREFIX)]
        assert alive_id in remaining_ids, remaining_ids
        assert dead_id not in remaining_ids, remaining_ids
        # Cleanup the alive obligation we just registered for the test.
        for o in obs_after.get("obligations", []):
            if _agent_id_from_obligation(o) == alive_id and o.get("id"):
                subprocess.run(
                    [cli, "satisfy", o["id"]],
                    capture_output=True, text=True, timeout=5,
                    env=proc_env, check=False)
    return True


