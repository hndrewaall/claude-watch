def test_bindings_concurrent_writes_never_corrupt():
    """Parallel arm-hook _upsert_binding writers keep the file always-parseable.

    Imports the real _upsert_binding from the arm hook and hammers it from
    many threads against one binding file; after every write the file must
    parse as JSON (atomic tmp+rename under flock), and the final file must
    contain every agent's binding.
    """
    import tempfile
    import threading
    import importlib.machinery
    import importlib.util
    hook_path = (Path(__file__).resolve().parent.parent
                 / "hooks" / "post-tool-agent-arm-hook")
    if not hook_path.exists():
        return True  # hook not co-located in this layout -- skip
    # The hook file has no .py extension, so use SourceFileLoader directly
    # (spec_from_file_location returns None for unrecognised suffixes).
    loader = importlib.machinery.SourceFileLoader("_arm_hook", str(hook_path))
    spec = importlib.util.spec_from_loader("_arm_hook", loader)
    mod = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    with tempfile.TemporaryDirectory() as td:
        bpath = Path(td) / "bindings.json"
        old = os.environ.get("CLAUDE_AGENT_QUEUE_BINDINGS_PATH")
        os.environ["CLAUDE_AGENT_QUEUE_BINDINGS_PATH"] = str(bpath)
        stop = threading.Event()
        errors = []

        def reader():
            # Continuously read; the file must NEVER fail to parse once it
            # exists (atomic rename guarantees a reader sees old-or-new,
            # never a half-written file).
            while not stop.is_set():
                if bpath.exists():
                    try:
                        raw = bpath.read_text()
                        if raw.strip():
                            json.loads(raw)
                    except json.JSONDecodeError as e:
                        errors.append(f"reader saw corrupt JSON: {e}")
                        return

        def writer(i):
            for j in range(10):
                mod._upsert_binding(f"agent-{i}-{j}", f"q-{i}")

        try:
            rd = threading.Thread(target=reader)
            rd.start()
            ws = [threading.Thread(target=writer, args=(i,)) for i in range(8)]
            for w in ws:
                w.start()
            for w in ws:
                w.join()
            stop.set()
            rd.join()
            assert not errors, errors
            # Final file parses and holds every binding (8 * 10 = 80).
            final = json.loads(bpath.read_text())
            assert len(final["bindings"]) == 80, len(final["bindings"])
        finally:
            stop.set()
            if old is None:
                os.environ.pop("CLAUDE_AGENT_QUEUE_BINDINGS_PATH", None)
            else:
                os.environ["CLAUDE_AGENT_QUEUE_BINDINGS_PATH"] = old
    return True


