        if not setup:
            return True
        env, inbox_path, _ob = setup
        here = Path(__file__).resolve().parent
        # Send via the real CLI under the sandboxed HOME.
        send_proc = subprocess.run(
            [str(here / "agent-msg"), "send", "gt-real-ack",
