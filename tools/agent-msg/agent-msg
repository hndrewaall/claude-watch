def test_ack_flips_read_keeps_bodies():
    """ack flips read=true + sets read_at; bodies stay on disk for re-read."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        inbox_dir = str(tmpdir / "inbox")
        cmd_send(_make_args(agent_id="ack-test", text="hi",
                            inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="ack-test", text="hi-2",
                            inbox_dir=inbox_dir))
        path = Path(inbox_dir) / "ack-test.json"
        before = _load_inbox_messages(path)
        assert len(before) == 2
        assert all(not m["read"] for m in before)
        rc = cmd_ack(_make_args(agent_id="ack-test", inbox_dir=inbox_dir))
        assert rc == 0
        after = _load_inbox_messages(path)
        # Bodies + count preserved.
        assert len(after) == 2
        assert [m["text"] for m in after] == ["hi", "hi-2"]
        assert all(m["read"] is True for m in after)
        assert all(isinstance(m["read_at"], str) and m["read_at"] for m in after)
    return True


def test_ack_specific_message_id():
    """ack --message-id only flips the targeted message."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        inbox_dir = str(Path(td) / "inbox")
        cmd_send(_make_args(agent_id="byid", text="a", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="byid", text="b", inbox_dir=inbox_dir))
