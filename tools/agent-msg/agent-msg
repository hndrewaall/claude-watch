def test_send_by_queue_id_live_no_inbox_yet_resolves():
    """BUG-1 repro: a live agent (transcript exists) that has NEVER been
    messaged (no inbox file yet) must resolve + receive the send, which
    CREATES the inbox. The old inbox-existence liveness check made this a
    chicken-and-egg: resolution refused the agent before send could create
    its inbox."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        _write_bindings(Path(td) / "bindings.json", {"agent-fresh": "q-fresh"})
        proj = _transcript_tree(Path(td))
        _mk_transcript(proj, "agent-fresh")  # alive: transcript exists
        # Deliberately do NOT create any inbox file first.
        inbox_path = Path(td) / "inbox" / "agent-fresh.json"
        assert not inbox_path.exists()
        old = os.environ.get("CLAUDE_PROJECTS_DIR")
        os.environ["CLAUDE_PROJECTS_DIR"] = str(proj)
        try:
            # Resolution succeeds (transcript-liveness), not "NONE are live".
            args = _resolve_args(td, queue_id="q-fresh")
            assert _resolve_queue_id_best("q-fresh", args) == "agent-fresh"
            # And the send goes through, creating the inbox.
            rc = cmd_send(_resolve_args(td, queue_id="q-fresh",
                                        text="correction", no_arm=True))
            assert rc == 0
            assert inbox_path.exists(), "send must create the inbox"
            data = _load_inbox_messages(inbox_path)
            assert [m["text"] for m in data] == ["correction"], data
        finally:
            if old is None:
                os.environ.pop("CLAUDE_PROJECTS_DIR", None)
            else:
                os.environ["CLAUDE_PROJECTS_DIR"] = old
    return True


