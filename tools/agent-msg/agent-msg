        _write_bindings(bpath, {"agent-a": "q-1", "agent-b": "q-2"})
        args = _resolve_args(td)
        b = _read_bindings(args)
        assert set(b.keys()) == {"agent-a", "agent-b"}
        assert b["agent-a"]["queue_id"] == "q-1"
        assert b["agent-b"]["queue_id"] == "q-2"
    return True


def test_bindings_corrupt_tolerated_on_read():
    """A corrupt / empty / wrong-shape binding file reads as {} (no crash)."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        bpath = Path(td) / "bindings.json"
        args = _resolve_args(td)
        # Missing file.
        assert _read_bindings(args) == {}
        # Empty file.
        bpath.write_text("")
        assert _read_bindings(args) == {}
        # Truncated / invalid JSON (the exact failure the main loop hit).
        bpath.write_text('{"bindings": {"a": {"queue_id": "q-1"')
        assert _read_bindings(args) == {}
        # Not-an-object root.
        bpath.write_text("[1, 2, 3]")
        assert _read_bindings(args) == {}
        # bindings is not a dict.
        bpath.write_text('{"bindings": []}')
        assert _read_bindings(args) == {}
        # Concatenated JSON objects (interleaved non-atomic writes).
        bpath.write_text('{"bindings": {}}{"bindings": {}}')
        assert _read_bindings(args) == {}
    return True


