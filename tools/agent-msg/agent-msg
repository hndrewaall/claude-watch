def test_gc_dead_implicit_runs_respects_rate_limit():
    """_maybe_implicit_gc_dead writes a stamp and skips re-runs within interval."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        inbox_dir = tmpdir / "inbox"
        inbox_dir.mkdir(parents=True, exist_ok=True)
        old_env = os.environ.copy()
        try:
            cw = _make_fake_claude_watch(tmpdir, alive_ids=[])
            os.environ["AGENT_MSG_CLAUDE_WATCH_CLI"] = str(cw)
            os.environ["AGENT_MSG_INBOX_DIR"] = str(inbox_dir)
            # 60 second debounce for the test.
            os.environ["AGENT_MSG_GC_DEAD_INTERVAL_SECS"] = "60"
            args = _make_args(inbox_dir=str(inbox_dir))
            stamp = inbox_dir / GC_DEAD_STAMP_FILENAME
            assert not stamp.exists()
            _maybe_implicit_gc_dead(args)
            assert stamp.exists()
            mtime1 = stamp.stat().st_mtime
            # Immediate re-run should not update mtime (rate-limited).
            time.sleep(0.05)
            _maybe_implicit_gc_dead(args)
            mtime2 = stamp.stat().st_mtime
            assert mtime2 == mtime1, "rate-limit should prevent re-touch"
        finally:
            os.environ.clear()
            os.environ.update(old_env)
    return True


