            capture_output=True, text=True, timeout=10, env=env, check=False,
        )
        assert all_proc.returncode == 0
        data = json.loads(all_proc.stdout)
        assert data["total"] == 1
        assert data["messages"][0]["text"] == "switch tasks please"
        assert data["messages"][0]["read"] is True
    return True


