# ----------------------------------------------------------------------
# Gate-mode end-to-end tests
#
# These tests register a real obligation through the obligations CLI in a
# sandboxed HOME, populate the inbox via cmd_send, and run the
# pre-tool-obligations-gate-hook to verify the gate behavior:
#
# 1. Subagent + non-empty inbox + non-exempt tool -> DENY
# 2. Subagent + non-empty inbox + agent-msg ack -> ALLOW (exempt)
# 3. Subagent + non-empty inbox + agent-msg inbox -> ALLOW (exempt)
# 4. Subagent + non-empty inbox + agent-msg disarm -> ALLOW (exempt)
# 5. Main loop + non-empty inbox -> ALLOW (is_main_loop scope-guard fires)
# 6. Subagent + after ack -> ALLOW (predicate satisfied again)
#
# We resolve the pre-tool hook from the same dir as this script.
# ----------------------------------------------------------------------


def _gate_hook_path():
    """Resolve pre-tool-obligations-gate-hook. Tests skip if missing.

    Search order:
      1. Sibling next to this script (in-tree dev layout, used to be the
         only path)
      2. Sibling in ``tools/hooks/`` of the same repo (canonical layout
         after the 2026-05-01 reorganization split obligations + hooks
         into separate top-level dirs under ``tools/``)
      3. ``~/bin/pre-tool-obligations-gate-hook`` (installed-via-make path)
    """
    here = Path(__file__).resolve().parent
    candidates = [
        here / "pre-tool-obligations-gate-hook",
        here.parent / "hooks" / "pre-tool-obligations-gate-hook",
        Path.home() / "bin" / "pre-tool-obligations-gate-hook",
    ]
    for candidate in candidates:
        try:
            if candidate.exists() and os.access(candidate, os.X_OK):
                return str(candidate)
        except OSError:
            continue
    return None


def _run_pre_hook(hook_path: str, payload: dict, env: dict):
    """Invoke the pre-tool hook with stdin payload. Return (rc, parsed_out)."""
    proc = subprocess.run(
        [hook_path], input=json.dumps(payload),
        capture_output=True, text=True, timeout=10, env=env, check=False,
    )
    try:
        out = json.loads(proc.stdout) if proc.stdout.strip() else {}
    except json.JSONDecodeError:
        out = {"__raw__": proc.stdout}
    return proc.returncode, out, proc.stderr


def _is_deny(out: dict) -> bool:
    hso = out.get("hookSpecificOutput") or {}
    return hso.get("permissionDecision") == "deny"


def _gate_test_setup(tmpdir: Path, agent_id: str = "gtest-agent"):
    """Common setup: sandbox HOME, register a real obligation via arm.

    Returns (env, inbox_path, ob_id) -- env to use for the hook,
    inbox_path so the test can send messages, ob_id to clean up after.
