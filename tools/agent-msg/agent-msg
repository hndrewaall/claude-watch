def _make_fake_claude_watch(tmpdir: Path, alive_ids: list[str],
                              *, exit_code: int = 0,
                              malformed: bool = False) -> Path:
    """Write a tiny shell script that mimics `claude-watch active-agents --json`.

    The agent-msg gc-dead path shells out to `claude-watch active-agents
    --json` and parses the {"agents":[{"agent_id":..., "alive":bool}]}
    shape. For unit tests we fake this with a script whose path is
    pinned via AGENT_MSG_CLAUDE_WATCH_CLI.
    """
    cw = tmpdir / "fake-claude-watch"
    if malformed:
        body = "#!/bin/sh\necho 'not json'\n"
    elif exit_code != 0:
        body = f"#!/bin/sh\nexit {exit_code}\n"
    else:
        agents = [{"agent_id": aid, "alive": True,
                   "queue_id": None, "jsonl_age_seconds": 0}
                  for aid in alive_ids]
        payload = json.dumps({
            "subagents": [],
            "workloads": [],
            "agents": agents,
        })
        body = f"#!/bin/sh\ncat <<'EOJ'\n{payload}\nEOJ\n"
    cw.write_text(body)
    cw.chmod(0o755)
    return cw


