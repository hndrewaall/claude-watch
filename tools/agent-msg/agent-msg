def test_gate_cross_agent_isolation_regression():
    """REGRESSION: agent A's unread inbox must NOT gate agent B's tool calls.

    Bug shape (2026-05-03 cross-agent leak):
        Agent A was armed; main loop sent a STOP message to A's inbox.
        A exited without disarming (PostToolUse hook never receives
        status=completed in practice -- the disarm path is dead code).
        The obligation row for A was left in the obligations DB.
        Later, agent B (a totally unrelated agent_id) was spawned for an
        unrelated queue item. On B's first non-exempt tool call, the
        still-active obligation for A's inbox path was evaluated:
            is_main_loop {negate: true}        -> True  (B is a subagent)
            agent_inbox_empty {path: A.json}   -> False (A had unread)
        The all_of returned False, B was denied with A's STOP message in
        the banner. B (correctly) interpreted this as "main loop wants me
        to abort" and exited.

    Fix (2026-05-03):
        agent_inbox_empty now accepts an `agent_id` param. When the
        registered agent_id != the current call's agent_id, the predicate
        auto-satisfies (returns True). agent-msg's _register_inbox_obligation
        passes the owning agent_id, so leaked rows from past agents are
        scoped to those agents and harmless to new ones.
    """
    hook = _gate_hook_path()
    if not hook:
        return True
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        # Arm agent A under a sandboxed HOME. This registers the obligation
        # row that, pre-fix, would leak across agents.
        setup_a = _gate_test_setup(tmpdir, "ga-leakA")
        if not setup_a:
            return True
        env, inbox_a_path, _ob_a = setup_a
        # Populate A's inbox so the predicate would fail for any subagent.
        inbox_a_path.write_text(json.dumps([{
            "from": "main-loop", "ts": _now_iso(),
            "queue_item": "q-A", "text": "STOP message intended for agent A only",
        }]))
        # SANITY CHECK: agent A IS still gated on its own calls -- the fix
        # narrows scope but must not break the per-agent gate.
        rc, out, _err = _run_pre_hook(
            hook,
            {"tool_name": "Bash", "tool_input": {"command": "ls"},
             "agent_id": "ga-leakA"},
            env,
        )
        assert rc == 0, f"rc={rc} out={out}"
        assert _is_deny(out), (
            f"agent A must STILL be denied while its own inbox has unread; "
            f"got {out}"
        )
        sysmsg = out.get("systemMessage") or ""
        assert "STOP message intended for agent A" in sysmsg, (
            f"A's banner must contain A's message: {sysmsg!r}"
        )
        # CORE REGRESSION CHECK: agent B (a different subagent id) MUST NOT
        # be denied. Its agent_id does not match the agent_id baked into
        # A's obligation row, so the predicate auto-satisfies for B.
        rc, out, _err = _run_pre_hook(
            hook,
            {"tool_name": "Bash", "tool_input": {"command": "ls"},
             "agent_id": "gb-leakB"},
            env,
        )
        assert rc == 0, f"rc={rc} out={out}"
        assert not _is_deny(out), (
            f"agent B must NOT be denied by agent A's leaked obligation row "
            f"(cross-agent leak regression); got {out}"
        )
        # Also: agent B must not see A's message anywhere in the deny payload
        # (in case some other unrelated obligation fires -- belt and braces).
        sysmsg_b = out.get("systemMessage") or ""
        assert "STOP message intended for agent A" not in sysmsg_b, (
            f"agent B saw agent A's message in its banner -- the leak is "
            f"NOT closed: {sysmsg_b!r}"
        )
    return True


def test_arm_registers_gate_mode_with_exempt_patterns():
    """`agent-msg arm` registers a GATE-mode obligation with the documented
    exempt_patterns. This guards against an accidental drop back to
    inform-mode (which empirically failed to surface to subagents)."""
    cli = _obligations_cli()
    if not cli:
        return True  # default-open
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        env = os.environ.copy()
        env["HOME"] = str(tmpdir)
        inbox_dir = tmpdir / "inbox"
        here = Path(__file__).resolve().parent
        arm_proc = subprocess.run(
            [str(here / "agent-msg"), "arm", "shape-test",
             "--inbox-dir", str(inbox_dir),
             "--ttl", "120", "--json"],
            capture_output=True, text=True, timeout=10, env=env, check=False,
        )
        assert arm_proc.returncode == 0, arm_proc.stderr
        ob_id = json.loads(arm_proc.stdout)["obligation_id"]
        # Inspect via `obligations show`.
        show_proc = subprocess.run(
            [cli, "show", ob_id],
            capture_output=True, text=True, timeout=5, env=env, check=False,
        )
        assert show_proc.returncode == 0, show_proc.stderr
        row = json.loads(show_proc.stdout)
        assert row["enforcement"] == "gate", (
            f"expected enforcement=gate, got {row['enforcement']!r} -- "
            f"do NOT regress to inform mode (silently drops messages to "
            f"subagents)"
        )
        exempts = row.get("exempt_patterns", [])
        # Must include the three documented exempt patterns.
        joined = " ".join(exempts)
        for needle in ("agent-msg", "ack", "inbox", "disarm"):
            assert needle in joined, (
                f"exempt_patterns missing {needle!r}: {exempts!r}"
            )
    return True


def test_v1_legacy_inbox_auto_migrates():
    """Reading a v1 bare-list inbox migrates it in place to a v2 envelope.

    This guards live in-flight agents that already have a v1 inbox on disk:
    the very next read flips the file to v2 without losing any pending
    messages, every entry gets read=false (so the predicate still blocks),
    and a fresh id field is synthesised."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        inbox_dir = Path(td) / "inbox"
        inbox_dir.mkdir()
        path = inbox_dir / "legacy.json"
        # v1 shape: bare list, no read/id.
        path.write_text(json.dumps([
            {"from": "main-loop", "ts": "2026-04-30T10:00:00+00:00",
             "queue_item": "q-x", "text": "old message"}
        ]))
        # Read via cmd_inbox -- should return rc=0 and surface the message.
        rc = cmd_inbox(_make_args(agent_id="legacy",
                                  inbox_dir=str(inbox_dir), json=True))
        assert rc == 0
        # On disk: now v2.
        envelope = json.loads(path.read_text())
        # First read in cmd_inbox is non-mutating (we unlock without writing).
        # We need to do something that triggers a write -- send a new message.
        cmd_send(_make_args(agent_id="legacy", text="new",
                            inbox_dir=str(inbox_dir)))
        envelope = json.loads(path.read_text())
        assert envelope["schema_version"] == 2
        assert isinstance(envelope["messages"], list)
        assert len(envelope["messages"]) == 2
        for m in envelope["messages"]:
            assert m["read"] is False, "v1 entries must migrate as unread"
            assert m["id"], "every entry must get an id post-migration"
    return True


def test_inbox_default_unread_only():
    """`agent-msg inbox` (no --all) shows only unread; --all shows history."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        inbox_dir = str(Path(td) / "inbox")
        cmd_send(_make_args(agent_id="dflt-unread", text="first",
                            inbox_dir=inbox_dir))
        cmd_ack(_make_args(agent_id="dflt-unread", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="dflt-unread", text="second",
                            inbox_dir=inbox_dir))
        # Default view: unread only.
        import io
        from contextlib import redirect_stdout
        buf = io.StringIO()
        with redirect_stdout(buf):
            cmd_inbox(_make_args(agent_id="dflt-unread",
                                 inbox_dir=inbox_dir, json=True))
        result = json.loads(buf.getvalue())
        assert result["unread"] == 1
        assert result["total"] == 2
        assert len(result["messages"]) == 1
        assert result["messages"][0]["text"] == "second"
        # --all view: shows both.
        buf2 = io.StringIO()
        with redirect_stdout(buf2):
            cmd_inbox(_make_args(agent_id="dflt-unread",
                                 inbox_dir=inbox_dir,
                                 all=True, json=True))
        result2 = json.loads(buf2.getvalue())
        assert result2["unread"] == 1
        assert result2["total"] == 2
        assert len(result2["messages"]) == 2
        assert [m["text"] for m in result2["messages"]] == ["first", "second"]
    return True


def test_gc_drops_aged_read_messages():
    """GC drops messages whose read_at is older than the TTL; keeps others.

    Manually backdate a read_at, then run cmd_gc with a 1h TTL -- only the
    aged entry should drop."""
    import tempfile
    from datetime import timedelta
    with tempfile.TemporaryDirectory() as td:
        inbox_dir = str(Path(td) / "inbox")
        cmd_send(_make_args(agent_id="gc-test", text="old", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="gc-test", text="recent", inbox_dir=inbox_dir))
        cmd_send(_make_args(agent_id="gc-test", text="unread", inbox_dir=inbox_dir))
        # ack the first two: they pick up read_at=now.
        path = Path(inbox_dir) / "gc-test.json"
        cmd_ack(_make_args(agent_id="gc-test", inbox_dir=inbox_dir))
        # cmd_ack flips ALL unread, so all three are now read. Manually
        # un-ack the third one to make it unread again.
        envelope = json.loads(path.read_text())
        envelope["messages"][2]["read"] = False
        envelope["messages"][2]["read_at"] = None
        # Backdate the first message's read_at by 25 hours.
        old_ts = (datetime.now(timezone.utc) - timedelta(hours=25)).isoformat()
        envelope["messages"][0]["read_at"] = old_ts
        path.write_text(json.dumps(envelope))
        # Run GC with a 24h TTL (default) via cmd_gc.
        rc = cmd_gc(_make_args(agent_id="gc-test", inbox_dir=inbox_dir,
                               ttl_hours=24.0, json=True))
        assert rc == 0
        after = _load_inbox_messages(path)
        # "old" was read 25h ago -> dropped. "recent" + "unread" remain.
        texts = [m["text"] for m in after]
        assert "old" not in texts, f"expected old to be gc'd: got {texts}"
        assert "recent" in texts and "unread" in texts, texts
    return True


