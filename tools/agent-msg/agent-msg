                        "queue_id": None, "jsonl_age_seconds": 300}],
        })
        # Record argv, then emit the payload. (jsonl_age_seconds=300 models a
        # quiet-but-running agent; the flag is what makes cw report alive=True.)
        cw.write_text(
            "#!/bin/sh\n"
