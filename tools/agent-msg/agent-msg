def _isolated_test_env(tmpdir: Path):
    """Build a sandbox: separate inbox dir + separate obligations file."""
    return {
        "inbox_dir": str(tmpdir / "inbox"),
        "obligations_file": str(tmpdir / "obligations.json"),
    }


def _make_args(**kwargs):
    """Cheap argparse.Namespace stand-in."""
    defaults = {
        "agent_id": None, "text": None, "from_label": None,
        "queue_item": None, "dry_run": False, "json": False,
        "inbox_dir": None, "ttl": DEFAULT_OBLIGATION_TTL_SECS,
        "no_obligation": True,  # tests default to skipping obligation registration
        "description": "",
        # New v2 fields (read/all/gc):
        "all": False,
        "message_id": None,
        "all_history": False,
        "ttl_hours": None,
        # gc-dead default
        "command": None,
    }
    defaults.update(kwargs)
    return argparse.Namespace(**defaults)


def _load_inbox_messages(path: Path) -> list:
    """Test helper: load the v2 envelope on disk and return the messages list."""
    raw = path.read_text(encoding="utf-8")
    data = json.loads(raw) if raw.strip() else {}
    if isinstance(data, dict):
        return data.get("messages", []) or []
    if isinstance(data, list):
        # v1 leftover (shouldn't normally happen post-migration).
        return data
    return []


def test_send_writes_correct_json():
    """send writes a JSON entry with from/ts/queue_item/text fields."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        tmpdir = Path(td)
        inbox_dir = str(tmpdir / "inbox")
        args = _make_args(agent_id="test-1", text="hello",
                          from_label="tester", queue_item="q-test",
                          inbox_dir=inbox_dir)
        rc = cmd_send(args)
        assert rc == 0
        path = Path(inbox_dir) / "test-1.json"
        assert path.exists()
        data = _load_inbox_messages(path)
        assert isinstance(data, list)
        assert len(data) == 1
        assert data[0]["from"] == "tester"
        assert data[0]["text"] == "hello"
        assert data[0]["queue_item"] == "q-test"
        assert "ts" in data[0]
        # New v2 fields:
        assert data[0]["read"] is False
        assert data[0]["read_at"] is None
        assert data[0]["id"]
        # File-level: v2 envelope shape on disk.
        envelope = json.loads(path.read_text())
        assert envelope["schema_version"] == 2
        assert isinstance(envelope["messages"], list)
    return True


