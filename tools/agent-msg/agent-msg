def test_resolve_multi_match_picks_newest_live():
    """Two LIVE agents on the same q-id (nested/retry) -> deterministic
    newest-registered-live wins, no error (the old behavior errored)."""
    import tempfile
    import io
    from contextlib import redirect_stdout
    with tempfile.TemporaryDirectory() as td:
        # agent-2 registered AFTER agent-1 (newer -> should win).
        bpath = Path(td) / "bindings.json"
        bindings = {
            "agent-1": {"queue_id": "q-dup", "registered_at": 1000,
                        "registered_at_iso": _now_iso(), "pid": 1},
            "agent-2": {"queue_id": "q-dup", "registered_at": 2000,
                        "registered_at_iso": _now_iso(), "pid": 2},
        }
        bpath.parent.mkdir(parents=True, exist_ok=True)
        bpath.write_text(json.dumps({"bindings": bindings}, indent=2) + "\n")
        proj = _transcript_tree(Path(td))
        _mk_transcript(proj, "agent-1")
        _mk_transcript(proj, "agent-2")
        old = os.environ.get("CLAUDE_PROJECTS_DIR")
        os.environ["CLAUDE_PROJECTS_DIR"] = str(proj)
        try:
            args = _resolve_args(td, queue_id="q-dup")
            aid = _resolve_queue_id_best("q-dup", args)
            assert aid == "agent-2", aid  # newest live wins
            buf = io.StringIO()
            with redirect_stdout(buf):
                rc = cmd_resolve(_resolve_args(td, queue_id="q-dup"))
            assert rc == 0
            assert buf.getvalue().strip() == "agent-2"
        finally:
            if old is None:
                os.environ.pop("CLAUDE_PROJECTS_DIR", None)
            else:
                os.environ["CLAUDE_PROJECTS_DIR"] = old
    return True


def test_resolve_multi_match_prunes_dead_picks_live():
    """Two bindings, only the OLDER has a transcript: the live one wins even
    though it's older -- dead newest is pruned (the bug-2 nested case where
    a nested agent exited but the primary is still running)."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
        bpath = Path(td) / "bindings.json"
        bindings = {
            "agent-old-live": {"queue_id": "q-mix2", "registered_at": 1000,
                               "registered_at_iso": _now_iso(), "pid": 1},
            "agent-new-dead": {"queue_id": "q-mix2", "registered_at": 2000,
                               "registered_at_iso": _now_iso(), "pid": 2},
        }
        bpath.parent.mkdir(parents=True, exist_ok=True)
        bpath.write_text(json.dumps({"bindings": bindings}, indent=2) + "\n")
        proj = _transcript_tree(Path(td))
        _mk_transcript(proj, "agent-old-live")  # only this one is live
        _mk_transcript(proj, "decoy")           # make tree walkable
        old = os.environ.get("CLAUDE_PROJECTS_DIR")
        os.environ["CLAUDE_PROJECTS_DIR"] = str(proj)
        try:
            args = _resolve_args(td, queue_id="q-mix2")
            assert _resolve_queue_id_best("q-mix2", args) == "agent-old-live"
        finally:
            if old is None:
                os.environ.pop("CLAUDE_PROJECTS_DIR", None)
            else:
                os.environ["CLAUDE_PROJECTS_DIR"] = old
    return True


def test_resolve_all_lists_live_and_stale():
    """resolve --all lists every match, marking live vs stale, never errors.

    Liveness is now transcript-existence: agent-live has a transcript,
    agent-stale does not (but the tree is walkable, so it's provably stale)."""
    import tempfile
    import io
    from contextlib import redirect_stdout
    with tempfile.TemporaryDirectory() as td:
        bpath = Path(td) / "bindings.json"
        bindings = {
            "agent-live": {"queue_id": "q-mix", "registered_at": 2000,
                           "registered_at_iso": _now_iso(), "pid": 1},
            "agent-stale": {"queue_id": "q-mix", "registered_at": 1000,
                            "registered_at_iso": _now_iso(), "pid": 2},
        }
        bpath.parent.mkdir(parents=True, exist_ok=True)
        bpath.write_text(json.dumps({"bindings": bindings}, indent=2) + "\n")
        proj = _transcript_tree(Path(td))
        _mk_transcript(proj, "agent-live")
        _mk_transcript(proj, "decoy")  # tree walkable -> agent-stale provably stale
        old = os.environ.get("CLAUDE_PROJECTS_DIR")
        os.environ["CLAUDE_PROJECTS_DIR"] = str(proj)
        try:
            buf = io.StringIO()
            with redirect_stdout(buf):
                rc = cmd_resolve(_resolve_args(td, queue_id="q-mix",
                                               all=True, json=True))
            assert rc == 0
            result = json.loads(buf.getvalue())
            assert result["live"] == ["agent-live"], result
            assert result["stale"] == ["agent-stale"], result
            assert set(result["all"]) == {"agent-live", "agent-stale"}
        finally:
            if old is None:
                os.environ.pop("CLAUDE_PROJECTS_DIR", None)
            else:
                os.environ["CLAUDE_PROJECTS_DIR"] = old
    return True


