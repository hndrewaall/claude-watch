def _write_bindings(path: Path, mapping: dict) -> None:
    """Test helper: write a {agent_id: queue_id} mapping in arm-hook schema."""
    import time as _t
    now = int(_t.time())
    bindings = {
        aid: {"queue_id": qid, "registered_at": now,
              "registered_at_iso": _now_iso(), "pid": 1}
        for aid, qid in mapping.items()
    }
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps({"bindings": bindings}, indent=2) + "\n")


def _resolve_args(td: Path, **kw):
    """Args namespace pointing both binding map + inbox dir into a sandbox."""
    return _make_args(
        bindings_path=str(Path(td) / "bindings.json"),
        inbox_dir=str(Path(td) / "inbox"),
        **kw,
    )


def test_bindings_roundtrip():
    """_read_bindings reads back exactly what the arm-hook schema writes."""
    import tempfile
    with tempfile.TemporaryDirectory() as td:
