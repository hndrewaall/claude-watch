def build_parser():
    p = argparse.ArgumentParser(
        prog="agent-msg",
        description="Async messaging for Claude Code background agents (via obligations).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("--test", action="store_true", help="run embedded test suite")
    sub = p.add_subparsers(dest="command", help="subcommand")

    # list
    sub.add_parser("list", help="show all tracked agents (index)")

    # show
    p_show = sub.add_parser("show", help="show metadata for one agent (index)")
    p_show.add_argument("agent_id")

    # send
    p_send = sub.add_parser("send", help="append a message to an agent's inbox")
    p_send.add_argument("agent_id")
    p_send.add_argument("text")
    p_send.add_argument("--from", dest="from_label", default=None,
                        help="sender label (default: andrew@signal)")
    p_send.add_argument("--queue-item", default=None,
                        help="associated queue item id")
    p_send.add_argument("--inbox-dir", default=None,
                        help="override inbox dir (default: ~/.config/claude/agent-inbox/)")
    p_send.add_argument("--dry-run", action="store_true",
                        help="show what would be sent; do not write")
    p_send.add_argument("--json", action="store_true")

    # inbox (read without consuming) -- defaults to UNREAD only
    p_inb = sub.add_parser("inbox", help="read an agent's inbox (default: unread only)")
    p_inb.add_argument("agent_id")
    p_inb.add_argument("--inbox-dir", default=None)
    p_inb.add_argument("--all", action="store_true",
                       help="include already-read messages (kept on disk until GC)")
    p_inb.add_argument("--json", action="store_true")

    # ack -- flips read=true; KEEPS bodies on disk
    p_ack = sub.add_parser(
        "ack", help="mark unread messages as read (keeps bodies on disk)")
    p_ack.add_argument("agent_id")
    p_ack.add_argument("--inbox-dir", default=None)
    p_ack.add_argument("--message-id", default=None,
                       help="ack only the specified message id (default: all unread)")
    p_ack.add_argument("--all-history", action="store_true",
                       help="re-stamp read_at on already-read messages too (rare)")
    p_ack.add_argument("--json", action="store_true")

    # gc -- explicit garbage-collect of read messages older than the TTL
    p_gc = sub.add_parser(
        "gc", help="drop already-read messages older than the TTL")
    p_gc.add_argument("agent_id")
    p_gc.add_argument("--inbox-dir", default=None)
    p_gc.add_argument("--ttl-hours", type=float, default=None,
                      help=f"TTL hours (default: ${{AGENT_MSG_TTL_HOURS}} or "
                           f"{DEFAULT_READ_TTL_HOURS}); <=0 disables GC")
    p_gc.add_argument("--json", action="store_true")

    # gc-dead -- sweep inbox obligations whose owning agent is no longer alive
    p_gcd = sub.add_parser(
        "gc-dead",
        help="satisfy inbox obligations whose owning agent is no longer alive "
             "(backstop for broken PostToolUse disarm path)")
    p_gcd.add_argument("--inbox-dir", default=None)
    p_gcd.add_argument("--dry-run", action="store_true",
                       help="show what would be satisfied without taking action")
    p_gcd.add_argument("--json", action="store_true")

    # arm
    p_arm = sub.add_parser("arm", help="initialise inbox + register gate-mode obligation")
    p_arm.add_argument("agent_id")
    p_arm.add_argument("--inbox-dir", default=None)
    p_arm.add_argument("--ttl", type=int, default=DEFAULT_OBLIGATION_TTL_SECS,
                       help=f"obligation TTL in seconds (default: {DEFAULT_OBLIGATION_TTL_SECS})")
    p_arm.add_argument("--no-obligation", action="store_true",
                       help="skip obligation registration (testing only)")
    p_arm.add_argument("--json", action="store_true")

    # disarm
    p_dis = sub.add_parser("disarm", help="clear inbox + remove obligation for an agent")
    p_dis.add_argument("agent_id")
    p_dis.add_argument("--inbox-dir", default=None)
    p_dis.add_argument("--no-obligation", action="store_true",
                       help="skip obligation cleanup (testing only)")
    p_dis.add_argument("--json", action="store_true")

    # index
    p_idx = sub.add_parser("index", help="manage the agent index")
    idx_sub = p_idx.add_subparsers(dest="index_cmd")
    p_reg = idx_sub.add_parser("register", help="register agent in the index")
    p_reg.add_argument("agent_id")
    p_reg.add_argument("--queue-item", required=True)
    p_reg.add_argument("--description", default="")
    p_done = idx_sub.add_parser("done", help="remove agent from the index")
    p_done.add_argument("agent_id")

    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.test:
        return run_tests()

    if not args.command:
        parser.print_help()
        return 0

    # Implicit GC sweep at the top of every CLI invocation. The
    # AGENT_MSG_TTL_HOURS env var controls aging (default 24h). Errors
    # are swallowed inside _maybe_implicit_gc so a stuck file never
    # blocks send/ack/inbox.
    _maybe_implicit_gc(args)

    if args.command == "list":
        return cmd_list(args)
    if args.command == "show":
        return cmd_show(args)
    if args.command == "send":
        return cmd_send(args)
    if args.command == "inbox":
        return cmd_inbox(args)
    if args.command == "ack":
        return cmd_ack(args)
    if args.command == "gc":
        return cmd_gc(args)
    if args.command == "gc-dead":
        return cmd_gc_dead(args)
    if args.command == "arm":
        return cmd_arm(args)
    if args.command == "disarm":
        return cmd_disarm(args)
    if args.command == "index":
        if args.index_cmd == "register":
            return cmd_index_register(args)
        if args.index_cmd == "done":
            return cmd_index_done(args)
        # No subcommand -> help
        for action in parser._actions:
            if isinstance(action, argparse._SubParsersAction):
                action.choices["index"].print_help()
                break
        return 0
    parser.print_help()
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
