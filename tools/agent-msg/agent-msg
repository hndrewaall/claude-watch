# ----------------------------------------------------------------------
# Argparse wiring
# ----------------------------------------------------------------------


# ----------------------------------------------------------------------
# Queue-id -> agent-id resolution (binding map)
#
# The PostToolUse:Agent arm hook (tools/hooks/post-tool-agent-arm-hook)
# writes an agent_id -> queue_id binding map to
# ~/.config/claude/agent-queue-bindings.json with the schema:
#
#     {"bindings": {
#        "<agent_id>": {"queue_id": "q-...", "registered_at": <int>,
#                       "registered_at_iso": "...", "pid": <int>},
#        ...
#     }}
#
# The main loop usually knows the QUEUE id (e.g. q-2026-06-23-96a0) but
# `agent-msg send` takes the AGENT id. Guessing the agent id caused a
# real misroute (corrections delivered to the wrong agent's inbox). These
# helpers resolve q-id -> agent-id(s) off the binding map, and `resolve`
# / `send --queue-id` use them so the main loop never has to guess.
#
# "Live" definition: a bound agent is considered LIVE iff its Claude Code
# TRANSCRIPT file exists on disk:
#
#     ~/.claude/projects/<slug>/<session>/subagents/agent-<agent_id>.jsonl
#
# (honoring CLAUDE_PROJECTS_DIR for tests). Every running subagent has a
# transcript JSONL the harness appends to as it works, so its presence is
# the authoritative "is this agent actually alive" signal -- independent
# of whether the agent has ever been messaged.
#
# Why NOT inbox existence (the old definition): the inbox file is created
# only by `arm` / the FIRST `send`. So `send --queue-id` -- which resolves
# BEFORE it creates the inbox -- declared a live-but-never-messaged agent
# DEAD and refused the send (a chicken-and-egg: can't message until messaged).
# That was the operator-facing bug. Transcript-existence has no such cycle.
#
# Default-OPEN posture: if transcript resolution is impossible (no projects
# dir, walk error, etc.) a binding is treated as LIVE. Delivering to a
# maybe-dead agent's inbox is harmless (it never reads it); REFUSING to
# message a genuinely-live agent is the real failure. This inverts the old
# overly-conservative posture on purpose.
#
# Resolution is DETERMINISTIC: among bindings for a q-id, prune the dead
# (by transcript-liveness), then if MULTIPLE live remain pick the
# MOST-RECENTLY-REGISTERED (newest `registered_at` wins). The nested-agent
# case (a sub-subagent inheriting the parent's "Queue item:" marker binds a
# second agent-id to the same q-id) thus resolves to the newest actively
# running agent rather than erroring. Resolution ERRORS only when ZERO
# bindings exist for the q-id at all.
# ----------------------------------------------------------------------


DEFAULT_BINDINGS_PATH = CONFIG_DIR / "agent-queue-bindings.json"


def _bindings_path(args=None) -> Path:
    """Resolve the binding-map path. --bindings-path > env > default."""
    if args is not None and getattr(args, "bindings_path", None):
        return Path(os.path.expanduser(args.bindings_path))
    env_override = os.environ.get(
        "CLAUDE_AGENT_QUEUE_BINDINGS_PATH", "",
    ).strip()
    if env_override:
        return Path(os.path.expanduser(env_override))
    return DEFAULT_BINDINGS_PATH


def _read_bindings(args=None) -> dict:
    """Read the binding map, returning {agent_id: {"queue_id": ...}}.

    Tolerant on read: a missing / empty / corrupt-JSON / wrong-shape file
    returns {} (never raises). This mirrors the default-open posture the
    arm-hook writer and the subagent_queue_item_running predicate use --
    a malformed binding file must never crash a send/resolve.
    """
    path = _bindings_path(args)
    try:
        if not path.exists():
            return {}
        raw = path.read_text(encoding="utf-8")
    except OSError:
        return {}
    if not raw.strip():
        return {}
    try:
        data = json.loads(raw)
    except (json.JSONDecodeError, ValueError):
        return {}
    if not isinstance(data, dict):
        return {}
    bindings = data.get("bindings", {})
    if not isinstance(bindings, dict):
        return {}
    return bindings


def _projects_dir() -> Path:
    """Claude Code projects dir holding subagent transcripts.

    Honors CLAUDE_PROJECTS_DIR (used by tests + agent-tail) so the
    transcript-liveness check can be exercised against a sandbox tree.
    """
    override = os.environ.get("CLAUDE_PROJECTS_DIR", "").strip()
    if override:
        return Path(os.path.expanduser(override))
    return Path.home() / ".claude" / "projects"


def _transcript_exists(agent_id: str) -> bool | None:
    """Does a transcript JSONL exist for ``agent_id``?

    Returns:
      * True  -- a transcript file exists at
                 <projects>/<slug>/<session>/subagents/agent-<id>.jsonl
      * False -- the projects tree was walkable but no transcript matched
      * None  -- resolution was impossible (no projects dir, walk error);
                 the caller should treat this as "unknown" and DEFAULT OPEN.

    Mirrors agent-tail's transcript layout / resolution. Accepts an id with
    or without the ``agent-`` prefix.
    """
    base = _projects_dir()
    try:
        if not base.is_dir():
            return None
    except OSError:
        return None

    needle = agent_id.strip()
    if needle.startswith("agent-"):
        needle = needle[len("agent-"):]
    target = f"agent-{needle}.jsonl"

    walked_any = False
    try:
        for project_entry in base.iterdir():
            if not project_entry.is_dir():
                continue
            for session_entry in project_entry.iterdir():
                if not session_entry.is_dir():
                    continue
                subagents = session_entry / "subagents"
                if not subagents.is_dir():
                    continue
                walked_any = True
                try:
                    children = list(subagents.iterdir())
                except OSError:
                    continue
                for child in children:
                    if child.name == target and child.is_file():
                        return True
    except OSError:
        return None

    # Tree existed and was walkable but no transcript matched. If we never
    # even found a subagents/ dir to walk, treat as unknown (default-open)
    # rather than a definitive "dead" -- the layout may differ.
    if not walked_any:
        return None
    return False


def _agent_is_live(agent_id: str, args=None) -> bool:
    """An agent is LIVE iff its transcript JSONL exists on disk.

    DEFAULT-OPEN: if transcript resolution is impossible (None -- no
    projects dir, walk error, no subagents/ dir to inspect) the agent is
    treated as LIVE. Refusing to message a genuinely-live agent is the
    real operator-facing failure; delivering to a maybe-dead agent's inbox
    is harmless. ``args`` is accepted for signature compatibility / future
    overrides but the transcript layout is global (CLAUDE_PROJECTS_DIR).
    """
    res = _transcript_exists(agent_id)
    if res is None:
        return True  # unknown -> default open
    return res


def _resolve_queue_id(queue_id: str, args=None,
                      *, live_only: bool = True) -> tuple[list, list]:
    """Resolve a queue id to bound agent ids.

    Returns (live, all) where:
      * ``all``  = every agent_id whose binding's queue_id == queue_id,
                   sorted NEWEST-REGISTERED-FIRST (by ``registered_at``)
      * ``live`` = the subset whose transcript JSONL exists on disk
                   (default-open: an un-resolvable transcript counts live),
                   preserving the newest-first order.

    Newest-first ordering means a deterministic ``best`` pick (the newest
    live agent) falls out of ``live[0]``. When ``live_only`` is False the
    caller wants the raw set (used by resolve --all for diagnostics).
    """
    bindings = _read_bindings(args)
    matched = []  # (registered_at, agent_id)
    for agent_id, rec in bindings.items():
        if not isinstance(rec, dict):
            continue
        if rec.get("queue_id") == queue_id:
            ra = rec.get("registered_at")
            ra = ra if isinstance(ra, (int, float)) else 0
            matched.append((ra, agent_id))
    # Newest registration first; tie-break on agent_id for determinism.
    matched.sort(key=lambda t: (-t[0], t[1]))
    ordered = [aid for (_, aid) in matched]
    if not live_only:
        return list(ordered), list(ordered)
    live = [a for a in ordered if _agent_is_live(a, args)]
    return live, ordered


def _resolve_queue_id_best(queue_id: str, args=None) -> str:
    """Resolve a q-id to the BEST single agent id, or raise ValueError.

    Deterministic: among bindings for the q-id, the dead are pruned (by
    transcript-liveness) and the NEWEST-REGISTERED live agent is chosen.
    The nested-agent case (a second agent-id bound to the same q-id because
    a sub-subagent inherited the parent's "Queue item:" marker) resolves to
    whichever is most recently registered -- the right correction target.

    ERRORS only when ZERO bindings exist for the q-id at all. If bindings
    exist but every one is provably dead (transcript gone), the newest
    binding is still returned (default-toward-delivery) rather than refusing
    -- delivering to a dead agent's inbox is harmless; refusing a live one
    is the failure we are guarding against.
    """
    live, matched = _resolve_queue_id(queue_id, args)
    if not matched:
        raise ValueError(
            f"no binding found for queue id {queue_id!r} "
            f"(no agent was ever bound to it; check the q-id, or the "
            f"agent was spawned without a 'Queue item:' marker / before "
            f"the arm hook ran)"
        )
    if live:
        return live[0]  # newest live (matched is newest-first)
    # No provably-live agent, but bindings exist: deliver to the newest
    # binding anyway (harmless if dead; correct if our liveness check was a
    # false-negative). matched is newest-first.
    return matched[0]


# Back-compat alias: historic callers / tests referenced _resolve_queue_id_unique.
# It is no longer "unique" (we pick deterministically rather than erroring on
# multiple), but keep the name pointing at the best-resolver so old call sites
# continue to work.
def _resolve_queue_id_unique(queue_id: str, args=None) -> str:
    return _resolve_queue_id_best(queue_id, args)


def cmd_resolve(args) -> int:
    """Print the best agent id bound to a queue id.

    Default: resolves deterministically (newest-registered live agent, by
    transcript-liveness) and prints just that id (so it composes in scripts /
    command substitution); errors only when ZERO agents are bound. --all
    prints all matches (live + stale) for diagnostics and never errors on
    count.
    """
    queue_id = args.queue_id
    show_all = bool(getattr(args, "all", False))

    if show_all:
        live, matched = _resolve_queue_id(queue_id, args)
        stale = [a for a in matched if a not in live]
        if args.json:
            print(json.dumps({
                "queue_id": queue_id,
                "live": live, "stale": stale, "all": matched,
            }, indent=2))
        else:
            if not matched:
                print(f"(no agent bound to {queue_id})")
            else:
                for a in matched:
                    marker = "live" if a in live else "stale"
                    print(f"{a}\t{marker}")
        return 0

    try:
        agent_id = _resolve_queue_id_unique(queue_id, args)
    except ValueError as e:
        if args.json:
            print(json.dumps({"ok": False, "queue_id": queue_id,
                              "error": str(e)}, indent=2))
        else:
            print(f"ERROR: {e}", file=sys.stderr)
        return 1
    if args.json:
        print(json.dumps({"ok": True, "queue_id": queue_id,
                          "agent_id": agent_id}, indent=2))
    else:
        print(agent_id)
    return 0


def cmd_whoami(args) -> int:
    """Reverse lookup: print the queue id bound to an agent id."""
    agent_id = args.agent_id
    bindings = _read_bindings(args)
    rec = bindings.get(agent_id)
    qid = rec.get("queue_id") if isinstance(rec, dict) else None
    if args.json:
        print(json.dumps({"ok": qid is not None, "agent_id": agent_id,
                          "queue_id": qid}, indent=2))
        return 0 if qid else 1
    if qid:
        print(qid)
        return 0
    print(f"(no binding found for agent {agent_id})", file=sys.stderr)
    return 1


def build_parser():
    p = argparse.ArgumentParser(
        prog="agent-msg",
        description="Async messaging for Claude Code background agents (via obligations).",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("--test", action="store_true", help="run embedded test suite")
    sub = p.add_subparsers(dest="command", help="subcommand")

    # list
    sub.add_parser("list", help="show all tracked agents (index)")

    # show
    p_show = sub.add_parser("show", help="show metadata for one agent (index)")
    p_show.add_argument("agent_id")

    # send
    p_send = sub.add_parser(
        "send",
        help="append a message to an agent's inbox "
             "(by agent id, or --queue-id <q-id> to resolve)")
    p_send.add_argument("agent_id", nargs="?", default=None,
                        help="target agent id (omit when using --queue-id)")
    p_send.add_argument("text")
    p_send.add_argument("--queue-id", default=None,
                        help="resolve the target agent from this queue id "
                             "(errors loudly on zero / multiple live agents)")
    p_send.add_argument("--bindings-path", default=None,
                        help="override the q-id->agent-id binding map path "
                             "(default: ~/.config/claude/agent-queue-bindings.json)")
    p_send.add_argument("--from", dest="from_label", default=None,
                        help="sender label (default: andrew@signal)")
    p_send.add_argument("--queue-item", default=None,
                        help="associated queue item id")
    p_send.add_argument("--inbox-dir", default=None,
                        help="override inbox dir (default: ~/.config/claude/agent-inbox/)")
    p_send.add_argument("--dry-run", action="store_true",
                        help="show what would be sent; do not write")
    p_send.add_argument("--no-arm", action="store_true",
                        help="do NOT auto-register the inbox gate obligation "
                             "(rare; test / no-gate delivery only)")
    p_send.add_argument("--json", action="store_true")

    # inbox (read without consuming) -- defaults to UNREAD only
    p_inb = sub.add_parser("inbox", help="read an agent's inbox (default: unread only)")
    p_inb.add_argument("agent_id")
    p_inb.add_argument("--inbox-dir", default=None)
    p_inb.add_argument("--all", action="store_true",
                       help="include already-read messages (kept on disk until GC)")
    p_inb.add_argument("--json", action="store_true")

    # ack -- flips read=true; KEEPS bodies on disk
    p_ack = sub.add_parser(
        "ack", help="mark unread messages as read (keeps bodies on disk)")
    p_ack.add_argument("agent_id")
    p_ack.add_argument("--inbox-dir", default=None)
    p_ack.add_argument("--message-id", default=None,
                       help="ack only the specified message id (default: all unread)")
    p_ack.add_argument("--all-history", action="store_true",
                       help="re-stamp read_at on already-read messages too (rare)")
    p_ack.add_argument("--json", action="store_true")

    # gc -- explicit garbage-collect of read messages older than the TTL
    p_gc = sub.add_parser(
        "gc", help="drop already-read messages older than the TTL")
    p_gc.add_argument("agent_id")
    p_gc.add_argument("--inbox-dir", default=None)
    p_gc.add_argument("--ttl-hours", type=float, default=None,
                      help=f"TTL hours (default: ${{AGENT_MSG_TTL_HOURS}} or "
                           f"{DEFAULT_READ_TTL_HOURS}); <=0 disables GC")
    p_gc.add_argument("--json", action="store_true")

    # gc-dead -- sweep inbox obligations whose owning agent is no longer alive
    p_gcd = sub.add_parser(
        "gc-dead",
        help="satisfy inbox obligations whose owning agent is no longer alive "
             "(backstop for broken PostToolUse disarm path)")
    p_gcd.add_argument("--inbox-dir", default=None)
    p_gcd.add_argument("--dry-run", action="store_true",
                       help="show what would be satisfied without taking action")
    p_gcd.add_argument("--json", action="store_true")

    # arm
    p_arm = sub.add_parser("arm", help="initialise inbox + register gate-mode obligation")
    p_arm.add_argument("agent_id")
    p_arm.add_argument("--inbox-dir", default=None)
    p_arm.add_argument("--ttl", type=int, default=DEFAULT_OBLIGATION_TTL_SECS,
                       help=f"obligation TTL in seconds (default: {DEFAULT_OBLIGATION_TTL_SECS})")
    p_arm.add_argument("--no-obligation", action="store_true",
                       help="skip obligation registration (testing only)")
    p_arm.add_argument("--json", action="store_true")

    # disarm
    p_dis = sub.add_parser("disarm", help="clear inbox + remove obligation for an agent")
    p_dis.add_argument("agent_id")
    p_dis.add_argument("--inbox-dir", default=None)
    p_dis.add_argument("--no-obligation", action="store_true",
                       help="skip obligation cleanup (testing only)")
    p_dis.add_argument("--json", action="store_true")

    # resolve -- q-id -> live agent id
    p_res = sub.add_parser(
        "resolve",
        help="print the live agent id bound to a queue id "
             "(errors on zero / multiple live agents; --all lists matches)")
    p_res.add_argument("queue_id", help="queue item id, e.g. q-2026-06-23-96a0")
    p_res.add_argument("--bindings-path", default=None,
                       help="override the binding map path")
    p_res.add_argument("--inbox-dir", default=None,
                       help="override inbox dir (used for liveness check)")
    p_res.add_argument("--all", action="store_true",
                       help="list ALL bound agents (live+stale) for the q-id; "
                            "does not error on count")
    p_res.add_argument("--json", action="store_true")

    # whoami -- agent id -> q-id (reverse lookup)
    p_who = sub.add_parser(
        "whoami", help="print the queue id bound to an agent id (reverse lookup)")
    p_who.add_argument("agent_id")
    p_who.add_argument("--bindings-path", default=None,
                       help="override the binding map path")
    p_who.add_argument("--json", action="store_true")

    # index
    p_idx = sub.add_parser("index", help="manage the agent index")
    idx_sub = p_idx.add_subparsers(dest="index_cmd")
    p_reg = idx_sub.add_parser("register", help="register agent in the index")
    p_reg.add_argument("agent_id")
    p_reg.add_argument("--queue-item", required=True)
    p_reg.add_argument("--description", default="")
    p_done = idx_sub.add_parser("done", help="remove agent from the index")
    p_done.add_argument("agent_id")

    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.test:
        return run_tests()

    if not args.command:
        parser.print_help()
        return 0

    # Implicit GC sweep at the top of every CLI invocation. The
    # AGENT_MSG_TTL_HOURS env var controls aging (default 24h). Errors
    # are swallowed inside _maybe_implicit_gc so a stuck file never
    # blocks send/ack/inbox.
    _maybe_implicit_gc(args)

    if args.command == "list":
        return cmd_list(args)
    if args.command == "show":
        return cmd_show(args)
    if args.command == "send":
        return cmd_send(args)
    if args.command == "inbox":
        return cmd_inbox(args)
    if args.command == "ack":
        return cmd_ack(args)
    if args.command == "gc":
        return cmd_gc(args)
    if args.command == "gc-dead":
        return cmd_gc_dead(args)
    if args.command == "resolve":
        return cmd_resolve(args)
    if args.command == "whoami":
        return cmd_whoami(args)
    if args.command == "arm":
        return cmd_arm(args)
    if args.command == "disarm":
        return cmd_disarm(args)
    if args.command == "index":
        if args.index_cmd == "register":
            return cmd_index_register(args)
        if args.index_cmd == "done":
            return cmd_index_done(args)
        # No subcommand -> help
        for action in parser._actions:
            if isinstance(action, argparse._SubParsersAction):
                action.choices["index"].print_help()
                break
        return 0
    parser.print_help()
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
