# ---------------------------------------------------------------------------
# State file I/O (locked)
# ---------------------------------------------------------------------------


def _empty():
    return {"obligations": [], "overrides": []}


def _normalize_data(data):
    """Ensure data is a dict with both 'obligations' and 'overrides' lists.

    Backward-compat: existing state files predate the 'overrides' key, so we
    silently add it when missing. Mutates ``data`` in place.
    """
    if not isinstance(data, dict):
        return _empty()
    if "obligations" not in data or not isinstance(data.get("obligations"), list):
        data["obligations"] = []
    if "overrides" not in data or not isinstance(data.get("overrides"), list):
        data["overrides"] = []
    return data


def _open_locked():
    """Open obligations.json with fcntl.LOCK_EX. Returns (fh, data)."""
    OBLIGATIONS_FILE.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(str(OBLIGATIONS_FILE), os.O_RDWR | os.O_CREAT, 0o600)
    fh = os.fdopen(fd, "r+")
    fcntl.flock(fh, fcntl.LOCK_EX)
    fh.seek(0)
    raw = fh.read()
    if not raw.strip():
        data = _empty()
    else:
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            backup = OBLIGATIONS_FILE.with_suffix(".json.corrupt")
            try:
                backup.write_text(raw)
            except OSError:
                pass
            data = _empty()
    data = _normalize_data(data)
    return fh, data


def _write_unlock(fh, data):
    fh.seek(0)
    fh.truncate()
    fh.write(json.dumps(data, indent=2) + "\n")
    fh.flush()
    try:
        os.fsync(fh.fileno())
    except OSError:
        pass
    fcntl.flock(fh, fcntl.LOCK_UN)
    fh.close()
    try:
        OBLIGATIONS_FILE.chmod(0o600)
    except OSError:
        pass


def _unlock(fh):
    try:
        fcntl.flock(fh, fcntl.LOCK_UN)
    except OSError:
        pass
    try:
        fh.close()
    except OSError:
        pass


def _read_only():
    """Read obligations without taking a lock. Returns the dict."""
    if not OBLIGATIONS_FILE.exists():
        return _empty()
    try:
        raw = OBLIGATIONS_FILE.read_text()
        if not raw.strip():
            return _empty()
        data = json.loads(raw)
        return _normalize_data(data)
    except (OSError, json.JSONDecodeError):
        return _empty()


# ---------------------------------------------------------------------------
# IDs and helpers
# ---------------------------------------------------------------------------


def _new_id():
    day = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    return f"ob-{day}-{secrets.token_hex(2)}"


def _new_override_id():
    day = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    return f"ov-{day}-{secrets.token_hex(2)}"


# Audit log path for override-create (separate from the env-var bypass log,
# but we use the SAME file because both are "this call bypassed the gate"
# events and operationally we want one place to look). The pre-tool hook
# also writes here when OBLIGATIONS_BYPASS=1 fires.
BYPASS_LOG_PATH = Path.home() / ".config" / "claude" / "obligations-bypass.log"


def _audit_override(record):
    """Append an audit record to the bypass log. Best-effort, swallows I/O errors."""
    try:
        BYPASS_LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
        ts = datetime.now(timezone.utc).isoformat()
        with BYPASS_LOG_PATH.open("a", encoding="utf-8") as fh:
            fh.write(json.dumps({"ts": ts, "pid": os.getpid(), **record}) + "\n")
        try:
            BYPASS_LOG_PATH.chmod(0o600)
        except OSError:
            pass
    except (OSError, ValueError):
        pass


def _pingme_override(ov_id, reason, duration_secs):
    """Fire a Pushover notification when an audited override is created.

    Best-effort: any failure (missing pingme, exec error, timeout) is
    swallowed so the override path itself never breaks. Test-suite
    isolation: when ``OBLIGATIONS_DISABLE_PINGME=1`` is set, this is a
    no-op (so unit tests don't spam Andrew's phone).

    The notification carries the override id, reason, and duration --
    the same data audited to obligations-bypass.log -- so a phone glance
    is enough to know what was just bypassed and for how long.
    """
    if os.environ.get("OBLIGATIONS_DISABLE_PINGME", "").strip() not in ("", "0"):
        return
    cli = shutil.which("pingme")
    if not cli:
        return
    title = "obligations override"
    # Format duration human-friendly: <60s shows seconds, <3600 minutes,
    # else hours. Cap precision at 1 decimal for the >60s cases.
    if duration_secs < 60:
        dur_str = f"{int(duration_secs)}s"
    elif duration_secs < 3600:
        dur_str = f"{duration_secs / 60:.1f}m".rstrip("0").rstrip(".")
    else:
        dur_str = f"{duration_secs / 3600:.1f}h".rstrip("0").rstrip(".")
    body = f"{ov_id} ({dur_str}): {reason}"
    try:
        subprocess.run(
            [cli, "-p", "low", body, title],
            capture_output=True, text=True, timeout=5, check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        pass


def _now() -> float:
    return time.time()


def _is_expired(ob, now=None):
    expires_at = ob.get("expires_at")
    if expires_at is None or expires_at == 0:
        return False  # ttl_secs=0 means non-expiring
    if now is None:
        now = _now()
    return now >= expires_at


def _prune_expired(data, now=None):
    """Mutate data in place, removing expired obligations + overrides.

    Returns the list of dropped obligations (overrides are pruned but not
    returned -- they're not interesting to callers).
    """
    if now is None:
        now = _now()
    keep = []
    drop = []
    for ob in data.get("obligations", []):
        if _is_expired(ob, now):
            drop.append(ob)
        else:
            keep.append(ob)
    data["obligations"] = keep
    # Overrides ALWAYS expire (TTL is required at create time). Drop any
    # whose expires_at has passed.
    overrides = data.get("overrides", [])
    if isinstance(overrides, list):
        data["overrides"] = [
            ov for ov in overrides
            if isinstance(ov, dict)
            and ov.get("expires_at") is not None
            and ov.get("expires_at", 0) > now
        ]
    return drop


def _active_override(data, now=None):
    """Return the first non-expired override (dict) or None.

    Used by `_check_core` to bypass ALL gate-mode obligations when an
    operator-issued override is in effect. The override is *not* mutated --
    callers may inspect/audit it.
    """
    if now is None:
        now = _now()
    for ov in data.get("overrides", []) or []:
        if not isinstance(ov, dict):
            continue
        exp = ov.get("expires_at")
        if exp is None:
            # Defensive: treat missing TTL as expired (we always set one).
            continue
        if exp > now:
            return ov
    return None


# ---------------------------------------------------------------------------
# Queue introspection helpers (for the stale_ready_queue_present predicate)
# ---------------------------------------------------------------------------


def _parse_iso_ts(ts):
    """Parse an ISO-8601 timestamp into a unix timestamp (float seconds since
    epoch). Returns None on garbage input.

    Accepts both ``...+00:00`` and trailing ``Z`` forms. Naive datetimes are
    treated as UTC (the queue writes everything in UTC).
    """
    if not ts or not isinstance(ts, str):
        return None
    raw = ts.strip()
    if not raw:
        return None
    # Python <3.11 doesn't accept trailing 'Z' in fromisoformat.
    if raw.endswith("Z"):
        raw = raw[:-1] + "+00:00"
    try:
        dt = datetime.fromisoformat(raw)
    except ValueError:
        return None
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt.timestamp()


def _queue_item_is_ready_now(items, item):
    """Replicate session-task's ``_item_is_ready`` logic against the bare
    queue.json items list.

    Pure function -- no I/O. An item is ready_now iff:
      - status == "pending"
      - it is the head of its group (highest-priority pending/running
        member, with FIFO tiebreak by created_at)
      - no other group member is currently running
    """
    if item.get("status") != "pending":
        return False
    group_id = item.get("group_id")
    if not group_id:
        # No group => degenerate single-member group containing only this
        # item. With status=pending, it is trivially the head.
        return True
    # Members of the same group with status pending or running.
    members = [
        it for it in items
        if it.get("group_id") == group_id
        and it.get("status") in ("pending", "running")
    ]
    if not members:
        return False
    # Group head = running member if any (highest priority then FIFO),
    # otherwise the highest-priority/FIFO pending member.
    def _sort_key(it):
        try:
            prio = -int(it.get("priority", 5))
        except (TypeError, ValueError):
            prio = -5
        return (prio, it.get("created_at", ""))
    running = [m for m in members if m.get("status") == "running"]
    if running:
        # Something else in the group is running => no pending member is
        # ready_now.
        return False
    head = sorted(members, key=_sort_key)[0]
    return head.get("id") == item.get("id")


def _stale_ready_items(queue_path, threshold_secs, now_unix):
    """Return the list of queue items that are ready_now AND have been
    waiting >= threshold_secs (computed from each item's created_at).

    Each result dict is the raw queue item with an extra ``age_secs`` field
    so callers can render summaries. Sorted oldest-first.

    Raises if queue.json is unreadable or malformed -- callers (the
    predicate) wrap with default-open semantics.
    """
    p = Path(queue_path) if not isinstance(queue_path, Path) else queue_path
    if not p.exists():
        return []
    raw = p.read_text(encoding="utf-8")
    if not raw.strip():
        return []
    data = json.loads(raw)
    # queue.json may be either {"items": [...]} (the live shape) or a bare
    # list (older shape / hand-built test fixtures).
    if isinstance(data, dict):
        items = data.get("items", [])
        if not isinstance(items, list):
            return []
    elif isinstance(data, list):
        items = data
    else:
        return []
    out = []
    for it in items:
        if not isinstance(it, dict):
            continue
        if not _queue_item_is_ready_now(items, it):
            continue
        created = _parse_iso_ts(it.get("created_at", ""))
        if created is None:
            continue
        age = now_unix - created
        if age < float(threshold_secs):
            continue
        enriched = dict(it)
        enriched["age_secs"] = age
        out.append(enriched)
    out.sort(key=lambda x: x.get("age_secs", 0), reverse=True)
    return out


# ---------------------------------------------------------------------------
# Predicate evaluation
# ---------------------------------------------------------------------------


def _eval_predicate(pred, tool_name, command_string, agent_id=None):
    """Return (satisfied: bool, why: str). 'satisfied' True => obligation met,
    so the tool call is allowed. 'why' is human-readable diagnostics.

    For BAN-style predicates (no_pipe_pattern), satisfied=True means the regex
    did NOT match (i.e. the command is OK).

    ``agent_id`` is the hook payload's ``agent_id`` field (empty/missing in
    the main loop, non-empty inside a subagent). Threaded through so the
    ``is_main_loop`` predicate -- and any future predicate that needs to
    distinguish the main loop from subagents -- can read it. ``all_of``
    forwards it to child predicates so the composition works at any depth.
    """
    kind = pred.get("kind", "")
    params = pred.get("params", {}) or {}

    if kind == "file_mtime_within":
        path = params.get("path")
        max_age = params.get("max_age_secs")
        if not path or max_age is None:
            return (True, "missing path/max_age_secs (allow by default)")
        try:
            full = os.path.expanduser(str(path))
            st = os.stat(full)
            age = _now() - st.st_mtime
            if age <= float(max_age):
                return (True, f"{path} mtime is {age:.1f}s old (<= {max_age}s)")
            return (False, f"{path} mtime is {age:.1f}s old (> {max_age}s -- stale)")
        except (OSError, ValueError):
            return (False, f"{path} not found or unreadable")

    if kind in ("file_exists", "marker_file_present"):
        path = params.get("path")
        negate = bool(params.get("negate", False))
        if not path:
            return (True, "missing path (allow by default)")
        full = os.path.expanduser(str(path))
        present = os.path.exists(full)
        # Default semantics: satisfied = present. negate flips.
        ok = (not present) if negate else present
        if ok:
            return (True, f"{path} exists={present} (negate={negate}) -> satisfied")
        return (False, f"{path} exists={present} (negate={negate}) -> NOT satisfied")

    if kind == "env_present":
        var = params.get("var")
        value = params.get("value")
        if not var:
            return (True, "missing var (allow)")
        env_val = os.environ.get(var)
        if env_val is None:
            return (False, f"env var {var!r} not set")
        if value is not None and env_val != value:
            return (False, f"env var {var!r}={env_val!r}, expected {value!r}")
        return (True, f"env var {var!r} present")

    if kind == "queue_status":
        qid = params.get("id")
        want = params.get("status")
        if not qid or not want:
            return (True, "missing id/status (allow)")
        try:
            proc = subprocess.run(
                ["session-task", "queue", "show", qid],
                capture_output=True, text=True, timeout=4, check=False,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
            return (True, "session-task unavailable (default-open)")
        if proc.returncode != 0:
            return (False, f"queue id {qid!r} not found")
        try:
            d = json.loads(proc.stdout)
        except (json.JSONDecodeError, ValueError):
            return (True, "could not parse queue show output (default-open)")
        got = d.get("status") if isinstance(d, dict) else None
        if got == want:
            return (True, f"queue {qid} status={got}")
        return (False, f"queue {qid} status={got!r}, want {want!r}")

    if kind == "no_pipe_pattern":
        regex = params.get("regex", "")
        if not regex:
            return (True, "no regex configured (allow)")
        # Only check Bash-like tools. For non-Bash tools, the predicate is N/A.
        if tool_name not in ("Bash",):
            return (True, f"tool {tool_name} is not Bash (predicate N/A)")
        cmd = command_string or ""
        try:
            patt = re.compile(regex)
        except re.error as e:
            return (True, f"invalid regex (default-open): {e}")
        if patt.search(cmd):
            return (False, f"command matches forbidden pattern /{regex}/")
        return (True, f"command does not match /{regex}/")

    if kind == "process_alive":
        pid_file = params.get("pid_file")
        if not pid_file:
            return (True, "missing pid_file (allow by default)")
        full = os.path.expanduser(str(pid_file))
        if not os.path.exists(full):
            return (False, f"pid_file {pid_file} does not exist")
        try:
            raw = open(full, "r", encoding="utf-8").read().strip()
        except (OSError, UnicodeDecodeError) as e:
            return (False, f"pid_file {pid_file} unreadable: {e}")
        if not raw:
            return (False, f"pid_file {pid_file} is empty")
        try:
            pid = int(raw)
        except ValueError:
            return (False, f"pid_file {pid_file} contents {raw!r} is not an integer")
        if pid <= 0:
            return (False, f"pid_file {pid_file} contains non-positive pid {pid}")
        # Check process liveness. Prefer /proc/<pid> (Linux), fall back to kill(pid, 0).
        proc_path = f"/proc/{pid}"
        if os.path.isdir(proc_path):
            return (True, f"pid {pid} (from {pid_file}) is alive (/proc/{pid} exists)")
        try:
            os.kill(pid, 0)
            return (True, f"pid {pid} (from {pid_file}) is alive (kill 0 ok)")
        except ProcessLookupError:
            return (False, f"pid {pid} (from {pid_file}) is not running")
        except PermissionError:
            # Process exists but we can't signal it -- treat as alive.
            return (True, f"pid {pid} (from {pid_file}) exists (EPERM on kill 0)")
        except OSError as e:
            return (False, f"pid {pid} (from {pid_file}) liveness check failed: {e}")

    if kind == "process_in_pgrep":
        pattern = params.get("pattern", "")
        if not pattern:
            return (True, "missing pattern (allow by default)")
        try:
            proc = subprocess.run(
                ["pgrep", "-f", str(pattern)],
                capture_output=True, text=True, timeout=4, check=False,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as e:
            return (True, f"pgrep unavailable (default-open): {e}")
        # pgrep exits 0 with PIDs on stdout when matches found, 1 when none.
        if proc.returncode == 0 and proc.stdout.strip():
            pids = proc.stdout.strip().split()
            return (True, f"pgrep -f {pattern!r} matched pids {pids}")
        return (False, f"pgrep -f {pattern!r} found no matching processes")

    if kind == "no_pending_watcher_outputs":
        # Default-open on any filesystem error: a broken sidecar dir must
        # never blackhole the loop.
        try:
            # Exemption short-circuit: if the tool/command being checked is one
            # of the recovery / diagnosis / read paths needed to clear the
            # gate, allow it through unconditionally. Without this the gate
            # self-deadlocks (the very tools needed to satisfy it would also
            # be blocked).
            for exempt_pat, why in NO_PENDING_WATCHER_OUTPUTS_EXEMPT_PATTERNS:
                if _tool_pattern_matches(exempt_pat, tool_name, command_string):
                    return (True, f"exempt: {exempt_pat} ({why})")

            # Walk the sidecar dir. Each file is a JSON describing one
            # captured-but-possibly-unread watcher output.
            sidecar_dir = _watcher_pending_dir()
            if not sidecar_dir.exists():
                return (True, "no pending watcher output sidecars")
            unread = []
            for sidecar_path in sorted(sidecar_dir.glob("*.json")):
                try:
                    sc = json.loads(sidecar_path.read_text())
                except (OSError, json.JSONDecodeError):
                    # Corrupt sidecar -- remove it so the gate doesn't wedge.
                    try:
                        sidecar_path.unlink()
                    except OSError:
                        pass
                    continue
                output_path = sc.get("output_file_path")
                registered_at = sc.get("registered_at", 0)
                if not output_path:
                    try:
                        sidecar_path.unlink()
                    except OSError:
                        pass
                    continue
                # Stat the output file. Missing file => stale sidecar => clean.
                try:
                    st = os.stat(output_path)
                except OSError:
                    try:
                        sidecar_path.unlink()
                    except OSError:
                        pass
                    continue
                # Predicate fails iff the output file has been written since
                # the watcher was registered (size > 0 AND mtime > registered_at).
                if st.st_size > 0 and st.st_mtime > float(registered_at):
                    unread.append(output_path)
            if not unread:
                return (True, "all pending watcher outputs are empty or read")
            # Carry ALL unread paths in the why so the deny banner can render
            # every path the caller needs to Read. Comma-separated for easy
            # parse + bullet-list render in the hook formatter.
            if len(unread) == 1:
                return (False, f"unread watcher output: {unread[0]}")
            return (False,
                    "unread watcher outputs: " + ", ".join(unread))
        except Exception as e:  # noqa: BLE001 -- default-open on any error
            return (True, f"no_pending_watcher_outputs default-open on error: {e}")

    if kind == "agent_inbox_empty":
        # Satisfied iff the JSON inbox at `path` is absent OR contains
        # no UNREAD messages. The inbox is the agent-msg v2 envelope:
        #     {"schema_version": 2, "messages": [{... "read": bool ...}]}
        # but we also accept the legacy v1 bare-list shape and treat
        # every entry there as unread (since v1 had no read field).
        # When unread messages are queued, the predicate fails and the
        # `why` string carries a multi-line summary so an inform-mode
        # obligation can surface the contents to the subagent.
        path = params.get("path")
        if not path:
            return (True, "missing path (allow by default)")
        full = os.path.expanduser(str(path))
        if not os.path.exists(full):
            return (True, f"inbox {path} does not exist (no messages)")
        try:
            raw = open(full, "r", encoding="utf-8").read()
        except (OSError, UnicodeDecodeError) as e:
            # Default-open: a broken inbox file must not blackhole the
            # loop. The agent-msg arm/disarm path keeps it 0o600 + valid
            # JSON; if something corrupted it, prefer noise-free.
            return (True, f"inbox {path} unreadable (default-open): {e}")
        if not raw.strip():
            return (True, f"inbox {path} is empty (treated as no messages)")
        try:
            data = json.loads(raw)
        except json.JSONDecodeError as e:
            return (True, f"inbox {path} malformed JSON (default-open): {e}")
        # Coerce to a list of message dicts. v2: dict with "messages";
        # v1: bare list (every entry treated as unread). Anything else
        # is default-open.
        if isinstance(data, dict):
            messages = data.get("messages", [])
            if not isinstance(messages, list):
                return (True,
                        f"inbox {path} v2 envelope has non-list messages "
                        f"(default-open)")
        elif isinstance(data, list):
            messages = data
        else:
            return (True, f"inbox {path} is not a JSON array or v2 envelope "
                          f"(default-open)")
        if len(messages) == 0:
            return (True, f"inbox {path} has no messages")
        # Filter to UNREAD. A v1 entry has no "read" field -- treat as
        # unread (legacy compat: pre-migration messages must still
        # block). For v2 entries, read=true means already-acked and
        # therefore satisfies the predicate (history, not pending work).
        unread = []
        for entry in messages:
            if not isinstance(entry, dict):
                # Defensive: malformed entries always count as unread
                # so the agent gets a chance to inspect them.
                unread.append(entry)
                continue
            if not entry.get("read"):
                unread.append(entry)
        if len(unread) == 0:
            return (True,
                    f"inbox {path} has {len(messages)} message(s), all read "
                    f"(no unread to surface)")
        # Non-empty unread set: build a banner-friendly summary. Header
        # line names the inbox path so the subagent knows where to ack
        # it; per-entry lines show from / ts / text (truncated).
        total = len(messages)
        lines = [f"AGENT INBOX has {len(unread)} unread message(s) "
                 f"({total} total) at {path}:"]
        for idx, entry in enumerate(unread):
            if not isinstance(entry, dict):
                lines.append(f"  [{idx}] (malformed entry: {entry!r})")
                continue
            sender = entry.get("from", "?")
            ts = entry.get("ts", "?")
            qi = entry.get("queue_item")
            mid = entry.get("id")
            text = entry.get("text", "")
            if not isinstance(text, str):
                text = str(text)
            # Cap each message body at 240 chars so a runaway inbox
            # doesn't flood the banner.
            if len(text) > 240:
                text = text[:237] + "..."
            qi_part = f" [q={qi}]" if qi else ""
            id_part = f" id={mid}" if mid else ""
            lines.append(f"  [{idx}] from={sender}{qi_part} ts={ts}{id_part}")
            for body_line in text.splitlines() or [""]:
                lines.append(f"    {body_line}")
        lines.append(
            "Run `agent-msg ack <agent-id>` after processing -- bodies stay "
            "on disk so you can re-read with `agent-msg inbox <agent-id> --all`."
        )
        return (False, "\n".join(lines))

    if kind == "stale_ready_queue_present":
        # BAN-style: satisfied (=True, allow) iff NO ready_now item has been
        # waiting >= threshold_secs. Failure (=False, deny) means the main
        # loop is sitting on a dispatchable queue item.
        threshold = params.get("threshold_secs",
                               DEFAULT_STALE_READY_THRESHOLD_SECS)
        try:
            threshold_secs = float(threshold)
        except (TypeError, ValueError):
            threshold_secs = float(DEFAULT_STALE_READY_THRESHOLD_SECS)
        path_param = params.get("queue_path")
        queue_path = (Path(os.path.expanduser(str(path_param)))
                      if path_param else DEFAULT_QUEUE_PATH)
        # Default-open on any read / parse error: a broken queue.json must
        # never blackhole the loop.
        try:
            stale = _stale_ready_items(queue_path, threshold_secs, _now())
        except Exception as e:  # noqa: BLE001
            return (True, f"stale_ready_queue_present default-open on error: {e}")
        if not stale:
            return (True,
                    f"no ready+pending items past {int(threshold_secs)}s "
                    f"in {queue_path}")
        # Build a multi-line why so the deny banner names the offending ids.
        n = len(stale)
        oldest_age = max(it["age_secs"] for it in stale)
        head = (f"{n} ready+pending item(s) in queue past "
                f"{int(threshold_secs)}s (oldest {int(oldest_age)}s); "
                f"dispatch (queue register + Agent) or abandon before unrelated work")
        lines = [head]
        # Cap the per-item enumeration so a runaway queue doesn't blow up
        # the banner.
        for it in stale[:5]:
            qid = it.get("id", "?")
            summary = it.get("summary") or "(no summary)"
            age_min = int(it["age_secs"] // 60)
            lines.append(f"  {qid} [{age_min}m] {summary}")
        if n > 5:
            lines.append(f"  ... (+{n - 5} more)")
        return (False, "\n".join(lines))

    if kind == "is_main_loop":
        # Satisfied iff the call is from the main loop (no agent_id).
        # negate=true flips: satisfied iff inside a subagent.
        negate = bool(params.get("negate", False))
        in_main = not _is_subagent_context(agent_id)
        ok = (not in_main) if negate else in_main
        if ok:
            if negate:
                return (True, f"in subagent context (agent_id={agent_id!r})")
            return (True, "in main-loop context (no agent_id)")
        if negate:
            return (False, "in main-loop context (expected subagent)")
        return (False, f"in subagent context (agent_id={agent_id!r}); main-loop required")

    if kind == "all_of":
        children = params.get("predicates", [])
        if not isinstance(children, list):
            return (True, "all_of params.predicates is not a list (default-open)")
        if not children:
            # Empty AND is trivially true (logical convention).
            return (True, "all_of [] (empty -> trivially satisfied)")
        for idx, child in enumerate(children):
            if not isinstance(child, dict):
                return (True, f"all_of child {idx} is not a dict (default-open)")
            child_kind = child.get("kind", "")
            if child_kind not in VALID_PREDICATE_KINDS:
                # Unknown nested kind => default-open with a note (mirrors
                # the leaf default-open semantics).
                return (True, f"all_of child {idx} has unknown kind {child_kind!r} (default-open)")
            ok, why = _eval_predicate(child, tool_name, command_string,
                                       agent_id=agent_id)
            if not ok:
                # Scope-guard short-circuit: a failing is_main_loop child
                # means "this obligation does not apply in the current
                # context (subagent vs main-loop, or vice versa with
                # negate=true)". Treat the all_of as inactive (satisfied)
                # rather than denying. This is the cornerstone of the
                # "main-loop only enforce X" pattern: register
                # `all_of [is_main_loop, X]`, and subagents bypass.
                if child_kind == "is_main_loop":
                    return (True, f"all_of child[{idx}] is_main_loop scope-guard "
                                  f"INACTIVE: {why}")
                # Any other failing child => standard AND => not satisfied.
                # Surface the failing child's why for actionable banners.
                return (False, f"all_of child[{idx}] kind={child_kind} FAIL: {why}")
        return (True, f"all_of [{len(children)}] all children satisfied")

    if kind == "watchers_healthy":
        # Run `watcher-status --unhealthy-only`. Empty stdout => everything is
        # healthy => predicate satisfied. Any stdout => predicate fails, and we
        # carry the unhealthy report through as the `why` string so the
        # PostToolUse hook can surface it verbatim.
        cli = shutil.which("watcher-status")
        if not cli:
            for cand in (
                os.path.expanduser("~/bin/watcher-status"),
                "/usr/local/bin/watcher-status",
            ):
                if os.path.exists(cand):
                    cli = cand
                    break
        if not cli or not os.path.exists(cli):
            # Default-open: missing tool must not block / spam.
            return (True, "watcher-status not found (default-open)")
        try:
            proc = subprocess.run(
                [cli, "--unhealthy-only"],
                capture_output=True, text=True,
                timeout=WATCHERS_HEALTHY_TIMEOUT_SECS, check=False,
            )
        except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as e:
            return (True, f"watcher-status unavailable (default-open): {e}")
        out = (proc.stdout or "").rstrip()
        if not out:
            return (True, "all watchers healthy")
        return (False, out)

    # Unknown predicate kind: default-open with a note.
    return (True, f"unknown predicate kind {kind!r} (default-open)")


# ---------------------------------------------------------------------------
# tool_pattern matching
# ---------------------------------------------------------------------------


def _tool_pattern_matches(pattern, tool_name, command_string):
    """A tool_pattern is one of:
        '*'                       => matches every tool
        'Bash'                    => matches when tool_name == 'Bash'
        'Bash:<regex>'            => matches when tool_name=='Bash' AND
                                     command_string matches <regex>
        '<name>'                  => matches when tool_name == <name>
    """
    if not pattern or pattern == "*":
        return True
    if ":" in pattern:
        head, rest = pattern.split(":", 1)
        if tool_name != head:
            return False
        try:
            return re.search(rest, command_string or "") is not None
        except re.error:
            # Bad regex => treat as match-by-name only, conservative
            return True
    return pattern == tool_name


def _exempt_match(exempt_patterns, tool_name, command_string):
    """Return (matched: bool, which: str|None).

    Iterate ``exempt_patterns`` (list of tool_pattern strings) and return
    True + the first matching pattern as soon as one fires. Empty / missing
    exempt list => never matches.
    """
    if not exempt_patterns:
        return (False, None)
    if not isinstance(exempt_patterns, list):
        return (False, None)
    for pat in exempt_patterns:
        if not isinstance(pat, str) or not pat:
            continue
        if _tool_pattern_matches(pat, tool_name, command_string):
            return (True, pat)
    return (False, None)


def _universal_recovery_exempt_match(tool_name, command_string):
    """Return (matched: bool, which: str|None) against
    ``UNIVERSAL_RECOVERY_EXEMPT_PATTERNS``.

    Applied at the framework level by ``_check_core`` and
    ``_inform_check_core`` BEFORE per-obligation predicates run. This is the
    deadlock-prevention floor: no matter how many obligations are active,
    the recovery / escape-hatch surface always passes.

    See ``UNIVERSAL_RECOVERY_EXEMPT_PATTERNS`` for rationale + the list.
    """
    return _exempt_match(
        UNIVERSAL_RECOVERY_EXEMPT_PATTERNS, tool_name, command_string,
    )


# ---------------------------------------------------------------------------
# Subcommand: add
# ---------------------------------------------------------------------------


def cmd_add(args):
    try:
        params = json.loads(args.params) if args.params else {}
    except json.JSONDecodeError as e:
        print(f"ERROR: --params must be JSON: {e}", file=sys.stderr)
        return 2

    if args.predicate not in VALID_PREDICATE_KINDS:
        print(
            f"ERROR: --predicate must be one of {sorted(VALID_PREDICATE_KINDS)}",
            file=sys.stderr,
        )
        return 2

    enforcement = args.enforcement
    if enforcement not in VALID_ENFORCEMENT_MODES:
        print(
            f"ERROR: --enforcement must be one of {sorted(VALID_ENFORCEMENT_MODES)}",
            file=sys.stderr,
        )
        return 2

    ttl = int(args.ttl)
    now = _now()
    expires_at = now + ttl if ttl > 0 else None

    satisfied_by = None
    if args.satisfied_by_tool or args.satisfied_by_cmd_regex:
        satisfied_by = {
            "tool_pattern": args.satisfied_by_tool or "*",
            "command_pattern": args.satisfied_by_cmd_regex or "",
        }

    # Normalize the exempt patterns list. argparse with action="append"
    # leaves None when the flag was never passed.
    exempt_patterns = list(args.exempt_tool_pattern or [])

    fh, data = _open_locked()
    try:
        _prune_expired(data, now)
        ob_id = _new_id()
        # Avoid duplicate ids in the unlikely case of secrets collision
        existing_ids = {it.get("id") for it in data["obligations"]}
        while ob_id in existing_ids:
            ob_id = _new_id()
        ob = {
            "id": ob_id,
            "tool_pattern": args.tool_pattern,
            "exempt_patterns": exempt_patterns,
            "predicate": {"kind": args.predicate, "params": params},
            "enforcement": enforcement,
            "ttl_secs": ttl,
            "expires_at": expires_at,
            "created_at": now,
            "created_by": args.created_by,
            "satisfied_by": satisfied_by,
            "deny_message": args.deny_msg,
        }
        data["obligations"].append(ob)
        _write_unlock(fh, data)
    except Exception:
        _unlock(fh)
        raise

    if args.json:
        print(json.dumps(ob, indent=2))
    else:
        print(f"Added obligation {ob_id}")
        print(f"  tool_pattern:    {args.tool_pattern}")
        if exempt_patterns:
            print(f"  exempt_patterns: {exempt_patterns}")
        print(f"  predicate:       {args.predicate} {params}")
        print(f"  enforcement:     {enforcement}")
        print(f"  ttl:             {ttl}s ({'non-expiring' if ttl == 0 else f'expires at {expires_at}'})")
        if satisfied_by:
            print(f"  satisfied_by:    {satisfied_by}")
    return 0


