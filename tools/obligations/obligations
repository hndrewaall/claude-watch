# Subcommand: list
# ---------------------------------------------------------------------------


def cmd_list(args):
    data = _read_only()
    now = _now()
    items = list(data.get("obligations", []))
    overrides = list(data.get("overrides", []))
    if not args.all:
        items = [ob for ob in items if not _is_expired(ob, now)]
        overrides = [
            ov for ov in overrides
            if isinstance(ov, dict) and ov.get("expires_at", 0) > now
        ]
    if args.json:
        print(json.dumps({
            "obligations": items,
            "overrides": overrides,
        }, indent=2))
        return 0
    if overrides:
        print("ACTIVE OVERRIDES (bypass all gate-mode obligations):")
        for ov in overrides:
            exp = ov.get("expires_at")
            when = (f"expires in {int(exp - now)}s"
                    if exp and exp > now else "EXPIRED")
            print(f"  {ov.get('id')} [{when}] by {ov.get('created_by','?')}")
            print(f"    reason: {ov.get('reason','(no reason)')}")
        print()
    if not items:
        print("(no obligations)")
        return 0
    for ob in items:
        exp = ob.get("expires_at")
        when = "non-expiring" if not exp else (
            f"expires in {int(exp - now)}s" if exp > now else "EXPIRED"
        )
        enforcement = ob.get("enforcement", "gate")
        print(f"  {ob.get('id')} [{when}] enforcement={enforcement}")
        print(f"    tool_pattern: {ob.get('tool_pattern')}")
        if ob.get("exempt_patterns"):
            print(f"    exempt_patterns: {ob['exempt_patterns']}")
        pred = ob.get("predicate", {}) or {}
        print(f"    predicate:    {pred.get('kind')} {pred.get('params')}")
        if ob.get("satisfied_by"):
            print(f"    satisfied_by: {ob['satisfied_by']}")
    return 0


# ---------------------------------------------------------------------------
# Subcommand: show
# ---------------------------------------------------------------------------


def cmd_show(args):
    data = _read_only()
    for ob in data.get("obligations", []):
        if ob.get("id") == args.id:
            print(json.dumps(ob, indent=2))
            return 0
    print(f"not found: {args.id}", file=sys.stderr)
    return 2


# ---------------------------------------------------------------------------
# Subcommand: satisfy
# ---------------------------------------------------------------------------


def cmd_satisfy(args):
    fh, data = _open_locked()
    try:
        before_obs = len(data["obligations"])
        before_ovs = len(data.get("overrides", []))
        data["obligations"] = [
            ob for ob in data["obligations"] if ob.get("id") != args.id
        ]
        data["overrides"] = [
            ov for ov in data.get("overrides", [])
            if ov.get("id") != args.id
        ]
        after_obs = len(data["obligations"])
        after_ovs = len(data.get("overrides", []))
        _write_unlock(fh, data)
    except Exception:
        _unlock(fh)
        raise
    if before_obs == after_obs and before_ovs == after_ovs:
        print(f"not found: {args.id}", file=sys.stderr)
        return 2
    if before_ovs != after_ovs:
        print(f"Cleared override {args.id}")
    else:
        print(f"Satisfied (removed) {args.id}")
    return 0


# ---------------------------------------------------------------------------
# Subcommand: override -- per-call audited bypass with TTL
# ---------------------------------------------------------------------------


def cmd_override(args):
    """Register a short-TTL override that bypasses all gate-mode obligations.

    Every override carries a human-readable reason, a TTL, and gets audited
    to ``~/.config/claude/obligations-bypass.log`` at create time AND on
    every call it ends up bypassing (see ``_check_core``). Overrides
    self-clear via ``_prune_expired`` and are also clearable early via
    ``obligations satisfy <ov-id>``.
    """
    duration = _parse_duration(args.duration)
    if duration <= 0:
        print(
            "ERROR: --duration must be a positive value like 60, 5m, 1h",
            file=sys.stderr,
        )
        return 2
    if duration > 86400:
        # 24h cap. Anything longer should be a real obligation edit, not an
        # override -- otherwise the gate is effectively disabled.
        print(
            "ERROR: --duration capped at 24h (86400s); for longer bypasses "
            "edit the underlying obligation directly",
            file=sys.stderr,
        )
        return 2
    reason = (args.reason or "").strip()
    if not reason:
        print("ERROR: reason argument is required and must be non-empty",
              file=sys.stderr)
        return 2

    now = _now()
    fh, data = _open_locked()
    try:
        _prune_expired(data, now)
        ov_id = _new_override_id()
        existing = {ov.get("id") for ov in data.get("overrides", [])}
        while ov_id in existing:
            ov_id = _new_override_id()
        ov = {
            "id": ov_id,
            "reason": reason,
            "duration_secs": duration,
            "expires_at": now + duration,
            "created_at": now,
            "created_by": args.created_by,
        }
        data["overrides"].append(ov)
        _write_unlock(fh, data)
    except Exception:
        _unlock(fh)
        raise

    _audit_override({
        "kind": "override-created",
        "override_id": ov_id,
        "reason": reason,
        "duration_secs": duration,
        "created_by": args.created_by,
    })
    # Fire-and-forget Pushover so Andrew sees on his phone that an audited
    # bypass just landed. Best-effort -- any pingme failure is swallowed.
    _pingme_override(ov_id, reason, duration)

    if args.json:
        print(json.dumps(ov, indent=2))
    else:
        print(f"Override active: {ov_id}")
        print(f"  reason:     {reason}")
        print(f"  duration:   {duration}s (expires in {duration}s)")
        print(f"  created_by: {args.created_by}")
        print()
        print("All gate-mode obligations are bypassed for the duration.")
        print(f"Cancel early: obligations satisfy {ov_id}")
    return 0


# ---------------------------------------------------------------------------
# Subcommand: prune
# ---------------------------------------------------------------------------


def _parse_duration(s):
    """Parse '1h', '30m', '5d', '120s' into seconds."""
    if not s:
        return 0
    s = str(s).strip().lower()
    units = {"s": 1, "m": 60, "h": 3600, "d": 86400}
    if s[-1] in units:
        try:
            return int(s[:-1]) * units[s[-1]]
        except ValueError:
            return 0
    try:
        return int(s)
    except ValueError:
        return 0


def cmd_prune(args):
    cutoff_age = _parse_duration(args.older_than) if args.older_than else 0
    fh, data = _open_locked()
    try:
        now = _now()
        kept = []
        dropped = []
        for ob in data["obligations"]:
            # Always drop expired
            if _is_expired(ob, now):
                dropped.append(ob)
                continue
            # If older-than is set, also drop very-old non-expiring obligations
            if cutoff_age:
                created = ob.get("created_at", now)
                if (now - created) >= cutoff_age:
                    dropped.append(ob)
                    continue
            kept.append(ob)
        if args.dry_run:
            _unlock(fh)
            print(f"would prune {len(dropped)} (keep {len(kept)})")
            for ob in dropped:
                print(f"  drop: {ob.get('id')}")
            return 0
        data["obligations"] = kept
        _write_unlock(fh, data)
    except Exception:
        _unlock(fh)
        raise
    print(f"pruned {len(dropped)} (kept {len(kept)})")
    return 0


# ---------------------------------------------------------------------------
# Subcommand: check  -- the hot path called by hooks
# ---------------------------------------------------------------------------


def _is_subagent_context(agent_id):
    """Return True iff the caller is inside a subagent.

    Per Claude Code's hook contract, the PreToolUse / PostToolUse JSON payload
    carries an ``agent_id`` field ONLY when the tool call originates from
    inside a subagent. Main-loop tool calls have no ``agent_id`` (or an empty
    string). We accept both ``None`` and ``""`` as "main loop".
    """
    return bool(agent_id) and isinstance(agent_id, str) and agent_id.strip() != ""


def _check_core(tool_name, command_string, prune=True, agent_id=None):
    """Pure check: returns (ok: bool, blocking: list). blocking is a list of
    {id, deny_message, predicate, why} dicts for any obligations that match
    the tool but are not currently satisfied.

    Inform-mode obligations are SKIPPED here -- they never gate. They are
    surfaced separately by `inform_check_core` in the PostToolUse hook.

    ``agent_id``: forwarded to ``_eval_predicate`` so predicates that care
    about subagent vs main-loop context (currently ``is_main_loop``, and
    by composition any ``all_of`` containing it) can distinguish. There is
    no row-level main-loop scoping; encode it via ``all_of [is_main_loop,
    <other>]`` instead.
    """
    # Read-only path (no lock) for speed.
    data = _read_only()
    now = _now()

    # Per-call audited override: if any non-expired override exists, ALL
    # gate-mode obligations are bypassed. The override is logged at create
    # time; we re-audit each bypassed call for forensic completeness.
    active_ov = _active_override(data, now)
    if active_ov:
        _audit_override({
            "kind": "override-applied",
            "override_id": active_ov.get("id"),
            "reason": active_ov.get("reason"),
            "tool_name": tool_name,
            "command_string_preview": (command_string or "")[:200],
            "agent_id": agent_id or "",
        })
        return (True, [])

    # Universal recovery exempts: the framework-level deadlock-prevention
    # floor. Tools matching UNIVERSAL_RECOVERY_EXEMPT_PATTERNS are allowed
    # past EVERY obligation regardless of per-row exempt_patterns. This is
    # the structural guarantee that the escape hatch (`obligations
    # override`), the dispatcher (`session-task queue`, Agent), and the
    # watcher recovery surface always work, no matter which combination of
    # obligations is active. See UNIVERSAL_RECOVERY_EXEMPT_PATTERNS for
    # the rationale + the list.
    universal_hit, _universal_pat = _universal_recovery_exempt_match(
        tool_name, command_string,
    )
    if universal_hit:
        return (True, [])

    blocking = []
    for ob in data.get("obligations", []):
        if _is_expired(ob, now):
            continue
        # Inform-mode obligations are non-gating: they only surface in
        # PostToolUse via inform_check_core. Skip here so we never deny.
        if ob.get("enforcement", "gate") == "inform":
            continue
        pat = ob.get("tool_pattern", "*")
        if not _tool_pattern_matches(pat, tool_name, command_string):
            continue
        # Per-obligation exemption: even when tool_pattern matches, an
        # entry in exempt_patterns wins ("the gate exists, but THIS
        # specific recovery / read-only path must always be allowed").
        exempt_hit, _exempt_pat = _exempt_match(
            ob.get("exempt_patterns") or [], tool_name, command_string,
        )
        if exempt_hit:
            continue
        pred = ob.get("predicate", {}) or {}
        ok, why = _eval_predicate(pred, tool_name, command_string,
                                   agent_id=agent_id)
        if not ok:
            blocking.append({
                "id": ob.get("id"),
                "deny_message": ob.get("deny_message", ""),
                "predicate": pred,
                "why": why,
            })
    return (len(blocking) == 0, blocking)


def _inform_check_core(tool_name, command_string, agent_id=None):
    """Evaluate every active inform-mode obligation whose tool_pattern matches
    the tool that just completed. Returns a list of
    {id, deny_message, predicate, why} dicts for any whose predicate fails.

    Used by the PostToolUse hook to print non-blocking advisories to stderr.

    ``agent_id``: forwarded to ``_eval_predicate`` so ``is_main_loop`` (and
    any ``all_of`` containing it) can distinguish main-loop from subagent
    callers. No row-level main-loop scoping -- compose with ``all_of``.
    """
    data = _read_only()
    now = _now()
    # Universal recovery exempts apply to inform-mode too: if the caller
    # is on a framework-level recovery path (override / dispatcher /
    # watcher recovery), suppress the "watcher X is DOWN" / "queue is
    # stale" advisory rather than re-surfacing what the caller is already
    # acting on. Mirrors _check_core's framework floor.
    universal_hit, _universal_pat = _universal_recovery_exempt_match(
        tool_name, command_string,
    )
    if universal_hit:
        return []
    failing = []
    for ob in data.get("obligations", []):
        if _is_expired(ob, now):
            continue
        if ob.get("enforcement", "gate") != "inform":
            continue
        pat = ob.get("tool_pattern", "*")
        if not _tool_pattern_matches(pat, tool_name, command_string):
            continue
        # Honor exempt_patterns even for inform-mode -- if the caller is on
        # the recovery path, surfacing "watcher X is DOWN" again would be
        # noise. (Overrides do NOT suppress inform-mode advisories: they
        # are about gating, not visibility.)
        exempt_hit, _exempt_pat = _exempt_match(
            ob.get("exempt_patterns") or [], tool_name, command_string,
        )
        if exempt_hit:
            continue
        pred = ob.get("predicate", {}) or {}
        ok, why = _eval_predicate(pred, tool_name, command_string,
                                   agent_id=agent_id)
        if not ok:
            failing.append({
                "id": ob.get("id"),
                "deny_message": ob.get("deny_message", ""),
                "predicate": pred,
                "why": why,
            })
    return failing


def cmd_check(args):
    ok, blocking = _check_core(
        args.tool, args.command_string or "",
        agent_id=getattr(args, "agent_id", None),
    )
    if args.json:
        print(json.dumps({"ok": ok, "blocking": blocking}, indent=2))
        return 0 if ok else 2
    if ok:
        print("OK: no blocking obligations")
        return 0
    print("BLOCKED by obligations:")
    for b in blocking:
        print(f"  - {b['id']}: {b['deny_message']}")
        print(f"    why: {b['why']}")
    return 2


# ---------------------------------------------------------------------------
# Subcommand: post-tool-satisfy  -- called by PostToolUse hook
# ---------------------------------------------------------------------------


def _satisfy_by_completion(tool_name, command_string):
    """Find any obligations whose satisfied_by matches the tool that just ran.
    Remove them. Returns list of removed obligation ids.
    """
    fh, data = _open_locked()
    try:
        before_ids = {ob.get("id") for ob in data["obligations"]}
        kept = []
        removed_ids = []
        for ob in data["obligations"]:
            sb = ob.get("satisfied_by")
            if not sb:
                kept.append(ob)
                continue
            sb_tool_pat = sb.get("tool_pattern") or "*"
            sb_cmd_pat = sb.get("command_pattern") or ""
            # tool_pattern check uses our standard matcher
            if not _tool_pattern_matches(sb_tool_pat, tool_name, command_string):
                kept.append(ob)
                continue
            # command_pattern is a regex match against command_string
            if sb_cmd_pat:
                try:
                    patt = re.compile(sb_cmd_pat)
                except re.error:
                    kept.append(ob)
                    continue
                if not patt.search(command_string or ""):
                    kept.append(ob)
                    continue
            removed_ids.append(ob.get("id"))
        data["obligations"] = [
            ob for ob in data["obligations"] if ob.get("id") not in removed_ids
        ]
        # Also opportunistically prune expired
        _prune_expired(data)
        _write_unlock(fh, data)
        return removed_ids
    except Exception:
        _unlock(fh)
        raise


def cmd_post_satisfy(args):
    removed = _satisfy_by_completion(args.tool, args.command_string or "")
    if args.json:
        print(json.dumps({"removed": removed}, indent=2))
        return 0
    if removed:
        print(f"satisfied {len(removed)} obligation(s): {removed}")
    else:
        print("no obligations satisfied")
    return 0


# ---------------------------------------------------------------------------
# Subcommand: inform-check  -- called by PostToolUse hook for inform-mode
# ---------------------------------------------------------------------------


def _format_inform_failures(failing):
    lines = []
    for f in failing:
        msg = f.get("deny_message") or "(no message)"
        lines.append(f"[obligations:inform] {f.get('id')}: {msg}")
        why = f.get("why")
        if why:
            for line in str(why).splitlines() or [""]:
                lines.append(f"    {line}")
    return "\n".join(lines)


def cmd_inform_check(args):
    failing = _inform_check_core(
        args.tool, args.command_string or "",
        agent_id=getattr(args, "agent_id", None),
    )
    if args.json:
        print(json.dumps({"failing": failing}, indent=2))
        return 0 if not failing else 2
    if not failing:
        return 0
    print(_format_inform_failures(failing))
    return 2


# ---------------------------------------------------------------------------
# Subcommand: post-tool  -- combined hot path called by PostToolUse hook
# ---------------------------------------------------------------------------


def cmd_post_tool(args):
    """One-shot for the PostToolUse hook: runs satisfy-by-completion AND
    inform-check in a single python process.

    Wire output:
      - stdout: JSON {"removed": [...], "failing": [...]} when --json,
                otherwise the inform-check banner (one line per failure).
      - stderr: never used by this subcommand directly.
      - exit:   0 always (the post-tool hook never blocks).
    """
    removed = _satisfy_by_completion(args.tool, args.command_string or "")
    failing = _inform_check_core(
        args.tool, args.command_string or "",
        agent_id=getattr(args, "agent_id", None),
    )
    if args.json:
        print(json.dumps({"removed": removed, "failing": failing}, indent=2))
        return 0
    if failing:
        print(_format_inform_failures(failing))
    return 0


# ---------------------------------------------------------------------------
# Argparse wiring
# ---------------------------------------------------------------------------


def build_parser():
    p = argparse.ArgumentParser(
        prog="obligations",
        description="Generic obligations gate -- enforces 'must do X before Y' rules at the tool layer.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    # add
    p_add = sub.add_parser("add", help="register a new obligation")
    p_add.add_argument("--tool-pattern", required=True,
                       help="'*' | 'Bash' | 'Bash:<regex>' | '<ToolName>'")
    p_add.add_argument("--exempt-tool-pattern", action="append", default=None,
                       help="repeatable; tool_pattern syntax. When the call "
                            "being checked matches the obligation's "
                            "tool_pattern AND any --exempt-tool-pattern, the "
                            "obligation auto-allows. Use to encode 'this gate "
                            "exists but the recovery path (e.g. "
                            "Bash:^watcher-ctl run) must always be allowed'.")
    p_add.add_argument("--predicate", required=True,
                       help=f"one of {sorted(VALID_PREDICATE_KINDS)}")
    p_add.add_argument("--params", default="{}", help="JSON object of predicate params")
    p_add.add_argument("--ttl", type=int, required=True,
                       help="seconds; 0 = non-expiring")
    p_add.add_argument("--enforcement", default="gate",
                       choices=sorted(VALID_ENFORCEMENT_MODES),
                       help="'gate' (default; PreToolUse denies) or 'inform' "
                            "(PostToolUse prints a banner; never blocks)")
    p_add.add_argument("--deny-msg", required=True,
                       help="message shown when the obligation blocks a tool call "
                            "(or surfaces in the inform banner)")
    p_add.add_argument("--satisfied-by-tool", default=None,
                       help="tool_pattern for auto-satisfy")
    p_add.add_argument("--satisfied-by-cmd-regex", default=None,
                       help="command regex for auto-satisfy")
    p_add.add_argument("--created-by", default="manual",
                       help="audit string (e.g. 'main-loop', 'andrew')")
    p_add.add_argument("--json", action="store_true", help="emit JSON")
    p_add.set_defaults(func=cmd_add)

    # list
    p_list = sub.add_parser("list", help="list active obligations")
    p_list.add_argument("--all", action="store_true",
                        help="include expired entries")
    p_list.add_argument("--json", action="store_true")
    p_list.set_defaults(func=cmd_list)

    # show
    p_show = sub.add_parser("show", help="show one obligation by id")
    p_show.add_argument("id")
    p_show.set_defaults(func=cmd_show)

    # satisfy
    p_sat = sub.add_parser("satisfy",
                           help="manually mark obligation satisfied (remove); "
                                "also accepts override ids to cancel early")
    p_sat.add_argument("id")
    p_sat.set_defaults(func=cmd_satisfy)

    # override
    p_ov = sub.add_parser(
        "override",
        help="register an audited per-call bypass that disables all "
             "gate-mode obligations for a short duration",
        description="Audited per-call escape hatch. Logs to "
                    "~/.config/claude/obligations-bypass.log and self-clears "
                    "via TTL. Cap: 24h (86400s).",
    )
    p_ov.add_argument("reason", help="human-readable why (required, audited)")
    p_ov.add_argument("--duration", required=True,
                      help="how long to bypass: 60, 5m, 1h, 30m, 1d, etc. "
                           "Hard cap 24h.")
    p_ov.add_argument("--created-by", default="main-loop",
                      help="audit string (e.g. 'main-loop', 'andrew')")
    p_ov.add_argument("--json", action="store_true")
    p_ov.set_defaults(func=cmd_override)

    # prune
    p_prune = sub.add_parser("prune", help="remove expired (and optionally old) obligations")
    p_prune.add_argument("--older-than", default=None,
                         help="duration like 1h / 30m / 5d / 3600 (default: only expired)")
    p_prune.add_argument("-n", "--dry-run", action="store_true")
    p_prune.set_defaults(func=cmd_prune)

    # check (used by PreToolUse hook)
    p_chk = sub.add_parser("check", help="check whether a tool call is currently blocked")
    p_chk.add_argument("--tool", required=True)
    p_chk.add_argument("--command-string", default="")
    p_chk.add_argument("--agent-id", default="",
                       help="payload.agent_id from the hook, when present; "
                            "non-empty value marks a subagent context. "
                            "Forwarded to the is_main_loop predicate (and "
                            "any all_of containing it).")
    p_chk.add_argument("--json", action="store_true")
    p_chk.set_defaults(func=cmd_check)

    # post-satisfy (used by PostToolUse hook)
    p_post = sub.add_parser("post-satisfy",
                            help="auto-satisfy obligations whose satisfied_by matches the just-run tool")
    p_post.add_argument("--tool", required=True)
    p_post.add_argument("--command-string", default="")
    p_post.add_argument("--json", action="store_true")
    p_post.set_defaults(func=cmd_post_satisfy)

    # inform-check (used by PostToolUse hook for non-gating obligations)
    p_inform = sub.add_parser("inform-check",
                              help="evaluate inform-mode obligations after the tool ran; "
                                   "print failures (exit 2 when any fail, 0 when all healthy)")
    p_inform.add_argument("--tool", required=True)
    p_inform.add_argument("--command-string", default="")
    p_inform.add_argument("--agent-id", default="",
                          help="payload.agent_id from the hook (subagent bypass)")
    p_inform.add_argument("--json", action="store_true")
    p_inform.set_defaults(func=cmd_inform_check)

    # post-tool (combined satisfy + inform-check in one process for hook speed)
    p_pt = sub.add_parser("post-tool",
                          help="combined post-satisfy + inform-check (PostToolUse hot path); "
                               "always exits 0; prints inform banner on stdout")
    p_pt.add_argument("--tool", required=True)
    p_pt.add_argument("--command-string", default="")
    p_pt.add_argument("--agent-id", default="",
                      help="payload.agent_id from the hook (subagent bypass)")
    p_pt.add_argument("--json", action="store_true")
    p_pt.set_defaults(func=cmd_post_tool)

    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
