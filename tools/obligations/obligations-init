        if verbose:
            print("no_grep_watcher_output: already seeded -- skipping",
                  file=sys.stderr)
        return 0

    # The evaluator script receives the Bash command on stdin and
    # exits 0 (allow) or 1 (deny). Only scoped to the main loop
    # (subagents reading their own task output is fine; the main loop
    # should read ALL output unfiltered).
    # Main-loop ONLY: wrap the evaluator behind an is_main_loop
    # scope-guard inside all_of so this gate NEVER fires inside a
    # subagent context (which carries an agent_id). A bare evaluator
    # row (no guard) fired in subagents, letting a subagent clobber
    # the MAIN loop's state it does not own. See
    # _main_loop_only_evaluator_params().
    predicate_params = _main_loop_only_evaluator_params(
        "/usr/local/bin/eval-no-grep-watcher-output")

    cmd = [
        cli, "add",
        "--tool-pattern", "Bash",
        "--predicate", "all_of",
        "--params", json.dumps(predicate_params),
        "--ttl", "0",  # non-expiring
        "--enforcement", "gate",
        "--deny-msg", NO_GREP_WATCHER_OUTPUT_TAG,
        "--created-by", "obligations-init",
        "--json",
