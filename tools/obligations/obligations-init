#!/usr/bin/env python3
"""Seed the default-bundled obligations rows for a fresh container / install.

Run by the container entrypoint after the obligations CLI is available
on PATH. Idempotent: each default row carries a marker tag in its
``deny_message`` so we can detect "already seeded" and skip re-adding.

Currently seeded rows:

  - ``subagent_queue_item_running`` — continuous queue-discipline
    enforcement for subagents. The PreToolUse:Agent queue-gate hook
    checks at SPAWN time that the Agent's prompt carries a
    ``Queue item: q-XXXX`` marker and that q-id is running; this
    predicate enforces the same invariant AFTER spawn so a subagent
    whose q-id has been marked done / abandoned (or has gone missing
    from the queue entirely) can no longer make tool calls. Pairs with
    the ``post-tool-agent-arm-hook`` (PostToolUse:Agent) which writes
    agent_id -> q-id bindings to
    ``~/.config/claude/agent-queue-bindings.json`` on every successful
    async-launched spawn.

  - ``no_grep_watcher_output`` — prevents the main loop from filtering
    watcher/task output through grep/sed/awk/head/tail. Uses the
    ``evaluator`` predicate with an external script
    (``/usr/local/bin/eval-no-grep-watcher-output``) that inspects Bash
    commands on stdin. Commands that read task output files
    (``/tmp/claude-*/tasks/*.output``) through a pipe or pass them as
    args to a filter tool are DENIED. Plain ``cat`` of the file (no
    pipe) is ALLOWED. Ensures the operator sees ALL events unfiltered.

  - ``event_must_act`` — blocks Bash tool calls while actionable events
    remain un-acked. When ``claude-event-watch`` delivers events with
    actionable tags (``pr-status-change`` with CI failure/success,
    ``slack-unread``, ``workbot-prompt``, ``queue-stale-ready``), they
    are recorded in ``~/.config/claude-events/pending-actions.json``.
    The evaluator (``/usr/local/bin/eval-event-must-act``) denies Bash
    calls until each pending event is acked via ``event-ack``. Ensures
    the main loop triages every actionable event before moving on.

  - ``agent_ack_pending`` — blocks Bash tool calls while completed agents
    await acknowledgment. When a subagent delivers a task-notification,
    the main loop must register it (``agent-ack register <queue-id>``),
    read the output, call ``session-task queue done/abandon``, then clear
    it (``agent-ack done <queue-id>``). The evaluator
    (``/usr/local/bin/eval-agent-ack-pending``) denies Bash calls after N
    consecutive non-exempt calls (default N=2) while pending-ack entries
    exist. Ensures agent results are never silently dropped.

  - ``queue_ready_unspawned`` — blocks Bash tool calls when
    ``session-task queue list`` shows items with status=pending and
    ready_now=true. Forces the main loop to spawn agents for ready
    work before doing anything else. The evaluator
    (``/usr/local/bin/eval-queue-ready-unspawned``) denies Bash calls
    when ready-but-unspawned items exist. Default-open on errors.

  - ``no_backgrounded_watcher`` — prevents the main loop from launching a
    watcher with a shell ``&`` (or ``nohup ... &`` / ``(... &)``) instead
    of the Bash tool's ``run_in_background: true``. Uses the NATIVE
    AST-backed ``no_backgrounded_watcher`` predicate (shell_ast), not an
    external evaluator, so a ``&`` inside quotes / a heredoc body / a
    ``2>&1`` redirection does NOT false-positive-deny. Replaces the
    half-ported ``check-no-bg-ampersand`` exec-hook whose target binary
    was absent from the container image (silent no-op). Main-loop scoped
    via ``all_of [is_main_loop, no_backgrounded_watcher]``.

MAIN-LOOP SCOPING: the four evaluator-backed rows above
(``no_grep_watcher_output``, ``event_must_act``, ``agent_ack_pending``,
``queue_ready_unspawned``) are all conceptually MAIN-LOOP ONLY -- they gate
on state that only the main loop owns (watcher output it must read in full,
event triage, pending agent-ack bookkeeping, ready-queue spawning). They MUST
NOT fire inside a subagent. The ``evaluator`` predicate alone has no
main-loop scoping, so each is wrapped in
``all_of [is_main_loop {}, evaluator]`` via
``_main_loop_only_evaluator_params()``: in a subagent the ``is_main_loop``
child fails and short-circuits the all_of to inactive (the gate does not
fire); in the main loop it passes and the evaluator decides. This mirrors
``subagent_queue_item_running`` (which uses the INVERSE
``is_main_loop {negate: true}`` to fire ONLY in subagents). Without the guard
a bare evaluator row fired inside subagent contexts, letting a subagent block
itself over -- and then clobber -- the main loop's pending-ack / event /
queue state.

The script is best-effort: any failure (missing CLI, broken state file,
permission error) is logged to stderr but exits 0 so the entrypoint
keeps going. The whole obligations system is default-open on internal
errors anyway -- a missing seed row just means the gate is inert until
the next ``obligations-init`` run.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys


# Tag in the deny_message used to detect already-seeded rows. Bumping
# this value (or changing the row shape) effectively re-seeds on next
# run; existing rows with the OLD tag stay until their TTL expires
# (or until an operator runs `obligations satisfy <id>` against them).
SUBAGENT_QID_RUNNING_TAG = "[default-seed] subagent_queue_item_running"
NO_GREP_WATCHER_OUTPUT_TAG = "[default-seed] no_grep_watcher_output"
EVENT_MUST_ACT_TAG = "[default-seed] event_must_act"
AGENT_ACK_PENDING_TAG = "[default-seed] agent_ack_pending"
QUEUE_READY_UNSPAWNED_TAG = "[default-seed] queue_ready_unspawned"
NO_BACKGROUNDED_WATCHER_TAG = "[default-seed] no_backgrounded_watcher"
SUBAGENT_QUEUE_MUTATING_BANNED_TAG = "[default-seed] subagent_queue_mutating_banned"

# Exempts that must always pass even when the gate is firing. These are
# the recovery surface a subagent uses to either re-register a queue
# item, inspect / ack agent-msg messages, or read claude-watch alerts.
# Same shape as the agent-msg inbox-gate exempt set.
DEFAULT_EXEMPT_PATTERNS = [
    # Queue dispatch surface: a subagent that just got denied needs to
    # be able to inspect the queue state to figure out whether to re-
    # register (q-id changed) or stop. ``status``, ``spawn-check``,
    # ``register``, ``show``, ``list`` cover the read + claim path.
    r"Bash:^session-task\s+queue\s+(status|spawn-check|register|show|list)",
    # Obligations inspection / override -- the operator's escape hatch
    # must always work. ``obligations override`` is universal-exempt at
    # the framework level too, but listing it here makes the row's
    # intent self-documenting.
    r"Bash:^obligations\s+(list|show|status|check|override|satisfy)",
    # Claude-watch alert ack surface -- a subagent that hits both this
    # gate AND an active claude-watch alert needs to be able to read
    # + ack the alert before it can do anything else.
    r"Bash:^claude-watch-ack\b",
    r"Bash:^claude-watch-dispatch\b",
    # agent-msg ack / inbox / gc / disarm -- the subagent's own inbox
    # surface. Same set the agent-msg inbox gate exempts.
    r"Bash:^agent-msg\s+(ack|inbox|gc|disarm)\b",
    # agent-tail self-inspection (rare, but harmless when allowed).
    r"Bash:^agent-tail\b",
]


def _resolve_cli() -> str | None:
    """Resolve the obligations CLI path. Prefer PATH, fall back to known
    install locations. Returns None when not found."""
    cli = shutil.which("obligations")
    if cli:
        return cli
    for cand in ("/usr/local/bin/obligations",
                 os.path.expanduser("~/bin/obligations")):
        if os.path.isfile(cand) and os.access(cand, os.X_OK):
            return cand
    return None


def _row_already_present(cli: str, tag: str) -> bool:
    """True iff an active obligation with the seed tag already exists."""
    try:
        proc = subprocess.run(
            [cli, "list", "--json"],
            capture_output=True, text=True, timeout=10, check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return False
    if proc.returncode != 0:
        return False
    try:
        data = json.loads(proc.stdout)
    except (json.JSONDecodeError, ValueError):
        return False
    if not isinstance(data, dict):
        return False
    obligations = data.get("obligations", [])
    if not isinstance(obligations, list):
        return False
    for ob in obligations:
        if not isinstance(ob, dict):
            continue
        if ob.get("deny_message") == tag:
            return True
    return False


def _main_loop_only_evaluator_params(eval_cmd: str) -> dict:
    """Return ``all_of`` params wrapping an ``evaluator`` predicate behind an
    ``is_main_loop`` scope-guard so the gate fires ONLY in the main loop.

    This is the canonical "main-loop only enforce X" wiring documented in the
    obligations CLI docstring (and mirrored by ``seed_subagent_queue_item_running``,
    which uses the INVERSE ``is_main_loop {negate: true}`` to fire only in
    SUBAGENTS). Inside an ``all_of``, a FAILING ``is_main_loop`` child
    short-circuits the whole ``all_of`` to "inactive" (satisfied=True):

      - Subagent (hook payload carries an ``agent_id``): ``is_main_loop`` FAILS
        -> all_of short-circuits to inactive -> gate does NOT fire. Subagents
        bypass entirely. This is the bug fix -- without the guard, the bare
        ``evaluator`` row fired inside subagent contexts, blocking a subagent
        over the MAIN loop's pending-ack / event / queue state (state the
        subagent does not own and must not mutate).

      - Main loop (no ``agent_id``): ``is_main_loop`` PASSES -> the all_of
        proceeds to the ``evaluator`` child -> the gate fires iff the
        evaluator denies. Unchanged from the previous behavior in the main
        loop.

    NOTE: ``is_main_loop`` takes NO ``negate`` here -- plain ``is_main_loop``
    is satisfied in the main loop, so it is the correct precondition gate for
    "main-loop only". (``subagent_queue_item_running`` wants the opposite, so
    it uses ``negate: true``.)
    """
    return {
        "predicates": [
            {"kind": "is_main_loop", "params": {}},
            {
                "kind": "evaluator",
                "params": {
                    "cmd": eval_cmd,
                    "timeout_ms": 5000,
                    "stdin_field": "tool_input.command",
                    "decision_mode": "exit_code",
                },
            },
        ]
    }


def seed_subagent_queue_item_running(cli: str, *, dry_run: bool = False,
                                       force: bool = False,
                                       verbose: bool = False) -> int:
    """Add the default subagent_queue_item_running obligation. Returns 0
    on success (added or already present), non-zero on hard failure."""
    if not force and _row_already_present(cli, SUBAGENT_QID_RUNNING_TAG):
        if verbose:
            print("subagent_queue_item_running: already seeded -- skipping",
                  file=sys.stderr)
        return 0

    # We scope the predicate to subagents only via an `all_of` wrapping
    # `is_main_loop {negate: true}`. With the scope guard, calls from
    # the main loop short-circuit to satisfied (the all_of's is_main_loop
    # child fails, which the all_of treats as "inactive scope" by design)
    # so the predicate ONLY applies to subagents. This is exactly the
    # pattern documented in the obligations CLI docstring and used by
    # cron-queue-check + agent-msg arm.
    predicate_params = {
        "predicates": [
            {"kind": "is_main_loop", "params": {"negate": True}},
            {"kind": "subagent_queue_item_running", "params": {}},
        ]
    }

    cmd = [
        cli, "add",
        "--tool-pattern", "*",
        "--predicate", "all_of",
        "--params", json.dumps(predicate_params),
        "--ttl", "0",  # non-expiring
        "--enforcement", "gate",
        "--deny-msg", SUBAGENT_QID_RUNNING_TAG,
        "--created-by", "obligations-init",
        "--json",
    ]
    for pat in DEFAULT_EXEMPT_PATTERNS:
        cmd.extend(["--exempt-tool-pattern", pat])

    if dry_run:
        print("DRY-RUN: " + " ".join(cmd))
        return 0

    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=10, check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as e:
        print(f"obligations-init: subprocess failed: {e}", file=sys.stderr)
        return 1
    if proc.returncode != 0:
        print("obligations-init: obligations add failed "
              f"rc={proc.returncode}", file=sys.stderr)
        if proc.stderr:
            print(proc.stderr, file=sys.stderr)
        return 1
    if verbose:
        try:
            row = json.loads(proc.stdout)
            print(f"subagent_queue_item_running: seeded "
                  f"id={row.get('id', '?')}", file=sys.stderr)
        except (json.JSONDecodeError, ValueError):
            print(f"subagent_queue_item_running: seeded "
                  f"(rc={proc.returncode})", file=sys.stderr)
    return 0


def seed_no_grep_watcher_output(cli: str, *, dry_run: bool = False,
                                   force: bool = False,
                                   verbose: bool = False) -> int:
