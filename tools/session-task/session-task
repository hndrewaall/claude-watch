    )
    q_depend.add_argument("id")
    q_depend.add_argument(
        "--add",
        action="append",
        default=[],
        help=(
            "Queue id(s) to add as dependencies. Comma-separated values "
            "and repeated --add flags both work."
        ),
    )
    q_depend.add_argument(
        "--remove",
        action="append",
        default=[],
        help=(
            "Queue id(s) to remove from depends_on. Comma-separated values "
            "and repeated --remove flags both work."
        ),
    )
    q_depend.add_argument(
        "--clear",
        action="store_true",
        help="Remove ALL deps from this item (applied before --add).",
    )
    q_depend.add_argument("--json", action="store_true")

    q_prune = qsub.add_parser("prune", help="Remove done/abandoned items")
    q_prune.add_argument("--older-than", help="e.g. 7d, 24h, 30m")
    q_prune.add_argument("-n", "--dry-run", action="store_true")

    qsub.add_parser("banner", help="Top-5 ready items banner")

    # Manual scope locks (added 2026-05-08).
    q_lock = qsub.add_parser(
        "lock",
        help=(
            "Park any pending item whose scope overlaps <scope> until the "
            "scope is unlocked. Use to enqueue work that depends on a "
            "real-world condition (hardware install, manual config, etc.)."
        ),
    )
    q_lock.add_argument("scope", help="Scope token to lock (same syntax as --scope on `queue add`)")
    q_lock.add_argument(
        "--reason",
        help="Free-form note describing why the scope is locked. Surfaces in `queue locks`.",
    )
    q_lock.add_argument("--json", action="store_true")

    q_unlock = qsub.add_parser(
        "unlock",
        help=(
            "Remove <scope> from the locked-scopes set. Items previously "
            "blocked-only-by-the-lock become ready immediately. No-op (exit 0) "
