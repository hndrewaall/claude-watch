def cmd_queue_groups(args):
    fh, data = _queue_open_locked("r")
    items = list(data["items"])
    _queue_unlock_readonly(fh)

    by_group = {}
    for it in items:
        if it.get("status") not in ACTIVE_STATUSES:
            continue
        by_group.setdefault(it["group_id"], []).append(it)

    out = []
    for gid, members in sorted(by_group.items()):
        gscope = _union_scopes(*(m.get("scope", []) for m in members))
        running = [m for m in members if m.get("status") == "running"]
        pending = [m for m in members if m.get("status") == "pending"]
        wedged = [m for m in members if m.get("status") == "wedged"]
        blocked = [m for m in members if m.get("status") == "blocked"]
        head = _group_head(items, gid)
        out.append({
            "group_id": gid,
            "scope": gscope,
            "running_count": len(running),
            "pending_count": len(pending),
            "wedged_count": len(wedged),
            "blocked_count": len(blocked),
            "head_id": head["id"] if head else None,
            "members": [m["id"] for m in sorted(members, key=_sort_key)],
        })

    if args.json:
        print(json.dumps(out, indent=2))
        return

    if not out:
        print("(no active groups)")
        return
    for g in out:
        wedged_str = f"  wedged={g['wedged_count']}" if g.get("wedged_count") else ""
        blocked_str = f"  blocked={g['blocked_count']}" if g.get("blocked_count") else ""
        print(f"{g['group_id']}  running={g['running_count']}  pending={g['pending_count']}{wedged_str}{blocked_str}  head={g['head_id']}")
        print(f"  scope: {','.join(g['scope'])}")
        print(f"  members: {','.join(g['members'])}")


