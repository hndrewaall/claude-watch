def cmd_queue_show(args):
    fh, data = _queue_open_locked("r")
    items = list(data["items"])
    _queue_unlock_readonly(fh)
    for it in items:
        if it["id"] == args.id:
            ready = _item_is_ready(items, it)
            out = dict(it)
            out["ready_now"] = ready
            out["group_scope"] = _group_scope(items, it["group_id"])
            # Surface dep state + dependents so a single `queue show` is
            # enough to inspect the dependency edges in / out of this item
            # without re-reading queue.json.
            deps = list(out.get("depends_on") or [])
            by_id = {x.get("id"): x for x in items if x.get("id")}
            dep_status = []
            unmet = []
            for d in deps:
                tgt = by_id.get(d)
                if tgt is None:
                    dep_status.append({"id": d, "status": "missing"})
                    unmet.append(d)
                else:
                    s = tgt.get("status") or "?"
                    dep_status.append({"id": d, "status": s})
                    if s != "done":
                        unmet.append(d)
            out["depends_on_status"] = dep_status
            out["dep_blockers"] = unmet
            out["dep_cycle"] = _has_dep_cycle(items, it["id"]) if deps else False
            # Reverse-edges: items that name THIS item in their depends_on.
            dependents = [
                x.get("id")
                for x in items
                if x.get("id")
                and isinstance(x.get("depends_on"), list)
                and it["id"] in x.get("depends_on", [])
            ]
            out["dependents"] = dependents
            print(json.dumps(out, indent=2))
            return
    print(f"not found: {args.id}", file=sys.stderr)
    sys.exit(1)


