def cmd_queue_register(args):
    """Atomically claim a pending item as running (spawn-gating entry point).

    Refuses if:
      * item does not exist
      * item is not pending (already running/done/abandoned)
      * item is not the ready head of its group (blocked on a peer)
      * any OTHER running item's scope overlaps this item's scope
        (cross-group conflict -- indicates an unregistered in-flight agent
        the main loop is responsible for)

    This is the single source of truth for "is this agent allowed to spawn
    right now". The main loop MUST call register before invoking the Agent
    tool; an unregistered spawn is an operating-rules violation.
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        locked_scopes = data.get("locked_scopes") or {}
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: QUEUE ITEM {args.id!r} NOT FOUND.",
                  file=sys.stderr)
            print("!! DO NOT SPAWN ANY AGENT. THE QUEUE HAS NO RECORD OF THIS WORK.",
                  file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        if target.get("status") == "running":
            # Idempotent-ish: re-registering something that's already running
            # is fine if --if-absent, but default refuses so the caller
            # notices double-register.
            if args.if_absent:
                print(f"already running: {args.id}")
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                return
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS ALREADY RUNNING.",
                  file=sys.stderr)
            print("!! DOUBLE-SPAWN DETECTED. DO NOT SPAWN ANOTHER AGENT.",
                  file=sys.stderr)
            print("!! IF THE ORIGINAL AGENT DIED, MARK IT ABANDONED FIRST:",
                  file=sys.stderr)
            print(f"!!   session-task queue abandon {args.id} --reason '...'",
                  file=sys.stderr)
            print("!! OR USE --if-absent TO NO-OP WHEN THE ITEM IS ALREADY RUNNING.",
                  file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        if target.get("status") == "wedged":
            # A wedged item still owns its scope. Re-registering would
            # blow past the wedge without resolving it. Operator must
            # explicitly unwedge (back to running) or abandon first.
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS WEDGED.", file=sys.stderr)
            print("!! THE OWNING AGENT IS STUCK BUT STILL HOLDS THE SCOPE.",
                  file=sys.stderr)
            print("!! UNWEDGE OR ABANDON BEFORE REGISTERING A REPLACEMENT:",
                  file=sys.stderr)
            print(f"!!   session-task queue unwedge {args.id}", file=sys.stderr)
            print(f"!!   session-task queue abandon {args.id} --reason '...'",
                  file=sys.stderr)
            wr = target.get("wedged_reason")
            if wr:
                print(f"!! WEDGED REASON: {wr}", file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        if target.get("status") == "blocked":
            # A blocked item is parked on an external blocker but still
            # owns its scope. Operator must explicitly unblock (back to
            # running) or move to a terminal state first. Re-registering
            # would lose the block_reason audit trail and race with
            # whatever external action is in flight.
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS BLOCKED.", file=sys.stderr)
            print("!! THE ITEM IS PARKED ON AN EXTERNAL BLOCKER AND STILL OWNS THE SCOPE.",
                  file=sys.stderr)
            print("!! UNBLOCK OR ABANDON BEFORE REGISTERING A REPLACEMENT:",
                  file=sys.stderr)
            print(f"!!   session-task queue unblock {args.id}", file=sys.stderr)
            print(f"!!   session-task queue abandon {args.id} --reason '...'",
                  file=sys.stderr)
            br = target.get("block_reason")
            if br:
                print(f"!! BLOCK REASON: {br}", file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        ok, reasons, conflicts = _spawn_check(items, target, locked_scopes=locked_scopes)
        if not ok:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS NOT CLEAR TO SPAWN.",
                  file=sys.stderr)
            print("!! DO NOT SPAWN ANY AGENT FOR THIS WORK.", file=sys.stderr)
            print("!! RUN THE CONFLICTING WORK FIRST OR WAIT FOR IT TO FINISH.",
                  file=sys.stderr)
            print("!!", file=sys.stderr)
            print(f"!! ITEM  : {args.id} (status={target.get('status')}, "
                  f"group={target.get('group_id')})", file=sys.stderr)
            print(f"!! SCOPE : {','.join(target.get('scope', []))}",
                  file=sys.stderr)
            print("!! REASONS:", file=sys.stderr)
            for r in reasons:
                print(f"!!   - {r}", file=sys.stderr)
            if conflicts:
                print("!! RUNNING SCOPE OVERLAPS:", file=sys.stderr)
                for c in conflicts:
                    print(
                        f"!!   - {c['id']} (group {c.get('group_id')}): "
                        f"{','.join(c.get('scope', []))}",
                        file=sys.stderr,
                    )
            print(bar, file=sys.stderr)
            sys.exit(2)

        target["status"] = "running"
        target["started_at"] = _fmt_ts()
        target["registered_at"] = target["started_at"]
        # Liveness telemetry (added 2026-05-01, revised same day).
        #
        # `pid` is OPTIONAL and defaults to None (deferred PID stamping). Why:
        # `register` is overwhelmingly invoked from a shell wrapper inside the
        # main loop, and that shell is ephemeral — `os.getpid()` returns the
        # bash subshell PID, which exits within seconds, so any /proc-based
        # liveness check immediately sees a dead PID and fires a false-
        # positive WorkQueueOrphaned alert (the bug fixed here). Pass
        # `--pid N` explicitly when the caller actually has a long-lived PID
        # to stamp (e.g. a wrapper that fork+execs the agent and knows the
        # child PID). Subagents typically don't either — they live inside an
        # LLM context, not a single OS process — so they should heartbeat
        # against `last_heartbeat_at` instead of trying to claim a PID.
        #
        # `last_heartbeat_at` is initialized to started_at. The exporter
        # treats pid=None items as "trusted alive" while their heartbeat age
        # is within HEARTBEAT_GRACE_SECONDS (default 300s); subagents call
        # `queue heartbeat <id>` periodically to refresh that timestamp.
        # Once heartbeat age exceeds the grace window, the exporter flips
        # has_live_owner to 0 and WorkQueueOrphaned fires.
        if args.pid is not None:
            try:
                target["pid"] = int(args.pid)
            except (TypeError, ValueError):
                # Bad explicit --pid value — leave unstamped rather than
                # silently fall back to the caller's ephemeral PID.
                target["pid"] = None
        else:
            target["pid"] = None
        target["last_heartbeat_at"] = target["started_at"]
        if args.note:
            target.setdefault("register_notes", []).append({
                "at": target["started_at"],
                "note": args.note,
            })
        _recompute_group_heads(items)
        registered = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    # Lifecycle notification: task start. Never blocks the register op.
    # Summary goes on the first line so it's the Pushover preview text;
    # scope/priority follow as secondary context.
    _pingme_notify(
        title=f"queue started: {registered['id']}",
        message=(
            f"{_item_summary(registered)}\n"
            f"scope: {','.join(registered.get('scope', []))} "
            f"| priority: {registered.get('priority', 5)}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event lifecycle emit: queue-running. Informational — lets the
    # main loop see transitions without having to poll queue.json.
    _claude_event_notify(
        tag="queue-running",
        message=f"queue running: {registered['id']} ({_item_summary(registered)})",
        data={
            "queue_id": registered["id"],
            "group_id": registered.get("group_id"),
            "scope": registered.get("scope", []),
            "summary": _item_summary(registered),
            "created_by": registered.get("created_by", ""),
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(registered, indent=2))
    else:
        print(f"registered: {args.id} (now running)")
        print(f"  group : {registered.get('group_id')}")
        print(f"  scope : {','.join(registered.get('scope', []))}")
        print("  next  : spawn the agent. call `queue done` when it finishes.")


def cmd_queue_force_start(args):
    """Atomically promote a pending item to running, bypassing scope blockers.

    This is the manual override for the spawn-gate's serialization rules.
    Use ONLY when an operator has consciously decided to override scope-
    conflict serialization — e.g. because the running blocker is wedged,
    or because the work genuinely is independent and the scope tokens
    were mis-set.

    Refuses if:
      * --reason is missing or empty (force-start is auditable; an
        unattributed override defeats the audit log).
      * the item does not exist.
      * the item is not in status=pending (already running, done, or
        abandoned items can't be force-started).

    On success:
      * status flips to running, started_at + registered_at + heartbeat
        are stamped (same as `register`).
      * `force_started_at` (epoch seconds, unix int) and
        `force_started_reason` are written to the queue record so the
        item carries its own provenance.
      * `force_started_blockers_overridden` is the list of running
        items whose scope overlapped this one (the conflicts that the
        normal register path would have refused on).
      * an audit row is appended to QUEUE_FORCE_START_LOG.
      * a `queue-running` claude-event is emitted with
        force_started=true so downstream consumers can distinguish the
        override path from a normal register.

    Same atomic flock-on-queue.json discipline as register/done.
    """
    raw_reason = (args.reason or "").strip()
    if not raw_reason:
        print(
            "ERROR: --reason is required for force-start (override is auditable).",
            file=sys.stderr,
        )
        sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                f"ERROR: queue item {args.id!r} not found.",
                file=sys.stderr,
            )
            sys.exit(1)

        status = target.get("status")
        if status != "pending":
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                f"ERROR: force-start refused: {args.id} status={status!r} "
                f"(must be pending; running/done/abandoned items cannot be "
                f"force-started).",
                file=sys.stderr,
            )
            sys.exit(1)

        # Capture the blockers we are overriding so the audit log + queue
        # record carry the provenance. We do NOT bail on overlaps — that's
        # the entire point of force-start.
        scope = target.get("scope", [])
        gid = target.get("group_id")
        cross_blockers = _running_scope_conflicts(
            items, scope, exclude_id=target.get("id"),
        )
        # Same-group not-yet-running peers (the FIFO blockers within this
        # group) — they don't strictly "conflict" via overlapping scope
        # but they do block readiness. Captured for the audit log.
        same_group_pending_peers = [
            it for it in items
            if it.get("group_id") == gid
            and it.get("id") != target.get("id")
            and it.get("status") == "pending"
        ]

        blockers_overridden = []
        for c in cross_blockers:
            blockers_overridden.append({
                "id": c["id"],
                "group_id": c.get("group_id"),
                "status": c.get("status"),
                "scope": c.get("scope", []),
                "reason": "running scope overlap",
            })
        for p in same_group_pending_peers:
            blockers_overridden.append({
                "id": p["id"],
                "group_id": p.get("group_id"),
                "status": p.get("status"),
                "scope": p.get("scope", []),
                "reason": "same-group pending peer (FIFO blocker)",
            })

        # Autostop overlapping running peers (Andrew 2026-05-02 21:10 UTC):
        # any RUNNING item whose scope OVERLAPS the force-started item is
        # auto-abandoned, its recovery context captured, and (best-effort)
        # its agent process killed. The interrupter (the new agent) will
        # decide what to do with the leftovers — we never auto-stash.
        # Capture happens BEFORE `target` flips to running so the autostop
        # routine doesn't accidentally include `target` in its scope-
        # overlap walk (the running-status filter would catch it anyway,
        # but we belt-and-suspenders by running this first).
        autostop_bundles = _autostop_overlapping_peers(
            items, target, raw_reason=raw_reason,
        )

        now_iso = _fmt_ts()
        target["status"] = "running"
        target["started_at"] = now_iso
        target["registered_at"] = now_iso
        target["last_heartbeat_at"] = now_iso
        target["pid"] = None  # ephemeral-shell PID is not useful here
        target["force_started_at"] = int(datetime.now(timezone.utc).timestamp())
        target["force_started_reason"] = raw_reason
        target["force_started_blockers_overridden"] = blockers_overridden
        target["force_started_autostopped_peers"] = [
            b["queue_id"] for b in autostop_bundles
        ]

        _recompute_group_heads(items)
        promoted = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    # Audit log: append a JSONL row. Best-effort — never block the
    # promotion on a log write failure.
    try:
        QUEUE_FORCE_START_LOG.parent.mkdir(parents=True, exist_ok=True)
        audit_row = {
            "timestamp": promoted["force_started_at"],
            "timestamp_iso": now_iso,
            "queue_id": promoted["id"],
            "reason": raw_reason,
            "scope": promoted.get("scope", []),
            "group_id": promoted.get("group_id"),
            "summary": _item_summary(promoted),
            "blockers_overridden": blockers_overridden,
            "autostopped_peers": [b["queue_id"] for b in autostop_bundles],
        }
        with open(QUEUE_FORCE_START_LOG, "a") as logf:
            logf.write(json.dumps(audit_row) + "\n")
    except OSError as exc:
        print(
            f"WARNING: failed to append to {QUEUE_FORCE_START_LOG}: {exc}",
            file=sys.stderr,
        )

    # Recovery bundle: persist a per-force-start JSON file containing the
    # full recovery context (prompts, transcript paths, git status/diff,
    # queue summaries) for every autostopped peer. The new agent reads
    # this to decide resume/integrate/stash/abandon for each leftover.
    # The file is always written, even when there are zero autostopped
    # peers — the empty-list case is a useful "you're force-starting in
    # the clear" signal for downstream consumers.
    bundle_path = _write_force_start_bundle(
        target_id=promoted["id"],
        target_summary=_item_summary(promoted),
        raw_reason=raw_reason,
        autostop_bundles=autostop_bundles,
    )

    # Lifecycle pingme — same shape as register, with the override called
    # out so it's visually distinct in the notification stream.
    _pingme_notify(
        title=f"queue force-started: {promoted['id']}",
        message=(
            f"{_item_summary(promoted)}\n"
            f"scope: {','.join(promoted.get('scope', []))} "
            f"| priority: {promoted.get('priority', 5)}\n"
            f"force-started, blockers overridden: {len(blockers_overridden)}\n"
            f"reason: {raw_reason}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event emit: queue-running with force_started=true so consumers
    # can branch on the override path (alerting, exporter labels, etc.).
    _claude_event_notify(
        tag="queue-running",
        message=(
            f"queue running (force-started): {promoted['id']} "
            f"({_item_summary(promoted)})"
        ),
        data={
            "queue_id": promoted["id"],
            "group_id": promoted.get("group_id"),
            "scope": promoted.get("scope", []),
            "summary": _item_summary(promoted),
            "created_by": promoted.get("created_by", ""),
            "force_started": True,
            "force_started_reason": raw_reason,
            "force_started_blockers_overridden": [
                b["id"] for b in blockers_overridden
            ],
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    # Claude-event emit: dedicated `force-start` tag so `claude-event-watch`
    # surfaces force-starts distinctly to the main loop. The companion
    # obligation (next call) provides the hard gate; this event is the
    # signal-via-bus layer requested by Andrew (2026-05-02 19:54 ET):
    # "force starting should both emit an event AND add a hard obligation
    # to spawn." Routed in claude-event-routing.md.
    #
    # Recovery bundle path is included so the main loop can paste it into
    # the spawned Agent's prompt verbatim — the Agent reads the file to
    # see what was autostopped and triages.
    _claude_event_notify(
        tag="force-start",
        message=(
            f"queue force-started: {promoted['id']} "
            f"({_item_summary(promoted)}) -- main loop must dispatch "
            f"Agent before any other tool call"
            + (
                f" | autostopped {len(autostop_bundles)} running peer(s); "
                f"recovery bundle: {bundle_path}"
                if autostop_bundles else ""
            )
        ),
        data={
            "queue_id": promoted["id"],
            "group_id": promoted.get("group_id"),
            "scope": promoted.get("scope", []),
            "summary": _item_summary(promoted),
            "created_by": promoted.get("created_by", ""),
            "force_started_reason": raw_reason,
            "autostopped_peers": [b["queue_id"] for b in autostop_bundles],
            "recovery_bundle_path": bundle_path,
        },
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Obligations gate: hard-deny every non-exempt main-loop tool call
    # until an Agent has been spawned for this queue id. The Agent tool
    # is in UNIVERSAL_RECOVERY_EXEMPT_PATTERNS so the spawning call is
    # never blocked by its own gate. TTL 15min so a wedged main loop
    # doesn't deadlock forever.
    _obligations_register_force_start(
        queue_id=promoted["id"],
        summary=_item_summary(promoted),
        reason=raw_reason,
        bundle_path=bundle_path,
        autostopped_count=len(autostop_bundles),
    )

    if args.json:
        # Surface the recovery bundle path in JSON output too — UIs
        # (queue-minisite Force-Start button) want to thread the path
        # through to the next agent's prompt without re-running force-
        # start to fish it out.
        promoted_out = dict(promoted)
        promoted_out["force_started_recovery_bundle_path"] = bundle_path
        promoted_out["force_started_autostopped_peers"] = [
            b["queue_id"] for b in autostop_bundles
        ]
        print(json.dumps(promoted_out, indent=2))
    else:
        print(f"force-started: {args.id} (now running)")
        print(f"  group   : {promoted.get('group_id')}")
        print(f"  scope   : {','.join(promoted.get('scope', []))}")
        print(f"  reason  : {raw_reason}")
        if blockers_overridden:
            print(f"  blockers overridden: {len(blockers_overridden)}")
            for b in blockers_overridden:
                print(
                    f"    - {b['id']} ({b['reason']}; "
                    f"scope={','.join(b.get('scope', []))})"
                )
        else:
            print("  blockers overridden: none "
                  "(item was already ready — force-start was a no-op gate skip)")
        if autostop_bundles:
            print(f"  autostopped running peers: {len(autostop_bundles)}")
            for b in autostop_bundles:
                kill_outcome = b.get("agent_kill_outcome") or {}
                kill_str = (
                    "killed" if kill_outcome.get("ok")
                    else f"kill skipped ({kill_outcome.get('reason') or kill_outcome.get('exit_code')})"
                )
                print(
                    f"    - {b['queue_id']} (agent={b.get('agent_id') or 'n/a'}, "
                    f"{kill_str}; scope={','.join(b.get('scope', []))})"
                )
            if bundle_path:
                print(f"  recovery bundle: {bundle_path}")
                print(
                    "  NOTE: pass this path to the spawned Agent so it can "
                    "triage (resume/integrate/stash/abandon)."
                )
        elif bundle_path:
            print(f"  recovery bundle: {bundle_path} (no peers autostopped)")


def cmd_queue_heartbeat(args):
    """Refresh the liveness timestamp (and optionally PID) on a running item.

    Counterpart to the `last_heartbeat_at` field stamped by `register`.
    Designed to be called periodically by long-running subagents so the
    work-queue-exporter can distinguish "still active" from "abandoned"
    without false-positive orphan alerts.

    Behavior:
      * Item must exist and be in status=running. Anything else exits 1.
      * Default: bumps `last_heartbeat_at` to now and DOES NOT touch `pid`.
        This is the safe path for subagents calling from an ephemeral shell
        — `os.getpid()` would just stamp a soon-dead bash PID and trigger
        the very false-positive this CLI exists to prevent.
      * `--pid <N>` to stamp an explicit owning PID (caller asserts they
        have a real long-lived PID to point at). Bad values are rejected
        rather than falling back to the caller's PID.
      * `--keep-pid` is retained as a no-op alias for backward compatibility
        with the previous default (which DID stamp the caller PID); new
        callers can omit it.

    No pingme / claude-event emissions -- heartbeats are high-frequency by
    design and we don't want to spam the lifecycle bus. The exporter polls
    queue.json every scrape and surfaces both fields as gauges.
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        if target.get("status") != "running":
            print(
                f"heartbeat refused: {args.id} status={target.get('status')!r} "
                f"(must be running)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        now = _fmt_ts()
        target["last_heartbeat_at"] = now
        # Only update `pid` when the caller has explicitly asserted a value.
        # Default (and `--keep-pid`) leave the existing pid alone — never
        # stamp the ephemeral caller-shell PID, which would defeat the
        # purpose of the CLI. Sentinel `--pid 0` CLEARS the pid (back to
        # null) — useful for migrating existing items that were stamped
        # with the now-known-bad ephemeral-shell-PID default before the
        # 2026-05-01 fix.
        if args.pid is not None and not args.keep_pid:
            try:
                pid_int = int(args.pid)
                if pid_int == 0:
                    target["pid"] = None
                else:
                    target["pid"] = pid_int
            except (TypeError, ValueError):
                # Leave existing pid untouched on bad input rather than
                # silently corrupting it.
                pass
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"heartbeat: {args.id} pid={updated.get('pid')} "
            f"last_heartbeat_at={updated.get('last_heartbeat_at')}"
        )


def cmd_queue_wedge(args):
    """Flip a running queue item to status=wedged with a reason.

    Wedged is a transient "in-flight but stuck" state. The item still
    owns its scope (peers cannot grab it via spawn-gating) but is
    flagged distinctly in CLI/exporter/UI so the operator can see the
    wedge at a glance instead of the row sitting indistinguishable from
    a healthy long-runner.

    Two ways to recover:
      * `queue unwedge <id>`  -- back to running (the agent recovered)
      * `queue abandon <id>`  -- operator gives up

    Behavior:
      * Item must exist and be in status=running. Any other status (pending,
        wedged, done, abandoned) refuses.
      * `--reason TEXT` is REQUIRED -- a wedge without a reason defeats
        the operator-attention purpose. Common reasons:
          - "context_limit"       (claude-watch wedged-pane fired)
          - "prolonged-thinking"  (foreground monitor fired)
          - "heartbeat-stale"     (last_heartbeat_at older than threshold)
          - "operator-flag"       (manual: anything else)
      * Stamps `wedged_at` (ISO timestamp), `wedged_reason`. Preserves
        `started_at`, `last_heartbeat_at`, `pid` for post-mortem.
      * Emits a `queue-wedged` claude-event so the main loop / dashboard
        can surface a banner alert.
      * Pingme notification fires by default (this is an attention-
        required event); --silent suppresses it.
    """
    raw_reason = (args.reason or "").strip()
    if not raw_reason:
        print(
            "ERROR: --reason is required for wedge "
            "(common values: context_limit, prolonged-thinking, "
            "heartbeat-stale, operator-flag).",
            file=sys.stderr,
        )
        sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        status = target.get("status")
        if status != "running":
            print(
                f"wedge refused: {args.id} status={status!r} (must be running)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)

        target["status"] = "wedged"
        target["wedged_at"] = _fmt_ts()
        target["wedged_reason"] = raw_reason
        # group_head stays as-is -- a wedged item is still the in-flight
        # head of its group. _recompute_group_heads will confirm.
        _recompute_group_heads(items)
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    log_completed(
        f"[queue {target['id']} WEDGED] {target.get('description','')} "
        f"(reason: {raw_reason})",
        extra={
            "source": "queue",
            "event": "wedge",
            "id": target["id"],
            "group_id": target.get("group_id"),
            "reason": raw_reason,
        },
    )

    # Pingme: wedge IS an attention-required event. High priority so the
    # banner cuts through other notifications.
    _pingme_notify(
        title=f"queue WEDGED: {target['id']}",
        message=(
            f"{_item_summary(target)}\n"
            f"reason: {raw_reason} | "
            f"scope: {','.join(target.get('scope', []))}"
        ),
        priority="high",
        silent=getattr(args, "silent", False),
    )

    # Claude-event emit: queue-wedged. Main loop dashboard / status banner
    # picks this up and surfaces the wedge prominently. Includes
    # queue_id + reason so consumers can format their own banner without
    # round-tripping queue.json.
    _claude_event_notify(
        tag="queue-wedged",
        message=(
            f"queue WEDGED: {target['id']} ({_item_summary(target)}) "
            f"-- reason: {raw_reason}"
        ),
        data={
            "queue_id": target["id"],
            "group_id": target.get("group_id"),
            "scope": target.get("scope", []),
            "summary": _item_summary(target),
            "wedged_reason": raw_reason,
            "wedged_at": target["wedged_at"],
        },
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"wedged: {args.id} reason={raw_reason!r} "
            f"wedged_at={target['wedged_at']}"
        )


def cmd_queue_unwedge(args):
    """Flip a wedged queue item back to status=running.

    Used when the operator (or claude-watch's recovery path) sees the
    agent has recovered from the wedge -- e.g. after a self-clear, after
    Andrew manually pinged the agent and it resumed, or after the
    underlying API issue cleared.

    Behavior:
      * Item must exist and be in status=wedged. Any other status refuses.
      * Flips status=running. Refreshes `last_heartbeat_at` so the
        exporter doesn't immediately re-flag the item as stale.
      * Records `unwedged_at` (ISO timestamp). Preserves `wedged_at` /
        `wedged_reason` on the row for post-mortem -- they are the
        history, not current state.
      * Emits a `queue-unwedged` claude-event so dashboards can clear
        the wedge banner.
      * Pingme is opt-out via --silent (default fires; you want to
        confirm the recovery landed).
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        status = target.get("status")
        if status != "wedged":
            print(
                f"unwedge refused: {args.id} status={status!r} (must be wedged)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)

        prior_reason = target.get("wedged_reason") or "(unspecified)"
        now = _fmt_ts()
        target["status"] = "running"
        target["unwedged_at"] = now
        # Bump heartbeat so the exporter doesn't immediately flag the
        # item as stale right after recovery.
        target["last_heartbeat_at"] = now
        # Intentionally preserve wedged_at + wedged_reason on the row --
        # they are now the audit trail, not current state.
        _recompute_group_heads(items)
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    log_completed(
        f"[queue {target['id']} UNWEDGED] {target.get('description','')}",
        extra={
            "source": "queue",
            "event": "unwedge",
            "id": target["id"],
            "group_id": target.get("group_id"),
            "prior_reason": prior_reason,
        },
    )

    _pingme_notify(
        title=f"queue unwedged: {target['id']}",
        message=(
            f"{_item_summary(target)}\n"
            f"prior reason: {prior_reason} | "
            f"scope: {','.join(target.get('scope', []))}"
        ),
        priority="low",
        silent=getattr(args, "silent", False),
    )

    _claude_event_notify(
        tag="queue-unwedged",
        message=f"queue unwedged: {target['id']} ({_item_summary(target)})",
        data={
            "queue_id": target["id"],
            "group_id": target.get("group_id"),
            "scope": target.get("scope", []),
            "summary": _item_summary(target),
            "prior_reason": prior_reason,
            "unwedged_at": now,
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"unwedged: {args.id} prior_reason={prior_reason!r} "
            f"unwedged_at={now}"
        )


def cmd_queue_block(args):
    """Flip a running queue item to status=blocked with a reason.

    Blocked is a "parked on external blocker" state. The agent has done
    all the work it can autonomously and is waiting on something the
    queue/agent system cannot resolve: a human greenlight, a third-party
    API window, a branch-protection toggle, etc.

    Distinct from `wedged`:
      * `wedged`  -- the system can't progress (stuck agent, context
                     limit, prolonged thinking). Implies action.
      * `blocked` -- the system did its part; an EXTERNAL party needs to
                     do something. No live agent expected.

    Distinct from `running`:
      * `running` -- agent actively working, expected to have a live
                     transcript. The WorkQueueOrphaned alert fires when
                     a running item has no live owner.
      * `blocked` -- no live agent expected by design. Exporter labels
                     this state separately so orphan-detection skips it.

    Recovery:
      * `queue unblock <id>` -- blocked -> running (blocker cleared)
      * `queue done <id>`    -- blocked -> done (work was actually
                                complete, just needed acknowledgement)
      * `queue abandon <id>` -- blocked -> abandoned (operator gives up)

    Behavior:
      * Item must exist and be in status=running. Any other status
        (pending, wedged, blocked, done, abandoned) refuses. Pick a
        coherent state machine: only running -> blocked is supported.
        If you want to express "this item is parked before any work
        starts", use `queue lock <scope>` (real-world-condition locks
        on pending items).
      * `--reason TEXT` is REQUIRED -- a block without a reason defeats
        the operator-attention purpose. Common reasons:
          - "awaiting human greenlight"
          - "awaiting branch-protection toggle"
          - "third-party API rate-limited until $WHEN"
          - "awaiting hardware install"
      * Stamps `blocked_at` (ISO timestamp), `block_reason`. Preserves
        `started_at`, `last_heartbeat_at`, `pid` for post-mortem.
      * Emits a `queue-blocked` claude-event so dashboards / banners can
        surface the block prominently.
      * Pingme notification fires by default; --silent suppresses it.
    """
    raw_reason = (args.reason or "").strip()
    if not raw_reason:
        print(
            "ERROR: --reason is required for block "
            "(common values: 'awaiting human greenlight', "
            "'awaiting branch-protection toggle', "
            "'third-party API rate-limited').",
            file=sys.stderr,
        )
        sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        status = target.get("status")
        if status != "running":
            print(
                f"block refused: {args.id} status={status!r} (must be running)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)

        target["status"] = "blocked"
        target["blocked_at"] = _fmt_ts()
        target["block_reason"] = raw_reason
        # group_head stays as-is -- a blocked item is still the in-flight
        # head of its group. _recompute_group_heads will confirm.
        _recompute_group_heads(items)
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    log_completed(
        f"[queue {target['id']} BLOCKED] {target.get('description','')} "
        f"(reason: {raw_reason})",
        extra={
            "source": "queue",
            "event": "block",
            "id": target["id"],
            "group_id": target.get("group_id"),
            "reason": raw_reason,
        },
    )

    # Pingme: block IS an attention-required event (an external party
    # needs to do something). Normal priority -- distinct from a wedge
    # which is "system broken, fix me NOW".
    _pingme_notify(
        title=f"queue BLOCKED: {target['id']}",
        message=(
            f"{_item_summary(target)}\n"
            f"reason: {raw_reason} | "
            f"scope: {','.join(target.get('scope', []))}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event emit: queue-blocked. Dashboards / status banner can
    # surface the block; the main loop can route the event to the
    # appropriate "ping the operator" handler.
    _claude_event_notify(
        tag="queue-blocked",
        message=(
            f"queue BLOCKED: {target['id']} ({_item_summary(target)}) "
            f"-- reason: {raw_reason}"
        ),
        data={
            "queue_id": target["id"],
            "group_id": target.get("group_id"),
            "scope": target.get("scope", []),
            "summary": _item_summary(target),
            "block_reason": raw_reason,
            "blocked_at": target["blocked_at"],
        },
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"blocked: {args.id} reason={raw_reason!r} "
            f"blocked_at={target['blocked_at']}"
        )


def cmd_queue_unblock(args):
    """Flip a blocked queue item back to status=running.

    Used when the external blocker clears -- Andrew greenlit, the
    branch-protection toggle landed, the third-party API window opened,
    etc. The agent (or a fresh agent registered against this id) can
    resume work.

    Behavior:
      * Item must exist and be in status=blocked. Any other status
        refuses.
      * Flips status=running. Refreshes `last_heartbeat_at` so the
        exporter doesn't immediately re-flag the item as stale.
      * Records `unblocked_at` (ISO timestamp). Preserves `blocked_at` /
        `block_reason` on the row for post-mortem -- they are now the
        audit trail, not current state.
      * Emits a `queue-unblocked` claude-event so dashboards can clear
        the block banner.
      * Pingme is opt-out via --silent (default fires; you want to
        confirm the recovery landed).
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        status = target.get("status")
        if status != "blocked":
            print(
                f"unblock refused: {args.id} status={status!r} (must be blocked)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)

        prior_reason = target.get("block_reason") or "(unspecified)"
        now = _fmt_ts()
        target["status"] = "running"
        target["unblocked_at"] = now
        target["last_heartbeat_at"] = now
        # Intentionally preserve blocked_at + block_reason on the row --
        # they are now the audit trail, not current state.
        _recompute_group_heads(items)
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    log_completed(
        f"[queue {target['id']} UNBLOCKED] {target.get('description','')}",
        extra={
            "source": "queue",
            "event": "unblock",
            "id": target["id"],
            "group_id": target.get("group_id"),
            "prior_reason": prior_reason,
        },
    )

    _pingme_notify(
        title=f"queue unblocked: {target['id']}",
        message=(
            f"{_item_summary(target)}\n"
            f"prior reason: {prior_reason} | "
            f"scope: {','.join(target.get('scope', []))}"
        ),
        priority="low",
        silent=getattr(args, "silent", False),
    )

    _claude_event_notify(
        tag="queue-unblocked",
        message=f"queue unblocked: {target['id']} ({_item_summary(target)})",
        data={
            "queue_id": target["id"],
            "group_id": target.get("group_id"),
            "scope": target.get("scope", []),
            "summary": _item_summary(target),
            "prior_reason": prior_reason,
            "unblocked_at": now,
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"unblocked: {args.id} prior_reason={prior_reason!r} "
            f"unblocked_at={now}"
        )


