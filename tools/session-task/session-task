def build_parser():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command")

    # Layer 1 (single-slot resume action)
    p_set = sub.add_parser("set", help="Set a resume action")
    p_set.add_argument("description", help="What to do on resume")
    p_set.add_argument("--context", "-c", help="JSON context/state")

    p_append = sub.add_parser("append", help="Append to existing action")
    p_append.add_argument("text", help="Text to append")

    sub.add_parser("get", help="Print as JSON (silent if empty)")
    sub.add_parser("show", help="Pretty-print current action")
    sub.add_parser("clear", help="Mark done and remove")
    sub.add_parser("banner", help="Output for session-resume (internal)")

    p_complete = sub.add_parser("complete", help="Log a completed task")
    p_complete.add_argument("description", help="What was completed")

    p_history = sub.add_parser("history", help="Show last N completed tasks")
    p_history.add_argument("-n", "--count", type=int, default=10)
    p_history.add_argument(
        "--since",
        help="Filter to entries newer than this duration (e.g. 1h, 24h, 7d)",
    )
    p_history.add_argument(
        "--layer",
        choices=["resume", "queue", "all"],
        default="all",
        help="Filter by layer (resume=single-slot, queue=queue items, all=both)",
    )
    p_history.add_argument(
        "--no-scope", action="store_true",
        help="Do not append scope line under queue entries",
    )
    p_history_raw = sub.add_parser(
        "history-raw", help="Raw output for session-resume (internal)"
    )
    p_history_raw.add_argument(
        "--since", default="7d",
        help="Time window for history-raw (default: 7d)",
    )
    p_history_raw.add_argument(
        "--n-resume", type=int, default=5,
        help="Max resume-action entries to show (default: 5)",
    )
    p_history_raw.add_argument(
        "--n-queue", type=int, default=5,
        help="Max queue completion entries to show (default: 5)",
    )

    # Layer 2 (queue)
    p_queue = sub.add_parser("queue", help="Task queue with scope-based groups")
    qsub = p_queue.add_subparsers(dest="qcmd")

    q_add = qsub.add_parser("add", help="Add item")
    q_add.add_argument("description")
    q_add.add_argument("--scope", action="append", required=True)
    q_add.add_argument(
        "--summary",
        help=(
            "One-line (~10 word) human-readable headline. Surfaces verbatim "
            "in pingme queue-started/done/abandoned notifications. "
            "Soft-required: omitting it prints a stderr warning and the "
            "pingme message reads '(no summary)'. Use `queue set-summary "
            "<id> \"text\"` to add one after the fact."
        ),
    )
    q_add.add_argument("--priority", type=int, default=5)
    q_add.add_argument("--context")
    q_add.add_argument("--created-by")
    q_add.add_argument(
        "--depends-on",
        action="append",
        default=[],
        help=(
            "Queue id(s) this new item is blocked on. Adjacency-set storage "
            "(no transitive closure). Each dep must be a known queue id at "
            "add time; ready_now flips True only when every dep is 'done'. "
            "Comma-separated values and repeated flags both work."
        ),
    )
    q_add.add_argument("--json", action="store_true")
    q_add.add_argument(
        "--force-enqueue",
        action="store_true",
        help=(
            "Bypass the hard-fail scope-conflict check and enqueue anyway. "
            "The new item is still blocked behind the running item(s) for "
            "spawn purposes (register/spawn-check will refuse), but it will "
            "be recorded in the queue. Use ONLY when intentionally queueing "
            "follow-up work that must serialize after running work."
        ),
    )

    q_list = qsub.add_parser("list", help="List items (default: pending+running)")
    q_list.add_argument("--ready", action="store_true")
    q_list.add_argument("--all", action="store_true")
    q_list.add_argument("--group")
    q_list.add_argument("--json", action="store_true")

    q_show = qsub.add_parser("show", help="Show item details")
    q_show.add_argument("id")

    q_scope = qsub.add_parser("scope", help="Print an item's scope")
    q_scope.add_argument("id")

    q_groups = qsub.add_parser("groups", help="List active groups")
    q_groups.add_argument("--json", action="store_true")

    q_ready = qsub.add_parser("ready", help="Items ready to start")
    q_ready.add_argument("--json", action="store_true")

    q_done = qsub.add_parser("done", help="Mark item done")
    q_done.add_argument("id")
    q_done.add_argument(
        "--silent", action="store_true",
        help="Suppress the pingme lifecycle notification for this operation.",
    )

    q_abandon = qsub.add_parser("abandon", help="Mark item abandoned")
    q_abandon.add_argument("id")
    q_abandon.add_argument("--reason")
    q_abandon.add_argument(
        "--silent", action="store_true",
        help="Suppress the pingme lifecycle notification for this operation.",
    )

    q_pop = qsub.add_parser("pop", help="Atomically take next ready item")
    q_pop.add_argument("--id")

    q_register = qsub.add_parser(
        "register",
        help=("Atomically claim an item as running before spawning an agent. "
              "Refuses if another running item has overlapping scope."),
    )
    q_register.add_argument("id")
    q_register.add_argument("--if-absent", action="store_true",
                            help="Do not fail if the item is already running.")
    q_register.add_argument("--note",
                            help="Freeform note (e.g. spawned agent id) recorded on the item.")
    q_register.add_argument("--json", action="store_true")
    q_register.add_argument(
        "--pid",
        type=int,
        default=None,
        help=(
            "Owning process PID to stamp on the item. DEFAULT: unset — pid is "
            "deferred and the work-queue-exporter trusts the item alive while "
            "its `last_heartbeat_at` is within HEARTBEAT_GRACE_SECONDS (5min). "
            "Pass an explicit PID only when you have a long-lived process to "
            "point at; the caller's own PID is usually an ephemeral shell and "
            "stamping it triggers a false-positive WorkQueueOrphaned alert "
            "(the bug fixed 2026-05-01)."
        ),
    )
    q_register.add_argument(
        "--silent", action="store_true",
        help="Suppress the pingme lifecycle notification for this operation.",
    )

    q_heartbeat = qsub.add_parser(
        "heartbeat",
        help=(
            "Refresh last_heartbeat_at on a running item; optionally update the "
            "owning PID. Subagents call this periodically so a wedged-but-alive "
            "owner is distinguishable from a healthy long-runner."
        ),
    )
    q_heartbeat.add_argument("id")
    q_heartbeat.add_argument(
        "--pid",
        type=int,
        default=None,
        help=(
            "Stamp an explicit owning PID. OMIT to leave pid unchanged "
            "(the safe default — the caller's own PID is usually an "
            "ephemeral shell and stamping it triggers false-positive "
            "WorkQueueOrphaned alerts). Sentinel `--pid 0` CLEARS the "
            "pid (back to null) so the exporter falls through to "
            "heartbeat-grace evaluation — useful for migrating items "
            "stamped with a now-known-bad ephemeral PID."
        ),
    )
    q_heartbeat.add_argument(
        "--keep-pid",
        action="store_true",
        help=(
            "Backward-compat no-op: leave pid untouched. As of 2026-05-01 "
            "this is the default; flag retained so existing scripts keep "
            "working without semantic change."
        ),
    )
    q_heartbeat.add_argument("--json", action="store_true")

    q_spawn = qsub.add_parser(
        "spawn-check",
        help=("Check whether it is safe to spawn an agent for this item. "
              "Exit 0 = ok, 1 = conflict, 2 = not found."),
    )
    q_spawn.add_argument("id")
    q_spawn.add_argument("--json", action="store_true")

    q_force_start = qsub.add_parser(
        "force-start",
        help=(
            "Manually promote a pending item to running, bypassing scope-"
            "conflict serialization. AUDITABLE: --reason is required and the "
            "override is appended to ~/.config/claude/queue-force-start.log."
        ),
    )
    q_force_start.add_argument("id")
    q_force_start.add_argument(
        "--reason",
        required=True,
        help=(
            "Why are you overriding scope serialization? Recorded on the item "
            "as `force_started_reason` and appended to the audit log."
        ),
    )
    q_force_start.add_argument("--json", action="store_true")
    q_force_start.add_argument(
        "--silent", action="store_true",
        help="Suppress the pingme lifecycle notification for this operation.",
    )

    q_promote = qsub.add_parser("promote", help="Bump item priority to group head")
    q_promote.add_argument("id")

    q_setsum = qsub.add_parser(
        "set-summary",
        help=("Add / replace the one-line summary on an existing item. "
              "Useful for legacy items missing a summary or for typo fixes."),
    )
    q_setsum.add_argument("id")
    q_setsum.add_argument("summary", help="New summary text (~10 words)")

    q_depend = qsub.add_parser(
        "depend",
        help=(
            "Edit explicit interjob dependencies on a queue item. "
            "depends_on is an adjacency set of queue ids; ready_now flips "
            "True only when every dep is in 'done' state. "
            "Cross-group deps allowed."
        ),
    )
    q_depend.add_argument("id")
    q_depend.add_argument(
        "--add",
        action="append",
        default=[],
        help=(
            "Queue id(s) to add as dependencies. Comma-separated values "
            "and repeated --add flags both work."
        ),
    )
    q_depend.add_argument(
        "--remove",
        action="append",
        default=[],
        help=(
            "Queue id(s) to remove from depends_on. Comma-separated values "
            "and repeated --remove flags both work."
        ),
    )
    q_depend.add_argument(
        "--clear",
        action="store_true",
        help="Remove ALL deps from this item (applied before --add).",
    )
    q_depend.add_argument("--json", action="store_true")

    q_prune = qsub.add_parser("prune", help="Remove done/abandoned items")
    q_prune.add_argument("--older-than", help="e.g. 7d, 24h, 30m")
    q_prune.add_argument("-n", "--dry-run", action="store_true")

    qsub.add_parser("banner", help="Top-5 ready items banner")

    q_mig = qsub.add_parser("migrate", help="Parse legacy /tmp/claude-queued-tasks.txt")
    q_mig.add_argument("--from", dest="from_file", required=True)
    q_mig.add_argument("--yes", action="store_true")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "set":
        return cmd_set(args)
    if args.command == "append":
        return cmd_append(args)
    if args.command == "get":
        return cmd_get(args)
    if args.command == "show":
        return cmd_show(args)
    if args.command == "clear":
        return cmd_clear(args)
    if args.command == "banner":
        banner = for_session_resume()
        if banner:
            print(banner)
        return
    if args.command == "complete":
        return cmd_complete(args)
    if args.command == "history":
        return cmd_history(args)
    if args.command == "history-raw":
        print(for_session_resume_history(
            n_resume=args.n_resume,
            n_queue=args.n_queue,
            since=args.since,
        ))
        return
    if args.command == "queue":
        qmap = {
            "add": cmd_queue_add,
            "list": cmd_queue_list,
            "show": cmd_queue_show,
            "scope": cmd_queue_scope,
            "groups": cmd_queue_groups,
            "ready": cmd_queue_ready,
            "done": cmd_queue_done,
            "abandon": cmd_queue_abandon,
            "pop": cmd_queue_pop,
            "register": cmd_queue_register,
            "heartbeat": cmd_queue_heartbeat,
            "spawn-check": cmd_queue_spawn_check,
            "force-start": cmd_queue_force_start,
            "promote": cmd_queue_promote,
            "set-summary": cmd_queue_set_summary,
            "depend": cmd_queue_depend,
            "prune": cmd_queue_prune,
            "banner": cmd_queue_banner,
            "migrate": cmd_queue_migrate,
        }
        fn = qmap.get(args.qcmd)
        if fn is None:
            parser.parse_args(["queue", "--help"])
            sys.exit(1)
        return fn(args)

    parser.print_help()
    sys.exit(1)


if __name__ == "__main__":
    main()
