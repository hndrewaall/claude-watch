def cmd_queue_done(args):
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        if target["status"] == "done":
            print(f"already done: {args.id}")
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            return
        started_at = target.get("started_at")
        target["status"] = "done"
        target["completed_at"] = _fmt_ts()
        target["group_head"] = False
        # Archive the spawning subagent's transcript (or workload output,
        # for workload-bound items) while we still have the lock. Best-
        # effort: failures don't block the done transition. The path
        # lands on the item as `log_archive_path` so a queue viewer UI
        # can offer a "View log" affordance on Done entries.
        archive_path = _archive_for_item(target, reason="done")
        if archive_path:
            target["log_archive_path"] = archive_path
        _recompute_group_heads(items)
        next_head = _group_head(items, target["group_id"])
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    log_completed(
        f"[queue {target['id']}] {target['description']}",
        extra={
            "source": "queue",
            "id": target["id"],
            "group_id": target["group_id"],
        },
    )

    # Lifecycle notification: task completion (success). Never blocks.
    # Summary on line 1 (Pushover preview), elapsed/scope on line 2.
    elapsed = _elapsed_minutes(started_at)
    elapsed_sec = _elapsed_seconds(started_at)
    elapsed_str = f"{elapsed}m" if elapsed is not None else "unknown"
    _pingme_notify(
        title=f"queue done: {target['id']}",
        message=(
            f"{_item_summary(target)}\n"
            f"elapsed: {elapsed_str} "
            f"| scope: {','.join(target.get('scope', []))}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event lifecycle emit: queue-done. Main loop handler checks the
    # group for newly-unblocked next-in-group items and may spawn them.
    _claude_event_notify(
        tag="queue-done",
        message=f"queue done: {target['id']} ({_item_summary(target)})",
        data={
            "queue_id": target["id"],
            "group_id": target["group_id"],
            "scope": target.get("scope", []),
            "summary": _item_summary(target),
            "elapsed_sec": elapsed_sec,
            "created_by": target.get("created_by", ""),
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    print(f"done: {args.id}")
    if next_head:
        print(f"next in group {target['group_id']}: {next_head['id']} ({next_head['description'][:60]})")
    else:
        print(f"group {target['group_id']} is now empty")


