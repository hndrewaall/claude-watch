def cmd_queue_register(args):
    """Atomically claim a pending item as running (spawn-gating entry point).

    Refuses if:
      * item does not exist
      * item is not pending (already running/done/abandoned)
      * item is not the ready head of its group (blocked on a peer)
      * any OTHER running item's scope overlaps this item's scope
        (cross-group conflict -- indicates an unregistered in-flight agent
        the main loop is responsible for)

    This is the single source of truth for "is this agent allowed to spawn
    right now". The main loop MUST call register before invoking the Agent
    tool; an unregistered spawn is an operating-rules violation.
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: QUEUE ITEM {args.id!r} NOT FOUND.",
                  file=sys.stderr)
            print("!! DO NOT SPAWN ANY AGENT. THE QUEUE HAS NO RECORD OF THIS WORK.",
                  file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        if target.get("status") == "running":
            # Idempotent-ish: re-registering something that's already running
            # is fine if --if-absent, but default refuses so the caller
            # notices double-register.
            if args.if_absent:
                print(f"already running: {args.id}")
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                return
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS ALREADY RUNNING.",
                  file=sys.stderr)
            print("!! DOUBLE-SPAWN DETECTED. DO NOT SPAWN ANOTHER AGENT.",
                  file=sys.stderr)
            print("!! IF THE ORIGINAL AGENT DIED, MARK IT ABANDONED FIRST:",
                  file=sys.stderr)
            print(f"!!   session-task queue abandon {args.id} --reason '...'",
                  file=sys.stderr)
            print("!! OR USE --if-absent TO NO-OP WHEN THE ITEM IS ALREADY RUNNING.",
                  file=sys.stderr)
            print(bar, file=sys.stderr)
            sys.exit(2)

        ok, reasons, conflicts = _spawn_check(items, target)
        if not ok:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! REGISTER REFUSED: {args.id} IS NOT CLEAR TO SPAWN.",
                  file=sys.stderr)
            print("!! DO NOT SPAWN ANY AGENT FOR THIS WORK.", file=sys.stderr)
            print("!! RUN THE CONFLICTING WORK FIRST OR WAIT FOR IT TO FINISH.",
                  file=sys.stderr)
            print("!!", file=sys.stderr)
            print(f"!! ITEM  : {args.id} (status={target.get('status')}, "
                  f"group={target.get('group_id')})", file=sys.stderr)
            print(f"!! SCOPE : {','.join(target.get('scope', []))}",
                  file=sys.stderr)
            print("!! REASONS:", file=sys.stderr)
            for r in reasons:
                print(f"!!   - {r}", file=sys.stderr)
            if conflicts:
                print("!! RUNNING SCOPE OVERLAPS:", file=sys.stderr)
                for c in conflicts:
                    print(
                        f"!!   - {c['id']} (group {c.get('group_id')}): "
                        f"{','.join(c.get('scope', []))}",
                        file=sys.stderr,
                    )
            print(bar, file=sys.stderr)
            sys.exit(2)

        target["status"] = "running"
        target["started_at"] = _fmt_ts()
        target["registered_at"] = target["started_at"]
        # Liveness telemetry (added 2026-05-01, revised same day).
        #
        # `pid` is OPTIONAL and defaults to None (deferred PID stamping). Why:
        # `register` is overwhelmingly invoked from a shell wrapper inside the
        # main loop, and that shell is ephemeral — `os.getpid()` returns the
        # bash subshell PID, which exits within seconds, so any /proc-based
        # liveness check immediately sees a dead PID and fires a false-
        # positive WorkQueueOrphaned alert (the bug fixed here). Pass
        # `--pid N` explicitly when the caller actually has a long-lived PID
        # to stamp (e.g. a wrapper that fork+execs the agent and knows the
        # child PID). Subagents typically don't either — they live inside an
        # LLM context, not a single OS process — so they should heartbeat
        # against `last_heartbeat_at` instead of trying to claim a PID.
        #
        # `last_heartbeat_at` is initialized to started_at. The exporter
        # treats pid=None items as "trusted alive" while their heartbeat age
        # is within HEARTBEAT_GRACE_SECONDS (default 300s); subagents call
        # `queue heartbeat <id>` periodically to refresh that timestamp.
        # Once heartbeat age exceeds the grace window, the exporter flips
        # has_live_owner to 0 and WorkQueueOrphaned fires.
        if args.pid is not None:
            try:
                target["pid"] = int(args.pid)
            except (TypeError, ValueError):
                # Bad explicit --pid value — leave unstamped rather than
                # silently fall back to the caller's ephemeral PID.
                target["pid"] = None
        else:
            target["pid"] = None
        target["last_heartbeat_at"] = target["started_at"]
        if args.note:
            target.setdefault("register_notes", []).append({
                "at": target["started_at"],
                "note": args.note,
            })
        _recompute_group_heads(items)
        registered = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    # Lifecycle notification: task start. Never blocks the register op.
    # Summary goes on the first line so it's the Pushover preview text;
    # scope/priority follow as secondary context.
    _pingme_notify(
        title=f"queue started: {registered['id']}",
        message=(
            f"{_item_summary(registered)}\n"
            f"scope: {','.join(registered.get('scope', []))} "
            f"| priority: {registered.get('priority', 5)}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event lifecycle emit: queue-running. Informational — lets the
    # main loop see transitions without having to poll queue.json.
    _claude_event_notify(
        tag="queue-running",
        message=f"queue running: {registered['id']} ({_item_summary(registered)})",
        data={
            "queue_id": registered["id"],
            "group_id": registered.get("group_id"),
            "scope": registered.get("scope", []),
            "summary": _item_summary(registered),
            "created_by": registered.get("created_by", ""),
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(registered, indent=2))
    else:
        print(f"registered: {args.id} (now running)")
        print(f"  group : {registered.get('group_id')}")
        print(f"  scope : {','.join(registered.get('scope', []))}")
        print("  next  : spawn the agent. call `queue done` when it finishes.")


def cmd_queue_force_start(args):
    """Atomically promote a pending item to running, bypassing scope blockers.

    This is the manual override for the spawn-gate's serialization rules.
    Use ONLY when an operator has consciously decided to override scope-
    conflict serialization — e.g. because the running blocker is wedged,
    or because the work genuinely is independent and the scope tokens
    were mis-set.

    Refuses if:
      * --reason is missing or empty (force-start is auditable; an
        unattributed override defeats the audit log).
      * the item does not exist.
      * the item is not in status=pending (already running, done, or
        abandoned items can't be force-started).

    On success:
      * status flips to running, started_at + registered_at + heartbeat
        are stamped (same as `register`).
      * `force_started_at` (epoch seconds, unix int) and
        `force_started_reason` are written to the queue record so the
        item carries its own provenance.
      * `force_started_blockers_overridden` is the list of running
        items whose scope overlapped this one (the conflicts that the
        normal register path would have refused on).
      * an audit row is appended to QUEUE_FORCE_START_LOG.
      * a `queue-running` claude-event is emitted with
        force_started=true so downstream consumers can distinguish the
        override path from a normal register.

    Same atomic flock-on-queue.json discipline as register/done.
    """
    raw_reason = (args.reason or "").strip()
    if not raw_reason:
        print(
            "ERROR: --reason is required for force-start (override is auditable).",
            file=sys.stderr,
        )
        sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                f"ERROR: queue item {args.id!r} not found.",
                file=sys.stderr,
            )
            sys.exit(1)

        status = target.get("status")
        if status != "pending":
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                f"ERROR: force-start refused: {args.id} status={status!r} "
                f"(must be pending; running/done/abandoned items cannot be "
                f"force-started).",
                file=sys.stderr,
            )
            sys.exit(1)

        # Capture the blockers we are overriding so the audit log + queue
        # record carry the provenance. We do NOT bail on overlaps — that's
        # the entire point of force-start.
        scope = target.get("scope", [])
        gid = target.get("group_id")
        cross_blockers = _running_scope_conflicts(
            items, scope, exclude_id=target.get("id"),
        )
        # Same-group not-yet-running peers (the FIFO blockers within this
        # group) — they don't strictly "conflict" via overlapping scope
        # but they do block readiness. Captured for the audit log.
        same_group_pending_peers = [
            it for it in items
            if it.get("group_id") == gid
            and it.get("id") != target.get("id")
            and it.get("status") == "pending"
        ]

        blockers_overridden = []
        for c in cross_blockers:
            blockers_overridden.append({
                "id": c["id"],
                "group_id": c.get("group_id"),
                "status": c.get("status"),
                "scope": c.get("scope", []),
                "reason": "running scope overlap",
            })
        for p in same_group_pending_peers:
            blockers_overridden.append({
                "id": p["id"],
                "group_id": p.get("group_id"),
                "status": p.get("status"),
                "scope": p.get("scope", []),
                "reason": "same-group pending peer (FIFO blocker)",
            })

        now_iso = _fmt_ts()
        target["status"] = "running"
        target["started_at"] = now_iso
        target["registered_at"] = now_iso
        target["last_heartbeat_at"] = now_iso
        target["pid"] = None  # ephemeral-shell PID is not useful here
        target["force_started_at"] = int(datetime.now(timezone.utc).timestamp())
        target["force_started_reason"] = raw_reason
        target["force_started_blockers_overridden"] = blockers_overridden

        _recompute_group_heads(items)
        promoted = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    # Audit log: append a JSONL row. Best-effort — never block the
    # promotion on a log write failure.
    try:
        QUEUE_FORCE_START_LOG.parent.mkdir(parents=True, exist_ok=True)
        audit_row = {
            "timestamp": promoted["force_started_at"],
            "timestamp_iso": now_iso,
            "queue_id": promoted["id"],
            "reason": raw_reason,
            "scope": promoted.get("scope", []),
            "group_id": promoted.get("group_id"),
            "summary": _item_summary(promoted),
            "blockers_overridden": blockers_overridden,
        }
        with open(QUEUE_FORCE_START_LOG, "a") as logf:
            logf.write(json.dumps(audit_row) + "\n")
    except OSError as exc:
        print(
            f"WARNING: failed to append to {QUEUE_FORCE_START_LOG}: {exc}",
            file=sys.stderr,
        )

    # Lifecycle pingme — same shape as register, with the override called
    # out so it's visually distinct in the notification stream.
    _pingme_notify(
        title=f"queue force-started: {promoted['id']}",
        message=(
            f"{_item_summary(promoted)}\n"
            f"scope: {','.join(promoted.get('scope', []))} "
            f"| priority: {promoted.get('priority', 5)}\n"
            f"force-started, blockers overridden: {len(blockers_overridden)}\n"
            f"reason: {raw_reason}"
        ),
        priority="normal",
        silent=getattr(args, "silent", False),
    )

    # Claude-event emit: queue-running with force_started=true so consumers
    # can branch on the override path (alerting, exporter labels, etc.).
    _claude_event_notify(
        tag="queue-running",
        message=(
            f"queue running (force-started): {promoted['id']} "
            f"({_item_summary(promoted)})"
        ),
        data={
            "queue_id": promoted["id"],
            "group_id": promoted.get("group_id"),
            "scope": promoted.get("scope", []),
            "summary": _item_summary(promoted),
            "created_by": promoted.get("created_by", ""),
            "force_started": True,
            "force_started_reason": raw_reason,
            "force_started_blockers_overridden": [
                b["id"] for b in blockers_overridden
            ],
        },
        priority="low",
        silent=getattr(args, "silent", False),
    )

    if args.json:
        print(json.dumps(promoted, indent=2))
    else:
        print(f"force-started: {args.id} (now running)")
        print(f"  group   : {promoted.get('group_id')}")
        print(f"  scope   : {','.join(promoted.get('scope', []))}")
        print(f"  reason  : {raw_reason}")
        if blockers_overridden:
            print(f"  blockers overridden: {len(blockers_overridden)}")
            for b in blockers_overridden:
                print(
                    f"    - {b['id']} ({b['reason']}; "
                    f"scope={','.join(b.get('scope', []))})"
                )
        else:
            print("  blockers overridden: none "
                  "(item was already ready — force-start was a no-op gate skip)")


def cmd_queue_heartbeat(args):
    """Refresh the liveness timestamp (and optionally PID) on a running item.

    Counterpart to the `last_heartbeat_at` field stamped by `register`.
    Designed to be called periodically by long-running subagents so the
    work-queue-exporter can distinguish "still active" from "abandoned"
    without false-positive orphan alerts.

    Behavior:
      * Item must exist and be in status=running. Anything else exits 1.
      * Default: bumps `last_heartbeat_at` to now and DOES NOT touch `pid`.
        This is the safe path for subagents calling from an ephemeral shell
        — `os.getpid()` would just stamp a soon-dead bash PID and trigger
        the very false-positive this CLI exists to prevent.
      * `--pid <N>` to stamp an explicit owning PID (caller asserts they
        have a real long-lived PID to point at). Bad values are rejected
        rather than falling back to the caller's PID.
      * `--keep-pid` is retained as a no-op alias for backward compatibility
        with the previous default (which DID stamp the caller PID); new
        callers can omit it.

    No pingme / claude-event emissions -- heartbeats are high-frequency by
    design and we don't want to spam the lifecycle bus. The exporter polls
    queue.json every scrape and surfaces both fields as gauges.
    """
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        if target.get("status") != "running":
            print(
                f"heartbeat refused: {args.id} status={target.get('status')!r} "
                f"(must be running)",
                file=sys.stderr,
            )
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        now = _fmt_ts()
        target["last_heartbeat_at"] = now
        # Only update `pid` when the caller has explicitly asserted a value.
        # Default (and `--keep-pid`) leave the existing pid alone — never
        # stamp the ephemeral caller-shell PID, which would defeat the
        # purpose of the CLI. Sentinel `--pid 0` CLEARS the pid (back to
        # null) — useful for migrating existing items that were stamped
        # with the now-known-bad ephemeral-shell-PID default before the
        # 2026-05-01 fix.
        if args.pid is not None and not args.keep_pid:
            try:
                pid_int = int(args.pid)
                if pid_int == 0:
                    target["pid"] = None
                else:
                    target["pid"] = pid_int
            except (TypeError, ValueError):
                # Leave existing pid untouched on bad input rather than
                # silently corrupting it.
                pass
        updated = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise

    if args.json:
        print(json.dumps(updated, indent=2))
    else:
        print(
            f"heartbeat: {args.id} pid={updated.get('pid')} "
            f"last_heartbeat_at={updated.get('last_heartbeat_at')}"
        )


