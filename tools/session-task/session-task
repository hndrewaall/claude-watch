    )
    q_unlock.add_argument("scope", help="Scope token to unlock")
    q_unlock.add_argument("--json", action="store_true")

    q_locks = qsub.add_parser(
        "locks",
        help="List currently locked scopes with reason, lock timestamp, and held-item count.",
    )
    q_locks.add_argument("--json", action="store_true")

    q_mig = qsub.add_parser("migrate", help="Parse legacy /tmp/claude-queued-tasks.txt")
    q_mig.add_argument("--from", dest="from_file", required=True)
    q_mig.add_argument("--yes", action="store_true")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "set":
        return cmd_set(args)
    if args.command == "append":
        return cmd_append(args)
    if args.command == "get":
        return cmd_get(args)
    if args.command == "show":
        return cmd_show(args)
    if args.command == "clear":
        return cmd_clear(args)
    if args.command == "banner":
        banner = for_session_resume()
        if banner:
            print(banner)
        return
    if args.command == "complete":
        return cmd_complete(args)
    if args.command == "history":
        return cmd_history(args)
    if args.command == "history-raw":
        print(for_session_resume_history(
            n_resume=args.n_resume,
            n_queue=args.n_queue,
            since=args.since,
        ))
        return
    if args.command == "queue":
        qmap = {
            "add": cmd_queue_add,
            "list": cmd_queue_list,
            "show": cmd_queue_show,
            "scope": cmd_queue_scope,
            "groups": cmd_queue_groups,
            "ready": cmd_queue_ready,
            "done": cmd_queue_done,
            "abandon": cmd_queue_abandon,
            "pop": cmd_queue_pop,
            "register": cmd_queue_register,
            "heartbeat": cmd_queue_heartbeat,
            "wedge": cmd_queue_wedge,
            "unwedge": cmd_queue_unwedge,
            "block": cmd_queue_block,
            "unblock": cmd_queue_unblock,
            "spawn-check": cmd_queue_spawn_check,
            "force-start": cmd_queue_force_start,
            "promote": cmd_queue_promote,
            "set-summary": cmd_queue_set_summary,
            "depend": cmd_queue_depend,
            "prune": cmd_queue_prune,
            "banner": cmd_queue_banner,
            "lock": cmd_queue_lock,
            "unlock": cmd_queue_unlock,
            "locks": cmd_queue_locks,
            "migrate": cmd_queue_migrate,
        }
        fn = qmap.get(args.qcmd)
        if fn is None:
            parser.parse_args(["queue", "--help"])
            sys.exit(1)
        return fn(args)

    parser.print_help()
    sys.exit(1)


if __name__ == "__main__":
    main()
