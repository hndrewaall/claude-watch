            "stuck) -- blocked means the system did its part and waits on "
            "someone else. The exporter labels this state separately so the "
            "WorkQueueOrphaned alert (which fires on running-without-owner) "
            "does NOT fire on blocked items. Recover via `unblock`, `done`, "
            "or `abandon`."
        ),
    )
    q_block.add_argument("id")
    q_block.add_argument(
        "--reason",
        required=True,
        help=(
            "Why is the agent blocked? Common values: 'awaiting human "
            "greenlight', 'awaiting branch-protection toggle', "
