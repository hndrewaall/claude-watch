import sys
from datetime import datetime, timedelta, timezone
from pathlib import Path

TASK_FILE = Path.home() / ".config" / "session" / "resume-action.json"
COMPLETED_FILE = Path.home() / ".config" / "session" / "completed-tasks.jsonl"
QUEUE_FILE = Path.home() / ".config" / "session" / "queue.json"
QUEUE_SCHEMA_VERSION = 2

# Queue item lifecycle states:
#   pending    -- created but not yet claimed by a running agent
#   running    -- claimed (via `register`) and actively being worked
#   wedged     -- was running but the owning agent is stuck (context-limit /
#                 prolonged-thinking / heartbeat-stale). Still owns its scope
#                 (peers cannot spawn into the same scope) but is flagged
#                 distinctly in CLI/exporter/UI so the operator can see the
#                 wedge without scrolling logs. Set via `queue wedge <id>
#                 --reason ...`. Cleared via `queue unwedge <id>` (back to
#                 running) or `queue abandon <id>` (operator gives up).
#   blocked    -- the agent has done all the work it can autonomously and is
#                 waiting on an EXTERNAL blocker (human greenlight,
#                 third-party API, branch-protection toggle, etc.). NOT the
#                 same as wedged (which is for items the system can't progress
#                 through code/state-machine issues). Still owns its scope
#                 so peers can't grab it. Distinguished from running in the
#                 exporter so the WorkQueueOrphaned alert (which fires on
#                 "running without live agent") does NOT fire on blocked
#                 items -- by design, blocked items have no live agent.
#                 Set via `queue block <id> --reason ...`. Cleared via
#                 `queue unblock <id>` (back to running), `queue done <id>`
#                 (work was actually complete) or `queue abandon <id>`.
#   done       -- terminal: completed successfully
#   abandoned  -- terminal: gave up (with optional reason)
#
# `ACTIVE_STATUSES` is the canonical "in-flight" set used by serialization
# and spawn-gating. `RUNNING_STATUSES` is the subset that owns a slot
# (running, wedged, OR blocked); wedged is included precisely because a wedge
# is transient and the agent still holds the scope. Blocked is included
# because the queue item is still parked on its scope until the external
# blocker resolves -- letting a peer grab the scope would race the unblock.
ACTIVE_STATUSES = ("pending", "running", "wedged", "blocked")
RUNNING_STATUSES = ("running", "wedged", "blocked")

