def _infer_scope_from_text(text):
    """Heuristic scope inference for legacy /tmp/claude-queued-tasks.txt."""
    t = text.lower()
    scope = []

    # agent-proto: mentions
    proto_map = {
        "ebook-convert-pdf": "agent-proto:ebook-convert-pdf",
        "em-dash": "agent-proto:ebook-convert-pdf",
        "chapter-breaks": "agent-proto:ebook-convert-pdf",
        "epub-check-breaks": "agent-proto:ebook-convert-pdf",
        "line-break": "agent-proto:ebook-convert-pdf",
        "toc": "agent-proto:ebook-convert-pdf",
        "security-patcher": "agent-proto:security-patcher",
        "security-scanner": "agent-proto:security-scanner",
    }
    for needle, tok in proto_map.items():
        if needle in t and tok not in scope:
            scope.append(tok)

    # repo: mentions
    if "~/repos/docker-gomorrah" in t or "docker-gomorrah" in t or "monitoring/docker-compose" in t:
        scope.append("repo:docker-gomorrah")
    if "~/repos/media-tools" in t or "media-tools" in t or "ebook-convert-pdf" in t:
        scope.append("repo:media-tools")
    if ".claude/agents" in t or "agents/security-" in t:
        scope.append("repo:claude-config")

    # book: mentions
    if "fadr" in t or "first and rare" in t:
        scope.append("book:fadr")
    if "laws of trading" in t or "calibre id 342" in t:
        scope.append("book:laws-of-trading")

    # Dedupe
    seen = set()
    out = []
    for s in scope:
        if s not in seen:
            seen.add(s)
            out.append(s)

    if not out:
        out = ["*"]
    return out


def _parse_legacy_queue(text):
    """Parse /tmp/claude-queued-tasks.txt into a list of (description, scope)."""
    # Items start with "QUEUED" or "QUEUED N" (possibly with trailing punctuation)
    blocks = re.split(r"(?m)^QUEUED[^\n]*\n", text)
    headers = re.findall(r"(?m)^QUEUED[^\n]*", text)
    # Re-zip header + body
    items = []
    for header, body in zip(headers, blocks[1:]):
        # Trim body
        body = body.strip()
        # Use first line after header (or header itself if body is empty) as short desc
        first_line = body.splitlines()[0].strip() if body else header.strip()
        desc = f"{header.strip()} -- {first_line[:160]}"
        full = header + "\n" + body
        scope = _infer_scope_from_text(full)
        items.append((desc, scope, body))
    return items


def cmd_queue_migrate(args):
    src = Path(args.from_file).expanduser()
    if not src.exists():
        print(f"ERROR: source does not exist: {src}", file=sys.stderr)
        sys.exit(1)
    text = src.read_text()
    parsed = _parse_legacy_queue(text)
    if not parsed:
        print("No items parsed. Nothing to migrate.")
        return
    print(f"Parsed {len(parsed)} items from {src}")
    for i, (desc, scope, body) in enumerate(parsed, 1):
        print(f"  {i}. scope={scope}")
        print(f"      {desc[:100]}")
    if not args.yes:
        print("Re-run with --yes to commit.")
        return

    # Actually add each as a queue item.
    # Use moderate priority 5 and --created-by migrate
    added = []
    for desc, scope, body in parsed:
        ns = argparse.Namespace(
            description=desc,
            scope=scope,
            priority=5,
            context=json.dumps({"legacy_body": body}),
            created_by="migrate",
            json=True,
        )
        # Inline version of cmd_queue_add so we can collect IDs.
        try:
            norm_scope = [_normalize_token(t) for t in scope]
        except ValueError as e:
            print(f"ERROR on item: {e}", file=sys.stderr)
            continue
        try:
            context = json.loads(ns.context) if ns.context else None
        except json.JSONDecodeError:
            context = None

        fh, data = _queue_open_locked("rw")
        try:
            items = data["items"]
            overlapping = _group_ids_overlapping(items, norm_scope)
            if len(overlapping) == 0:
                group_id = _new_group_id()
            elif len(overlapping) == 1:
                group_id = overlapping[0]
            else:
                group_id = _new_group_id()
                for it in items:
                    if it.get("group_id") in overlapping:
                        it["group_id"] = group_id
                log_completed(
                    f"[queue merge] {len(overlapping)} groups merged into {group_id}",
                    extra={"source": "queue", "event": "merge",
                           "merged_groups": overlapping, "new_group_id": group_id},
                )
            new_id = _new_id()
            existing_ids = {it["id"] for it in items}
            while new_id in existing_ids:
                new_id = _new_id()
            item = {
                "id": new_id,
                "description": desc,
                "summary": DEFAULT_SUMMARY,
                "scope": norm_scope,
                "group_id": group_id,
                "group_head": False,
                "status": "pending",
                "priority": 5,
                "created_at": _fmt_ts(),
                "created_by": "migrate",
            }
            if context is not None:
                item["context"] = context
            items.append(item)
            _recompute_group_heads(items)
            _queue_write_and_unlock(fh, data)
            added.append(new_id)
        except Exception:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            raise

    print(f"Migrated {len(added)} items: {added}")


