# ---------------------------------------------------------------------------
# Layer 1: resume-action.json (single "top-of-mind" slot)
# ---------------------------------------------------------------------------


def load():
    """Load current resume action, or None."""
    if not TASK_FILE.exists():
        return None
    try:
        data = json.loads(TASK_FILE.read_text())
        if not data:
            return None
        return data
    except (json.JSONDecodeError, OSError):
        return None


def save(data):
    """Save resume action."""
    TASK_FILE.parent.mkdir(parents=True, exist_ok=True)
    TASK_FILE.write_text(json.dumps(data, indent=2) + "\n")


def cmd_set(args):
    data = {
        "task": args.description,
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    if args.context:
        try:
            data["context"] = json.loads(args.context)
        except json.JSONDecodeError:
            print(f"ERROR: --context must be valid JSON: {args.context}", file=sys.stderr)
            sys.exit(1)
    save(data)
    print(f"Resume action set: {args.description}")


def cmd_append(args):
    current = load()
    if not current:
        print("No current resume action. Use 'set' first.", file=sys.stderr)
        sys.exit(1)
    current["task"] += "\n" + args.text
    current["updated_at"] = datetime.now(timezone.utc).isoformat()
    save(current)
    print("Appended to resume action.")


def cmd_get(args):
    current = load()
    if not current:
        sys.exit(1)  # silent for scripting
    print(json.dumps(current, indent=2))


def cmd_show(args):
    current = load()
    if not current:
        print("No pending resume action.")
        return
    print("=" * 60)
    print("PENDING RESUME ACTION")
    print("=" * 60)
    print(f"Task: {current['task']}")
    if current.get("context"):
        print(f"Context: {json.dumps(current['context'], indent=2)}")
    print(f"Set at: {current['created_at']}")
    if current.get("updated_at"):
        print(f"Updated: {current['updated_at']}")
    print("=" * 60)


def log_completed(description, extra=None):
    COMPLETED_FILE.parent.mkdir(parents=True, exist_ok=True)
    entry = {
        "task": description,
        "completed_at": datetime.now(timezone.utc).isoformat(),
    }
    if extra:
        entry.update(extra)
    with open(COMPLETED_FILE, "a") as f:
        f.write(json.dumps(entry) + "\n")


def cmd_complete(args):
    log_completed(args.description)
    print(f"Logged completed task: {args.description}")


def _classify_entry(entry):
    """Return ('resume' | 'queue-done' | 'queue-abandoned' | 'queue-merge' | 'other', tag_str).

    Uses structured fields (source, event) when present, and falls back to
    parsing the task-string prefix for legacy rows written before the queue
    layer was added.
    """
    source = entry.get("source")
    event = entry.get("event")
    task = entry.get("task", "") or ""
    if source == "queue":
        if event == "merge":
            qid = entry.get("new_group_id") or entry.get("group_id") or "?"
            return "queue-merge", f"[queue MERGE {qid}]"
        if event == "abandon" or "abandoned" in task[:40]:
            qid = entry.get("id") or "?"
            gid = entry.get("group_id") or "?"
            return "queue-abandoned", f"[queue {qid} {gid} ABANDONED]"
        qid = entry.get("id") or "?"
        gid = entry.get("group_id") or "?"
        return "queue-done", f"[queue {qid} {gid}]"
    # Legacy: inspect task prefix
    if task.startswith("[queue "):
        # Best-effort: pull id if present (format: "[queue q-YYYY-MM-DD-xxxx] ...")
        m = re.match(r"^\[queue (q-\S+?)(?:\s+abandoned)?\]", task)
        if m and "abandoned" in task[: 60]:
            return "queue-abandoned", f"[queue {m.group(1)} ABANDONED]"
        if m:
            return "queue-done", f"[queue {m.group(1)}]"
        return "queue-done", "[queue]"
    if task.startswith("[resume action]"):
        return "resume", "[resume-action]"
    return "other", "[other]"


def _entry_display_task(entry, kind):
    """Strip the layer-prefix from the task string (we render our own tag)."""
    task = entry.get("task", "?") or "?"
    for prefix in ("[resume action] ", "[resume action]"):
        if task.startswith(prefix):
            return task[len(prefix):]
    m = re.match(r"^\[queue [^\]]+\]\s*", task)
    if m:
        return task[m.end():]
    return task


def _entry_timestamp(entry):
    """Return the most authoritative timestamp for an entry as a datetime, or None."""
    ts_str = entry.get("completed_at") or entry.get("abandoned_at") or entry.get("created_at")
    if not ts_str:
        return None
    try:
        return datetime.fromisoformat(ts_str)
    except ValueError:
        return None


def _load_queue_items_silent():
    """Load queue.json items without taking a write lock, for scope lookup.

    Returns dict id -> item, or empty dict on any failure.
    """
    try:
        if not QUEUE_FILE.exists():
            return {}
        raw = QUEUE_FILE.read_text()
        if not raw.strip():
            return {}
        data = json.loads(raw)
        out = {}
        for it in data.get("items", []):
            if isinstance(it, dict) and "id" in it:
                out[it["id"]] = it
        return out
    except (json.JSONDecodeError, OSError):
        return {}


def _scope_for_queue_entry(entry, queue_items):
    """Best-effort scope lookup for a queue history entry.

    Uses the queue.json file if the item is still present, else returns None.
    """
    qid = entry.get("id")
    if not qid:
        return None
    it = queue_items.get(qid)
    if not it:
        return None
    return it.get("scope") or None


def _render_history_entries(entries, include_scope=True, width_total=None):
    """Pretty-print a list of entries with source tags. Returns list of lines."""
    if not entries:
        return ["(no entries)"]
    queue_items = _load_queue_items_silent() if include_scope else {}
    lines = []
    for entry in entries:
        try:
            kind, tag = _classify_entry(entry)
        except Exception:
            lines.append("  (corrupt entry)")
            continue
        ts = entry.get("completed_at") or entry.get("abandoned_at") or "?"
        if "T" in ts:
            ts = ts.split("T")[0] + " " + ts.split("T")[1][:8]
        desc = _entry_display_task(entry, kind)
        # Truncate description for one-line display
        if len(desc) > 140:
            desc = desc[:137] + "..."
        lines.append(f"  [{ts}] {tag} {desc}")
        if include_scope and kind.startswith("queue") and kind != "queue-merge":
            scope = _scope_for_queue_entry(entry, queue_items)
            if scope:
                scope_str = ",".join(scope)
                if len(scope_str) > 80:
                    scope_str = scope_str[:77] + "..."
                lines.append(f"        scope: {scope_str}")
    return lines


def _filter_entries(entries, since=None, layer=None):
    """Filter a list of parsed history entries by time window and/or layer."""
    cutoff = None
    if since:
        cutoff = datetime.now(timezone.utc) - _parse_duration(since)
    out = []
    for entry in entries:
        if cutoff is not None:
            ts = _entry_timestamp(entry)
            if ts is None or ts < cutoff:
                continue
        if layer and layer != "all":
            kind, _ = _classify_entry(entry)
            if layer == "resume" and kind != "resume":
                continue
            if layer == "queue" and not kind.startswith("queue"):
                continue
        out.append(entry)
    return out


def _load_all_history_entries():
    """Load and parse completed-tasks.jsonl. Returns list of dicts (oldest first)."""
    if not COMPLETED_FILE.exists():
        return []
    out = []
    for line in COMPLETED_FILE.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            out.append(json.loads(line))
        except json.JSONDecodeError:
            out.append({"_corrupt": True, "task": "(corrupt)"})
    return out


def cmd_history(args):
    n = args.count
    entries = _load_all_history_entries()
    if not entries:
        print("No completed tasks.")
        return

    # Apply --since / --layer filters BEFORE tail limit
    entries = _filter_entries(entries, since=getattr(args, "since", None),
                              layer=getattr(args, "layer", None))
    if not entries:
        print("No completed tasks (after filters).")
        return

    # Tail last N
    recent = entries[-n:] if len(entries) > n else entries

    # Header describes what filters were in effect so the user knows what
    # they're looking at.
    filter_bits = []
    if getattr(args, "since", None):
        filter_bits.append(f"since={args.since}")
    if getattr(args, "layer", None) and args.layer != "all":
        filter_bits.append(f"layer={args.layer}")
    filter_suffix = f" ({', '.join(filter_bits)})" if filter_bits else ""

    print(f"Last {len(recent)} completed tasks{filter_suffix}:")
    include_scope = not getattr(args, "no_scope", False)
    for line in _render_history_entries(recent, include_scope=include_scope):
        print(line)


def cmd_clear(args):
    if TASK_FILE.exists():
        current = load()
        if current:
            log_completed(f"[resume action] {current['task'][:200]}")
        TASK_FILE.unlink()
        print("Resume action cleared and logged as completed.")
    else:
        print("No resume action to clear.")


def for_session_resume():
    current = load()
    if not current:
        return ""
    lines = [
        "",
        "!" * 60,
        "!! RESUME ACTION — DO THIS IMMEDIATELY AFTER WATCHERS ARE UP",
        "!" * 60,
        "",
        f"Task: {current['task']}",
    ]
    if current.get("context"):
        lines.append(f"Context: {json.dumps(current['context'])}")
    lines.append(f"(set at {current['created_at']})")
    lines.append("")
    lines.append("After completing this, run: session-task clear")
    lines.append("!" * 60)
    lines.append("")
    return "\n".join(lines)


def for_session_resume_history(n_resume=5, n_queue=5, since="7d"):
    """Task-history block for session-resume, split into two panels.

    - Resume-action completions (the narrative thread)  : last n_resume in window
    - Queue completions (what finished since last review): last n_queue in window

    Everything older than `since` is excluded. This prevents a flurry of
    queue sweeps from drowning out the last few resume-action narratives.
    """
    entries = _load_all_history_entries()
    if not entries:
        return "No completed tasks recorded yet."

    try:
        windowed = _filter_entries(entries, since=since, layer="all")
    except ValueError:
        windowed = entries

    resume_entries = [e for e in windowed if _classify_entry(e)[0] == "resume"]
    queue_entries = [e for e in windowed if _classify_entry(e)[0].startswith("queue")]

    resume_tail = resume_entries[-n_resume:]
    queue_tail = queue_entries[-n_queue:]

    parts = []
    parts.append(f"### Resume-action trail (last {len(resume_tail)} in {since})")
    if resume_tail:
        parts.extend(_render_history_entries(resume_tail, include_scope=False))
    else:
        parts.append("  (none)")
    parts.append("")
    parts.append(f"### Queue completions (last {len(queue_tail)} in {since})")
    if queue_tail:
        parts.extend(_render_history_entries(queue_tail, include_scope=True))
    else:
        parts.append("  (none)")

    return "\n".join(parts)


# ---------------------------------------------------------------------------
# Layer 2: queue.json (scope-based serialization groups)
# ---------------------------------------------------------------------------


def _queue_empty():
    return {
        "schema_version": QUEUE_SCHEMA_VERSION,
        "items": [],
        "locked_scopes": {},
    }


def _queue_open_locked(mode):
    """Open queue.json with fcntl.LOCK_EX. Caller must close the file when done.

    Returns (file_handle, data). File is opened r+ (or created empty).
    mode is informational -- we always take LOCK_EX for safety.
    """
    QUEUE_FILE.parent.mkdir(parents=True, exist_ok=True)
    # Use os.open so we can get a writable fd even for new files.
    fd = os.open(str(QUEUE_FILE), os.O_RDWR | os.O_CREAT, 0o600)
    fh = os.fdopen(fd, "r+")
    fcntl.flock(fh, fcntl.LOCK_EX)
    fh.seek(0)
    raw = fh.read()
    if not raw.strip():
        data = _queue_empty()
    else:
        try:
            data = json.loads(raw)
        except json.JSONDecodeError:
            # Corrupt queue -- back up and start fresh so we don't lose more data.
            backup = QUEUE_FILE.with_suffix(".json.corrupt")
            backup.write_text(raw)
            data = _queue_empty()
    # Normalize
    if not isinstance(data, dict) or "items" not in data:
        data = _queue_empty()
    data.setdefault("schema_version", QUEUE_SCHEMA_VERSION)
    data.setdefault("items", [])
    # locked_scopes is a dict: {<token>: {"reason": "...", "locked_at": "iso"}}
    # Persists in queue.json so it survives /clear and process restarts.
    locked = data.get("locked_scopes")
    if not isinstance(locked, dict):
        locked = {}
    # Defensive: drop any obviously-malformed entries.
    cleaned: dict[str, dict] = {}
    for k, v in locked.items():
        if not isinstance(k, str) or not k:
            continue
        if isinstance(v, dict):
            cleaned[k] = {
                "reason": str(v.get("reason") or ""),
                "locked_at": str(v.get("locked_at") or ""),
            }
        else:
            # Tolerate legacy bare-string entries.
            cleaned[k] = {"reason": str(v) if v else "", "locked_at": ""}
    data["locked_scopes"] = cleaned

    # Read-time migration (2026-05-08): legacy items carrying a `depends_on`
    # list are translated into `task:<id>` scope tokens. Both representations
    # are unioned in `_iter_dep_ids` so behavior is identical regardless of
    # which form a record is stored in -- but going forward we materialize
    # deps as scope tokens so locks, depends_on, and serialization scope all
    # speak the same language. The legacy field is preserved on read and
    # only stripped when the item is rewritten via `_queue_write_and_unlock`.
    for it in data.get("items", []):
        if not isinstance(it, dict):
            continue
        legacy = it.get("depends_on")
        if not legacy or not isinstance(legacy, list):
            continue
        scope = list(it.get("scope") or [])
        existing_targets = {
            _task_token_target(t) for t in scope if _is_task_token(t)
        }
        added = False
        for d in legacy:
            if not isinstance(d, str) or not d:
                continue
            if d in existing_targets:
                continue
            scope.append(f"task:{d}")
            existing_targets.add(d)
            added = True
        if added:
            it["scope"] = scope
        # Drop the legacy field once the migration runs -- we keep the same
        # info as scope tokens. The next write persists it.
        it.pop("depends_on", None)
    return fh, data


def _queue_write_and_unlock(fh, data):
    data["schema_version"] = QUEUE_SCHEMA_VERSION
    fh.seek(0)
    fh.truncate()
    fh.write(json.dumps(data, indent=2) + "\n")
    fh.flush()
    os.fsync(fh.fileno())
    fcntl.flock(fh, fcntl.LOCK_UN)
    fh.close()


def _queue_unlock_readonly(fh):
    fcntl.flock(fh, fcntl.LOCK_UN)
    fh.close()


def _new_id():
    day = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    return f"q-{day}-{secrets.token_hex(2)}"


def _new_group_id():
    return f"g-{secrets.token_hex(4)}"


# --- scope tokens --------------------------------------------------------

_TYPED_TOKEN_RE = re.compile(r"^(repo|resource|book|agent-proto):")
# `path:<repo>/<subdir>` scope tokens (added 2026-05-11 to fix
# over-serialization within large repos -- e.g. docker-gomorrah's
# monitoring/ vs queue-minisite/ subtrees both tagging `repo:docker-gomorrah`
# even though their files are disjoint). Semantics: a `path:` token is a
# finer-grained claim WITHIN a repo. The first segment is the repo name;
# everything after is a path within that repo.
#  - Two `path:X/...` tokens overlap iff one path is a prefix of the other
#    (segment-wise) -- siblings are disjoint.
#  - `repo:X` overlaps every `path:X/...` (the broad claim still wins).
#  - `path:X/...` and `path:Y/...` never overlap (different repo).
_PATH_TOKEN_PREFIX = "path:"
# `task:<queue-id>` scope tokens (added 2026-05-08 to unify --depends-on with
# scope). Semantics: an item carrying `task:<id>` in its scope is blocked
# until queue id <id> reaches a terminal state (done). The token is INERT
# for normal scope-conflict / scope-overlap purposes -- it does NOT
# serialize peers. Two items both carrying `task:q-A` are NOT in scope
# conflict; the readiness gate (in _item_is_ready) consults the queue to
# resolve the dep separately. This way `--depends-on q-A` is just
# parser-level sugar for `--scope task:q-A`, and `queue lock task:q-A`
# Just Works without a second code path.
_TASK_TOKEN_PREFIX = "task:"


def _is_task_token(tok):
    return isinstance(tok, str) and tok.startswith(_TASK_TOKEN_PREFIX)


def _task_token_target(tok):
    """Return the queue id referenced by a `task:<id>` token, or None."""
    if not _is_task_token(tok):
        return None
    return tok[len(_TASK_TOKEN_PREFIX):]


def _normalize_token(tok):
    """Normalize a single scope token.

    - Expand leading ~ in file: tokens.
    - Strip a trailing /** on file: tokens (it's redundant with prefix match,
      kept purely as readability sugar in prompts).
    - Leave '*' alone.
    - Typed tokens (repo:/resource:/book:/agent-proto:) are exact-match.
    - `path:<repo>/<subdir>` tokens (since 2026-05-11) normalize the suffix:
      collapse repeated slashes, strip leading/trailing slashes, and reject
      empty / repo-only forms (`path:X` must use `repo:X` instead). The
      stored form is always `path:<repo>/<a>/<b>/...` with single-slash
      separators and no trailing slash.
    - `task:<id>` tokens (since 2026-05-08) are exact-match and inert for
      scope-conflict purposes; their semantics live in _item_is_ready.
    """
    if not tok or not isinstance(tok, str):
        raise ValueError(f"Scope token must be non-empty string: {tok!r}")
    if tok == "*":
        return "*"
    if tok.startswith("file:"):
        path = tok[len("file:"):]
        # Strip trailing /** or ** (explicit recursive intent -- same semantic)
        if path.endswith("/**"):
            path = path[:-3]
        elif path.endswith("**"):
            path = path[:-2]
        # Expand ~
        if path.startswith("~"):
            path = os.path.expanduser(path)
        # Keep trailing slash intent: directories prefix-match like file:/foo/
        # matches file:/foo/bar. We do NOT force or strip trailing slash --
        # prefix match handles both file:/foo and file:/foo/.
        return f"file:{path}"
    if tok.startswith(_PATH_TOKEN_PREFIX):
        body = tok[len(_PATH_TOKEN_PREFIX):]
        # Collapse repeated separators and strip leading/trailing /.
        segments = [s for s in body.split("/") if s]
        if len(segments) < 2:
            # `path:` is meant for sub-repo claims. A bare `path:X` would be
            # indistinguishable from `repo:X` and would muddle the overlap
            # rules -- force callers to use `repo:X` for the whole-repo claim.
            raise ValueError(
                f"path: tokens require a repo AND a subpath "
                f"(use repo:<name> for the whole repo): {tok!r}"
            )
        return f"{_PATH_TOKEN_PREFIX}{'/'.join(segments)}"
    if _TYPED_TOKEN_RE.match(tok):
        return tok
    if _is_task_token(tok):
        return tok
    # Unknown / untyped token: accept as-is (exact match).
    return tok


def _is_path_token(tok):
    return isinstance(tok, str) and tok.startswith(_PATH_TOKEN_PREFIX)


def _path_token_segments(tok):
    """Return the segment list of a normalized `path:<repo>/<a>/<b>` token.

    First element is the repo; remainder is the within-repo path. Caller is
    expected to pass an already-normalized token (so segments are non-empty
    and >= 2 long).
    """
    body = tok[len(_PATH_TOKEN_PREFIX):]
    return body.split("/")


def _path_token_repo(tok):
    """Return the repo name embedded in a `path:` token."""
    return _path_token_segments(tok)[0]


def _tokens_overlap(a, b):
    """Return True if two normalized scope tokens overlap.

    - '*' overlaps everything (including task: tokens).
    - Two file: tokens overlap if one is a prefix of the other.
    - Two `path:` tokens overlap iff they share the same repo AND one
      within-repo path is a (segment-wise) prefix of the other. Siblings
      (`path:X/a` vs `path:X/b`) are disjoint.
    - `repo:X` overlaps every `path:X/...` -- the broad whole-repo claim
      still wins over any narrower sub-claim. Cross-repo is never an
      overlap (`repo:X` vs `path:Y/...` is disjoint).
    - `task:<id>` tokens overlap only with the same exact `task:<id>` token
      (and '*'). They never overlap regular scope tokens. Lock machinery
      uses this so `queue lock task:q-XXXX` parks any pending item that
      lists `task:q-XXXX` in its scope.
    - Typed/other tokens overlap only if equal.

    NOTE: `task:` tokens are EXEMPT from group-merge and running-scope
    conflict checks. Those callers (`_group_ids_overlapping`,
    `_running_scope_conflicts`, `_group_scope`) filter task tokens out
    BEFORE calling this helper -- see `_serializing_scope`. Item readiness
    (the actual "wait for q-A" gate) is computed in `_item_is_ready` by
    consulting the queue, not by overlap.
    """
    if a == "*" or b == "*":
        return True
    a_is_file = a.startswith("file:")
    b_is_file = b.startswith("file:")
    if a_is_file and b_is_file:
        pa = a[len("file:"):]
        pb = b[len("file:"):]
        # Directory-style prefix: we treat file:/foo and file:/foo/ as the same.
        # Add trailing slash for correct prefix match so file:/foo doesn't
        # accidentally match file:/foobar.
        def with_sep(p):
            return p if p.endswith("/") else p + "/"
        if pa == pb:
            return True
        wa = with_sep(pa)
        wb = with_sep(pb)
        # Either is a directory-prefix of the other, OR one is an exact file
        # that lives under the other's directory.
        return wa.startswith(wb) or wb.startswith(wa)
    a_is_path = _is_path_token(a)
    b_is_path = _is_path_token(b)
    if a_is_path and b_is_path:
        # Same repo + segment-wise prefix => overlap. Siblings disjoint.
        sa = _path_token_segments(a)
        sb = _path_token_segments(b)
        if sa[0] != sb[0]:
            return False
        # Compare the within-repo segments (everything after the repo name).
        ra = sa[1:]
        rb = sb[1:]
        # One must be a (possibly equal) segment-wise prefix of the other.
        # Since both are normalized non-empty and the repo matched, this is
        # the standard prefix check.
        if len(ra) <= len(rb):
            return rb[: len(ra)] == ra
        return ra[: len(rb)] == rb
    # `repo:X` overlaps any `path:X/...`: the broad whole-repo claim wins.
    a_is_repo = a.startswith("repo:")
    b_is_repo = b.startswith("repo:")
    if a_is_repo and b_is_path:
        return a[len("repo:"):] == _path_token_repo(b)
    if b_is_repo and a_is_path:
        return b[len("repo:"):] == _path_token_repo(a)
    # Mixed types or two non-file/non-path tokens: exact match only.
    return a == b


def _serializing_scope(scope):
    """Return scope tokens that participate in serialization / group-merge.

    Filters out `task:<id>` tokens, which are inert dep markers (their
    semantics live in `_item_is_ready` and locks, not in scope conflicts).
    Used by `_group_ids_overlapping`, `_running_scope_conflicts`, and
    `_group_scope` so a `--depends-on` cross-group dep does NOT fold the
    dependent into the depended-on item's group.
    """
    return [t for t in (scope or []) if not _is_task_token(t)]


def _scope_sets_overlap(set_a, set_b):
    """True if any token from set_a overlaps any token from set_b."""
    for ta in set_a:
        for tb in set_b:
            if _tokens_overlap(ta, tb):
                return True
    return False


def _union_scopes(*sets):
    """Union of token sets, with simple dedupe."""
    merged = []
    seen = set()
    for s in sets:
        for t in s:
            if t not in seen:
                seen.add(t)
                merged.append(t)
    return merged


def _active_items(items):
    return [it for it in items if it.get("status") in ACTIVE_STATUSES]


def _group_members(items, group_id):
    return [it for it in items if it.get("group_id") == group_id]


def _group_scope(items, group_id):
    members = _group_members(items, group_id)
    # task: tokens are inert for serialization purposes -- they get exposed
    # via item-level scope but are stripped from the aggregated group scope.
    return _serializing_scope(
        _union_scopes(*(m.get("scope", []) for m in members))
    )


def _group_ids_overlapping(items, new_scope):
    """Return list of group_ids whose aggregated scope overlaps new_scope.

    Only considers groups with at least one pending/running member.
    `task:<id>` tokens are inert here (they're cross-group dep markers,
    not serialization keys).
    """
    new_serializing = _serializing_scope(new_scope)
    if not new_serializing:
        # Item carries only inert (e.g. task:) tokens -- it never merges
        # into an existing group on serialization grounds.
        return []
    active = _active_items(items)
    by_group = {}
    for it in active:
        by_group.setdefault(it["group_id"], []).append(it)
    overlapping = []
    for gid, members in by_group.items():
        gscope = _serializing_scope(
            _union_scopes(*(m.get("scope", []) for m in members))
        )
        if _scope_sets_overlap(gscope, new_serializing):
            overlapping.append(gid)
    return overlapping


def _running_scope_conflicts(items, candidate_scope, *, exclude_id=None,
                             exclude_group=None):
    """Return list of running OR wedged items whose scope overlaps candidate_scope.

    Used for spawn-gating: if ANY running/wedged item overlaps the
    candidate's scope (even across groups -- which should be rare given
    the merge semantics but can happen for untracked/unregistered
    in-flight work), spawning is a conflict.

    Wedged items still own their scope -- the agent is stuck but hasn't
    released the slot. Letting a peer claim the same scope while the
    wedge is unresolved would defeat the queue's serialization guarantee.

    `exclude_id` skips a specific item (e.g. the candidate itself once
    it's been marked running). `exclude_group` skips an entire group (used
    when the caller already knows group-level invariant holds).
    """
    # task: tokens are inert for running-conflict purposes (they're
    # cross-group dep hints, not serialization keys). Strip them from
    # both sides before overlap check so two items both carrying
    # `task:q-A` don't falsely report a conflict.
    candidate_serializing = _serializing_scope(candidate_scope)
    out = []
    for it in items:
        if it.get("status") not in RUNNING_STATUSES:
            continue
        if exclude_id and it.get("id") == exclude_id:
            continue
        if exclude_group and it.get("group_id") == exclude_group:
            continue
        if _scope_sets_overlap(
            _serializing_scope(it.get("scope", [])), candidate_serializing
        ):
            out.append(it)
    return out


def _sort_key(item):
    # Priority descending (higher priority = earlier), FIFO tiebreak.
    return (-int(item.get("priority", 5)), item.get("created_at", ""))


def _group_head(items, group_id):
    """Return the current head (running/wedged if any, else next pending).

    Wedged items count as "in flight" for head-of-group purposes so a
    peer pending item in the same group cannot be promoted while the
    wedge is unresolved.
    """
    members = [it for it in _group_members(items, group_id) if it.get("status") in ACTIVE_STATUSES]
    if not members:
        return None
    running = [it for it in members if it.get("status") in RUNNING_STATUSES]
    if running:
        return sorted(running, key=_sort_key)[0]
    return sorted(members, key=_sort_key)[0]


def _locked_tokens_blocking_item(item, locked_scopes):
    """Return the list of locked-scope tokens that overlap this item's scope.

    Empty list if `locked_scopes` is empty/None or no token overlaps.
    A "lock" is just a string token in the locked-scopes set; an item is
    blocked when ANY of its scope tokens overlaps ANY locked token (using
    the same overlap semantics as scope-conflict detection).
    """
    if not locked_scopes:
        return []
    item_scope = item.get("scope") or []
    blockers = []
    for tok in locked_scopes.keys():
        for it_tok in item_scope:
            if _tokens_overlap(it_tok, tok):
                blockers.append(tok)
                break
    return blockers


def _item_is_ready(items, item, locked_scopes=None):
    if item.get("status") != "pending":
        return False
    # Manual lock (added 2026-05-08): operator-declared "park this scope
    # until I say so" gate. Any pending item whose scope overlaps a locked
    # token is held in pending+blocked-by-lock state and is NOT ready.
    # Stored in queue.json under "locked_scopes" so it survives /clear.
    if _locked_tokens_blocking_item(item, locked_scopes):
        return False
    head = _group_head(items, item["group_id"])
    if head is None:
        return False
    if head["id"] != item["id"]:
        return False
    # Head must not be running OR wedged (anything in flight blocks).
    members = _group_members(items, item["group_id"])
    if any(m.get("status") in RUNNING_STATUSES for m in members):
        return False
    # Explicit interjob deps (added 2026-05-02; unified with scope tokens
    # 2026-05-08): every dep id must resolve to an item with status=done.
    # Targets that are missing, abandoned, or part of a dependency cycle
    # are treated as permanent blockers (the item stays not-ready until a
    # human edits the deps). Lazy read-time compute path -- no
    # transitive-closure cache.
    #
    # As of 2026-05-08, deps live BOTH on `depends_on` (legacy field, still
    # honored for back-compat in case any caller stamped one directly) AND
    # as `task:<id>` scope tokens (the new canonical surface, materialized
    # by `--depends-on` / `queue depend` and the read-time migration in
    # `_queue_open_locked`). They union here -- either source blocks.
    deps = list(_iter_dep_ids(item))
    if deps:
        if _has_dep_cycle(items, item["id"]):
            return False
        items_by_id = {it.get("id"): it for it in items if it.get("id")}
        for dep_id in deps:
            dep = items_by_id.get(dep_id)
            if dep is None:
                # Dangling dep — treat as a permanent blocker. Operator must
                # remove it explicitly via `queue depend ... --remove`.
                return False
            if dep.get("status") != "done":
                return False
    return True


def _iter_dep_ids(item):
    """Yield the queue ids this item depends on, deduplicated.

    Combines two sources:
      * `task:<id>` scope tokens (canonical 2026-05-08+).
      * Legacy `depends_on` list (older queue.json files; the read-time
        migration in `_queue_open_locked` translates these into task:
        scope tokens, so this branch is mostly defensive).

    Order is stable: `task:` tokens in scope order first, then any legacy
    `depends_on` entries that aren't already covered by a task: token.
    """
    seen: set[str] = set()
    for tok in (item.get("scope") or []):
        target = _task_token_target(tok)
        if target and target not in seen:
            seen.add(target)
            yield target
    for d in (item.get("depends_on") or []):
        if isinstance(d, str) and d and d not in seen:
            seen.add(d)
            yield d


def _has_dep_cycle(items, root_id):
    """Detect a dependency cycle reachable from root_id.

    Lazy DFS, computed at read time only when an item has any deps. We do
    NOT block writes on cycle detection (per the architecture brief —
    "Don't block writes on cycle check") to keep `queue depend` cheap;
    instead, ready_now flips False the moment a cycle becomes reachable.

    Bounded by the active item count (the call site walks a single
    item's dep graph), so worst case O(N) per ready_now call where N is
    the queue size. For the typical ≤50-item queue this is trivially
    fast.
    """
    by_id = {it.get("id"): it for it in items if it.get("id")}
    visited = set()
    on_path = set()

    root_item = by_id.get(root_id, {})
    walk = [(root_id, iter(list(_iter_dep_ids(root_item))))]
    on_path.add(root_id)
    while walk:
        _node, it_children = walk[-1]
        try:
            child = next(it_children)
        except StopIteration:
            popped, _ = walk.pop()
            on_path.discard(popped)
            visited.add(popped)
            continue
        if not isinstance(child, str):
            continue
        if child in on_path:
            return True
        if child in visited:
            continue
        child_item = by_id.get(child)
        if child_item is None:
            # Dangling — not a cycle (just a dead edge). The caller's
            # ready check will treat it as a permanent blocker.
            visited.add(child)
            continue
        on_path.add(child)
        walk.append((child, iter(list(_iter_dep_ids(child_item)))))
    return False


def _gc_groups(items):
    """Remove any reference to groups that have no pending/running members.

    (Groups are derived from group_id on items, so nothing to remove except
    logging completed done/abandoned members as they age out. Items with
    status done/abandoned older than the prune threshold can be kicked by
    `queue prune`.)
    """
    return items


def _recompute_group_heads(items):
    """Ensure invariant: at most one running per group, head flag is accurate."""
    by_group = {}
    for it in items:
        by_group.setdefault(it.get("group_id"), []).append(it)
    for gid, members in by_group.items():
        head = _group_head(items, gid)
        for m in members:
            m["group_head"] = (head is not None and m["id"] == head["id"])


# --- queue subcommands ---------------------------------------------------


def _fmt_ts():
    return datetime.now(timezone.utc).isoformat()


def _pingme_notify(title, message, priority="normal", silent=False):
    """Fire a Pushover notification via the ``pingme`` CLI.

    Called from queue lifecycle hooks (register / done / abandon). Failures
    MUST NOT block the underlying queue state transition, so every error
    path here is swallowed to stderr and returns None.

    Suppression:
        * ``silent=True`` (from ``--silent`` on the CLI) skips the call.
        * ``PINGME_SESSION_TASK=0`` env var skips all session-task pingmes
          (useful for batch scripts / noisy flows).
        * ``pingme`` not on PATH -> silent no-op (not an error).
    """
    if silent:
        return None
    if os.environ.get("PINGME_SESSION_TASK") == "0":
        return None
    pingme = shutil.which("pingme")
    if not pingme:
        return None
    if priority not in ("low", "normal", "high", "emergency"):
        priority = "normal"
    cmd = [pingme, "-p", priority, message, title]
    try:
        subprocess.run(
            cmd,
            check=False,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except Exception as exc:  # noqa: BLE001 -- never block the queue op
        print(f"[pingme] notification failed ({exc.__class__.__name__}): {exc}",
              file=sys.stderr)
        return None
    return cmd


def _claude_event_notify(tag, message, data, priority="low", silent=False):
    """Emit a claude-event for a queue lifecycle transition.

    Wraps the ``claude-event`` CLI. Events land in ``~/claude-events/`` and
    are picked up by ``claude-event-watch``, letting the main loop react to
    queue transitions (e.g. spawn the next-in-group item when a blocker
    clears).

    MUST NEVER block or fail the underlying queue op. All errors are caught
    and logged to stderr as a warning. A broken ``claude-event`` is a
    warning, not a crash.

    Suppression mirrors pingme:
        * ``silent=True`` (from ``--silent`` on the CLI) skips the call.
        * ``CLAUDE_EVENT_SESSION_TASK=0`` env var skips all emits
          (useful for batch scripts / test harnesses).
        * ``claude-event`` not on PATH -> silent no-op (not an error).
    """
    if silent:
        return None
    if os.environ.get("CLAUDE_EVENT_SESSION_TASK") == "0":
        return None
    emitter = shutil.which("claude-event")
    if not emitter:
        return None
    if priority not in ("low", "normal", "high", "urgent"):
        priority = "low"
    cmd = [
        emitter,
        message,
        "--source", "queue",
        "--tag", tag,
        "--priority", priority,
    ]
    # Flatten data dict into repeated --data KEY=VAL args. Nested structures
    # (scope list) get JSON-serialised so the consumer can round-trip them.
    for k, v in (data or {}).items():
        if isinstance(v, (list, dict)):
            v = json.dumps(v, separators=(",", ":"))
        cmd.extend(["--data", f"{k}={v}"])
    try:
        subprocess.run(
            cmd,
            check=False,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except Exception as exc:  # noqa: BLE001 -- never block the queue op
        print(
            f"[claude-event] emit failed ({exc.__class__.__name__}): {exc}",
            file=sys.stderr,
        )
        return None
    return cmd


def _obligations_register_force_start(queue_id, summary, reason, ttl_secs=900,
                                       bundle_path=None, autostopped_count=0):
    """Register a `force_started_unspawned` obligation on the queue id.

    Wired by `cmd_queue_force_start` after a successful pending->running
    promotion. The obligation gates `*` (every tool) until the main loop
    actually spawns an Agent for the queue item -- the predicate clears
    the moment claude-watch's active-agents JSON shows a live record for
    the qid. The Agent tool itself is in `UNIVERSAL_RECOVERY_EXEMPT_PATTERNS`
    so the spawning Agent call is never blocked by the gate it satisfies.

    MUST NEVER block or fail the underlying queue op. All errors are
    caught and logged to stderr as a warning. Suppression mirrors
    pingme / claude-event:
      * `OBLIGATIONS_FORCE_START=0` env var skips the call entirely
        (test harnesses, scripted batch runs).
      * `obligations` not on PATH -> silent no-op (not an error).

    The TTL defaults to 15 min (900s). If the main loop genuinely can't
    dispatch within that window the obligation auto-expires rather than
    deadlocking forever; this matches Andrew's "short" guidance in the
    spec. Bump or pass a larger value if that proves too tight in
    practice.

    ``bundle_path`` (when present) is woven into the deny banner so the
    main loop sees the recovery context location at gate-fire time. The
    spawned Agent is expected to read that file as its FIRST action so
    it can triage the autostopped peers' uncommitted work.
    """
    if os.environ.get("OBLIGATIONS_FORCE_START") == "0":
        return None
    cli = shutil.which("obligations")
    if not cli:
        return None
    bundle_hint = ""
    if bundle_path:
        if autostopped_count:
            bundle_hint = (
                f" Autostopped {autostopped_count} running peer(s); "
                f"the recovery bundle at {bundle_path} contains their "
                f"prompts, transcript paths, and uncommitted git state — "
                f"the spawning Agent must read it and triage."
            )
        else:
            bundle_hint = (
                f" Recovery bundle at {bundle_path} (no peers autostopped)."
            )
    deny_msg = (
        f"FORCE-START: q={queue_id} ({summary}) was force-started but no "
        f"Agent has been spawned for it yet. Dispatch the agent before "
        f"running any other tool. Reason: {reason}.{bundle_hint}"
    )
    params = json.dumps({"queue_id": queue_id})
    cmd = [
        cli,
        "add",
        "--tool-pattern", "*",
        "--predicate", "force_started_unspawned",
        "--params", params,
        "--ttl", str(int(ttl_secs)),
        "--deny-msg", deny_msg,
        "--enforcement", "gate",
        "--created-by", f"force-start:{queue_id}",
    ]
    try:
        subprocess.run(
            cmd,
            check=False,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except Exception as exc:  # noqa: BLE001 -- never block the queue op
        print(
            f"[obligations] force-start register failed "
            f"({exc.__class__.__name__}): {exc}",
            file=sys.stderr,
        )
        return None
    return cmd


def _item_summary(item):
    """Read the one-line summary of a queue item, defaulting to placeholder.

    Legacy items (written before 2026-04-19) have no ``summary`` field; they
    surface as ``DEFAULT_SUMMARY`` until edited via ``queue set-summary``.
    """
    s = (item.get("summary") or "").strip()
    return s if s else DEFAULT_SUMMARY


def _elapsed_minutes(started_at_iso):
    """Return integer minutes elapsed since an ISO-8601 timestamp, or None."""
    sec = _elapsed_seconds(started_at_iso)
    if sec is None:
        return None
    return sec // 60


def _elapsed_seconds(started_at_iso):
    """Return integer seconds elapsed since an ISO-8601 timestamp, or None.

    Used by the claude-event emitter so the consumer can render minute-level
    precision for short tasks (<60s) that would otherwise log as "0m".
    """
    if not started_at_iso:
        return None
    try:
        started = datetime.fromisoformat(started_at_iso)
    except (TypeError, ValueError):
        return None
    now = datetime.now(timezone.utc)
    if started.tzinfo is None:
        # Treat naive as UTC rather than crashing -- queue writes utc iso.
        started = started.replace(tzinfo=timezone.utc)
    delta = now - started
    return max(0, int(delta.total_seconds()))


def _agent_id_for_queue(queue_id):
    """Look up the spawned agent_id for a queue item via claude-watch state.

    Returns the agent_id string, or None if the state file is missing /
    unreadable / has no record for ``queue_id``. Mirrors the dedup rule
    in ``claude_agents.agents_by_queue_id`` (live > stale, smaller jsonl
    age wins) but inlined here so this script stays stdlib-only.
    """
    try:
        with open(CLAUDE_AGENTS_STATE, "r") as f:
            state = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(state, dict):
        return None
    best = None
    for rec in state.get("agents", []) or []:
        if not isinstance(rec, dict):
            continue
        if rec.get("queue_id") != queue_id:
            continue
        if best is None:
            best = rec
            continue
        b_alive = bool(best.get("alive"))
        r_alive = bool(rec.get("alive"))
        if r_alive and not b_alive:
            best = rec
            continue
        if r_alive == b_alive:
            b_age = best.get("jsonl_age_seconds")
            r_age = rec.get("jsonl_age_seconds")
            if r_age is not None and (b_age is None or r_age < b_age):
                best = rec
    if best is None:
        return None
    aid = best.get("agent_id")
    return aid if isinstance(aid, str) and aid else None


def _find_agent_jsonl(agent_id):
    """Locate the most-recent JSONL transcript for ``agent_id``.

    Layout::
        <CLAUDE_AGENTS_JSONL_ROOT>/<session-uuid>/subagents/agent-<id>.jsonl

    Returns a ``Path`` or None. Path-traversal-safe: agent_id is matched
    against a strict regex before any filesystem walk. Multiple project
    roots (e.g. one per cwd token) are supported by setting
    ``CLAUDE_AGENTS_JSONL_ROOT`` to the parent — we walk one level deep
    looking for ``subagents/`` containers.
    """
    if not isinstance(agent_id, str):
        return None
    if not re.match(r"^[a-z0-9-]{4,64}$", agent_id):
        return None
    root = CLAUDE_AGENTS_JSONL_ROOT
    if not root.is_dir():
        return None
    needle = f"agent-{agent_id}.jsonl"
    best = None  # (mtime, path)
    # Two-level walk: <root>/<host-token>/<session>/subagents/<file>, OR
    # <root>/<session>/subagents/<file> (the gomorrah deploy mounts the
    # host-token level directly so the session is one level down). Try
    # both shapes — first hit wins per session-uuid, then we rank by mtime.
    candidates_dirs = [root]
    try:
        for child in root.iterdir():
            if child.is_dir():
                candidates_dirs.append(child)
    except OSError:
        return None
    seen = set()
    for d in candidates_dirs:
        try:
            sessions = list(d.iterdir())
        except OSError:
            continue
        for sess in sessions:
            candidate = sess / "subagents" / needle
            if candidate in seen:
                continue
            seen.add(candidate)
            try:
                mt = candidate.stat().st_mtime
            except OSError:
                continue
            if best is None or mt > best[0]:
                best = (mt, candidate)
    return best[1] if best else None


def _archive_agent_transcript(item, *, reason="done"):
    """Best-effort archive of the spawning subagent's JSONL transcript.

    Called from cmd_queue_done / cmd_queue_abandon BEFORE the queue write
    is finalized, so the resulting ``log_archive_path`` field is persisted
    into queue.json alongside the status transition. Failures are non-
    fatal: missing claude-watch state, missing JSONL, or copy errors all
    log to stderr and return None — the lifecycle transition completes
    regardless. We never raise from inside here.

    Idempotent: if the archive file already exists for this queue id we
    leave it alone (the first archive wins) and return its relative
    path. Subsequent calls are a no-op.

    Returns the relative-to-archive-dir filename (e.g. "q-XXXX.jsonl") on
    success, or None on failure. The caller stores this on the item as
    ``log_archive_path`` so a queue viewer UI can detect that an archive
    exists and offer a "View log" affordance.
    """
    qid = item.get("id")
    if not isinstance(qid, str) or not qid:
        return None

    if not re.match(r"^q-[a-z0-9-]{4,64}$", qid):
        return None

    archive_name = f"{qid}.jsonl"
    dest = QUEUE_LOG_ARCHIVE_DIR / archive_name

    # Idempotent: never overwrite. The first archive (typically created
    # at done-time) wins; a later abandon would otherwise clobber the
    # canonical transcript with a partial copy if the agent dirtied the
    # file between transitions.
    if dest.exists():
        return archive_name

    aid = _agent_id_for_queue(qid)
    if aid is None:
        print(
            f"[archive] no agent record for {qid}; skipping transcript archive ({reason})",
            file=sys.stderr,
        )
        return None

    src = _find_agent_jsonl(aid)
    if src is None:
        print(
            f"[archive] no transcript file found for {qid} agent={aid}; "
            f"checked {CLAUDE_AGENTS_JSONL_ROOT} ({reason})",
            file=sys.stderr,
        )
        return None

    try:
        QUEUE_LOG_ARCHIVE_DIR.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print(
            f"[archive] failed to create {QUEUE_LOG_ARCHIVE_DIR}: {exc}",
            file=sys.stderr,
        )
        return None

    try:
        shutil.copyfile(src, dest)
    except OSError as exc:
        print(
            f"[archive] copy failed {src} -> {dest}: {exc}",
            file=sys.stderr,
        )
        return None

    print(
        f"[archive] {qid} -> {archive_name} (from agent={aid}, reason={reason})",
        file=sys.stderr,
    )
    return archive_name


def _extract_workload_label(scope):
    """Return the bare workload label encoded in a scope list, or None.

    `workload run <label>` creates a queue item with scope
    `["workload:<label>"]`. Mirrors the canonical extractor in
    queue-minisite/app.py — kept inline here so this script stays
    stdlib-only and the two implementations agree on the regex gate.

    Returns the bare label string (e.g. ``"saoirse-logical-200x"``) or
    None if the scope contains no `workload:` token, the token is
    malformed, or the value isn't a list. We honor only the FIRST match
    — multi-binding would be a bug elsewhere we don't paper over here.
    """
    if not isinstance(scope, list):
        return None
    for s in scope:
        if not isinstance(s, str):
            continue
        if not s.startswith("workload:"):
            continue
        label = s[len("workload:"):]
        if _WORKLOAD_LABEL_RE.match(label):
            return label
    return None


def _archive_workload_output(item, *, reason="done"):
    """Best-effort archive of a workload-bound queue item's stdout file.

    Workload-driven queue items (created by `workload run <label>`) carry
    scope `["workload:<label>"]` and have NO entry in the active-agents
    map (workloads aren't subagents). Their stdout/stderr lands in
    ``WORKLOAD_OUTPUT_DIR/<label>.output`` (default
    ``/tmp/claude-workloads/<label>.output``) which is on tmpfs and gets
    cleaned up. To make historical workload logs survive /tmp cleanup +
    session restart the same way subagent JSONL transcripts do, this
    helper copies that file into ``QUEUE_LOG_ARCHIVE_DIR`` at queue-done
    / queue-abandon time.

    Lifecycle / safety contract — mirrors ``_archive_agent_transcript``:

    * Best-effort. Missing source file or copy errors log to stderr and
      return None — the lifecycle transition completes regardless.
    * Idempotent on dest existence: if the archive already exists for
      this queue id we leave it alone (first archive wins) and return
      its relative path.
    * Path-traversal-safe. Both the queue id and the workload label are
      regex-gated before any filesystem walk.

    Returns the relative-to-archive-dir filename
    (``"<qid>.workload.txt"``) on success, or None on failure /
    not-applicable. The caller stores this on the item as
    ``log_archive_path`` (same field used by the agent variant — the
    suffix differentiates the on-disk format for downstream readers).
    """
    qid = item.get("id")
    if not isinstance(qid, str) or not qid:
        return None

    if not re.match(r"^q-[a-z0-9-]{4,64}$", qid):
        return None

    label = _extract_workload_label(item.get("scope") or [])
    if label is None:
        # Not a workload item — nothing to archive here. Caller will
        # have separately tried the agent-transcript variant.
        return None

    archive_name = f"{qid}.workload.txt"
    dest = QUEUE_LOG_ARCHIVE_DIR / archive_name

    # Idempotent: never overwrite. Same rule as the agent variant.
    if dest.exists():
        return archive_name

    src = WORKLOAD_OUTPUT_DIR / f"{label}.output"
    if not src.is_file():
        print(
            f"[archive] no workload output file for {qid} label={label}; "
            f"checked {src} ({reason})",
            file=sys.stderr,
        )
        return None

    try:
        QUEUE_LOG_ARCHIVE_DIR.mkdir(parents=True, exist_ok=True)
    except OSError as exc:
        print(
            f"[archive] failed to create {QUEUE_LOG_ARCHIVE_DIR}: {exc}",
            file=sys.stderr,
        )
        return None

    try:
        shutil.copyfile(src, dest)
    except OSError as exc:
        print(
            f"[archive] copy failed {src} -> {dest}: {exc}",
            file=sys.stderr,
        )
        return None

    print(
        f"[archive] {qid} -> {archive_name} (from workload={label}, reason={reason})",
        file=sys.stderr,
    )
    return archive_name


def _archive_for_item(item, *, reason="done"):
    """Dispatch to the appropriate archive helper for ``item``.

    Workload-bound items (scope contains ``workload:<label>``) get the
    workload-output archive. Everything else falls through to the agent
    transcript archive. The two are mutually exclusive — workload items
    have no active-agent record by construction.

    Returns the archive filename (relative to ``QUEUE_LOG_ARCHIVE_DIR``)
    or None. Best-effort: failures inside the helpers are non-fatal and
    surface only as stderr warnings. Caller stamps ``log_archive_path``
    on the item with whatever we return.
    """
    if _extract_workload_label(item.get("scope") or []) is not None:
        return _archive_workload_output(item, reason=reason)
    return _archive_agent_transcript(item, reason=reason)


# ---------------------------------------------------------------------------
# Force-start autostop + recovery bundle (added 2026-05-02)
# ---------------------------------------------------------------------------
#
# When `queue force-start q-X` flips a blocked-pending item to running, any
# OTHER running item whose scope overlaps q-X's scope is now (per Andrew's
# 2026-05-02 21:10 UTC directive) auto-abandoned and its recovery context
# captured for the new agent to triage. The interrupter (the new agent)
# decides resume/integrate/stash/abandon — we do NOT auto-stash. We just
# bundle up the breadcrumbs so the next operator has the full picture.


def _extract_repo_paths_from_scope(scope_tokens):
    """Map scope tokens to local git-repo working-tree paths (best effort).

    Scope tokens we know how to map:
        ``repo:NAME``    -> ``~/repos/NAME`` (if present and a git repo)
        ``file:PATH``    -> nearest enclosing git repo root for PATH

    Tokens that don't resolve are silently dropped — the recovery bundle
    is always best-effort.
    """
    home = Path.home()
    repos_root = home / "repos"
    out = []
    seen = set()

    def _git_root(path):
        # Walk up looking for a `.git` directory. Capped at 8 levels to
        # avoid pathological filesystems eating cycles.
        p = Path(path)
        for _ in range(8):
            if (p / ".git").exists():
                return p
            if p.parent == p:
                return None
            p = p.parent
        return None

    for token in scope_tokens or []:
        if not isinstance(token, str):
            continue
        if token.startswith("repo:"):
            name = token[len("repo:"):].strip()
            if not name:
                continue
            cand = repos_root / name
            if (cand / ".git").exists() or cand.is_dir():
                if str(cand) in seen:
                    continue
                seen.add(str(cand))
                out.append(cand)
        elif token.startswith("file:"):
            raw = token[len("file:"):].strip()
            if not raw:
                continue
            # Expand ~ if present (scope tokens can include user-home paths).
            try:
                p = Path(os.path.expanduser(raw))
            except Exception:
                continue
            if not p.exists():
                # The path itself may be gone; still try to walk up the
                # parent chain to find a repo root.
                p = p.parent
            root = _git_root(p)
            if root is None:
                continue
            if str(root) in seen:
                continue
            seen.add(str(root))
            out.append(root)
        # `resource:` tokens are abstract (e.g. resource:hardware) — no
        # local working tree to snapshot. Skipped.

    return out


def _git_status_and_diff(repo_path, *, max_diff_chars=200_000):
    """Capture porcelain status + unified diff for a git repo, best-effort.

    Returns a dict ``{"path": str, "status": str, "diff": str,
    "diff_truncated": bool}`` or None on hard failure (not a repo).

    The diff is capped at ``max_diff_chars`` so a runaway uncommitted
    binary blob can't blow up the bundle file. ``diff_truncated`` flags
    truncation.
    """
    repo_path = Path(repo_path)
    git_dir = repo_path / ".git"
    if not git_dir.exists():
        return None

    def _run_git(*argv):
        try:
            r = subprocess.run(
                ["git", "-C", str(repo_path), *argv],
                capture_output=True,
                text=True,
                timeout=15,
            )
            if r.returncode != 0:
                return ""
            return r.stdout
        except Exception:
            return ""

    status = _run_git("status", "--porcelain=v1", "--untracked-files=normal")
    diff = _run_git("diff", "--no-color")
    truncated = False
    if len(diff) > max_diff_chars:
        diff = diff[:max_diff_chars]
        truncated = True

    return {
        "path": str(repo_path),
        "status": status,
        "diff": diff,
        "diff_truncated": truncated,
    }


def _agent_jsonl_path_for_queue(queue_id):
    """Resolve the live ``agent-<id>.jsonl`` path for a running queue item.

    Returns ``Path`` or None. This is the live (in-progress) transcript
    of the agent that owns the queue id, distinct from the archived copy
    at QUEUE_LOG_ARCHIVE_DIR/<qid>.jsonl that lands at done/abandon time.
    """
    aid = _agent_id_for_queue(queue_id)
    if aid is None:
        return None
    return _find_agent_jsonl(aid)


def _read_first_user_prompt_from_jsonl(jsonl_path, *, max_chars=20_000):
    """Pull the FIRST user message out of an agent's JSONL transcript.

    The first non-sidechain user record is the original Agent-tool prompt
    (the prompt the main loop dispatched the subagent with). We walk
    forward until we find a record where ``message.role == "user"`` and
    ``message.content`` is a string (or a list of content blocks we can
    flatten to text). Returns the text, capped at ``max_chars``, or None
    if the file is missing / unreadable / has no user message.
    """
    if jsonl_path is None:
        return None
    try:
        with open(jsonl_path, "r") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    rec = json.loads(line)
                except (json.JSONDecodeError, ValueError):
                    continue
                msg = rec.get("message")
                if not isinstance(msg, dict):
                    continue
                if msg.get("role") != "user":
                    continue
                content = msg.get("content")
                text = None
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    pieces = []
                    for blk in content:
                        if isinstance(blk, dict) and blk.get("type") == "text":
                            t = blk.get("text")
                            if isinstance(t, str):
                                pieces.append(t)
                    if pieces:
                        text = "\n".join(pieces)
                if text is None:
                    continue
                truncated = False
                if len(text) > max_chars:
                    text = text[:max_chars]
                    truncated = True
                return {"text": text, "truncated": truncated}
    except OSError:
        return None
    return None


def _capture_recovery_for_item(item):
    """Build the recovery dict for one autostopped peer queue item.

    Captures: queue id/group/desc/summary/scope, the agent's live JSONL
    path, the original prompt (best-effort extracted), the
    /tmp/claude-1000/.../tasks/<aid>.output path (if any), and per-repo
    git status + diff for every repo we can resolve from the item's
    scope tokens. None of these are required — every field defaults to
    None or [] on failure so the bundle is always serialisable.
    """
    qid = item.get("id")
    aid = _agent_id_for_queue(qid) if qid else None

    jsonl_path = _find_agent_jsonl(aid) if aid else None
    prompt = _read_first_user_prompt_from_jsonl(jsonl_path) if jsonl_path else None

    # Best-effort guess at the .output path — the harness writes one per
    # task at /tmp/claude-1000/-home-<user>/<session-uuid>/tasks/<aid>.output
    # but the agent_id we resolve here uses claude-watch's `a*` form. The
    # task-id is the same string post-prefix. We surface the directory we
    # think it lives in rather than asserting — the new agent can ls it.
    task_output_path = None
    if aid:
        candidates = []
        try:
            user = os.environ.get("USER", "hndrewaall")
            uid = os.environ.get("UID") or os.getuid()
            roots = [
                Path(f"/tmp/claude-{uid}/-home-{user}"),
            ]
            for r in roots:
                if not r.is_dir():
                    continue
                # Look for <session>/tasks/<aid>.output and tasks/<aid>.output
                for sess in [r] + list(r.iterdir()):
                    if not sess.is_dir():
                        continue
                    cand = sess / "tasks" / f"{aid}.output"
                    if cand.exists():
                        candidates.append(cand)
        except Exception:
            candidates = []
        if candidates:
            # Most-recent wins
            candidates.sort(key=lambda p: p.stat().st_mtime, reverse=True)
            task_output_path = str(candidates[0])

    repos = _extract_repo_paths_from_scope(item.get("scope", []))
    repo_snapshots = []
    for r in repos:
        snap = _git_status_and_diff(r)
        if snap is not None:
            repo_snapshots.append(snap)

    return {
        "queue_id": qid,
        "group_id": item.get("group_id"),
        "scope": list(item.get("scope", [])),
        "summary": _item_summary(item),
        "description": item.get("description", ""),
        "agent_id": aid,
        "agent_jsonl_path": str(jsonl_path) if jsonl_path else None,
        "task_output_path": task_output_path,
        "original_prompt": prompt,
        "repo_snapshots": repo_snapshots,
        "started_at": item.get("started_at"),
        "registered_at": item.get("registered_at"),
        "created_by": item.get("created_by", ""),
    }


def _agent_kill_best_effort(agent_id):
    """Try to kill the agent process tree for ``agent_id`` via claude-watch.

    Returns a dict describing the outcome (success, missing tool, no live
    process, error). Never raises. Agents between API calls (no live
    bash child) silently no-op — the obligations gate + abandoned queue
    row are sufficient to neutralise them on their next tool call.
    """
    if not isinstance(agent_id, str) or not agent_id:
        return {"ok": False, "reason": "no agent_id"}
    cli = shutil.which("claude-watch") or shutil.which("agent-ctl")
    if not cli:
        return {"ok": False, "reason": "claude-watch CLI not on PATH"}
    try:
        r = subprocess.run(
            [cli, "agent", "kill", agent_id],
            capture_output=True,
            text=True,
            timeout=15,
        )
        return {
            "ok": r.returncode == 0,
            "exit_code": r.returncode,
            "stdout": r.stdout[-500:],
            "stderr": r.stderr[-500:],
        }
    except Exception as exc:  # noqa: BLE001 -- best-effort
        return {"ok": False, "reason": f"exception: {exc.__class__.__name__}: {exc}"}


def _autostop_overlapping_peers(items, target, *, raw_reason):
    """Mark every running scope-overlapping peer of ``target`` as abandoned.

    Mutates ``items`` in place: each conflicting peer's status flips to
    ``abandoned`` with a clear ``abandon_reason`` explaining the override.
    Recovery bundles are captured BEFORE the mutation so we still have
    access to the running-state agent_id. Returns a list of bundle dicts
    (one per autostopped peer); callers persist them into the q-X bundle
    file and emit them in the claude-event.

    Best-effort agent kill is attempted for each abandoned peer. Failures
    are recorded inside the bundle (``agent_kill_outcome``) but never
    block the queue write — the abandon row + the obligations gate are
    sufficient to halt the agent on its next tool call regardless.

    Same atomic semantics as the surrounding flock — the caller (cmd_queue
    _force_start) holds the queue lock for this entire window.
    """
    target_id = target.get("id")
    target_scope = target.get("scope", [])
    abandoned_at = _fmt_ts()
    bundles = []
    for peer in items:
        if peer is target:
            continue
        if peer.get("id") == target_id:
            continue
        if peer.get("status") not in RUNNING_STATUSES:
            continue
        if not _scope_sets_overlap(
            _serializing_scope(peer.get("scope", [])),
            _serializing_scope(target_scope),
        ):
            continue

        # Capture BEFORE mutating: _agent_id_for_queue uses claude-watch's
        # active-agents.json which is keyed on queue_id, so the lookup
        # works either way, but we want to snapshot the running state for
        # downstream debugging.
        bundle = _capture_recovery_for_item(peer)

        # Best-effort kill (recorded in the bundle, never fatal).
        if bundle.get("agent_id"):
            bundle["agent_kill_outcome"] = _agent_kill_best_effort(
                bundle["agent_id"],
            )
        else:
            bundle["agent_kill_outcome"] = {
                "ok": False,
                "reason": "no agent_id resolved from active-agents.json",
            }

        # Mutate the peer record. Mirror the abandon-reason convention
        # used by cmd_queue_abandon so anything reading abandoned_reason
        # gets a uniform shape.
        peer["status"] = "abandoned"
        peer["abandoned_at"] = abandoned_at
        peer["abandon_reason"] = (
            f"autostopped by force-start of {target_id}: {raw_reason}"
        )
        peer["group_head"] = False
        peer["autostopped_by_force_start"] = target_id

        # Archive the spawning subagent's transcript (or workload output,
        # for workload-bound items) inside the queue lock window so the
        # archive lands BEFORE the queue.json write that transitions the
        # row to abandoned. _archive_for_item dispatches by scope and is
        # idempotent + best-effort.
        archive_path = _archive_for_item(peer, reason="autostop-force-start")
        if archive_path:
            peer["log_archive_path"] = archive_path

        bundle["abandoned_at"] = abandoned_at
        bundle["abandon_reason"] = peer["abandon_reason"]
        bundle["log_archive_path"] = peer.get("log_archive_path")

        bundles.append(bundle)

    return bundles


def _write_force_start_bundle(target_id, target_summary, raw_reason,
                              autostop_bundles):
    """Persist the per-force-start recovery bundle file.

    Path: ``FORCE_START_BUNDLE_DIR / <target_id>.json``. Idempotent: if
    the file already exists (rare — same q-X being force-started twice)
    we overwrite. The new agent's prompt should reference this path.

    Returns the path string on success, None on failure. Best-effort:
    failures log to stderr but never block the force-start.
    """
    if not isinstance(target_id, str) or not target_id:
        return None
    payload = {
        "schema_version": 1,
        "force_started_queue_id": target_id,
        "force_started_summary": target_summary,
        "force_started_reason": raw_reason,
        "force_started_at": _fmt_ts(),
        "autostopped_peers": autostop_bundles,
    }
    try:
        FORCE_START_BUNDLE_DIR.mkdir(parents=True, exist_ok=True)
        dest = FORCE_START_BUNDLE_DIR / f"{target_id}.json"
        # Atomic write via tmp+rename so a partial bundle never leaves a
        # corrupted file behind.
        tmp = dest.with_suffix(".json.tmp")
        tmp.write_text(json.dumps(payload, indent=2) + "\n")
        os.replace(tmp, dest)
        return str(dest)
    except OSError as exc:
        print(
            f"[force-start] failed to write recovery bundle for {target_id}: {exc}",
            file=sys.stderr,
        )
        return None


def cmd_queue_add(args):
    scope_raw = args.scope or []
    if not scope_raw:
        print("ERROR: at least one --scope required (e.g. --scope '*')", file=sys.stderr)
        sys.exit(1)
    # Split each --scope value on commas so callers can pass either
    #   --scope foo --scope bar
    # or
    #   --scope foo,bar
    # interchangeably. Whitespace around tokens is stripped (in case anyone
    # writes `--scope foo, bar`). Empty fragments (e.g. trailing comma) are
    # dropped. Andrew flagged 2026-04-27 after q-3dfa silently failed to
    # serialize behind q-8106 because the comma-joined scope was stored as a
    # single opaque token, making exact-match conflict detection miss it.
    scope_split = []
    seen_split = set()
    for raw in scope_raw:
        for piece in raw.split(","):
            piece = piece.strip()
            if not piece:
                continue
            if piece in seen_split:
                continue
            seen_split.add(piece)
            scope_split.append(piece)
    if not scope_split:
        print("ERROR: at least one --scope required (e.g. --scope '*')", file=sys.stderr)
        sys.exit(1)
    try:
        scope = [_normalize_token(t) for t in scope_split]
    except ValueError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)
    context = None
    if args.context:
        try:
            context = json.loads(args.context)
        except json.JSONDecodeError:
            print(f"ERROR: --context must be valid JSON: {args.context}", file=sys.stderr)
            sys.exit(1)

    # Soft-required one-line summary. Andrew 2026-04-19: "update queue
    # notifications to include one line summary. might have to require one
    # as input for task enqueuing ... like 10ish words long". We still accept
    # items without --summary (to avoid breaking legacy scripts / migration),
    # but we warn loudly to stderr so the caller notices. Pingme notifications
    # for items without a summary will read "(no summary)".
    summary = (args.summary or "").strip() or DEFAULT_SUMMARY
    if summary == DEFAULT_SUMMARY:
        print(
            "warning: no --summary provided; pingme notifications will say "
            "'(no summary)'. Pass --summary \"~10 word headline\" next time.",
            file=sys.stderr,
        )

    # ------------------------------------------------------------------
    # HARD-FAIL spawn-gate: if any currently-running item has overlapping
    # scope, refuse to even enqueue the item. Andrew 2026-04-17:
    #   "make sure it's not just a warning, but a loud failure with all
    #    caps and explicit instructions not to run"
    # This is intentional: adding without running-conflict check lets the
    # main loop queue up scope-overlapping work and then race to spawn it
    # before the running item finishes. Hard-fail on add forces the caller
    # to handle the conflict consciously (wait, or use --force-enqueue).
    # ------------------------------------------------------------------
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]

        # Parse --depends-on (comma-separated) and validate the targets
        # exist NOW. Each dep is materialized as a `task:<id>` scope token
        # (added 2026-05-08). The legacy `depends_on` field is no longer
        # written; the read-time migration in `_queue_open_locked`
        # translates pre-existing entries on next load.
        deps_raw = getattr(args, "depends_on", None) or []
        deps_split: list[str] = []
        seen_dep = set()
        for raw in deps_raw:
            for piece in str(raw).split(","):
                piece = piece.strip()
                if not piece:
                    continue
                if piece in seen_dep:
                    continue
                seen_dep.add(piece)
                deps_split.append(piece)
        # Pull any task: tokens already supplied via --scope into the same
        # bucket so they share validation + dedupe with --depends-on. We
        # leave them in the scope list either way; dedupe below ensures we
        # don't double-stamp.
        scope_task_targets: list[str] = []
        for tok in scope:
            tgt = _task_token_target(tok)
            if tgt and tgt not in seen_dep:
                seen_dep.add(tgt)
                scope_task_targets.append(tgt)
        all_dep_targets = deps_split + scope_task_targets
        if all_dep_targets:
            existing_ids_now = {it["id"] for it in items}
            unknown = [d for d in all_dep_targets if d not in existing_ids_now]
            if unknown:
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                print(
                    f"ERROR: --depends-on references unknown queue id(s): "
                    f"{','.join(unknown)}",
                    file=sys.stderr,
                )
                sys.exit(1)

        # Materialize --depends-on as task: scope tokens. Append rather
        # than prepend so user-supplied --scope ordering is preserved as
        # the head of the list. Skip targets already present as task:
        # tokens (so --scope task:q-A --depends-on q-A is a no-op union).
        existing_task_targets = {
            _task_token_target(t) for t in scope if _is_task_token(t)
        }
        for d in deps_split:
            if d not in existing_task_targets:
                scope.append(f"task:{d}")
                existing_task_targets.add(d)

        # Recompute deps_split from scope so downstream display reflects
        # the canonical dep set (--depends-on entries plus any task:
        # tokens that came in via --scope).
        deps_split = [
            _task_token_target(t) for t in scope if _is_task_token(t)
        ]

        running_conflicts = _running_scope_conflicts(items, scope)

        if running_conflicts and not args.force_enqueue:
            # Release lock before exiting so concurrent callers aren't blocked.
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            _print_add_conflict_banner(scope, running_conflicts)
            sys.exit(3)

        overlapping = _group_ids_overlapping(items, scope)

        if len(overlapping) == 0:
            group_id = _new_group_id()
        elif len(overlapping) == 1:
            group_id = overlapping[0]
        else:
            # Merge all overlapping groups into a brand-new group.
            group_id = _new_group_id()
            for it in items:
                if it.get("group_id") in overlapping:
                    it["group_id"] = group_id
            log_completed(
                f"[queue merge] {len(overlapping)} groups merged into {group_id}",
                extra={
                    "source": "queue",
                    "event": "merge",
                    "merged_groups": overlapping,
                    "new_group_id": group_id,
                },
            )

        new_id = _new_id()
        # Ensure unique id even if secrets collides (vanishingly rare).
        existing_ids = {it["id"] for it in items}
        while new_id in existing_ids:
            new_id = _new_id()

        item = {
            "id": new_id,
            "description": args.description,
            "summary": summary,
            "scope": scope,
            "group_id": group_id,
            "group_head": False,
            "status": "pending",
            "priority": int(args.priority),
            "created_at": _fmt_ts(),
            "created_by": args.created_by or "main-loop",
        }
        if context is not None:
            item["context"] = context
        items.append(item)

        _recompute_group_heads(items)

        # Determine ready_now + serialized_after
        group_members_sorted = sorted(
            [it for it in _group_members(items, group_id) if it.get("status") == "pending"],
            key=_sort_key,
        )
        position = next((i + 1 for i, it in enumerate(group_members_sorted) if it["id"] == new_id), -1)
        locked_scopes = data.get("locked_scopes") or {}
        ready_now = _item_is_ready(items, item, locked_scopes=locked_scopes)
        lock_blockers = _locked_tokens_blocking_item(item, locked_scopes)
        serialized_after = [it["id"] for it in group_members_sorted if it["id"] != new_id and _sort_key(it) < _sort_key(item)]
        # Also consider in-flight (running or wedged) items in same group
        running_in_group = [it["id"] for it in _group_members(items, group_id) if it.get("status") in RUNNING_STATUSES]
        serialized_after = running_in_group + serialized_after

        _queue_write_and_unlock(fh, data)
    except Exception:
        try:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
        except Exception:
            pass
        raise

    # Surface unmet dependencies separately from scope-serialized blockers
    # so the main loop / UI can distinguish "wait for queue head" from
    # "wait for explicit dep". depends_on is the operator-declared edge.
    dep_blockers: list[str] = []
    if deps_split:
        items_by_id_now = {it["id"]: it for it in items}
        for d in deps_split:
            tgt = items_by_id_now.get(d)
            if tgt is None or tgt.get("status") != "done":
                dep_blockers.append(d)

    # Build spawn_instruction string for the main loop to read literally.
    if ready_now:
        spawn_instruction = f"READY: register-and-spawn (session-task queue register {new_id})"
    else:
        parts: list[str] = []
        if lock_blockers:
            parts.append("locks: " + ",".join(lock_blockers))
        if dep_blockers:
            parts.append("deps: " + ",".join(dep_blockers))
        if serialized_after:
            parts.append("queue: " + ",".join(serialized_after))
        if parts:
            spawn_instruction = "BLOCKED: do not spawn, wait for " + " | ".join(parts)
        else:
            spawn_instruction = "BLOCKED: do not spawn (no head visible)"

    # Print result. running_conflicts is only populated via --force-enqueue
    # now, since without it we would have already exited above.
    running_conflict_info = [
        {"id": c["id"], "group_id": c.get("group_id"), "scope": c.get("scope", [])}
        for c in running_conflicts
    ]

    if args.json:
        print(json.dumps({
            "id": new_id,
            "group_id": group_id,
            "position": position,
            "ready_now": ready_now,
            "serialized_after": serialized_after,
            "depends_on": deps_split,
            "dep_blockers": dep_blockers,
            "lock_blockers": lock_blockers,
            "scope": scope,
            "running_scope_conflicts": running_conflict_info,
            "spawn_instruction": spawn_instruction,
        }, indent=2))
    else:
        print(f"added: {new_id}")
        print(f"assigned: group={group_id}, position={position}, ready_now={'true' if ready_now else 'false'}, serialized_after={serialized_after}")
        if deps_split:
            print(f"depends_on: {deps_split} (unmet: {dep_blockers})")
        if lock_blockers:
            print(f"lock_blockers: {lock_blockers}")
        print(f"spawn_instruction: {spawn_instruction}")
        if running_conflicts:
            # Only reachable via --force-enqueue. Still scream.
            print("", file=sys.stderr)
            print("!" * 70, file=sys.stderr)
            print("!! FORCE-ENQUEUED OVER RUNNING SCOPE CONFLICT. DO NOT SPAWN THIS AGENT.",
                  file=sys.stderr)
            for c in running_conflicts:
                print(f"!!   running {c['id']} (group {c.get('group_id')}): "
                      f"{','.join(c.get('scope', []))}", file=sys.stderr)
            print("!! RUN THE CONFLICTING WORK FIRST OR WAIT FOR IT TO FINISH.",
                  file=sys.stderr)
            print("!" * 70, file=sys.stderr)

    # NOTE: queue-added claude-event emit removed 2026-04-27 (Andrew DM:
    # "Remove queue added event, too noisy"). queue add is task creation,
    # not a state transition. The main loop already holds the return value
    # from queue add — surfacing it again as an event was double-handling.
    # State-transition emits (queue-running, queue-done, queue-abandoned)
    # remain in their respective code paths.


def _print_add_conflict_banner(new_scope, running_conflicts):
    """Scream-worthy ALL CAPS stderr banner for queue-add hard-fail.

    Used when a queue add attempts to enqueue scope that overlaps a
    currently-running item. The caller is expected to read this banner,
    abort the spawn attempt, and either (a) wait for the running item to
    finish, or (b) surface the conflict to a human.
    """
    print("", file=sys.stderr)
    bar = "!" * 72
    print(bar, file=sys.stderr)
    print("!! QUEUE ADD REFUSED: SCOPE CONFLICT WITH RUNNING ITEM(S).",
          file=sys.stderr)
    print("!! DO NOT SPAWN ANY AGENT FOR THIS WORK.", file=sys.stderr)
    print("!! RUN THE CONFLICTING WORK FIRST OR WAIT FOR IT TO FINISH.",
          file=sys.stderr)
    print("!!", file=sys.stderr)
    print(f"!! NEW SCOPE: {','.join(new_scope)}", file=sys.stderr)
    print("!! CONFLICTING RUNNING ITEM(S):", file=sys.stderr)
    for c in running_conflicts:
        print(
            f"!!   - {c['id']} (group {c.get('group_id')}): "
            f"{','.join(c.get('scope', []))}",
            file=sys.stderr,
        )
    print("!!", file=sys.stderr)
    print("!! IF YOU ABSOLUTELY MUST ENQUEUE OVER THIS CONFLICT (RARE):",
          file=sys.stderr)
    print("!!   session-task queue add ... --force-enqueue",
          file=sys.stderr)
    print("!! BUT YOU STILL MUST NOT SPAWN AN AGENT FOR IT UNTIL THE",
          file=sys.stderr)
    print("!! RUNNING ITEM(S) ABOVE REACH A DONE/ABANDONED STATE.",
          file=sys.stderr)
    print(bar, file=sys.stderr)


def cmd_queue_list(args):
    fh, data = _queue_open_locked("r")
    items = list(data["items"])
    locked_scopes = data.get("locked_scopes") or {}
    _queue_unlock_readonly(fh)

    # Filter
    if args.group:
        items = [it for it in items if it.get("group_id") == args.group]
    if args.ready:
        items = [it for it in items if _item_is_ready(data["items"], it, locked_scopes=locked_scopes)]
    elif not args.all:
        # Default view: in-flight items (pending + running + wedged). Wedged
        # included so the operator notices stuck agents at a glance — the
        # whole point of the wedged state is to surface attention.
        items = [it for it in items if it.get("status") in ACTIVE_STATUSES]

    items.sort(key=lambda it: (it.get("group_id", ""), _sort_key(it)))

    if args.json:
        print(json.dumps(items, indent=2))
        return

    if not items:
        print("(no items)")
        return

    # Tabular. WEDGED items get a leading `!` marker on the head column;
    # BLOCKED items get a leading `~` marker (distinct so the eye catches
    # the difference: `!` = system stuck, `~` = parked on external). Status
    # column shows `wedged` / `blocked` verbatim so JSON consumers and
    # grepping operators see the same word.
    # ANSI color (TTY only) further distinguishes: red for wedged
    # (system broken), yellow for blocked (waiting on external). Other
    # rows render plain.
    is_tty = sys.stdout.isatty()
    RED = "\033[31m" if is_tty else ""
    YELLOW = "\033[33m" if is_tty else ""
    RESET = "\033[0m" if is_tty else ""
    print(f"{'ID':22} {'GROUP':14} {'ST':8} {'PR':3} {'H':1} {'SCOPE'}")
    for it in items:
        status = it.get("status")
        if status == "wedged":
            head_mark = "!"
            color, color_reset = RED, RESET
        elif status == "blocked":
            head_mark = "~"
            color, color_reset = YELLOW, RESET
        else:
            head_mark = "*" if it.get("group_head") else " "
            color, color_reset = "", ""
        scope_str = ",".join(it.get("scope", []))
        if len(scope_str) > 48:
            scope_str = scope_str[:45] + "..."
        summary = _item_summary(it)
        if len(summary) > 90:
            summary = summary[:87] + "..."
        desc = it.get("description", "")
        if len(desc) > 80:
            desc = desc[:77] + "..."
        print(
            f"{color}{it['id']:22} {it.get('group_id',''):14} "
            f"{it.get('status',''):8} {it.get('priority',5):<3} {head_mark} "
            f"{scope_str}{color_reset}"
        )
        print(f"  summary: {summary}")
        print(f"  desc   : {desc}")
        # Surface the wedge / block reason inline so `queue list` is the
        # one-stop diagnosis surface -- no need to drill into `queue show`
        # for the most common operator question ("why is this stuck?").
        if status == "wedged" and it.get("wedged_reason"):
            print(f"  wedged : {it.get('wedged_reason')}")
        if status == "blocked" and it.get("block_reason"):
            print(f"  blocked: {it.get('block_reason')}")


def cmd_queue_show(args):
    fh, data = _queue_open_locked("r")
    items = list(data["items"])
    locked_scopes = data.get("locked_scopes") or {}
    _queue_unlock_readonly(fh)
    for it in items:
        if it["id"] == args.id:
            ready = _item_is_ready(items, it, locked_scopes=locked_scopes)
            out = dict(it)
            out["ready_now"] = ready
            out["group_scope"] = _group_scope(items, it["group_id"])
            out["lock_blockers"] = _locked_tokens_blocking_item(it, locked_scopes)
            # Surface dep state + dependents so a single `queue show` is
            # enough to inspect the dependency edges in / out of this item
            # without re-reading queue.json. Deps live as `task:<id>` scope
            # tokens (canonical 2026-05-08+); we expose the legacy
            # `depends_on` field in the output too so consumers (UI,
            # tests) keep the same shape.
            deps = list(_iter_dep_ids(it))
            by_id = {x.get("id"): x for x in items if x.get("id")}
            dep_status = []
            unmet = []
            for d in deps:
                tgt = by_id.get(d)
                if tgt is None:
                    dep_status.append({"id": d, "status": "missing"})
                    unmet.append(d)
                else:
                    s = tgt.get("status") or "?"
                    dep_status.append({"id": d, "status": s})
                    if s != "done":
                        unmet.append(d)
            # Mirror the dep set on the legacy `depends_on` key so existing
            # UI / tests / scripts keep reading the same field. The on-disk
            # record stores deps only as task: scope tokens.
            out["depends_on"] = deps
            out["depends_on_status"] = dep_status
            out["dep_blockers"] = unmet
            out["dep_cycle"] = _has_dep_cycle(items, it["id"]) if deps else False
            # Reverse-edges: items that name THIS item in their deps (via
            # task: scope token, or legacy depends_on for forward-compat).
            dependents = [
                x.get("id")
                for x in items
                if x.get("id") and it["id"] in list(_iter_dep_ids(x))
                and x.get("id") != it["id"]
            ]
            out["dependents"] = dependents
            print(json.dumps(out, indent=2))
            return
    print(f"not found: {args.id}", file=sys.stderr)
    sys.exit(1)


