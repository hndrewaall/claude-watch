def cmd_queue_pop(args):
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = None
        if args.id:
            target = next((it for it in items if it["id"] == args.id), None)
            if target is None:
                print(f"not found: {args.id}", file=sys.stderr)
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                sys.exit(1)
            if not _item_is_ready(items, target):
                print(f"not ready: {args.id}", file=sys.stderr)
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                sys.exit(1)
        else:
            ready = [it for it in items if _item_is_ready(items, it)]
            ready.sort(key=_sort_key)
            if not ready:
                print("(nothing ready)")
                fcntl.flock(fh, fcntl.LOCK_UN)
                fh.close()
                sys.exit(1)
            target = ready[0]

        # Belt-and-suspenders spawn-gating: even though _item_is_ready has
        # already checked group-head status, also refuse to pop if any OTHER
        # running item has overlapping scope. This catches the case where an
        # item got registered through a raced add, or there's an untracked
        # in-flight agent on the same scope (rare but possible). Mirrors the
        # `queue register` invariant so `pop` and `register` behave the same.
        ok, reasons, conflicts = _spawn_check(items, target)
        if not ok:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print("", file=sys.stderr)
            bar = "!" * 72
            print(bar, file=sys.stderr)
            print(f"!! POP REFUSED: {target['id']} IS NOT CLEAR TO SPAWN.",
                  file=sys.stderr)
            print("!! DO NOT SPAWN ANY AGENT FOR THIS WORK.", file=sys.stderr)
            print("!! RUN THE CONFLICTING WORK FIRST OR WAIT FOR IT TO FINISH.",
                  file=sys.stderr)
            print("!! REASONS:", file=sys.stderr)
            for r in reasons:
                print(f"!!   - {r}", file=sys.stderr)
            if conflicts:
                print("!! RUNNING SCOPE OVERLAPS:", file=sys.stderr)
                for c in conflicts:
                    print(
                        f"!!   - {c['id']} (group {c.get('group_id')}): "
                        f"{','.join(c.get('scope', []))}",
                        file=sys.stderr,
                    )
            print(bar, file=sys.stderr)
            sys.exit(2)

        target["status"] = "running"
        target["started_at"] = _fmt_ts()
        _recompute_group_heads(items)
        popped = dict(target)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise
    print(json.dumps(popped, indent=2))


def _spawn_check(items, item):
    """Return (ok, reasons, conflicts) tuple for spawn-gating.

    ok (bool):
        True iff it is safe to spawn an agent for this queue item right now.

    reasons (list[str]):
        Human-readable rejection reasons if not ok.

    conflicts (list[dict]):
        Running items whose scope overlaps this item's scope (excluding
        the item itself if it's already running).
    """
    reasons = []
    conflicts = _running_scope_conflicts(
        items, item.get("scope", []), exclude_id=item.get("id"),
    )

    status = item.get("status")
    if status not in ("pending", "running"):
        reasons.append(f"item status is {status!r} (must be pending or running)")
    elif status == "pending":
        if not _item_is_ready(items, item):
            reasons.append(
                "item is not ready (blocked behind another item in its group "
                f"{item.get('group_id')!r})"
            )

    # Any cross-group running conflict is a hard reject. Same-group conflicts
    # would be a group-invariant violation (only one running per group).
    cross = [c for c in conflicts if c.get("group_id") != item.get("group_id")]
    if cross:
        reasons.append(
            "scope overlaps {n} running item(s) in other group(s): {ids}".format(
                n=len(cross),
                ids=", ".join(f"{c['id']}({c.get('group_id')})" for c in cross),
            )
        )

    same_group_running = [
        c for c in conflicts if c.get("group_id") == item.get("group_id")
    ]
    if same_group_running and item.get("status") == "pending":
        # Should be caught by _item_is_ready above, but be explicit.
        reasons.append(
            "same-group running peer(s) exist: "
            + ", ".join(c["id"] for c in same_group_running)
        )

    return (len(reasons) == 0, reasons, conflicts)


