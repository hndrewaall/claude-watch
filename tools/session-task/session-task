    q_block.add_argument(
        "--silent", action="store_true",
        help="Suppress the pingme + claude-event notifications for this operation.",
    )

    q_unblock = qsub.add_parser(
        "unblock",
        help=(
            "Flip a blocked item back to status=running. Use when the "
            "external blocker clears (operator greenlit, branch-protection "
