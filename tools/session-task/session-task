def cmd_queue_depend(args):
    """Edit explicit interjob dependencies on an existing queue item.

    `session-task queue depend <id> [--add q-AAA] [--remove q-BBB] [--clear]`

    Storage (since 2026-05-08): each dep is stored as a `task:<id>` scope
    token on the dragged item. The legacy `depends_on` field is no longer
    written; the read-time migration in `_queue_open_locked` translates
    pre-existing entries on next load. `ready_now` flips True only when
    every dep is `done`. Cross-group deps are allowed.

    Architecture (per Andrew's perf brief): WRITE is just a set
    add/remove on the dragged item. NO transitive-closure cache, NO
    cascade work. Cycles are detected lazily on READ via
    ``_has_dep_cycle``.

    --add / --remove accept comma-separated id lists. --clear wipes ALL
    task: scope tokens (regular scope tokens are preserved). Done/
    abandoned items can't acquire new deps (the deps would be moot — the
    item is already terminal).
    """
    add_raw = list(getattr(args, "add", None) or [])
    remove_raw = list(getattr(args, "remove", None) or [])
    do_clear = bool(getattr(args, "clear", False))

    if not (add_raw or remove_raw or do_clear):
        print(
            "ERROR: pass at least one of --add, --remove, --clear",
            file=sys.stderr,
        )
        sys.exit(1)

    def _flatten(raw):
        out: list[str] = []
        seen = set()
        for piece_raw in raw:
            for p in str(piece_raw).split(","):
                p = p.strip()
                if not p or p in seen:
                    continue
                seen.add(p)
                out.append(p)
        return out

    to_add = _flatten(add_raw)
    to_remove = _flatten(remove_raw)

    if args.id in to_add:
        print(
            f"ERROR: an item cannot depend on itself ({args.id})",
            file=sys.stderr,
        )
        sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(f"not found: {args.id}", file=sys.stderr)
            sys.exit(1)
        if target.get("status") not in ACTIVE_STATUSES:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                f"ERROR: cannot edit deps on {target.get('status')} item",
                file=sys.stderr,
            )
            sys.exit(1)

        existing_ids = {it["id"] for it in items}
        unknown = [d for d in to_add if d not in existing_ids]
        if unknown:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            print(
                "ERROR: --add references unknown queue id(s): "
                + ",".join(unknown),
                file=sys.stderr,
            )
            sys.exit(1)

        before = list(_iter_dep_ids(target))
        # Split the target's scope into task: tokens vs everything else
        # so we can rebuild the task-token slice without disturbing the
        # rest. --clear wipes only task: tokens; regular scope is left
        # intact.
        non_task_scope = [
            t for t in (target.get("scope") or []) if not _is_task_token(t)
        ]
        if do_clear:
            after_deps: list[str] = []
        else:
            after_deps = list(before)

        # Removes first, then adds — so `--add x --remove x` is a no-op
        # rather than a delete (callers passing both for the same id is
        # almost certainly a mistake but we don't bake in surprises).
        if to_remove:
            after_deps = [d for d in after_deps if d not in set(to_remove)]
        for a in to_add:
            if a not in after_deps:
                after_deps.append(a)

        # Rewrite scope: regular tokens first (preserves user ordering),
        # then task: tokens in dep order. Drop the legacy field if a
        # migration left it lingering.
        target["scope"] = non_task_scope + [f"task:{d}" for d in after_deps]
        target.pop("depends_on", None)
        target["depends_on_updated_at"] = _fmt_ts()
        _queue_write_and_unlock(fh, data)
    except Exception:
        try:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
        except Exception:
            pass
        raise

    # Re-read to compute ready_now under the new edge set.
    fh2, data2 = _queue_open_locked("r")
    items2 = list(data2["items"])
    locked_scopes2 = data2.get("locked_scopes") or {}
    _queue_unlock_readonly(fh2)
    fresh = next((it for it in items2 if it["id"] == args.id), None)
    ready = _item_is_ready(items2, fresh, locked_scopes=locked_scopes2) if fresh else False
    cycle = (
        _has_dep_cycle(items2, args.id)
        if (fresh and list(_iter_dep_ids(fresh)))
        else False
    )

    if getattr(args, "json", False):
        print(json.dumps(
            {
                "id": args.id,
                "depends_on": after_deps,
                "added": to_add,
                "removed": to_remove,
                "cleared": do_clear,
                "ready_now": ready,
                "dep_cycle": cycle,
            },
            indent=2,
        ))
    else:
        print(f"deps updated: {args.id}")
        print(f"  before : {before}")
        print(f"  after  : {after_deps}")
        if cycle:
            print(
                "  WARNING: dependency cycle reachable from this item; "
                "ready_now will stay false until the cycle is broken.",
                file=sys.stderr,
            )


def cmd_queue_promote(args):
    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        target = next((it for it in items if it["id"] == args.id), None)
        if target is None:
            print(f"not found: {args.id}", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        if target.get("status") != "pending":
            print(f"can only promote pending items (status={target.get('status')})", file=sys.stderr)
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            sys.exit(1)
        # Bump priority high enough to be above everyone else in the group.
        members = _group_members(items, target["group_id"])
        max_p = max((int(m.get("priority", 5)) for m in members), default=5)
        target["priority"] = max(max_p + 1, int(target.get("priority", 5)) + 1)
        target["promoted_at"] = _fmt_ts()
        # Rewrite created_at to "now" so FIFO places this FIRST among equal priorities.
        # Actually safer: leave created_at alone and trust the priority bump.
        _recompute_group_heads(items)
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise
    print(f"promoted: {args.id} (priority={target['priority']})")


_DURATION_RE = re.compile(r"^(\d+)([dhm])$")


def _parse_duration(s):
    m = _DURATION_RE.match(s)
    if not m:
        raise ValueError(f"bad duration: {s} (use Nd/Nh/Nm)")
    n, unit = int(m.group(1)), m.group(2)
    if unit == "d":
        return timedelta(days=n)
    if unit == "h":
        return timedelta(hours=n)
    return timedelta(minutes=n)


def cmd_queue_prune(args):
    cutoff = None
    if args.older_than:
        try:
            cutoff = datetime.now(timezone.utc) - _parse_duration(args.older_than)
        except ValueError as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(1)

    fh, data = _queue_open_locked("rw")
    try:
        items = data["items"]
        to_remove = []
        for it in items:
            if it.get("status") not in ("done", "abandoned"):
                continue
            if cutoff is None:
                to_remove.append(it)
                continue
            ts_str = it.get("completed_at") or it.get("abandoned_at")
            if not ts_str:
                continue
            try:
                ts = datetime.fromisoformat(ts_str)
            except ValueError:
                continue
            if ts < cutoff:
                to_remove.append(it)
        if args.dry_run:
            print(f"would prune {len(to_remove)} items")
            for it in to_remove:
                print(f"  {it['id']}  {it.get('status')}  {it.get('description','')[:60]}")
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            return
        keep = [it for it in items if it not in to_remove]
        data["items"] = keep
        _queue_write_and_unlock(fh, data)
    except Exception:
        fcntl.flock(fh, fcntl.LOCK_UN)
        fh.close()
        raise
    print(f"pruned {len(to_remove)} items")


def cmd_queue_banner(args):
    fh, data = _queue_open_locked("r")
    items = list(data["items"])
    locked_scopes = data.get("locked_scopes") or {}
    _queue_unlock_readonly(fh)
    ready = [it for it in items if _item_is_ready(items, it, locked_scopes=locked_scopes)]
    ready.sort(key=_sort_key)
    pending = [it for it in items if it.get("status") == "pending"]
    running = [it for it in items if it.get("status") == "running"]
    wedged = [it for it in items if it.get("status") == "wedged"]
    blocked = [it for it in items if it.get("status") == "blocked"]

    if not ready and not pending and not running and not wedged and not blocked:
        return  # silent when empty -- banner only when something to show

    lines = [
        "",
        "#" * 60,
        "## SESSION-TASK QUEUE — TOP READY ITEMS",
        "#" * 60,
    ]
    # Wedged items lead the banner -- they're the highest-priority operator
    # signal: "you have a stuck agent, attention required".
    if wedged:
        lines.append(f"  !! WEDGED: {len(wedged)} item(s) need operator attention")
        for it in wedged[:5]:
            wr = it.get("wedged_reason") or "no reason"
            lines.append(
                f"     - [{it['id']}] {it.get('description','')[:70]}  ({wr[:40]})"
            )
        lines.append("")
    # Blocked items: parked on an external blocker. Lower urgency than
    # wedged (system isn't broken) but still surfaces in the banner so the
    # operator remembers what's waiting on their decision.
    if blocked:
        lines.append(f"  ~~ BLOCKED: {len(blocked)} item(s) parked on external blocker")
        for it in blocked[:5]:
            br = it.get("block_reason") or "no reason"
            lines.append(
                f"     - [{it['id']}] {it.get('description','')[:70]}  ({br[:40]})"
            )
        lines.append("")
    if ready:
        for it in ready[:5]:
            lines.append(
                f"  * [{it['id']}] pr={it.get('priority',5)} {it['description'][:80]}"
            )
            lines.append(
                f"        scope: {','.join(it.get('scope', []))[:90]}"
            )
    else:
        lines.append("  (no items are READY -- everything is blocked on a running peer or unblocked below)")

    waiting = [it for it in pending if not _item_is_ready(items, it, locked_scopes=locked_scopes)]
    if waiting:
        lines.append("")
        lines.append(f"  Waiting behind a group peer: {len(waiting)} item(s)")
    if running:
        lines.append(f"  In progress (running): {len(running)} item(s)")
    if locked_scopes:
        lines.append(f"  Locked scopes: {len(locked_scopes)} (see `session-task queue locks`)")

    lines.append("#" * 60)
    lines.append("")
    print("\n".join(lines))


