def _infer_scope_from_text(text):
    """Heuristic scope inference for legacy /tmp/claude-queued-tasks.txt."""
    t = text.lower()
    scope = []

    # agent-proto: mentions
    proto_map = {
        "ebook-convert-pdf": "agent-proto:ebook-convert-pdf",
        "em-dash": "agent-proto:ebook-convert-pdf",
        "chapter-breaks": "agent-proto:ebook-convert-pdf",
        "epub-check-breaks": "agent-proto:ebook-convert-pdf",
        "line-break": "agent-proto:ebook-convert-pdf",
        "toc": "agent-proto:ebook-convert-pdf",
        "security-patcher": "agent-proto:security-patcher",
        "security-scanner": "agent-proto:security-scanner",
    }
    for needle, tok in proto_map.items():
        if needle in t and tok not in scope:
            scope.append(tok)

    # repo: mentions
    if "~/repos/docker-gomorrah" in t or "docker-gomorrah" in t or "monitoring/docker-compose" in t:
        scope.append("repo:docker-gomorrah")
    if "~/repos/media-tools" in t or "media-tools" in t or "ebook-convert-pdf" in t:
        scope.append("repo:media-tools")
    if ".claude/agents" in t or "agents/security-" in t:
        scope.append("repo:claude-config")

    # book: mentions
    if "fadr" in t or "first and rare" in t:
        scope.append("book:fadr")
    if "laws of trading" in t or "calibre id 342" in t:
        scope.append("book:laws-of-trading")

    # Dedupe
    seen = set()
    out = []
    for s in scope:
        if s not in seen:
            seen.add(s)
            out.append(s)

    if not out:
        out = ["*"]
    return out


def _parse_legacy_queue(text):
    """Parse /tmp/claude-queued-tasks.txt into a list of (description, scope)."""
    # Items start with "QUEUED" or "QUEUED N" (possibly with trailing punctuation)
    blocks = re.split(r"(?m)^QUEUED[^\n]*\n", text)
    headers = re.findall(r"(?m)^QUEUED[^\n]*", text)
    # Re-zip header + body
    items = []
    for header, body in zip(headers, blocks[1:]):
        # Trim body
        body = body.strip()
        # Use first line after header (or header itself if body is empty) as short desc
        first_line = body.splitlines()[0].strip() if body else header.strip()
        desc = f"{header.strip()} -- {first_line[:160]}"
        full = header + "\n" + body
        scope = _infer_scope_from_text(full)
        items.append((desc, scope, body))
    return items


# ---------------------------------------------------------------------------
# Manual scope locks (added 2026-05-08)
#
# A "lock" is an operator-declared scope token that pauses any pending
# queue item whose scope overlaps it. Use case: queue a follow-up task
# that depends on a real-world condition (a hardware install, a manual
# config change, an out-of-band review) and don't want it to spawn until
# the operator says go. Distinct from `--depends-on` (which waits on
# another queue item) and from in-flight scope conflicts (which clear
# automatically when the running item finishes).
#
# Workflow:
#     session-task queue lock <scope> --reason "wait for hardware"
#     session-task queue add "..." --scope <scope> --summary "..."
#     # ... real-world condition met ...
#     session-task queue unlock <scope>
#
# Stored in queue.json under `locked_scopes`, so the lock survives
# /clear, restart, compaction, and process death.
# ---------------------------------------------------------------------------


def cmd_queue_lock(args):
    """Add <scope> to the locked-scopes set."""
    scope = _normalize_token(args.scope)
    reason = (args.reason or "").strip()
    fh, data = _queue_open_locked("rw")
    try:
        locked = data.get("locked_scopes") or {}
        was_locked = scope in locked
        prev_reason = locked.get(scope, {}).get("reason", "") if was_locked else ""
        prev_locked_at = locked.get(scope, {}).get("locked_at", "") if was_locked else ""
        if was_locked:
            # Idempotent: keep the original locked_at; refresh reason only if
            # a new one was passed (otherwise leave prior reason untouched).
            new_reason = reason or prev_reason
            locked[scope] = {
                "reason": new_reason,
                "locked_at": prev_locked_at or _fmt_ts(),
            }
        else:
            locked[scope] = {"reason": reason, "locked_at": _fmt_ts()}
        data["locked_scopes"] = locked
        _queue_write_and_unlock(fh, data)
    except Exception:
        try:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
        except Exception:
            pass
        raise

    if args.json:
        print(json.dumps({
            "scope": scope,
            "reason": locked[scope]["reason"],
            "locked_at": locked[scope]["locked_at"],
            "already_locked": was_locked,
        }, indent=2))
        return

    if was_locked:
        print(f"already locked: {scope} (locked_at={locked[scope]['locked_at']})")
        if reason and reason != prev_reason:
            print(f"  reason updated: {reason!r}")
    else:
        print(f"locked: {scope}")
        if reason:
            print(f"  reason: {reason}")
        print(f"  locked_at: {locked[scope]['locked_at']}")


def cmd_queue_unlock(args):
    """Remove <scope> from the locked-scopes set.

    No-op (exit 0) if the scope wasn't locked. Items previously
    blocked-only-by-the-lock become ready immediately on the next
    readiness evaluation.
    """
    scope = _normalize_token(args.scope)
    fh, data = _queue_open_locked("rw")
    try:
        locked = data.get("locked_scopes") or {}
        was_locked = scope in locked
        prev = locked.pop(scope, None)
        data["locked_scopes"] = locked
        _queue_write_and_unlock(fh, data)
    except Exception:
        try:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
        except Exception:
            pass
        raise

    if args.json:
        print(json.dumps({
            "scope": scope,
            "was_locked": was_locked,
            "previous_reason": (prev or {}).get("reason", "") if prev else "",
            "previous_locked_at": (prev or {}).get("locked_at", "") if prev else "",
        }, indent=2))
        return

    if was_locked:
        print(f"unlocked: {scope}")
    else:
        print(f"not locked: {scope} (no-op)")


def cmd_queue_locks(args):
    """List currently locked scopes."""
    fh, data = _queue_open_locked("r")
    locked = dict(data.get("locked_scopes") or {})
    items = list(data["items"])
    _queue_unlock_readonly(fh)

    rows = []
    for scope, meta in sorted(locked.items()):
        # Count pending items currently parked behind this lock.
        held = 0
        for it in items:
            if it.get("status") != "pending":
                continue
            if scope in _locked_tokens_blocking_item(it, {scope: meta}):
                held += 1
        rows.append({
            "scope": scope,
            "reason": (meta or {}).get("reason", ""),
            "locked_at": (meta or {}).get("locked_at", ""),
            "items_held": held,
        })

    if args.json:
        print(json.dumps(rows, indent=2))
        return

    if not rows:
        print("(no locked scopes)")
        return

    print(f"{'SCOPE':40} {'LOCKED_AT':32} {'HELD':4} REASON")
    for r in rows:
        scope_str = r["scope"]
        if len(scope_str) > 39:
            scope_str = scope_str[:36] + "..."
        print(
            f"{scope_str:40} {r['locked_at']:32} {r['items_held']:<4} "
            f"{r['reason']}"
        )


def cmd_queue_migrate(args):
    src = Path(args.from_file).expanduser()
    if not src.exists():
        print(f"ERROR: source does not exist: {src}", file=sys.stderr)
        sys.exit(1)
    text = src.read_text()
    parsed = _parse_legacy_queue(text)
    if not parsed:
        print("No items parsed. Nothing to migrate.")
        return
    print(f"Parsed {len(parsed)} items from {src}")
    for i, (desc, scope, body) in enumerate(parsed, 1):
        print(f"  {i}. scope={scope}")
        print(f"      {desc[:100]}")
    if not args.yes:
        print("Re-run with --yes to commit.")
        return

    # Actually add each as a queue item.
    # Use moderate priority 5 and --created-by migrate
    added = []
    for desc, scope, body in parsed:
        ns = argparse.Namespace(
            description=desc,
            scope=scope,
            priority=5,
            context=json.dumps({"legacy_body": body}),
            created_by="migrate",
            json=True,
        )
        # Inline version of cmd_queue_add so we can collect IDs.
        try:
            norm_scope = [_normalize_token(t) for t in scope]
        except ValueError as e:
            print(f"ERROR on item: {e}", file=sys.stderr)
            continue
        try:
            context = json.loads(ns.context) if ns.context else None
        except json.JSONDecodeError:
            context = None

        fh, data = _queue_open_locked("rw")
        try:
            items = data["items"]
            overlapping = _group_ids_overlapping(items, norm_scope)
            if len(overlapping) == 0:
                group_id = _new_group_id()
            elif len(overlapping) == 1:
                group_id = overlapping[0]
            else:
                group_id = _new_group_id()
                for it in items:
                    if it.get("group_id") in overlapping:
                        it["group_id"] = group_id
                log_completed(
                    f"[queue merge] {len(overlapping)} groups merged into {group_id}",
                    extra={"source": "queue", "event": "merge",
                           "merged_groups": overlapping, "new_group_id": group_id},
                )
            new_id = _new_id()
            existing_ids = {it["id"] for it in items}
            while new_id in existing_ids:
                new_id = _new_id()
            item = {
                "id": new_id,
                "description": desc,
                "summary": DEFAULT_SUMMARY,
                "scope": norm_scope,
                "group_id": group_id,
                "group_head": False,
                "status": "pending",
                "priority": 5,
                "created_at": _fmt_ts(),
                "created_by": "migrate",
            }
            if context is not None:
                item["context"] = context
            items.append(item)
            _recompute_group_heads(items)
            _queue_write_and_unlock(fh, data)
            added.append(new_id)
        except Exception:
            fcntl.flock(fh, fcntl.LOCK_UN)
            fh.close()
            raise

    print(f"Migrated {len(added)} items: {added}")


