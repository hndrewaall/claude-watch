#!/bin/bash
# claude-event-watch: Block until a new event appears in the Claude event queue,
# then print all pending events and exit. Intended to be run as a background
# task via watcher-ctl / claude-watch — the main loop re-invokes it after each
# delivery.
#
# Queue: ~/claude-events/ (override with $CLAUDE_EVENT_QUEUE, legacy
#        $CRON_EVENT_QUEUE also honored for backward compat)
#
# Behavior:
#   - Block on inotifywait for create/moved_to (or, if events are already
#     pending at startup, skip straight to the debounce collect loop).
#   - Debounce / coalesce: once at least one event is pending we enter an
#     ADAPTIVE quiet-period collect loop. We poll the queue every
#     $EVENT_WATCH_QUIET_SECONDS (default 3); each time the pending count
#     GROWS we reset the quiet timer; once the count holds steady for one
#     full quiet interval (a "quiet period") we drain EVERYTHING in one
#     batch and exit. A hard cap of $EVENT_WATCH_DEBOUNCE_SECONDS (default
#     120) bounds the total wait so a slow drip of events can't stall the
#     surface indefinitely. This batches staggered bursts (e.g. a
#     torrent-completed flood, or four unrelated events landing within a
#     few seconds) into a SINGLE .output so the main loop's mandatory
#     read-act-restart cycle fires once per window, not once per event.
#
#     CRITICAL: the collect loop only ever WAITS and COUNTS. It never acks,
#     consumes, hides, or reorders an event. Draining happens exactly once,
#     at the end, over whatever is on disk — so an event that arrives during
#     the window is surfaced in this batch, and one that lands a microsecond
#     after the final drain is still on disk for the next watcher run. No
#     event can be dropped by the debounce.
#
#     Both knobs are user-configurable (CLI flag wins over env var):
#       --debounce SECONDS  /  $EVENT_WATCH_DEBOUNCE_SECONDS   (max window)
#       --quiet SECONDS     /  $EVENT_WATCH_QUIET_SECONDS       (quiet period)
#     Set --debounce 0 to disable batching entirely (surface immediately,
#     pre-debounce behavior).
#   - Print each event as a single one-liner: EVENT[<source>/<tag>] <msg…>
#     then delete the queue file. Full event JSON (compact, one line) is
#     appended to the consumed-event ring buffer log at
#     $LOG_DIR/consumed.jsonl so `claude-event-tail` can show it after
#     the fact.
#   - Auto-ingest each delivered event through `event-ack ingest` (unless
#     $CLAUDE_EVENT_WATCH_AUTO_INGEST=0), routing it into the event-must-act
#     tier system so the event -> obligation rung of the alerting ladder
#     arms WITHOUT the main loop having to run `event-ack ingest` by hand.
#     Best-effort: a missing/failing event-ack CLI never breaks delivery.
#   - Print the WATCHER EXITED restart banner at the end.
#
# The one-liner stdout shape is intentional — the main loop's bash-task view
# stays small. Use `claude-event-tail` to inspect details.

set -uo pipefail

# Force line-buffered stdout so output is delivered immediately when run as a
# background task (Claude Code's run_in_background captures via pipe, which
# causes Python and even bash printf to block-buffer). We re-exec under stdbuf
# if available and stdout is not a tty.
if [[ ! -t 1 ]] && command -v stdbuf >/dev/null 2>&1 && [[ -z "${_CEW_STDBUF_WRAPPED:-}" ]]; then
    export _CEW_STDBUF_WRAPPED=1
    exec stdbuf -oL "$0" "$@"
fi
export PYTHONUNBUFFERED=1

# --- tty / foreground-misuse guard ---------------------------------------
# CONTRACT: this watcher must be launched as a run_in_background Bash task by
# the main loop. In that mode stdout is a captured PIPE (not a tty), so the
# block-print-exit output is delivered back to the session as a task-
# completion notification. When stdout IS a tty the watcher is being run
# interactively — either an operator debugging it by hand (legitimate) or a
# shell-`&` / nohup misuse (NOT legitimate; the main loop never sees the
# output). We cannot reliably tell those two cases apart from inside the
# process: a backgrounded `cmd &` from an interactive shell still inherits
# the terminal as stdout unless redirected, so `-t 1` does not distinguish
# shell-`&` from a foreground manual run. Because there is no stronger signal,
# we WARN loudly rather than hard-fail — a hard exit here would break the
# legitimate "operator runs it by hand to watch events scroll" debug path.
# (The flock singleton guard below is the real teeth: it is what actually
# blocks a duplicate inotifywait from racing the same queue.)
#
# NOTE: this check runs AFTER the stdbuf re-exec above. That re-exec only
# fires when stdout is NOT a tty (`! -t 1`), so by the time we reach here in
# a piped/background launch we are already in the re-exec'd child whose
# stdout is still the same non-tty pipe — the warning correctly stays silent.
# In a tty launch the re-exec is skipped entirely, so we are in the original
# process and the warning fires once.
if [[ -t 1 ]]; then
    echo "claude-event-watch: WARNING — stdout is a tty; this watcher is meant to run as a run_in_background task (block-print-exit). Continuing, but the main loop won't receive this output." >&2
fi

QUEUE_DIR="${CLAUDE_EVENT_QUEUE:-${CRON_EVENT_QUEUE:-$HOME/claude-events}}"
LOG_DIR="${CLAUDE_EVENT_LOG_DIR:-$HOME/.config/claude-events}"
LOG_FILE="$LOG_DIR/consumed.jsonl"
LOG_MAX_LINES="${CLAUDE_EVENT_LOG_MAX_LINES:-10000}"
LOG_KEEP_ROTATIONS=3

# Debounce window (seconds) — HARD CAP on the total collect wait. Once an
# event is pending we run an adaptive quiet-period collect loop (see below);
# this value bounds how long that loop can run regardless of continued
# arrivals. Override via --debounce flag or env var. Setting 0 disables
# batching entirely (surface immediately — pre-debounce behavior).
#
# KNOB #2 (event-delivery debounce), 2026-06-24: default raised 30 -> 120.
# At 30s the watcher fired-and-exited up to every 30s; each exit is a
# block-print-exit cycle the main loop MUST read + restart, and (combined with
# the daemon's aggressive watcher-down detection) the loop spent all its cycles
# acking + restarting instead of working. A ~120s window delivers AT MOST once
# every ~2min, batching everything in the window into a SINGLE delivery and
# slashing the read/restart churn. Events are never dropped — they accumulate
# on disk and surface in the next batch (see the CRITICAL note above).
DEBOUNCE_SECONDS="${EVENT_WATCH_DEBOUNCE_SECONDS:-120}"

# Quiet-period (seconds) — the settle interval for the adaptive collect loop.
# We poll the queue every QUIET_SECONDS; each time the pending count grows we
# reset the timer, and we drain once the count holds steady for one full
# quiet interval (or the DEBOUNCE_SECONDS cap is hit). Default 3s — small
# enough that a single lone event surfaces promptly, large enough to coalesce
# a staggered burst. Override via --quiet flag or $EVENT_WATCH_QUIET_SECONDS.
QUIET_SECONDS="${EVENT_WATCH_QUIET_SECONDS:-3}"

usage() {
    cat <<EOF
Usage: claude-event-watch [--debounce SECONDS] [--quiet SECONDS] [-h|--help]

Block until a new claude-event arrives in \$CLAUDE_EVENT_QUEUE
(default ~/claude-events/), batch any events that land in a short
adaptive window, print them all as one-liners, then exit.

Options:
  --debounce SECONDS  Hard cap on the collect window (default: 120). Bounds
                      how long the adaptive quiet-period loop may run.
                      Set to 0 to disable batching (surface immediately).
                      Also configurable via \$EVENT_WATCH_DEBOUNCE_SECONDS.
  --quiet SECONDS     Quiet-period / settle interval for the adaptive
                      collect loop (default: 3). The queue is polled every
                      SECONDS; each new event resets the timer, and the
                      batch is drained once the pending count holds steady
                      for one full quiet interval (or --debounce is hit).
                      Also configurable via \$EVENT_WATCH_QUIET_SECONDS.
  -h, --help          Show this help.

The collect loop never drops, hides, acks, or reorders an event — it only
waits and counts, then drains the queue once at the end. Events arriving
during the window are batched; events landing after the final drain remain
on disk for the next run.

Output: one line per event, shape:
  EVENT[<source>/<tag>] <first-60-chars-of-message>…

Full event JSON appended to \$CLAUDE_EVENT_LOG_DIR/consumed.jsonl
(default ~/.config/claude-events/, ring-buffered at
\$CLAUDE_EVENT_LOG_MAX_LINES lines, default 10000).
EOF
}

# Parse CLI args. Keep it simple — only --debounce / --help.
while [[ $# -gt 0 ]]; do
    case "$1" in
        --debounce)
            if [[ $# -lt 2 ]]; then
                echo "claude-event-watch: --debounce requires a value" >&2
                exit 2
            fi
            DEBOUNCE_SECONDS="$2"
            shift 2
            ;;
        --debounce=*)
            DEBOUNCE_SECONDS="${1#--debounce=}"
            shift
            ;;
        --quiet)
            if [[ $# -lt 2 ]]; then
                echo "claude-event-watch: --quiet requires a value" >&2
                exit 2
            fi
            QUIET_SECONDS="$2"
            shift 2
            ;;
        --quiet=*)
            QUIET_SECONDS="${1#--quiet=}"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "claude-event-watch: unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

# Validate DEBOUNCE_SECONDS is a non-negative integer.
if ! [[ "$DEBOUNCE_SECONDS" =~ ^[0-9]+$ ]]; then
    echo "claude-event-watch: DEBOUNCE_SECONDS must be a non-negative integer (got: $DEBOUNCE_SECONDS)" >&2
    exit 2
fi

# Validate QUIET_SECONDS is a positive integer (must be >= 1 — it's the poll
# interval for the collect loop; 0 would busy-spin).
if ! [[ "$QUIET_SECONDS" =~ ^[0-9]+$ ]] || (( QUIET_SECONDS < 1 )); then
    echo "claude-event-watch: QUIET_SECONDS must be a positive integer (got: $QUIET_SECONDS)" >&2
    exit 2
fi

mkdir -p "$QUEUE_DIR"
mkdir -p "$LOG_DIR"

# --- flock singleton guard ------------------------------------------------
# Only ONE claude-event-watch may run at a time: two concurrent instances
# would each block on inotifywait over the SAME queue dir, and on the next
# event both would wake, both would drain, and they'd race to consume/delete
# the same files — duplicating some events on one instance's stdout while the
# other sees a half-empty queue. The contract is "exactly one watcher, re-
# invoked by the main loop after each delivery"; this enforces it from inside
# the watcher itself (one place, unbypassable, self-documenting) rather than
# relying on an external PreToolUse gate.
#
# We use fd-based flock so the lock auto-releases when THIS process dies (no
# stale-lock file to clean up — a crash/kill frees it immediately). The lock
# is acquired here, after the stdbuf re-exec above, so it is taken exactly
# once in the final long-lived process. fd 9 is inherited across the re-exec
# only if we'd locked before it; we deliberately lock AFTER, so there is no
# self-conflict.
#
# Lockfile path mirrors the self-clear watcher's convention: override via
# $CLAUDE_EVENT_WATCH_LOCK, else $XDG_RUNTIME_DIR/claude-event-watch.lock,
# else /var/run/claude/claude-event-watch.lock. The override lets tests
# isolate so a real running watcher on the host can't make the test see a
# held lock (and vice-versa).
LOCKFILE="${CLAUDE_EVENT_WATCH_LOCK:-${XDG_RUNTIME_DIR:+$XDG_RUNTIME_DIR/claude-event-watch.lock}}"
LOCKFILE="${LOCKFILE:-/var/run/claude/claude-event-watch.lock}"
if command -v flock >/dev/null 2>&1; then
    # Read any existing holder pid FIRST, before we open the fd for write —
    # opening with `9>` truncates the file, which would otherwise wipe the
    # holder's pid before we get to read it in the refused branch below.
    prior_holder="$(cat "$LOCKFILE" 2>/dev/null | tr -d '[:space:]')"
    exec 9>"$LOCKFILE" || {
        echo "claude-event-watch: cannot open lockfile $LOCKFILE" >&2
        exit 1
    }
    if ! flock -n 9; then
        # Lock is held by a live instance — refuse. `prior_holder` was read
        # before the truncating open above, so it still names the holder (an
        # empty/stale read is fine; we still refuse with "unknown").
        echo "claude-event-watch: already running (pid ${prior_holder:-unknown}) — refusing to start a duplicate" >&2
        exit 3
    fi
    # We hold the lock. The truncating open already emptied the file; record
    # our pid so a refused second instance can name us. The fd stays open for
    # the lock's lifetime (auto-released on process death — no stale cleanup).
    printf '%s\n' "$$" >&9
else
    # flock unavailable (e.g. macOS without util-linux). Degrade gracefully:
    # the singleton guarantee is best-effort here, but the watcher still works.
    # Most deployments (the Linux container) ship flock, so this is the rare
    # path. We warn once so the gap is visible.
    echo "claude-event-watch: WARNING — flock not found; singleton guard disabled (duplicate watchers possible)" >&2
fi

print_restart_banner() {
    echo "===="
    echo "WATCHER EXITED. RESTART NOW: watcher-ctl run claude-event-watch"
    echo "===="
}

# Rotate consumed.jsonl when it exceeds LOG_MAX_LINES. Keeps last N rotations
# (consumed.jsonl.1 .. consumed.jsonl.N). Cheap line-count check before each
# append batch.
maybe_rotate_log() {
    [[ -f "$LOG_FILE" ]] || return 0
    local lines
    lines=$(wc -l <"$LOG_FILE" 2>/dev/null || echo 0)
    if (( lines >= LOG_MAX_LINES )); then
        local i
        for (( i=LOG_KEEP_ROTATIONS; i>=1; i-- )); do
            local src="$LOG_FILE.$i"
            local dst="$LOG_FILE.$((i+1))"
            if [[ -f "$src" ]]; then
                if (( i >= LOG_KEEP_ROTATIONS )); then
                    rm -f "$src"
                else
                    mv -f "$src" "$dst"
                fi
            fi
        done
        mv -f "$LOG_FILE" "$LOG_FILE.1"
    fi
}

# Whether to auto-ingest each delivered event through `event-ack ingest`
# (routing it into the actionable pending-actions.json / ambient-context.json
# tier so the event→obligation rung of the alerting ladder is armed WITHOUT
# the main loop having to remember a manual `event-ack ingest` step). Default
# ON; set CLAUDE_EVENT_WATCH_AUTO_INGEST=0 to disable (e.g. a host that runs
# no event-must-act gate). Best-effort in all cases — a missing / failing
# event-ack CLI never breaks event delivery. See the design note in
# process_event's Python block.
AUTO_INGEST="${CLAUDE_EVENT_WATCH_AUTO_INGEST:-1}"
# Resolve the event-ack CLI ONCE (PATH lookup) so we don't re-search per
# event. Empty when unavailable → auto-ingest silently degrades to a no-op.
EVENT_ACK_CLI=""
if [[ "$AUTO_INGEST" == "1" ]]; then
    EVENT_ACK_CLI="$(command -v event-ack 2>/dev/null || true)"
fi

# Process one event file: print a single one-liner to stdout AND append
# the compact JSON form to the log. We delegate JSON munging to Python so
# we don't depend on jq being installed (it isn't on every system).
#
# Concurrent appenders are safe because Python opens the log with
# O_APPEND ('a' mode) — POSIX guarantees atomicity for single write() calls
# below PIPE_BUF, and a one-line JSON event is well under that limit.
process_event() {
    local f="$1"
    local log="$2"
    EVENT_ACK_CLI="$EVENT_ACK_CLI" python3 -u - "$f" "$log" <<'PYEOF'
import json, os, subprocess, sys
src, log = sys.argv[1], sys.argv[2]
try:
    with open(src, "r", encoding="utf-8", errors="replace") as fp:
        ev = json.load(fp)
except Exception as e:
    # Malformed event file — print a placeholder one-liner, skip log append.
    print(f"EVENT[malformed/unknown] {os.path.basename(src)} ({e})")
    sys.exit(0)

source = str(ev.get("source", "unknown"))
tag = str(ev.get("tag", "untagged"))
# Full (untruncated) message for ingest/classify — the classifier keys on
# substrings (e.g. "CI failure") that a 60-char truncation could cut off.
full_message = str(ev.get("message", ""))
message = full_message
# Collapse whitespace; truncate at 60 chars + ellipsis.
message = " ".join(message.split())
if len(message) > 60:
    message = message[:60] + "…"

# Surface scalar fields from the event's `data` object on the one-liner so
# the main loop can act WITHOUT re-reading the JSON file. Many events carry
# the actionable payload there (e.g. heartbeat-tick's `path` = the heartbeat
# file to touch); without this the loop sees only an opaque message and can't
# tell what to do. Only flat string/number/bool values are appended (nested
# objects/arrays stay in the logged JSON); rendered as ` key=value` pairs in
# sorted order for determinism.
data = ev.get("data")
suffix = ""
if isinstance(data, dict):
    parts = []
    for k in sorted(data):
        v = data[k]
        if isinstance(v, bool) or isinstance(v, (int, float, str)):
            sv = " ".join(str(v).split())
            if len(sv) > 80:
                sv = sv[:80] + "…"
            parts.append(f"{k}={sv}")
    if parts:
        suffix = " [" + " ".join(parts) + "]"
print(f"EVENT[{source}/{tag}] {message}{suffix}")

# Compact one-line JSON for the log; ensure_ascii keeps the line PIPE_BUF-safe
# even with multibyte chars in the message field.
line = json.dumps(ev, separators=(",", ":"), ensure_ascii=False)
data = (line + "\n").encode("utf-8")
fd = os.open(log, os.O_WRONLY | os.O_APPEND | os.O_CREAT, 0o644)
try:
    os.write(fd, data)
finally:
    os.close(fd)

# --- Auto-ingest into the event-must-act tier system ----------------------
# The delivery layer is the ONE chokepoint every event flows through exactly
# once (the watcher drains + deletes each file), which makes it the right
# place to route an event into `event-ack ingest`. Without this, the
# event -> obligation rung of the alerting ladder (docs/concepts/
# event-hierarchy.md) never arms automatically: `event-ack ingest` populates
# pending-actions.json (actionable tier, which the event_must_act obligation
# gates on) / ambient-context.json (the UserPromptSubmit inject), and NOTHING
# else calls it. The main loop was expected to run `event-ack ingest` by hand
# per event, so an orphaned/stuck queue item (or any actionable event) that
# the loop didn't manually ingest sat silently — emitted + delivered, but
# never arming the gate. Auto-ingesting here closes that gap for EVERY event
# type, orphan/stuck included.
#
# Strictly best-effort: any failure (CLI missing, non-zero exit, timeout,
# OSError) is swallowed so event DELIVERY — the watcher's core contract — is
# never broken by an ingest hiccup. event-ack itself is default-open +
# flock-guarded, and idempotent (add_pending dedups on key), so a re-ingest
# across watcher restarts is harmless. We pass the FULL (untruncated) message
# so event-classify's substring rules (e.g. "CI failure") match correctly.
cli = os.environ.get("EVENT_ACK_CLI", "")
if cli:
    try:
        subprocess.run(
            [cli, "ingest", "--source", source, "--tag", tag,
             "--message", full_message],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            timeout=5, check=False,
        )
    except Exception:
        # Never let an ingest failure break event delivery.
        pass
PYEOF
}

# Count the number of pending event files currently in the queue. Used by the
# adaptive collect loop to decide when the burst has settled. Cheap: a single
# find piped to a count. Does NOT consume or modify anything.
count_pending() {
    find "$QUEUE_DIR" -maxdepth 1 -type f -name '*.json' 2>/dev/null | wc -l | tr -d '[:space:]'
}

# Adaptive quiet-period collect loop. Precondition: at least one event is
# already pending. We poll every QUIET_SECONDS; each time the pending count
# GROWS we reset the quiet timer (more of the burst is still landing). Once
# the count holds steady across one full quiet interval — or the
# DEBOUNCE_SECONDS hard cap is reached — we return so the caller drains.
#
# This loop NEVER touches the queue files: it only sleeps and counts. All
# draining/acking happens after it returns, exactly once, over whatever is on
# disk at that moment. An event landing during the loop is therefore batched;
# one landing after the post-loop drain stays on disk for the next run. No
# event can be lost or hidden here.
collect_burst() {
    # DEBOUNCE_SECONDS == 0 means batching disabled: surface immediately.
    if (( DEBOUNCE_SECONDS == 0 )); then
        return 0
    fi

    local waited=0
    local last_count
    last_count="$(count_pending)"

    while (( waited < DEBOUNCE_SECONDS )); do
        # Sleep up to QUIET_SECONDS, but never overshoot the hard cap.
        local remaining=$(( DEBOUNCE_SECONDS - waited ))
        local nap=$(( QUIET_SECONDS < remaining ? QUIET_SECONDS : remaining ))
        sleep "$nap"
        waited=$(( waited + nap ))

        local now_count
        now_count="$(count_pending)"
        if (( now_count > last_count )); then
            # Burst still growing — reset the quiet timer by continuing to
            # loop (we've consumed `nap` toward the hard cap, which is the
            # safety bound; the quiet period restarts implicitly because the
            # count changed this interval).
            last_count="$now_count"
            continue
        fi
        # Count held steady for a full quiet interval → burst settled.
        break
    done
}

print_pending() {
    local any=0
    maybe_rotate_log
    # Sort by filename (timestamp prefix) for chronological order
    while IFS= read -r -d '' f; do
        any=1
        process_event "$f" "$LOG_FILE"
        rm -f "$f"
    done < <(find "$QUEUE_DIR" -maxdepth 1 -type f -name '*.json' -print0 2>/dev/null | sort -z)
    return $any
}

# Ensure inotifywait is available before entering the wait loop. (Checked once
# here, up front — the loop below assumes it.)
if ! command -v inotifywait >/dev/null 2>&1; then
    echo "claude-event-watch: inotifywait not found (install inotify-tools)" >&2
    exit 1
fi

# --- catch-up / block loop (TOCTOU-safe) ----------------------------------
# We alternate between a "catch-up" scan of the queue and a BOUNDED block on
# inotifywait. The bound is the whole point: it closes a check-then-block race
# that previously let an event sit unconsumed indefinitely.
#
# THE RACE (the bug this loop fixes): the old code did a single catch-up scan,
# and if it found nothing fell straight through to an UNBOUNDED
#   inotifywait -e create -e moved_to ...
# inotifywait only fires on create/moved_to events that occur AFTER its watch
# is armed. There is an unavoidable gap between the catch-up `find` returning
# "empty" and inotifywait actually arming its inotify watch. An event .json
# that lands inside that gap is seen by NEITHER: the find already ran, and
# inotifywait wasn't watching yet. With an unbounded wait, that gap-event then
# sat on disk until the NEXT unrelated event happened to wake inotifywait —
# which could be many minutes (or never). The cron health-check
# (cw-watcher-health-check) then flags it as "WATCHER DOWN" at the 2-min mark,
# even though the watcher PROCESS is perfectly alive — it's just blind to the
# gap-event. That false "down" alert is what fired repeatedly all session.
#
# THE FIX: give inotifywait a timeout (-t) and loop back to the catch-up scan.
#   - rc=0  : an event fired      → loop; catch-up scan drains it → exit 0.
#   - rc=2  : timeout (no event)  → loop; catch-up scan catches any gap-event
#             that landed during the arm gap, draining within <= timeout.
#   - other : real inotifywait error → break and exit nonzero.
# So a gap-event can sit at most one timeout window (<=30s) instead of forever,
# and the catch-up scan — not inotifywait's event stream — is the thing that
# actually drains. External behavior is otherwise unchanged: with no events the
# loop keeps blocking a timeout-window at a time (same as a plain block); the
# moment any event is present it drains the WHOLE batch in one .output and
# EXITS, preserving the fire-and-exit / main-loop-restart contract. The
# debounce/collect_burst coalescing, flock singleton, and restart banner are
# all untouched.
INOTIFY_TIMEOUT="${EVENT_WATCH_INOTIFY_TIMEOUT:-30}"
while true; do
    # Catch-up: anything already pending (incl. a backlog that landed during
    # the main loop's read-act-restart gap, OR a gap-event from a prior
    # iteration's arm window) → coalesce the burst + drain + exit. We run the
    # adaptive collect loop here too so backlog siblings still landing are
    # batched into one .output rather than forcing the main loop through them
    # one at a time. (DEBOUNCE_SECONDS=0 short-circuits collect_burst,
    # preserving immediate-surface behavior.)
    if find "$QUEUE_DIR" -maxdepth 1 -type f -name '*.json' -print -quit 2>/dev/null | grep -q .; then
        collect_burst
        print_pending || true
        print_restart_banner
        exit 0
    fi

    # Block for new events, but with a timeout so the loop re-scans and a
    # gap-event can never sit unconsumed beyond one window.
    inotifywait -q -t "$INOTIFY_TIMEOUT" -e create -e moved_to \
        --include '\.json$' "$QUEUE_DIR" >/dev/null 2>&1
    rc=$?
    # rc=0: event fired → loop re-checks catch-up (drains). rc=2: timeout →
    # loop re-checks catch-up (catches any gap-event). Any other rc is a real
    # inotifywait error → stop looping and surface it.
    if [ "$rc" -ne 0 ] && [ "$rc" -ne 2 ]; then
        echo "claude-event-watch: inotifywait exited with rc=$rc — stopping" >&2
        print_restart_banner
        exit 1
    fi
done
